{"type":"tool_use","timestamp":1779200745966,"sessionID":"ses_1bf60b6f1ffeoFNttErrvz9f1s","part":{"type":"tool","tool":"read","callID":"call_03_bSGaynjkuU7ghUpVDKDk6505","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/admin/property-form.tsx"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/admin/property-form.tsx</path>\n<type>file</type>\n<content>\n1: import { useState, type FormEvent } from 'react';\n2: import { useNavigate, useParams } from 'react-router-dom';\n3: import { useCreateProperty, useUpdateProperty, usePropertyDetail } from '~/hooks/api/useProperties';\n4: import { useAmenityList } from '~/hooks/api/useAmenities';\n5: import type { CreatePropertyDto, PropertyTypeEnum } from '~/types/api/property';\n6: import { PROPERTY_TYPES } from '~/types/api/property';\n7: \n8: export default function PropertyForm() {\n9:   const { id } = useParams<{ id: string }>();\n10:   const navigate = useNavigate();\n11:   const isEdit = !!id;\n12: \n13:   const { data: existingProperty, isLoading: loadingExisting } = usePropertyDetail(id);\n14:   const { data: amenities } = useAmenityList();\n15:   const createProperty = useCreateProperty();\n16:   const updateProperty = useUpdateProperty();\n17: \n18:   const [error, setError] = useState<string | null>(null);\n19:   const [selectedAmenities, setSelectedAmenities] = useState<string[]>([]);\n20: \n21:   const isPending = createProperty.isPending || updateProperty.isPending;\n22: \n23:   const handleSubmit = (e: FormEvent<HTMLFormElement>) => {\n24:     e.preventDefault();\n25:     setError(null);\n26:     const form = new FormData(e.currentTarget);\n27: \n28:     const address = {\n29:       street: form.get('street') as string,\n30:       city: form.get('city') as string,\n31:       state: form.get('state') as string,\n32:       zipCode: form.get('zipCode') as string,\n33:     };\n34: \n35:     const data: CreatePropertyDto = {\n36:       title: form.get('title') as string,\n37:       description: form.get('description') as string,\n38:       price: parseFloat(form.get('price') as string),\n39:       bedrooms: parseInt(form.get('bedrooms') as string, 10),\n40:       bathrooms: parseInt(form.get('bathrooms') as string, 10),\n41:       squareFeet: form.get('squareFeet') ? parseInt(form.get('squareFeet') as string, 10) : undefined,\n42:       propertyType: form.get('propertyType') as PropertyTypeEnum,\n43:       address,\n44:       amenityIds: selectedAmenities,\n45:       availableFrom: (form.get('availableFrom') as string) || undefined,\n46:     };\n47: \n48:     if (isEdit && id) {\n49:       updateProperty.mutate(\n50:         { id, data },\n51:         { onSuccess: () => navigate('/admin/properties'), onError: (err) => setError((err as Error).message) }\n52:       );\n53:     } else {\n54:       createProperty.mutate(data, {\n55:         onSuccess: () => navigate('/admin/properties'),\n56:         onError: (err) => setError((err as Error).message),\n57:       });\n58:     }\n59:   };\n60: \n61:   const toggleAmenity = (id: string) => {\n62:     setSelectedAmenities((prev) =>\n63:       prev.includes(id) ? prev.filter((a) => a !== id) : [...prev, id]\n64:     );\n65:   };\n66: \n67:   if (isEdit && loadingExisting) {\n68:     return (\n69:       <div>\n70:         <h1 className=\"text-3xl font-bold\">Property Form</h1>\n71:         <p className=\"mt-2 text-muted-foreground\">Loading...</p>\n72:       </div>\n73:     );\n74:   }\n75: \n76:   return (\n77:     <div>\n78:       <h1 className=\"text-3xl font-bold\">{isEdit ? 'Edit Property' : 'Add Property'}</h1>\n79:       <p className=\"mt-2 text-muted-foreground\">{isEdit ? 'Update property details.' : 'Create a new property listing.'}</p>\n80: \n81:       {error && (\n82:         <div className=\"mt-4 p-3 rounded bg-destructive/10 text-destructive text-sm\">{error}</div>\n83:       )}\n84: \n85:       {createProperty.isSuccess && !isEdit && (\n86:         <div className=\"mt-4 p-3 rounded bg-green-500/10 text-green-500 text-sm\">Property created successfully!</div>\n87:       )}\n88: \n89:       <form onSubmit={handleSubmit} className=\"mt-6 space-y-4 max-w-2xl\">\n90:         <div>\n91:           <label className=\"block text-sm font-medium mb-1\">Title</label>\n92:           <input name=\"title\" required minLength={5} maxLength={200} defaultValue={existingProperty?.title || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n93:         </div>\n94:         <div>\n95:           <label className=\"block text-sm font-medium mb-1\">Description</label>\n96:           <textarea name=\"description\" required minLength={20} maxLength={5000} rows={4} defaultValue={existingProperty?.description || ''} className=\"w-full rounded-md border bg-background px-3 py-2 text-sm resize-y\" />\n97:         </div>\n98:         <div className=\"grid grid-cols-3 gap-4\">\n99:           <div>\n100:             <label className=\"block text-sm font-medium mb-1\">Price ($/mo)</label>\n101:             <input name=\"price\" type=\"number\" required min={0} step=\"0.01\" defaultValue={existingProperty?.price || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n102:           </div>\n103:           <div>\n104:             <label className=\"block text-sm font-medium mb-1\">Bedrooms</label>\n105:             <input name=\"bedrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bedrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n106:           </div>\n107:           <div>\n108:             <label className=\"block text-sm font-medium mb-1\">Bathrooms</label>\n109:             <input name=\"bathrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bathrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n110:           </div>\n111:         </div>\n112:         <div className=\"grid grid-cols-2 gap-4\">\n113:           <div>\n114:             <label className=\"block text-sm font-medium mb-1\">Square Feet</label>\n115:             <input name=\"squareFeet\" type=\"number\" min={0} defaultValue={existingProperty?.squareFeet || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n116:           </div>\n117:           <div>\n118:             <label className=\"block text-sm font-medium mb-1\">Property Type</label>\n119:             <select name=\"propertyType\" required defaultValue={existingProperty?.propertyType || 'apartment'} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\">\n120:               {PROPERTY_TYPES.map((t) => (\n121:                 <option key={t} value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>\n122:               ))}\n123:             </select>\n124:           </div>\n125:         </div>\n126:         <div>\n127:           <label className=\"block text-sm font-medium mb-1\">Available From</label>\n128:           <input name=\"availableFrom\" type=\"date\" defaultValue={existingProperty?.availableFrom?.split('T')[0] || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n129:         </div>\n130:         <fieldset className=\"border rounded-md p-4\">\n131:           <legend className=\"text-sm font-medium px-2\">Address</legend>\n132:           <div className=\"grid grid-cols-2 gap-4\">\n133:             <div className=\"col-span-2\">\n134:               <label className=\"block text-sm mb-1\">Street</label>\n135:               <input name=\"street\" required maxLength={200} defaultValue={existingProperty?.address?.street || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n136:             </div>\n137:             <div>\n138:               <label className=\"block text-sm mb-1\">City</label>\n139:               <input name=\"city\" required maxLength={100} defaultValue={existingProperty?.address?.city || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n140:             </div>\n141:             <div>\n142:               <label className=\"block text-sm mb-1\">State</label>\n143:               <input name=\"state\" required maxLength={100} defaultValue={existingProperty?.address?.state || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n144:             </div>\n145:             <div>\n146:               <label className=\"block text-sm mb-1\">ZIP Code</label>\n147:               <input name=\"zipCode\" required maxLength={10} defaultValue={existingProperty?.address?.zipCode || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n148:             </div>\n149:           </div>\n150:         </fieldset>\n151: \n152:         {amenities && amenities.length > 0 && (\n153:           <div>\n154:             <label className=\"block text-sm font-medium mb-2\">Amenities</label>\n155:             <div className=\"flex flex-wrap gap-2\">\n156:               {amenities.map((a) => (\n157:                 <label key={a.id} className=\"flex items-center gap-1.5 px-3 py-1.5 border rounded-md text-sm cursor-pointer hover:bg-muted\">\n158:                   <input\n159:                     type=\"checkbox\"\n160:                     checked={selectedAmenities.includes(a.id)}\n161:                     onChange={() => toggleAmenity(a.id)}\n162:                     className=\"accent-primary\"\n163:                   />\n164:                   {a.name}\n165:                 </label>\n166:               ))}\n167:             </div>\n168:           </div>\n169:         )}\n170: \n171:         <button type=\"submit\" disabled={isPending} className=\"inline-flex items-center justify-center h-10 px-6 rounded-md bg-primary text-primary-foreground text-sm font-semibold hover:opacity-90 disabled:opacity-50\">\n172:           {isPending ? 'Saving...' : isEdit ? 'Update Property' : 'Create Property'}\n173:         </button>\n174:       </form>\n175:     </div>\n176:   );\n177: }\n\n(End of file - total 177 lines)\n</content>","metadata":{"preview":"import { useState, type FormEvent } from 'react';\nimport { useNavigate, useParams } from 'react-router-dom';\nimport { useCreateProperty, useUpdateProperty, usePropertyDetail } from '~/hooks/api/useProperties';\nimport { useAmenityList } from '~/hooks/api/useAmenities';\nimport type { CreatePropertyDto, PropertyTypeEnum } from '~/types/api/property';\nimport { PROPERTY_TYPES } from '~/types/api/property';\n\nexport default function PropertyForm() {\n  const { id } = useParams<{ id: string }>();\n  const navigate = useNavigate();\n  const isEdit = !!id;\n\n  const { data: existingProperty, isLoading: loadingExisting } = usePropertyDetail(id);\n  const { data: amenities } = useAmenityList();\n  const createProperty = useCreateProperty();\n  const updateProperty = useUpdateProperty();\n\n  const [error, setError] = useState<string | null>(null);\n  const [selectedAmenities, setSelectedAmenities] = useState<string[]>([]);\n","truncated":false,"loaded":[]},"title":"frontend/app/pages/admin/property-form.tsx","time":{"start":1779200745676,"end":1779200745964}},"id":"prt_e40a0dbce001W8fSg38Xu7jGPM","sessionID":"ses_1bf60b6f1ffeoFNttErrvz9f1s","messageID":"msg_e40a0b5d0001wibIc6OroLmjtz"}}
