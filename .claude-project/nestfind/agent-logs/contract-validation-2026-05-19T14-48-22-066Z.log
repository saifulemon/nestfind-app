ty.id });\n36:     } else {\n37:       removeFav.mutate(property.id);\n38:     }\n39:   };\n40: \n41:   const handleInquirySubmit = (e: FormEvent<HTMLFormElement>) => {\n42:     e.preventDefault();\n43:     const form = e.currentTarget;\n44:     const formData = new FormData(form);\n45:     submitInquiry.mutate(\n46:       {\n47:         message: formData.get('message') as string,\n48:         name: (formData.get('name') as string) || undefined,\n49:         email: (formData.get('email') as string) || undefined,\n50:         phone: (formData.get('phone') as string) || undefined,\n51:       },\n52:       {\n53:         onSuccess: () => {\n54:           setInquirySuccess(true);\n55:           form.reset();\n56:         },\n57:       }\n58:     );\n59:   };\n60: \n61:   if (isLoading) {\n62:     return (\n63:       <div className=\"max-w-[1440px] mx-auto\">\n64:         <div className=\"flex items-center justify-center py-[120px] text-[#64748B] text-[16px]\">\n65:           Loading property details...\n66:         </div>\n67:       </div>\n68:     );\n69:   }\n70: \n71:   if (isError) {\n72:     return (\n73:       <div className=\"max-w-[1440px] mx-auto\">\n74:         <div className=\"flex flex-col items-center justify-center py-[120px] text-[#F87171] text-[16px]\">\n75:           <p>{(error as Error)?.message || 'Failed to load property'}</p>\n76:           <Link to=\"/search\" className=\"text-[#4A90D9] mt-[16px] hover:underline\">Back to search</Link>\n77:         </div>\n78:       </div>\n79:     );\n80:   }\n81: \n82:   if (!property) {\n83:     return (\n84:       <div className=\"max-w-[1440px] mx-auto\">\n85:         <div className=\"flex flex-col items-center justify-center py-[120px] text-[#64748B]\">\n86:           <p className=\"text-[18px]\">Property not found</p>\n87:           <Link to=\"/search\" className=\"text-[#4A90D9] mt-[16px] hover:underline\">Back to search</Link>\n88:         </div>\n89:       </div>\n90:     );\n91:   }\n92: \n93:   const photos = property.photos ?? [];\n94:   const thumbnails = photos.length > 0\n95:     ? photos.map((p) => p.url)\n96:     : ['linear-gradient(135deg,rgba(74,144,217,0.35),rgba(124,58,237,0.35))'];\n97: \n98:   const stats = [\n99:     { icon: Bed, value: String(property.bedrooms), label: 'Bedrooms' },\n100:     { icon: Bath, value: String(property.bathrooms), label: 'Bathrooms' },\n101:     { icon: Ruler, value: property.squareFeet?.toLocaleString() ?? '—', label: 'Square Feet' },\n102:     { icon: Building2, value: property.propertyType.charAt(0).toUpperCase() + property.propertyType.slice(1), label: 'Property Type', isSmall: true },\n103:   ];\n104: \n105:   const amenities = (property.amenities ?? []).map((a) => ({\n106:     icon: AMENITY_ICON_MAP[a.icon] || Wifi,\n107:     label: a.name,\n108:   }));\n109: \n110:   return (\n111:     <div className=\"max-w-[1440px] mx-auto\">\n112:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n113:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n114:           NestFind\n115:         </div>\n116:         <div className=\"flex gap-[32px] items-center\">\n117:           <Link to=\"/search\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-browse\">Browse</Link>\n118:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-favorites\">Favorites</Link>\n119:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-inquiries\">My Inquiries</Link>\n120:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-profile\">Profile</Link>\n121:         </div>\n122:       </nav>\n123: \n124:       <section className=\"p-[48px]\">\n125:         <Link to=\"/search\" className=\"inline-flex items-center gap-[6px] text-[#94A3B8] no-underline text-[14px] mb-[24px] transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-back\">\n126:           <ArrowLeft className=\"w-[18px] h-[18px]\" /> Back to search\n127:         </Link>\n128: \n129:         <div className=\"relative mb-[24px]\">\n130:           <div\n131:             className=\"w-full h-[400px] object-cover rounded-[12px] bg-cover bg-center\"\n132:             style={photos.length > 0 ? { backgroundImage: `url(${thumbnails[activeThumb]})` } : { background: thumbnails[activeThumb] as string }}\n133:           />\n134:         </div>\n135: \n136:         <div className=\"flex gap-[8px] mt-[12px]\">\n137:           {thumbnails.map((src, i) => (\n138:             <div\n139:               key={i}\n140:               onClick={() => setActiveThumb(i)}\n141:               className={`w-[80px] h-[60px] rounded-[8px] object-cover cursor-pointer border-2 bg-white/5 bg-cover bg-center transition-all duration-200 hover:border-[rgba(74,144,217,0.3)] ${i === activeThumb ? 'border-[#4A90D9]' : 'border-transparent'}`}\n142:               style={photos.length > 0 ? { backgroundImage: `url(${src})` } : { background: src }}\n143:               data-testid={`A-07-detail-thumb-${i}`}\n144:               role=\"button\"\n145:               tabIndex={0}\n146:               onKeyDown={(e) => { if (e.key === 'Enter') setActiveThumb(i); }}\n147:             />\n148:           ))}\n149:         </div>\n150: \n151:         <div className=\"flex items-center gap-[16px] mt-[32px] mb-[4px]\">\n152:           <h2 className=\"text-[36px] font-bold tracking-[-0.02em]\">\n153:             ${property.price.toLocaleString()}<small className=\"text-[18px] font-normal text-[#94A3B8]\">/mo</small>\n154:           </h2>\n155:           {property.availableFrom && (\n156:             <span className=\"inline-block px-[10px] py-[2px] rounded-full text-[11px] font-semibold text-[#4ADE80] shadow-[0_0_8px_rgba(74,222,128,0.3)]\">Available {new Date(property.availableFrom).toLocaleDateString()}</span>\n157:           )}\n158:           <button\n159:             onClick={handleToggleFav}\n160:             className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 ml-auto ${favorited ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n161:             data-testid=\"A-07-detail-fav-btn\"\n162:           >\n163:             <Heart className=\"w-[20px] h-[20px]\" fill={favorited ? 'currentColor' : 'none'} />\n164:           </button>\n165:         </div>\n166:         <p className=\"text-[16px] text-[#94A3B8] mb-[32px]\">\n167:           <MapPin className=\"w-[16px] h-[16px] inline align-[-2px]\" />\n168:           {' '}{property.address.street}, {property.address.city}, {property.address.state} {property.address.zipCode}\n169:         </p>\n170: \n171:         <div className=\"grid grid-cols-4 gap-[16px] mb-[40px]\">\n172:           {stats.map((stat, i) => {\n173:             const Icon = stat.icon;\n174:             return (\n175:               <div key={i} className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] p-[24px] text-center\">\n176:                 <p><Icon className=\"w-[20px] h-[20px] text-[#4A90D9] inline align-[-3px]\" /></p>\n177:                 <h3 className={`${stat.isSmall ? 'text-[18px]' : 'text-[32px]'} font-bold mb-[4px]`}>{stat.value}</h3>\n178:                 <p className=\"text-[#94A3B8] text-[13px]\">{stat.label}</p>\n179:               </div>\n180:             );\n181:           })}\n182:         </div>\n183: \n184:         <div className=\"grid grid-cols-[1fr_420px] gap-[40px]\">\n185:           <div>\n186:             <div className=\"mb-[40px]\">\n187:               <h3 className=\"text-[20px] font-semibold mb-[16px]\">Description</h3>\n188:               <p className=\"text-[#94A3B8] text-[14px] leading-[1.8]\">\n189:                 {property.description}\n190:               </p>\n191:             </div>\n192: \n193:             {amenities.length > 0 && (\n194:               <div className=\"mb-[40px]\">\n195:                 <h3 className=\"text-[20px] font-semibold mb-[16px]\">Amenities</h3>\n196:                 <div className=\"grid grid-cols-2 gap-[12px]\">\n197:                   {amenities.map((amenity, i) => {\n198:                     const Icon = amenity.icon;\n199:                     return (\n200:                       <div key={i} className=\"flex items-center gap-[10px] px-[14px] py-[10px] bg-white/[0.03] rounded-[8px] text-[14px] text-[#94A3B8]\">\n201:                         <Icon className=\"w-[20px] h-[20px] text-[#4A90D9]\" />\n202:                         {amenity.label}\n203:                       </div>\n204:                     );\n205:                   })}\n206:                 </div>\n207:               </div>\n208:             )}\n209: \n210:             <div className=\"mb-[40px]\">\n211:               <h3 className=\"text-[20px] font-semibold mb-[16px]\">Location</h3>\n212:               <div className=\"w-full h-[300px] bg-[linear-gradient(135deg,rgba(74,144,217,0.1),rgba(124,58,237,0.1))] rounded-[12px] flex items-center justify-center text-[#64748B] text-[14px] border border-white/10\">\n213:                 <span><MapIcon className=\"w-[20px] h-[20px] inline align-[-4px]\" /> Map — {property.address.street}, {property.address.city}, {property.address.state} {property.address.zipCode}</span>\n214:               </div>\n215:             </div>\n216:           </div>\n217: \n218:           <div>\n219:             <div className=\"sticky top-[24px] bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] p-[24px]\">\n220:               <h3 className=\"text-[20px] font-semibold mb-[4px]\">Send an Inquiry</h3>\n221:               <p className=\"text-[#94A3B8] text-[13px] mb-[20px]\">Interested? Send a message to the landlord.</p>\n222: \n223:               {inquirySuccess && (\n224:                 <div className=\"mb-[16px] p-[12px] bg-[rgba(74,222,128,0.1)] border border-[rgba(74,222,128,0.3)] rounded-[8px] text-[#4ADE80] text-[13px]\">\n225:                   Inquiry sent successfully!\n226:                 </div>\n227:               )}\n228: \n229:               {submitInquiry.isError && (\n230:                 <div className=\"mb-[16px] p-[12px] bg-[rgba(248,113,113,0.1)] border border-[rgba(248,113,113,0.3)] rounded-[8px] text-[#F87171] text-[13px]\">\n231:                   {(submitInquiry.error as Error)?.message || 'Failed to send inquiry'}\n232:                 </div>\n233:               )}\n234: \n235:               <form className=\"flex flex-col gap-[16px]\" onSubmit={handleInquirySubmit}>\n236:                 <div>\n237:                   <label className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">Full Name</label>\n238:                   <input type=\"text\" name=\"name\" placeholder=\"John Smith\" className=\"h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\" data-testid=\"A-07-detail-inquiry-name\" />\n239:                 </div>\n240:                 <div>\n241:                   <label className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">Email Address</label>\n242:                   <input type=\"email\" name=\"email\" placeholder=\"john@example.com\" className=\"h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\" data-testid=\"A-07-detail-inquiry-email\" />\n243:                 </div>\n244:                 <div>\n245:                   <label className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">Phone Number</label>\n246:                   <input type=\"tel\" name=\"phone\" placeholder=\"(512) 555-0142\" className=\"h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\" data-testid=\"A-07-detail-inquiry-phone\" />\n247:                 </div>\n248:                 <div>\n249:                   <label className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">Message</label>\n250:                   <textarea name=\"message\" placeholder=\"Hi, I'm interested in this property and would like to schedule a viewing...\" rows={4} className=\"min-h-[100px] resize-y w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] py-[12px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\" data-testid=\"A-07-detail-inquiry-message\" />\n251:                 </div>\n252:                 <button type=\"submit\" disabled={submitInquiry.isPending} className=\"inline-flex items-center justify-center gap-[8px] font-semibold cursor-pointer border-none transition-all duration-200 font-[inherit] w-full h-[48px] px-[24px] rounded-[12px] text-[14px] text-white bg-[linear-gradient(135deg,#4A90D9,#7C3AED)] hover:shadow-[0_0_24px_rgba(74,144,217,0.3)] hover:-translate-y-[1px] disabled:opacity-50 disabled:cursor-not-allowed\" data-testid=\"A-07-detail-inquiry-submit\">\n253:                   <Send className=\"w-[18px] h-[18px]\" /> {submitInquiry.isPending ? 'Sending...' : 'Send Inquiry'}\n254:                 </button>\n255:               </form>\n256:             </div>\n257:           </div>\n258:         </div>\n259:       </section>\n260:     </div>\n261:   );\n262: }\n\n(End of file - total 262 lines)\n</content>","metadata":{"preview":"import { useState, type FormEvent } from 'react';\nimport { Link, useParams } from 'react-router-dom';\nimport { ArrowLeft, Heart, MapPin, Bed, Bath, Ruler, Building2, Wifi, AirVent, WashingMachine, CookingPot, Car, Dumbbell, Waves, PawPrint, Send, MapIcon } from 'lucide-react';\nimport { usePropertyDetail } from '~/hooks/api/useProperties';\nimport { useAddFavorite, useRemoveFavorite } from '~/hooks/api/useFavorites';\nimport { useSubmitInquiry } from '~/hooks/api/useInquiries';\n\nconst AMENITY_ICON_MAP: Record<string, React.ComponentType<{ className?: string }>> = {\n  wifi: Wifi,\n  'air-conditioning': AirVent,\n  laundry: WashingMachine,\n  dishwasher: CookingPot,\n  parking: Car,\n  gym: Dumbbell,\n  pool: Waves,\n  'pet-friendly': PawPrint,\n};\n\nexport default function DetailPage() {\n  const { id } = useParams<{ id: string }>();","truncated":false,"loaded":[]},"title":"frontend/app/pages/renter/detail.tsx","time":{"start":1779202211565,"end":1779202211882}},"id":"prt_e40b73a03001i0MWBrbT7kSDx9","sessionID":"ses_1bf4a6827ffe1b6mGO89Km1Cnx","messageID":"msg_e40b728c0001xhG4TzNuBmMis6"}}
