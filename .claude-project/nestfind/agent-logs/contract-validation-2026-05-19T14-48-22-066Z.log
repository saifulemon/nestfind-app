ding, isError, error } = usePropertySearch(filters);\n31:   const addFav = useAddFavorite();\n32:   const removeFav = useRemoveFavorite();\n33:   const [favoritedIds, setFavoritedIds] = useState<Set<string>>(new Set());\n34: \n35:   const properties = data?.items ?? [];\n36:   const meta = data?.meta;\n37:   const chips = [\n38:     filters.city && `${filters.city}`,\n39:     filters.minPrice && filters.maxPrice\n40:       ? `$${filters.minPrice} - $${filters.maxPrice}`\n41:       : filters.minPrice\n42:         ? `$${filters.minPrice}+`\n43:         : filters.maxPrice\n44:           ? `Up to $${filters.maxPrice}`\n45:           : null,\n46:     filters.bedrooms ? `${filters.bedrooms}+ Beds` : null,\n47:     filters.propertyType ? filters.propertyType.charAt(0).toUpperCase() + filters.propertyType.slice(1) : null,\n48:   ].filter(Boolean) as string[];\n49: \n50:   const handleSearch = useCallback(() => {\n51:     setFilters((prev) => ({ ...prev, search: searchText || undefined, page: 1 }));\n52:   }, [searchText]);\n53: \n54:   const handleKeyDown = useCallback(\n55:     (e: React.KeyboardEvent) => {\n56:       if (e.key === 'Enter') handleSearch();\n57:     },\n58:     [handleSearch],\n59:   );\n60: \n61:   const updateFilter = useCallback((key: keyof PropertySearchParams, value: string) => {\n62:     setFilters((prev) => {\n63:       const next = { ...prev, page: 1 };\n64:       if (key === 'propertyType') {\n65:         next.propertyType = (value as PropertyTypeEnum) || undefined;\n66:       } else if (key === 'bedrooms') {\n67:         next.bedrooms = value ? parseInt(value, 10) : undefined;\n68:       } else if (key === 'sortBy') {\n69:         next.sortBy = SORT_MAP[value] || 'newest';\n70:       } else if (key === 'minPrice') {\n71:         if (value === '500-1000') { next.minPrice = 500; next.maxPrice = 1000; }\n72:         else if (value === '1000-1500') { next.minPrice = 1000; next.maxPrice = 1500; }\n73:         else if (value === '1500-2000') { next.minPrice = 1500; next.maxPrice = 2000; }\n74:         else if (value === '2000-3000') { next.minPrice = 2000; next.maxPrice = 3000; }\n75:         else if (value === '3000+') { next.minPrice = 3000; next.maxPrice = undefined; }\n76:         else { next.minPrice = undefined; next.maxPrice = undefined; }\n77:       }\n78:       return next;\n79:     });\n80:   }, []);\n81: \n82:   const setPage = useCallback((page: number) => {\n83:     setFilters((prev) => ({ ...prev, page }));\n84:   }, []);\n85: \n86:   const toggleFav = (propertyId: string, e: React.MouseEvent) => {\n87:     e.preventDefault();\n88:     e.stopPropagation();\n89:     const isFav = favoritedIds.has(propertyId);\n90:     setFavoritedIds((prev) => {\n91:       const next = new Set(prev);\n92:       if (isFav) {\n93:         next.delete(propertyId);\n94:         removeFav.mutate(propertyId);\n95:       } else {\n96:         next.add(propertyId);\n97:         addFav.mutate({ propertyId });\n98:       }\n99:       return next;\n100:     });\n101:   };\n102: \n103:   return (\n104:     <div className=\"max-w-[1440px] mx-auto\">\n105:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n106:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n107:           NestFind\n108:         </div>\n109:         <div className=\"flex gap-[32px] items-center\">\n110:           <Link to=\"/search\" className=\"text-[#F1F5F9] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-browse\">Browse</Link>\n111:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-favorites\">Favorites</Link>\n112:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-inquiries\">My Inquiries</Link>\n113:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-profile\">Profile</Link>\n114:         </div>\n115:       </nav>\n116: \n117:       <section className=\"p-[48px]\">\n118:         <div className=\"flex gap-[12px] items-center mb-[24px] flex-wrap\">\n119:           <div className=\"flex-1 min-w-[280px] relative\">\n120:             <Search className=\"absolute left-[16px] top-1/2 -translate-y-1/2 text-[#64748B] w-[20px] h-[20px]\" />\n121:             <input\n122:               type=\"text\"\n123:               placeholder=\"Search by city, neighborhood, or ZIP...\"\n124:               className={`${inputClass} !pl-[44px]`}\n125:               data-testid=\"A-06-search-input\"\n126:               value={searchText}\n127:               onChange={(e) => setSearchText(e.target.value)}\n128:               onKeyDown={handleKeyDown}\n129:             />\n130:           </div>\n131:           <select\n132:             className={`${selectClass} w-[170px]`}\n133:             data-testid=\"A-06-search-price-range\"\n134:             onChange={(e) => updateFilter('minPrice', e.target.value)}\n135:           >\n136:             <option value=\"\">Price Range</option>\n137:             <option value=\"500-1000\">$500 - $1,000</option>\n138:             <option value=\"1000-1500\">$1,000 - $1,500</option>\n139:             <option value=\"1500-2000\">$1,500 - $2,000</option>\n140:             <option value=\"2000-3000\">$2,000 - $3,000</option>\n141:             <option value=\"3000+\">$3,000+</option>\n142:           </select>\n143:           <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-bedrooms\" onChange={(e) => updateFilter('bedrooms', e.target.value)}>\n144:             <option value=\"\">Bedrooms</option>\n145:             <option value=\"0\">Studio</option>\n146:             <option value=\"1\">1 Bed</option>\n147:             <option value=\"2\">2 Beds</option>\n148:             <option value=\"3\">3 Beds</option>\n149:             <option value=\"4\">4+ Beds</option>\n150:           </select>\n151:           <select className={`${selectClass} w-[160px]`} data-testid=\"A-06-search-property-type\" onChange={(e) => updateFilter('propertyType', e.target.value)}>\n152:             <option value=\"\">Property Type</option>\n153:             <option value=\"apartment\">Apartment</option>\n154:             <option value=\"condo\">Condo</option>\n155:             <option value=\"townhouse\">Townhouse</option>\n156:             <option value=\"house\">Single Family</option>\n157:           </select>\n158:           <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-sort\" onChange={(e) => updateFilter('sortBy', e.target.value)}>\n159:             <option value=\"newest\">Sort: Newest</option>\n160:             <option value=\"price_asc\">Price: Low to High</option>\n161:             <option value=\"price_desc\">Price: High to Low</option>\n162:           </select>\n163:           <button className=\"w-[48px] h-[48px] rounded-[8px] bg-transparent text-[#94A3B8] inline-flex items-center justify-center cursor-pointer transition-all duration-200 border-none hover:bg-white/10 hover:text-[#F1F5F9]\" data-testid=\"A-06-search-map-toggle\" title=\"Toggle map view\">\n164:             <Map className=\"w-[22px] h-[22px]\" />\n165:           </button>\n166:         </div>\n167: \n168:         {chips.length > 0 && (\n169:           <div className=\"flex gap-[8px] items-center mb-[20px] flex-wrap\">\n170:             {chips.map((chip) => (\n171:               <span key={chip} className=\"inline-flex items-center gap-[6px] px-[14px] py-[6px] bg-white/5 border border-white/10 rounded-full text-[13px] text-[#94A3B8] cursor-pointer transition-all duration-200 bg-[rgba(74,144,217,0.15)] border-[rgba(74,144,217,0.4)] text-[#4A90D9]\">\n172:                 {chip}\n173:                 <X className=\"w-[14px] h-[14px] cursor-pointer\" />\n174:               </span>\n175:             ))}\n176:             <span className=\"text-[#64748B] text-[14px] ml-auto\">\n177:               Showing {meta?.total ?? 0} properties\n178:             </span>\n179:           </div>\n180:         )}\n181: \n182:         {isLoading && (\n183:           <div className=\"flex items-center justify-center py-[80px] text-[#64748B] text-[16px]\">\n184:             Loading properties...\n185:           </div>\n186:         )}\n187: \n188:         {isError && (\n189:           <div className=\"flex items-center justify-center py-[80px] text-[#F87171] text-[16px]\">\n190:             {(error as Error)?.message || 'Failed to load properties. Please try again.'}\n191:           </div>\n192:         )}\n193: \n194:         {!isLoading && !isError && properties.length === 0 && (\n195:           <div className=\"flex flex-col items-center justify-center py-[80px] text-[#64748B]\">\n196:             <p className=\"text-[18px]\">No properties found</p>\n197:             <p className=\"text-[14px] mt-[8px]\">Try adjusting your search filters</p>\n198:           </div>\n199:         )}\n200: \n201:         {!isLoading && !isError && properties.length > 0 && (\n202:           <div className=\"grid grid-cols-4 gap-[20px]\">\n203:             {properties.map((prop, i) => (\n204:               <Link key={prop.id} to={`/detail/${prop.id}`} className=\"no-underline text-inherit\">\n205:                 <div className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(74,144,217,0.15)] hover:-translate-y-[2px]\">\n206:                   <div className=\"relative\">\n207:                     <div\n208:                       className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n209:                       style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.4),rgba(124,58,237,0.4))' }}\n210:                     />\n211:                       <button\n212:                       onClick={(e) => toggleFav(prop.id, e)}\n213:                       className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${favoritedIds.has(prop.id) ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n214:                       data-testid={`A-06-search-fav-btn-${i}`}\n215:                     >\n216:                       <Heart className=\"w-[18px] h-[18px]\" fill={favoritedIds.has(prop.id) ? 'currentColor' : 'none'} />\n217:                     </button>\n218:                   </div>\n219:                   <div className=\"p-[20px]\">\n220:                     <div className=\"text-[22px] font-bold\">\n221:                       ${prop.price.toLocaleString()}\n222:                       <small className=\"text-[14px] font-normal text-[#94A3B8]\">/mo</small>\n223:                     </div>\n224:                     <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">{prop.address.street}, {prop.address.city}, {prop.address.state}</div>\n225:                     <div className=\"flex gap-[16px] text-[13px] text-[#64748B] flex-wrap\">\n226:                       <span><Bed className=\"w-[14px] h-[14px] inline\" /> {prop.bedrooms} {prop.bedrooms === 1 ? 'Bed' : 'Beds'}</span>\n227:                       <span><Bath className=\"w-[14px] h-[14px] inline\" /> {prop.bathrooms} {prop.bathrooms === 1 ? 'Bath' : 'Baths'}</span>\n228:                       <span><Ruler className=\"w-[14px] h-[14px] inline\" /> {prop.squareFeet?.toLocaleString()} sqft</span>\n229:                     </div>\n230:                   </div>\n231:                 </div>\n232:               </Link>\n233:             ))}\n234:           </div>\n235:         )}\n236: \n237:         {meta && meta.totalPages > 1 && (\n238:           <div className=\"flex gap-[4px] justify-center mt-[32px]\">\n239:             <button\n240:               className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n241:               data-testid=\"A-06-search-pagination-prev\"\n242:               onClick={() => setPage(Math.max(1, meta.page - 1))}\n243:               disabled={meta.page <= 1}\n244:             >\n245:               <ChevronLeft className=\"w-[18px] h-[18px]\" />\n246:             </button>\n247:             {Array.from({ length: Math.min(meta.totalPages, 5) }, (_, i) => i + 1).map((n) => (\n248:               <button\n249:                 key={n}\n250:                 className={`w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium cursor-pointer border-none transition-all duration-200 ${n === meta.page ? 'bg-[linear-gradient(135deg,#4A90D9,#7C3AED)] text-white' : 'text-[#94A3B8] bg-transparent hover:bg-white/10 hover:text-[#F1F5F9]'}`}\n251:                 data-testid={`A-06-search-pagination-${n}`}\n252:                 onClick={() => setPage(n)}\n253:               >\n254:                 {n}\n255:               </button>\n256:             ))}\n257:             {meta.totalPages > 5 && (\n258:               <span className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8]\">...</span>\n259:             )}\n260:             <button\n261:               className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n262:               data-testid=\"A-06-search-pagination-next\"\n263:               onClick={() => setPage(Math.min(meta.totalPages, meta.page + 1))}\n264:               disabled={meta.page >= meta.totalPages}\n265:             >\n266:               <ChevronRight className=\"w-[18px] h-[18px]\" />\n267:             </button>\n268:           </div>\n269:         )}\n270:       </section>\n271:     </div>\n272:   );\n273: }\n\n(End of file - total 273 lines)\n</content>","metadata":{"preview":"import { useState, useCallback } from 'react';\nimport { Link } from 'react-router-dom';\nimport { Search, X, Map, Heart, ChevronLeft, ChevronRight, Bed, Bath, Ruler } from 'lucide-react';\nimport { usePropertySearch } from '~/hooks/api/useProperties';\nimport { useAddFavorite, useRemoveFavorite } from '~/hooks/api/useFavorites';\nimport type { PropertyTypeEnum, PropertySearchParams } from '~/types/api/property';\n\nexport const inputClass =\n  'h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nexport const selectClass =\n  'h-[48px] bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nconst SORT_MAP: Record<string, PropertySearchParams['sortBy']> = {\n  '': 'newest',\n  'price_asc': 'price_asc',\n  'price_desc': 'price_desc',\n  'newest': 'newest',\n  'oldest': 'oldest',\n};","truncated":false,"loaded":[]},"title":"frontend/app/pages/renter/search.tsx","time":{"start":1779202307751,"end":1779202308139}},"id":"prt_e40b8b1cb0015a3REYWXzdPH48","sessionID":"ses_1bf4a6827ffe1b6mGO89Km1Cnx","messageID":"msg_e40b8a300001K0LPwOyLIbaLGk"}}
