property.availableFrom && (\n156:             <span className=\"inline-block px-[10px] py-[2px] rounded-full text-[11px] font-semibold text-[#4ADE80] shadow-[0_0_8px_rgba(74,222,128,0.3)]\">Available {new Date(property.availableFrom).toLocaleDateString()}</span>\n157:           )}\n158:           <button\n159:             onClick={handleToggleFav}\n160:             className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 ml-auto ${favorited ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n161:             data-testid=\"A-07-detail-fav-btn\"\n162:           >\n163:             <Heart className=\"w-[20px] h-[20px]\" fill={favorited ? 'currentColor' : 'none'} />\n164:           </button>\n165:         </div>\n166:         <p className=\"text-[16px] text-[#94A3B8] mb-[32px]\">\n167:           <MapPin className=\"w-[16px] h-[16px] inline align-[-2px]\" />\n168:           {' '}{property.addressStreet}, {property.addressCity}, {property.addressState} {property.addressZipCode}\n169:         </p>\n170: \n171:         <div className=\"grid grid-cols-4 gap-[16px] mb-[40px]\">\n172:           {stats.map((stat, i) => {\n173:             const Icon = stat.icon;\n174:             return (\n175:               <div key={i} className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] p-[24px] text-center\">\n176:                 <p><Icon className=\"w-[20px] h-[20px] text-[#4A90D9] inline align-[-3px]\" /></p>\n177:                 <h3 className={`${stat.isSmall ? 'text-[18px]' : 'text-[32px]'} font-bold mb-[4px]`}>{stat.value}</h3>\n178:                 <p className=\"text-[#94A3B8] text-[13px]\">{stat.label}</p>\n179:               </div>\n180:             );\n181:           })}\n182:         </div>\n183: \n184:         <div className=\"grid grid-cols-[1fr_420px] gap-[40px]\">\n185:           <div>\n186:             <div className=\"mb-[40px]\">\n187:               <h3 className=\"text-[20px] font-semibold mb-[16px]\">Description</h3>\n188:               <p className=\"text-[#94A3B8] text-[14px] leading-[1.8]\">\n189:                 {property.description}\n190:               </p>\n191:             </div>\n192: \n193:             {amenities.length > 0 && (\n194:               <div className=\"mb-[40px]\">\n195:                 <h3 className=\"text-[20px] font-semibold mb-[16px]\">Amenities</h3>\n196:                 <div className=\"grid grid-cols-2 gap-[12px]\">\n197:                   {amenities.map((amenity, i) => {\n198:                     const Icon = amenity.icon;\n199:                     return (\n200:                       <div key={i} className=\"flex items-center gap-[10px] px-[14px] py-[10px] bg-white/[0.03] rounded-[8px] text-[14px] text-[#94A3B8]\">\n201:                         <Icon className=\"w-[20px] h-[20px] text-[#4A90D9]\" />\n202:                         {amenity.label}\n203:                       </div>\n204:                     );\n205:                   })}\n206:                 </div>\n207:               </div>\n208:             )}\n209: \n210:             <div className=\"mb-[40px]\">\n211:               <h3 className=\"text-[20px] font-semibold mb-[16px]\">Location</h3>\n212:               <div className=\"w-full h-[300px] bg-[linear-gradient(135deg,rgba(74,144,217,0.1),rgba(124,58,237,0.1))] rounded-[12px] flex items-center justify-center text-[#64748B] text-[14px] border border-white/10\">\n213:                 <span><MapIcon className=\"w-[20px] h-[20px] inline align-[-4px]\" /> Map — {property.addressStreet}, {property.addressCity}, {property.addressState} {property.addressZipCode}</span>\n214:               </div>\n215:             </div>\n216:           </div>\n217: \n218:           <div>\n219:             <div className=\"sticky top-[24px] bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] p-[24px]\">\