ty.id });\n36:     } else {\n37:       removeFav.mutate(property.id);\n38:     }\n39:   };\n40: \n41:   const handleInquirySubmit = (e: FormEvent<HTMLFormElement>) => {\n42:     e.preventDefault();\n43:     const form = e.currentTarget;\n44:     const formData = new FormData(form);\n45:     submitInquiry.mutate(\n46:       {\n47:         message: formData.get('message') as string,\n48:         name: (formData.get('name') as string) || undefined,\n49:         email: (formData.get('email') as string) || undefined,\n50:         phone: (formData.get('phone') as string) || undefined,\n51:       },\n52:       {\n53:         onSuccess: () => {\n54:           setInquirySuccess(true);\n55:           form.reset();\n56:         },\n57:       }\n58:     );\n59:   };\n60: \n61:   if (isLoading) {\n62:     return (\n63:       <div className=\"max-w-[1440px] mx-auto\">\n64:         <div className=\"flex items-center justify-center py-[120px] text-[#64748B] text-[16px]\">\n65:           Loading property details...\n66:         </div>\n67:       </div>\n68:     );\n69:   }\n70: \n71:   if (isError) {\n72:     return (\n73:       <div className=\"max-w-[1440px] mx-auto\">\n74:         <div className=\"flex flex-col items-center justify-center py-[120px] text-[#F87171] text-[16px]\">\n75:           <p>{(error as Error)?.message || 'Failed to load property'}</p>\n76:           <Link to=\"/search\" className=\"text-[#4A90D9] mt-[16px] hover:underline\">Back to search</Link>\n77:         </div>\n78:       </div>\n79:     );\n80:   }\n81: \n82:   if (!property) {\n83:     return (\n84:       <div className=\"max-w-[1440px] mx-auto\">\n85:         <div className=\"flex flex-col items-center justify-center py-[120px] text-[#64748B]\">\n86:           <p className=\"text-[18px]\">Property not found</p>\n87:           <Link to=\"/search\" className=\"text-[#4A90D9] mt-[16px] hover:underline\">Back to search</Link>\n88:         </div>\n89:       </div>\n90:     );\n91:   }\n92: \n93:   const photos = property.photos ?? [];\n94:   const thumbnails = photos.length > 0\n95:     ? photos.map((p) => p.url)\n96:     : ['linear-gradient(135deg,rgba(74,144,217,0.35),rgba(124,58,237,0.35))'];\n97: \n98:   const stats = [\n99:     { icon: Bed, value: String(property.bedrooms), label: 'Bedrooms' },\n100:     { icon: Bath, value: String(property.bathrooms), label: 'Bathrooms' },\n101:     { icon: Ruler, value: property.squareFeet?.toLocaleString() ?? '—', label: 'Square Feet' },\n102:     { icon: Building2, value: property.propertyType.charAt(0).toUpperCase() + property.propertyType.slice(1), label: 'Property Type', isSmall: true },\n103:   ];\n104: \n105:   const amenities = (property.amenities ?? []).map((a) => ({\n106:     icon: AMENITY_ICON_MAP[a.icon] || Wifi,\n107:     label: a.name,\n108:   }));\n109: \n110:   return (\n111:     <div className=\"max-w-[1440px] mx-auto\">\n112:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n113:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n114:           NestFind\n115:         </div>\n116:         <div className=\"flex gap-[32px] items-center\">\n117:           <Link to=\"/search\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-browse\">Browse</Link>\n118:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-favorites\">Favorites</Link>\n119:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-07-detail-nav-inquiries\">My Inquiries</Link>\n120:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testi