{"type":"tool_use","timestamp":1779253248393,"sessionID":"ses_1bc3faaa8ffeuQxc4RLqet37VH","part":{"type":"tool","tool":"read","callID":"call_05_CztHLTGx3FanogSOJDiN7129","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/admin/property-form.tsx"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/admin/property-form.tsx</path>\n<type>file</type>\n<content>\n1: import { useState, type FormEvent } from 'react';\n2: import { useNavigate, useParams } from 'react-router-dom';\n3: import { useCreateProperty, useUpdateProperty, usePropertyDetail } from '~/hooks/api/useProperties';\n4: import { useAmenityList } from '~/hooks/api/useAmenities';\n5: import type { CreatePropertyDto, PropertyTypeEnum } from '~/types/api/property';\n6: import { PROPERTY_TYPES } from '~/types/api/property';\n7: \n8: export default function PropertyForm() {\n9:   const { id } = useParams<{ id: string }>();\n10:   const navigate = useNavigate();\n11:   const isEdit = !!id;\n12: \n13:   const { data: existingProperty, isLoading: loadingExisting } = usePropertyDetail(id);\n14:   const { data: amenities } = useAmenityList();\n15:   const createProperty = useCreateProperty();\n16:   const updateProperty = useUpdateProperty();\n17: \n18:   const [error, setError] = useState<string | null>(null);\n19:   const [selectedAmenities, setSelectedAmenities] = useState<string[]>([]);\n20: \n21:   const isPending = createProperty.isPending || updateProperty.isPending;\n22: \n23:   const handleSubmit = (e: FormEvent<HTMLFormElement>) => {\n24:     e.preventDefault();\n25:     setError(null);\n26:     const form = new FormData(e.currentTarget);\n27: \n28:     const data: CreatePropertyDto = {\n29:       title: form.get('title') as string,\n30:       description: form.get('description') as string,\n31:       price: parseFloat(form.get('price') as string),\n32:       bedrooms: parseInt(form.get('bedrooms') as string, 10),\n33:       bathrooms: parseInt(form.get('bathrooms') as string, 10),\n34:       squareFeet: form.get('squareFeet') ? parseInt(form.get('squareFeet') as string, 10) : undefined,\n35:       propertyType: form.get('propertyType') as PropertyTypeEnum,\n36:       addressStreet: form.get('addressStreet') as string,\n37:       addressCity: form.get('addressCity') as string,\n38:       addressState: form.get('addressState') as string,\n39:       addressZipCode: form.get('addressZipCode') as string,\n40:       amenityIds: selectedAmenities,\n41:       availableFrom: (form.get('availableFrom') as string) || undefined,\n42:     };\n43: \n44:     if (isEdit && id) {\n45:       updateProperty.mutate(\n46:         { id, data },\n47:         { onSuccess: () => navigate('/admin/properties'), onError: (err) => setError((err as Error).message) }\n48:       );\n49:     } else {\n50:       createProperty.mutate(data, {\n51:         onSuccess: () => navigate('/admin/properties'),\n52:         onError: (err) => setError((err as Error).message),\n53:       });\n54:     }\n55:   };\n56: \n57:   const toggleAmenity = (id: string) => {\n58:     setSelectedAmenities((prev) =>\n59:       prev.includes(id) ? prev.filter((a) => a !== id) : [...prev, id]\n60:     );\n61:   };\n62: \n63:   if (isEdit && loadingExisting) {\n64:     return (\n65:       <div>\n66:         <h1 className=\"text-3xl font-bold\">Property Form</h1>\n67:         <p className=\"mt-2 text-muted-foreground\">Loading...</p>\n68:       </div>\n69:     );\n70:   }\n71: \n72:   return (\n73:     <div>\n74:       <h1 className=\"text-3xl font-bold\">{isEdit ? 'Edit Property' : 'Add Property'}</h1>\n75:       <p className=\"mt-2 text-muted-foreground\">{isEdit ? 'Update property details.' : 'Create a new property listing.'}</p>\n76: \n77:       {error && (\n78:         <div className=\"mt-4 p-3 rounded bg-destructive/10 text-destructive text-sm\">{error}</div>\n79:       )}\n80: \n81:       {createProperty.isSuccess && !isEdit && (\n82:         <div className=\"mt-4 p-3 rounded bg-green-500/10 text-green-500 text-sm\">Property created successfully!</div>\n83:       )}\n84: \n85:       <form onSubmit={handleSubmit} className=\"mt-6 space-y-4 max-w-2xl\">\n86:         <div>\n87:           <label className=\"block text-sm font-medium mb-1\">Title</label>\n88:           <input name=\"title\" required minLength={5} maxLength={200} defaultValue={existingProperty?.title || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n89:         </div>\n90:         <div>\n91:           <label className=\"block text-sm font-medium mb-1\">Description</label>\n92:           <textarea name=\"description\" required minLength={20} maxLength={5000} rows={4} defaultValue={existingProperty?.description || ''} className=\"w-full rounded-md border bg-background px-3 py-2 text-sm resize-y\" />\n93:         </div>\n94:         <div className=\"grid grid-cols-3 gap-4\">\n95:           <div>\n96:             <label className=\"block text-sm font-medium mb-1\">Price ($/mo)</label>\n97:             <input name=\"price\" type=\"number\" required min={0} step=\"0.01\" defaultValue={existingProperty?.price || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n98:           </div>\n99:           <div>\n100:             <label className=\"block text-sm font-medium mb-1\">Bedrooms</label>\n101:             <input name=\"bedrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bedrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n102:           </div>\n103:           <div>\n104:             <label className=\"block text-sm font-medium mb-1\">Bathrooms</label>\n105:             <input name=\"bathrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bathrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n106:           </div>\n107:         </div>\n108:         <div className=\"grid grid-cols-2 gap-4\">\n109:           <div>\n110:             <label className=\"block text-sm font-medium mb-1\">Square Feet</label>\n111:             <input name=\"squareFeet\" type=\"number\" min={0} defaultValue={existingProperty?.squareFeet || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n112:           </div>\n113:           <div>\n114:             <label className=\"block text-sm font-medium mb-1\">Property Type</label>\n115:             <select name=\"propertyType\" required defaultValue={existingProperty?.propertyType || 'apartment'} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\">\n116:               {PROPERTY_TYPES.map((t) => (\n117:                 <option key={t} value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>\n118:               ))}\n119:             </select>\n120:           </div>\n121:         </div>\n122:         <div>\n123:           <label className=\"block text-sm font-medium mb-1\">Available From</label>\n124:           <input name=\"availableFrom\" type=\"date\" defaultValue={existingProperty?.availableFrom?.split('T')[0] || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n125:         </div>\n126:         <fieldset className=\"border rounded-md p-4\">\n127:           <legend className=\"text-sm font-medium px-2\">Address</legend>\n128:           <div className=\"grid grid-cols-2 gap-4\">\n129:             <div className=\"col-span-2\">\n130:               <label className=\"block text-sm mb-1\">Street</label>\n131:               <input name=\"addressStreet\" required maxLength={200} defaultValue={existingProperty?.addressStreet || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n132:             </div>\n133:             <div>\n134:               <label className=\"block text-sm mb-1\">City</label>\n135:               <input name=\"addressCity\" required maxLength={100} defaultValue={existingProperty?.addressCity || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n136:             </div>\n137:             <div>\n138:               <label className=\"block text-sm mb-1\">State</label>\n139:               <input name=\"addressState\" required maxLength={100} defaultValue={existingProperty?.addressState || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n140:             </div>\n141:             <div>\n142:               <label className=\"block text-sm mb-1\">ZIP Code</label>\n143:               <input name=\"addressZipCode\" required maxLength={10} defaultValue={existingProperty?.addressZipCode || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n144:             </div>\n145:           </div>\n146:         </fieldset>\n147: \n148:         {amenities && amenities.length > 0 && (\n149:           <div>\n150:             <label className=\"block text-sm font-medium mb-2\">Amenities</label>\n151:             <div className=\"flex flex-wrap gap-2\">\n152:               {amenities.map((a) => (\n153:                 <label key={a.id} className=\"flex items-center gap-1.5 px-3 py-1.5 border rounded-md text-sm cursor-pointer hover:bg-muted\">\n154:                   <input\n155:                     type=\"checkbox\"\n156:                     checked={selectedAmenities.includes(a.id)}\n157:                     onChange={() => toggleAmenity(a.id)}\n158:                     className=\"accent-primary\"\n159:                   />\n160:                   {a.name}\n161:                 </label>\n162:               ))}\n163:             </div>\n164:           </div>\n165:         )}\n166: \n167:         <button type=\"submit\" disabled={isPending} className=\"inline-flex items-center justify-center h-10 px-6 rounded-md bg-primary text-primary-foreground text-sm font-semibold hover:opacity-90 disabled:opacity-50\">\n168:           {isPending ? 'Saving...' : isEdit ? 'Update Property' : 'Create P