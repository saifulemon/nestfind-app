className=\"relative\">\n210:                     <div\n211:                       className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n212:                       style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.4),rgba(124,58,237,0.4))' }}\n213:                     />\n214:                       <button\n215:                       onClick={(e) => toggleFav(prop.id, e)}\n216:                       className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${favoritedIds.has(prop.id) ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n217:                       data-testid={`A-06-search-fav-btn-${i}`}\n218:                     >\n219:                       <Heart className=\"w-[18px] h-[18px]\" fill={favoritedIds.has(prop.id) ? 'currentColor' : 'none'} />\n220:                     </button>\n221:                   </div>\n222:                   <div className=\"p-[20px]\">\n223:                     <div className=\"text-[22px] font-bold\">\n224:                       ${prop.price.toLocaleString()}\n225:                       <small className=\"text-[14px] font-normal text-[#94A3B8]\">/mo</small>\n226:                     </div>\n227:                     <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">{prop.addressStreet}, {prop.addressCity}, {prop.addressState}</div>\n228:                     <div className=\"flex gap-[16px] text-[13px] text-[#64748B] flex-wrap\">\n229:                       <span><Bed className=\"w-[14px] h-[14px] inline\" /> {prop.bedrooms} {prop.bedrooms === 1 ? 'Bed' : 'Beds'}</span>\n230:                       <span><Bath className=\"w-[14px] h-[14px] inline\" /> {prop.bathrooms} {prop.bathrooms === 1 ? 'Bath' : 'Baths'}</span>\n231:          