[#94A3B8] mb-[6px]\">{t('auth.newPassword')}</label>\n62:             <input id=\"new-password\" type=\"password\" placeholder={t('auth.enterNewPassword')} {...form.register('newPassword')}\n63:               className=\"h-[48px] bg-white/[0.04] border border-white/[0.08] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none w-full placeholder:text-[#64748B] focus:border-[#4A90D9]/50 focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\"\n64:               data-testid=\"A-05-reset-password-new-password\" />\n65:             {form.formState.errors.newPassword ? (\n66:               <p className=\"text-[#F87171] text-[12px] mt-[4px]\">{form.formState.errors.newPassword.message}</p>\n67:             ) : (\n68:               <p className=\"text-[12px] text-[#64748B] mt-[6px]\">{t('auth.atLeast8Chars')}</p>\n69:             )}\n70:           </div>\n71:           <div className=\"mb-[16px]\">\n72:             <label htmlFor=\"confirm-new-password\" className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">{t('auth.confirmNewPassword')}</label>\n73:             <input id=\"confirm-new-password\" type=\"password\" placeholder={t('auth.reEnterNewPassword')} {...form.register('confirmNewPassword')}\n74:               className=\"h-[48px] bg-white/[0.04] border border-white/[0.08] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none w-full placeholder:text-[#64748B] focus:border-[#4A90D9]/50 focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]\"\n75:               data-testid=\"A-05-reset-password-confirm-new-password\" />\n76:             {form.formState.errors.confirmNewPassword && (\n77:               <p className=\"text-[#F87171] text-[12px] mt-[4px]\">{form.formState.errors.confirmNewPassword.message}</p>\n78:             )}\n79:           </div>\n80:           <button type=\"submit\" disabled={resetPassword.isPending}\n81:             className=\"inline-flex items-center justify-center font-semibold cursor-pointer border-0 transition-all duration-200 