{"type":"tool_use","timestamp":1779253428022,"sessionID":"ses_1bc3faaa8ffeuQxc4RLqet37VH","part":{"type":"tool","tool":"read","callID":"call_00_qSCsPC2hUhDAAbKIT6wq8272","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/properties/property.controller.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/properties/property.controller.ts</path>\n<type>file</type>\n<content>\n1: import {\n2:   Controller,\n3:   Get,\n4:   Post,\n5:   Patch,\n6:   Delete,\n7:   Body,\n8:   Param,\n9:   Query,\n10:   ParseUUIDPipe,\n11:   HttpCode,\n12:   HttpStatus,\n13:   UseGuards,\n14:   UseInterceptors,\n15:   UploadedFiles,\n16: } from '@nestjs/common';\n17: import { FilesInterceptor } from '@nestjs/platform-express';\n18: import { memoryStorage } from 'multer';\n19: import { ApiTags, ApiOperation, ApiResponse, ApiParam, ApiBearerAuth } from '@nestjs/swagger';\n20: import { Public } from '../../core/decorators/public.decorator';\n21: import { Roles } from '../../core/decorators/roles.decorator';\n22: import { CurrentUser } from '../../core/decorators/current-user.decorator';\n23: import { RolesGuard } from '../../core/guards/roles.guard';\n24: import { PropertyService } from './property.service';\n25: import { CreatePropertyDto } from './dto/create-property.dto';\n26: import { UpdatePropertyDto } from './dto/update-property.dto';\n27: import { ReorderPhotosDto } from './dto/reorder-photos.dto';\n28: import { IJwtPayload } from '../../shared/interfaces/jwt-payload.interface';\n29: \n30: @ApiTags('Properties')\n31: @Controller('properties')\n32: @UseGuards(RolesGuard)\n33: export class PropertyController {\n34:   constructor(private readonly propertyService: PropertyService) {}\n35: \n36:   @Public()\n37:   @Get()\n38:   @HttpCode(HttpStatus.OK)\n39:   @ApiOperation({ summary: 'Search properties with filters (public)' })\n40:   @ApiResponse({ status: 200, description: 'Properties retrieved successfully' })\n41:   async search(@Query() query: any) {\n42:     const result = await this.propertyService.search(query);\n43:     return {\n44:       message: 'Properties retrieved successfully',\n45:       data: {\n46:         items: result.items,\n47:         meta: {\n48:           total: result.total,\n49:           page: result.page,\n50:           limit: result.limit,\n51:           totalPages: result.totalPages,\n52:         },\n53:       },\n54:     };\n55:   }\n56: \n57:   @Public()\n58:   @Get(':id')\n59:   @HttpCode(HttpStatus.OK)\n60:   @ApiOperation({ summary: 'Get property detail (public)' })\n61:   @ApiResponse({ status: 200, description: 'Property retrieved successfully' })\n62:   @ApiResponse({ status: 404, description: 'Property not found' })\n63:   @ApiParam({ name: 'id', type: String, description: 'Property UUID' })\n64:   async findOne(\n65:     @Param('id', ParseUUIDPipe) id: string,\n66:     @CurrentUser() user?: IJwtPayload,\n67:   ) {\n68:     const property = await this.propertyService.getPropertyDetail(\n69:       id,\n70:       user?.id,\n71:     );\n72:     return { message: 'Property retrieved successfully', data: property };\n73:   }\n74: \n75:   @Roles('admin')\n76:   @Post()\n77:   @HttpCode(HttpStatus.CREATED)\n78:   @ApiBearerAuth()\n79:   @ApiOperation({ summary: 'Create a new property (admin only)' })\n80:   @ApiResponse({ status: 201, description: 'Property created successfully' })\n81:   @ApiResponse({ status: 400, description: 'Validation failed' })\n82:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n83:   @ApiResponse({ status: 403, description: 'Not an admin' })\n84:   async create(@Body() dto: CreatePropertyDto) {\n85:     const property = await this.propertyService.createProperty(dto);\n86:     return { message: 'Property created successfully', data: property };\n87:   }\n88: \n89:   @Roles('admin')\n90:   @Patch(':id')\n91:   @HttpCode(HttpStatus.OK)\n92:   @ApiBearerAuth()\n93:   @ApiOperation({ summary: 'Update a property (admin only)' })\n94:   @ApiResponse({ status: 200, description: 'Property updated successfully' })\n95:   @ApiResponse({ status: 400, description: 'Validation failed' })\n96:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n97:   @ApiResponse({ status: 403, description: 'Not an admin' })\n98:   @ApiResponse({ status: 404, description: 'Property not found' })\n99:   @ApiParam({ name: 'id', type: String, description: 'Property UUID' })\n100:   async update(\n101:     @Param('id', ParseUUIDPipe) id: string,\n102:     @Body() dto: UpdatePropertyDto,\n103:   ) {\n104:     const property = await this.propertyService.updateProperty(id, dto);\n105:     return { message: 'Property updated successfully', data: property };\n106:   }\n107: \n108:   @Roles('admin')\n109:   @Delete(':id')\n110:   @HttpCode(HttpStatus.OK)\n111:   @ApiBearerAuth()\n112:   @ApiOperation({ summary: 'Archive a property (admin only)' })\n113:   @ApiResponse({ status: 200, description: 'Property archived successfully' })\n114:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n115:   @ApiResponse({ status: 403, description: 'Not an admin' })\n116:   @ApiResponse({ status: 404, description: 'Property not found' })\n117:   @ApiParam({ name: 'id', type: String, description: 'Property UUID' })\n118:   async archive(@Param('id', ParseUUIDPipe) id: string) {\n119:     await this.propertyService.archive(id);\n120:     return { message: 'Property archived successfully', data: null };\n121:   }\n122: \n123:   @Roles('admin')\n124:   @Post(':id/photos')\n125:   @HttpCode(HttpStatus.CREATED)\n126:   @ApiBearerAuth()\n127:   @ApiOperation({ summary: 'Upload photos for a property (admin only)' })\n128:   @ApiResponse({ status: 201, description: 'Photos uploaded successfully' })\n129:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n130:   @ApiResponse({ status: 403, description: 'Not an admin' })\n131:   @ApiResponse({ status: 404, description: 'Property not found' })\n132:   @ApiParam({ name: 'id', type: String, description: 'Property UUID' })\n133:   @UseInterceptors(\n134:     FilesInterceptor('files', 10, { storage: memoryStorage() }),\n135:   )\n136:   async uploadPhotos(\n137:     @Param('id', ParseUUIDPipe) id: string,\n138:     @UploadedFiles() files: Express.Multer.File[],\n139:   ) {\n140:     if (!files || files.length === 0) {\n141:       return { message: 'Photos uploaded successfully', data: [] };\n142:     }\n143:     const photos = await this.propertyService.uploadPhotos(id, files);\n144:     return { message: 'Photos uploaded successfully', data: photos };\n145:   }\n146: \n147:   @Roles('admin')\n148:   @Delete(':id/photos/:photoId')\n149:   @HttpCode(HttpStatus.OK)\n150:   @ApiBearerAuth()\n151:   @ApiOperation({ summary: 'Delete a photo from a property (admin only)' })\n152:   @ApiResponse({ status: 200, description: 'Photo deleted successfully' })\n153:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n154:   @ApiResponse({ status: 403, description: 'Not an admin' })\n155:   @ApiResponse({ status: 404, description: 'Property or photo not found' })\n156:   @ApiParam({ name: 'id', type: String, description: 'Property UUID' })\n157:   @ApiParam({ name: 'photoId', type: String, description: 'Photo UUID' })\n158:   async deletePhoto(\n159:     @Param('id', ParseUUIDPipe) id: string,\n160:     @Param('photoId', ParseUUIDPipe) photoId: string,\n161:   ) {\n162:     await this.propertyService.deletePhoto(id, photoId);\n163:     return { message: 'Photo deleted successfully', data: null };\n164:   }\n165: \n166:   @Roles('admin')\n167:   @Patch(':id/photos/:photoId/primary')\n168:   @HttpCode(HttpStatus.OK)\n169:   @ApiBearerAuth()\n170:   @ApiOperation({ summary: 'Set a photo as primary for a property (admin only)' })\n171:   @ApiResponse({ status: 200, description: 'Primary photo set successfully' })\n172:   @ApiResponse({ status: 401, description: 'Not au