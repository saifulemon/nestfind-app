User.fulfilled, (state, action) => {\n107:         state.isLoading = false;\n108:         state.isAuthenticated = true;\n109:         state.authChecked = true;\n110:         state.user = action.payload;\n111:       })\n112:       .addCase(fetchCurrentUser.rejected, (state) => {\n113:         state.isLoading = false;\n114:         state.isAuthenticated = false;\n115:         state.authChecked = true;\n116:         state.user = null;\n117:       })\n118:       .addCase(logoutUser.fulfilled, (state) => {\n119:         state.isAuthenticated = false;\n120:         state.authChecked = true;\n121:         state.user = null;\n122:       })\n123:       .addCase(logoutUser.rejected, (state) => {\n124:         state.isAuthenticated = false;\n125:         state.authChecked = true;\n126:         state.user = null;\n127:       });\n128:   },\n129: });\n130: \n131: export const { clearAuthError, setAuthChecked } = authSlice.actions;\n132: export default authSlice.reducer;\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"import { createSlice, createAsyncThunk } from '@reduxjs/toolkit';\nimport { httpService } from '~/services/httpService';\nimport type { AuthState, AuthUser, LoginCredentials, RegisterCredentials } from '~/types/auth';\n\nconst initialState: AuthState = {\n  user: null,\n  isAuthenticated: false,\n  isLoading: false,\n  authChecked: false,\n  error: null,\n};\n\nexport const loginUser = createAsyncThunk(\n  'auth/loginUser',\n  async (credentials: LoginCredentials, { rejectWithValue }) => {\n    try {\n      const response = await httpService.post<{ data: AuthUser }>('/auth/login', credentials);\n      return response.data;\n    } catch (error: any) {\n      return rejectWithValue(error.message);","truncated":false,"loaded":[]},"title":"frontend/app/redux/features/authSlice.ts","time":{"start":1779192431812,"end":1779192432078}},"id":"prt_e4021ff4b001u8SjNwjhoLQgZU","sessionID":"ses_1bfdf007dffemH8z7Kja4F2YQZ","messageID":"msg_e4021e301001HH5ru