 text-muted-foreground hover:text-foreground\">\n                {t('nav.inquiries')}\n              </Link>\n              <Link to=\"/profile\" className=\"text-sm text-muted-foreground hover:text-foreground\">\n                {t('nav.profile')}\n              </Link>\n              {user?.role === 'admin' && (\n                <Link to=\"/admin\" className=\"text-sm text-muted-foreground hover:text-foreground\">\n                  {t('nav.admin')}\n                </Link>\n              )}\n            </>\n          ) : (\n            <>\n              <Link to=\"/login\" className=\"text-sm text-muted-foreground hover:text-foreground\">\n                {t('nav.login')}\n              </Link>\n              <Link to=\"/signup\" className=\"text-sm text-muted-foreground hover:text-foreground\">\n                {t('nav.signup')}\n              </Link>\n            </>\n          )}\n          <button\n            onClick={toggleLanguage}\n            className=\"text-xs px-2 py-1 rounded border border-border text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n            aria-label={t('common.language')}\n          >\n            {i18n.language === 'en' ? 'KO' : 'EN'}\n          </button>\n        </nav>\n      </div>\n    </header>\n  );\n}"},"output":"Edit applied successfully.","metadata":{"diagnostics":{},"diff":"Index: /Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/layout/header.tsx\n===================================================================\n--- /Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/layout/header.tsx\n+++ /Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/layout/header.tsx\n@@ -1,15 +1,61 @@\n-import { Link } from \"react-router\";\n+import { Link } from 'react-router';\n+import { useTranslation } from 'react-i18next';\n+import { useAuth } from '~/hooks/useAuth';\n \n export default function Header() {\n+  const { t, i18n } = useTransla