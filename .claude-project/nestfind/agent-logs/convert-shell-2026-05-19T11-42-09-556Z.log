{"type":"tool_use","timestamp":1779191780374,"sessionID":"ses_1bff4e2c5ffelBqOnmJS1wuf2p","part":{"type":"tool","tool":"write","callID":"call_00_uFQQOs8rsePwQGeyLOUW3850","state":{"status":"completed","input":{"content":"import { Outlet, Navigate, useLocation, Link } from 'react-router';\nimport { useAuth } from '~/hooks/useAuth';\nimport Header from '~/components/layout/header';\nimport { Loader2 } from 'lucide-react';\nimport { RoleEnum } from '~/enums/role.enum';\n\nconst routeAccess: Record<string, Array<string | number>> = {\n  '/admin': [RoleEnum.ADMIN],\n  '/admin/properties': [RoleEnum.ADMIN],\n  '/admin/inquiries': [RoleEnum.ADMIN],\n  '/admin/users': [RoleEnum.ADMIN],\n};\n\nexport default function AdminLayout() {\n  const { isAuthenticated, authChecked, user } = useAuth();\n  const location = useLocation();\n\n  if (!authChecked) {\n    return (\n      <div className=\"flex h-screen items-center justify-center\">\n        <Loader2 className=\"h-8 w-8 animate-spin text-primary\" />\n      </div>\n    );\n  }\n\n  if (!isAuthenticated || !user) {\n    return <Navigate to=\"/admin/login\" replace />;\n  }\n\n  const currentPath = '/' + location.pathname.split('/').filter(Boolean).slice(0, 2).join('/');\n  const allowedRoles = routeAccess[currentPath];\n  if (allowedRoles && !allowedRoles.map(String).includes(String(user.role))) {\n    return <Navigate to=\"/unauthorized\" replace />;\n  }\n\n  return (\n    <div className=\"flex h-screen\">\n      <aside className=\"w-60 bg-sidebar border-r border-border flex flex-col\">\n        <div className=\"p-4 border-b border-border\">\n          <Link to=\"/admin\" className=\"text-xl font-bold bg-gradient-to-r from-blue-500 to-violet-500 bg-clip-text text-transparent\">\n            NestFind Admin\n          </Link>\n        </div>\n        <nav className=\"flex-1 p-3 space-y-1\">\n          <Link\n            to=\"/admin\"\n            className=\"flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n          >\n            <span className=\"iconify\" data-icon=\"lucide:layout-dashboard\" data-inline=\"false\" />\n            Dashboard\n          </Link>\n          <Link\n            to=\"/admin/properties\"\n            className=\"flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n          >\n            <span className=\"iconify\" data-icon=\"lucide:building-2\" data-inline=\"false\" />\n            Properties\n          </Link>\n          <Link\n            to=\"/admin/inquiries\"\n            className=\"flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n          >\n            <span className=\"iconify\" data-icon=\"lucide:message-square\" data-inline=\"false\" />\n            Inquiries\n          </Link>\n          <Link\n            to=\"/admin/users\"\n            className=\"flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n          >\n            <span className=\"iconify\" data-icon=\"lucide:users\" data-inline=\"false\" />\n            Users\n          </Link>\n        </nav>\n        <div className=\"p-3 border-t border-border\">\n          <Link\n            to=\"/search\"\n            className=\"flex items-center gap-3 px-3 py-2 rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-accent transition-colors\"\n          >\n            <span className=\"iconify\" data-icon=\"lucide:arrow-left\" data-inline=\"false\" />\n            Back to Site\n          </Link>\n        </div>\n      </aside>\n      <div className=\"flex-1 flex flex-col min-h-0 overflow-hidden\">\n        <Header />\n        <main className=\"flex-1 overflow-y-auto p-6\">\n          <Outlet />\n        </main>\n      </div>\n    </div>\n  );\n}\n","filePath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/layouts/AdminLayout.tsx"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/layouts/AdminLayout.tsx","exists":false,"truncated":false},"title":"frontend/app/components/layouts/AdminLayout.tsx","time":{"start":1779191780092,"end":1779191780373}},"id":"prt_e401796930016Y3c7wjogR49C4","sessionID":"ses_1bff4e2c5ffelBqOnmJS1wuf2p","messageID":"msg_e40177c11001CH4ZGrJbsds61U"}}
