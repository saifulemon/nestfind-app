{"type":"tool_use","timestamp":1779191740993,"sessionID":"ses_1bff4e2c5ffelBqOnmJS1wuf2p","part":{"type":"tool","tool":"write","callID":"call_08_6poaInNzCDz9hir6pqZn0934","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/guards/RoleGuard.tsx","content":"import { Navigate, Outlet } from 'react-router';\nimport { useAuth } from '~/hooks/useAuth';\n\ninterface RoleGuardProps {\n  allowedRoles: Array<string | number>;\n  children?: React.ReactNode;\n}\n\nexport function RoleGuard({ allowedRoles, children }: RoleGuardProps) {\n  const { user, isAuthenticated } = useAuth();\n\n  if (!isAuthenticated || !user) {\n    return <Navigate to=\"/login\" replace />;\n  }\n\n  const allowed = allowedRoles.map(String).includes(String(user.role));\n  if (!allowed) {\n    return <Navigate to=\"/unauthorized\" replace />;\n  }\n\n  return children ? <>{children}</> : <Outlet />;\n}\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/components/guards/RoleGuard.tsx","exists":false,"truncated":false},"title":"frontend/app/components/guards/RoleGuard.tsx","time":{"start":1779191740724,"end":1779191740992}},"id":"prt_e40175e75001C46eMEqC71QeS0","sessionID":"ses_1bff4e2c5ffelBqOnmJS1wuf2p","messageID":"msg_e4015e148001XFFOtm33KPI8Tu"}}
