4:   let stack: string | undefined;\n55: \n56:   if (isRouteErrorResponse(error)) {\n57:     message = error.status === 404 ? \"404\" : \"Error\";\n58:     details =\n59:       error.status === 404\n60:         ? \"The requested page could not be found.\"\n61:         : error.statusText || details;\n62:   } else if (import.meta.env.DEV && error && error instanceof Error) {\n63:     details = error.message;\n64:     stack = error.stack;\n65:   }\n66: \n67:   return (\n68:     <main className=\"pt-16 p-4 container mx-auto\">\n69:       <h1>{message}</h1>\n70:       <p>{details}</p>\n71:       {stack && (\n72:         <pre className=\"w-full p-4 overflow-x-auto\">\n73:           <code>{stack}</code>\n74:         </pre>\n75:       )}\n76:     </main>\n77:   );\n78: }\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"// @ts-nocheck\nimport {\n  isRouteErrorResponse,\n  Links,\n  Meta,\n  Outlet,\n  Scripts,\n  ScrollRestoration,\n} from \"react-router\";\nimport { Providers } from './hooks/providers/providers';\nimport type { Route } from \"./+types/root\";\nimport \"./styles/app.css\";\n\nexport const links: Route.LinksFunction = () => [\n  { rel: \"preconnect\", href: \"https://fonts.googleapis.com\" },\n  {\n    rel: \"preconnect\",\n    href: \"https://fonts.gstatic.com\",\n    crossOrigin: \"anonymous\",\n  },","truncated":false,"loaded":[]},"title":"frontend/app/root.tsx","time":{"start":1779251945577,"end":1779251945855}},"id":"prt_e43ae1bc0001qbCqDKlT0CkXYI","sessionID":"ses_1bc52681dffeWiUkUqWPwEUCph","messageID":"msg_e43adf8f6001DaxgTt4Qsouuk3"}}
