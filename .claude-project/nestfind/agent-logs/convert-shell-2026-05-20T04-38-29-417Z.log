.nav-logo{font-size:24px;font-weight:700;background:linear-gradient(135deg,#4A90D9,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{color:#94A3B8;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}
.nav-links a:hover{color:#F1F5F9}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;font-family:inherit;text-decoration:none}
.btn-primary{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff;height:48px;padding:0 24px;border-radius:12px;font-size:14px}
.btn-primary:hover{box-shadow:0 0 24px rgba(74,144,217,0.3);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:#F1F5F9;height:40px;padding:0 16px;border-radius:8px;font-size:14px}
.btn-ghost:hover{background:rgba(255,255,255,0.06)}
.btn-secondary{background:rgba(255,255,255,0.06);color:#F1F5F9;height:48px;padding:0 24px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);font-size:14px}
.btn-secondary:hover{background:rgba(255,255,255,0.1)}
.btn-sm{height:36px;padding:0 14px;border-radius:8px;font-size:13px}
.btn-danger{background:rgba(248,113,113,0.15);color:#F87171;height:40px;padding:0 16px;border-radius:8px;border:1px solid rgba(248,113,113,0.2);font-size:13px}
.btn-danger:hover{background:rgba(248,113,113,0.25)}
.card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:24px}
input[type="text"],input[type="email"],input[type="password"],input[type="tel"],input[type="number"],textarea,select{height:48px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0 16px;color:#F1F5F9;font-size:14px;font-family:inherit;outline:none;width:100%}
input:focus,textarea:focus,select:focus{border-color:rgba(74,144,217,0.5);box-shadow:0 0 0 3px rgba(74,144,217,0.1)}
input::placeholder,textarea::placeholder{color:#64748B}
textarea{height:auto;padding:12px 16px;resize:vertical;min-height:100px}
label{display:block;font-size:13px;font-weight:500;color:#94A3B8;margin-bottom:6px}
.form-group{margin-bottom:16px}
.badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:600}
.badge-success{color:#4ADE80;box-shadow:0 0 8px rgba(74,222,128,0.3)}
.badge-warning{color:#FBBF24;box-shadow:0 0 8px rgba(251,191,36,0.3)}
.badge-error{color:#F87171;box-shadow:0 0 8px rgba(248,113,113,0.3)}
.badge-primary{color:#4A90D9;box-shadow:0 0 8px rgba(74,144,217,0.3)}
.avatar{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#4A90D9,#7C3AED);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;color:#fff}
.avatar-sm{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#4A90D9,#7C3AED);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;color:#fff}
.prop-card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;transition:all 0.3s}
.prop-card:hover{box-shadow:0 0 20px rgba(74,144,217,0.15);transform:translateY(-2px)}
.prop-img{width:100%;height:200px;object-fit:cover;background:linear-gradient(135deg,rgba(74,144,217,0.3),rgba(124,58,237,0.3))}
.prop-body{padding:20px}
.prop-price{font-size:22px;font-weight:700}
.prop-addr{color:#94A3B8;font-size:14px;margin:4px 0 8px}
.prop-meta{display:flex;gap:16px;font-size:13px;color:#64748B;flex-wrap:wrap}
.section{padding:48px}
.section-header{margin-bottom:32px}
h2{font-size:32px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px}
.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:8px}
.status-new{background:#4ADE80;box-shadow:0 0 6px rgba(74,222,128,0.4)}
.status-read{background:#64748B}
.status-responded{background:#4A90D9;box-shadow:0 0 6px rgba(74,144,217,0.4)}
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:12px 16px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#64748B;border-bottom:1px

