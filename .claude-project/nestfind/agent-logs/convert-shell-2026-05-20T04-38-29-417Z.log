e=\"w-[48px] h-[48px] rounded-[12px] bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] flex items-center justify-center text-[20px] font-bold mx-auto mb-[16px]\">\n189:                 {step.num}\n190:               </div>\n191:               <h4 className=\"text-[18px] font-semibold mb-[8px]\">\n192:                 {t(`landing.howItWorks.step${i + 1}Title`, step.title)}\n193:               </h4>\n194:               <p className=\"text-[#94A3B8] text-[14px]\">\n195:                 {t(`landing.howItWorks.step${i + 1}Desc`, step.desc)}\n196:               </p>\n197:             </div>\n198:           ))}\n199:         </div>\n200:       </section>\n201: \n202:       <section className=\"px-[48px] py-[64px]\">\n203:         <div className=\"text-[12px] font-semibold uppercase tracking-[0.08em] text-[#4A90D9] mb-[8px]\">\n204:           {t('landing.featured.label', 'Featured Properties')}\n205:         </div>\n206:         <h2 className=\"text-[36px] font-bold mb-[16px] tracking-[-0.02em]\">\n207:           {t('landing.featured.title', 'Homes you might love')}\n208:         </h2>\n209:         <p className=\"text-[#94A3B8] text-[16px] max-w-[560px] mb-[48px]\">\n210:           {t('landing.featured.subtitle', 'Hand-picked listings from our curated collection.')}\n211:         </p>\n212:         <div className=\"grid grid-cols-3 gap-[24px]\">\n213:           {featuredProperties.length > 0 ? (\n214:             featuredProperties.map((prop, i) => (\n215:               <Link\n216:                 key={prop.id}\n217:                 to={`/detail/${prop.id}`}\n218:                 data-testid={`A-01-landing-property-card-${i}`}\n219:                 className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(74,144,217,0.15)] hover:-translate-y-[2px] cursor-pointer no-underline text-inherit block\"\n220:               >\n221:                 <div\n222:                   className=\"w-full h-[200px] object-cover bg-cover bg-center flex items-center justify-center text-[48px] text-white/10\"\n223:                   style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,#1e3a5f,#2d1b69)' }}\n224:                 />\n225:                 <div className=\"p-[20px]\">\n226:                   <span className=\"inline-block px-[10px] py-[2px] rounded-full text-[11px] font-semibold mb-[8px] text-[#4ADE80] shadow-[0_0_8px_rgba(74,222,128,0.3)]\">\n227:                     {t('landing.property.availableNow', 'Available Now')}\n228:                   </span>\n229:                   <div className=\"text-[22px] font-bold\">\n230:                     ${prop.price.toLocaleString()}\n231:                     <span className=\"text-[14px] font-normal text-[#94A3B8]\">{t('landing.property.perMonth', '/mo')}</span>\n232:                   </div>\n233:                   <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">\n234:                     {prop.addressStreet}, {prop.addressCity}, {prop.addressState}\n235:                   </div>\n236:                   <div className=\"flex gap-[16px] text-[13px] text-[#64748B]\">\n237:                     <span>{prop.bedrooms} {t('landing.property.bd', 'bd')}</span>\n238:                     <span>{prop.bathrooms} {t('landing.property.ba', 'ba')}</span>\n239:                     <span>{prop.squareFeet ? `${prop.squareFeet.toLocaleString()} ${t('landing.property.sqft', 'sqft')}` : ''}</span>\n240:                     <span>{prop.propertyType.charAt(0).toUpperCase() + prop.propertyType.slice(1)}</span>\n241:                   </div>\n242:                 </div>\n243:               </Link>\n244:             ))\n245:           ) : (\n246:             <div className=\"col-span-3 text-center py-[40px] text-[#64748B] text-[14px]\">\n247:               {t('landing.featured.empty', 'Featured properties coming soon.')}\n248:             </div>\n249:           )