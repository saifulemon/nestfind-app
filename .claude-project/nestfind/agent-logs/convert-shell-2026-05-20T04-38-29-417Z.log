1:     \"why\": {\n162:       \"label\": \"NestFind의 장점\",\n163:       \"title\": \"광고주가 아닌 임차인을 위해 만들어졌습니다\",\n164:       \"subtitle\": \"임대 매물을 찾을 때 실제로 중요한 것에 집중했습니다.\",\n165:       \"feat1Title\": \"광고 없는 검색\",\n166:       \"feat1Desc\": \"스폰서 매물이 검색 결과를 어지럽히지 않습니다. 모든 결과는 자연 검색입니다.\",\n167:       \"feat2Title\": \"즉시 필터\",\n168:       \"feat2Desc\": \"가격, 침실 수, 유형별 실시간 필터링. 페이지 새로고침이 필요 없습니다.\",\n169:       \"feat3Title\": \"빠른 즐겨찾기\",\n170:       \"feat3Desc\": \"한 번의 클릭으로 매물을 저장하세요. 어디서나 즐겨찾기에 접근할 수 있습니다.\",\n171:       \"feat4Title\": \"지도 보기\",\n172:       \"feat4Desc\": \"각 매물의 정확한 위치를 확인하세요. 모든 매물에 Google 지도가 통합되어 있습니다.\"\n173:     },\n174:     \"footer\": {\n175:       \"col1Title\": \"NestFind\",\n176:       \"col2Title\": \"임차인\",\n177:       \"col3Title\": \"임대인\",\n178:       \"col4Title\": \"고객지원\"\n179:     }\n180:   }\n181: }\n\n(End of file - total 181 lines)\n</content>","metadata":{"preview":"{\n  \"nav\": {\n    \"home\": \"홈\",\n    \"search\": \"검색\",\n    \"favorites\": \"즐겨찾기\",\n    \"inquiries\": \"문의\",\n    \"profile\": \"프로필\",\n    \"login\": \"로그인\",\n    \"signup\": \"회원가입\",\n    \"logout\": \"로그아웃\",\n    \"admin\": \"관리자\"\n  },\n  \"auth\": {\n    \"login\": \"로그인\",\n    \"signup\": \"회원가입\",\n    \"logout\": \"로그아웃\",\n    \"email\": \"이메일\",\n    \"password\": \"비밀번호\",\n    \"confirmPassword\": \"비밀번호 확인\",\n    \"name\": \"이름\",","truncated":false,"loaded":[]},"title":"frontend/public/locales/ko/common.json","time":{"start":1779252154871,"end":1779252155625}},"id":"prt_e43b14cdc001hxr7wafHagqpXJ","sessionID":"ses_1bc52681dffeWiUkUqWPwEUCph","messageID":"msg_e43afb900001gFAt9oiznj4rLy"}}
