Integrated Google Maps on every listing.',\n46:   },\n47: ];\n48: \n49: const FOOTER_COLUMNS = [\n50:   {\n51:     title: 'NestFind',\n52:     links: ['About', 'Careers', 'Press', 'Blog'],\n53:   },\n54:   {\n55:     title: 'Renters',\n56:     links: ['Browse Properties', 'How It Works', 'Renter Guide', 'Safety Tips'],\n57:   },\n58:   {\n59:     title: 'Owners',\n60:     links: ['List a Property', 'Owner Dashboard', 'Pricing', 'Resources'],\n61:   },\n62:   {\n63:     title: 'Support',\n64:     links: ['Help Center', 'Contact Us', 'Privacy Policy', 'Terms of Service'],\n65:   },\n66: ];\n67: \n68: function chipTestId(label: string): string {\n69:   return `A-01-landing-chip-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;\n70: }\n71: \n72: function footerLinkTestId(label: string): string {\n73:   return `A-01-landing-footer-${label.toLowerCase().replace(/\\s+/g, '-')}`;\n74: }\n75: \n76: export default function LandingPage() {\n77:   const { t } = useTranslation();\n78:   const { data: featuredData } = usePropertySearch({ sortBy: 'createdAt', sortOrder: 'DESC', limit: 3, page: 1 });\n79:   const featuredProperties = featuredData?.items ?? [];\n80: \n81:   return (\n82:     <div className=\"max-w-[1440px] mx-auto\">\n83:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n84:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n85:           {t('landing.nav.brand', 'NestFind')}\n86:         </div>\n87:         <div className=\"flex gap-[32px] items-center\">\n88:           <Link\n89:             to=\"/search\"\n90:             className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n91:             data-testid=\"A-01-landing-nav-browse\"\n92:           >\n93:             {t('landing.nav.browse', 'Browse')}\n94:           </Link>\n95:           <a\n96:             href=\"#how-it-works\"\n97:             className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n98:             data-testid=\"A-01-landing-nav-how-it-works\"\n99:             onClick={(e) => { e.preventDefault(); document.getElementById('how-it-works')?.scrollIntoView({ behavior: 'smooth' }); }}\n100:           >\n101:             {t('landing.nav.howItWorks', 'How It Works')}\n102:           </a>\n103:           <a\n104:             href=\"#\"\n105:             className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n106:             data-testid=\"A-01-landing-nav-for-owners\"\n107:             onClick={(e) => { e.preventDefault(); /* TODO */ }}\n108:           >\n109:             {t('landing.nav.forOwners', 'For Owners')}\n110:           </a>\n111:           <Link\n112:             to=\"/login\"\n113:             className=\"inline-flex items-center justify-center font-semibold cursor-pointer border-none transition-all font-[inherit] no-underline bg-transparent text-[#F1F5F9] h-[40px] px-[16px] rounded-[8px] text-[14px] hover:bg-white/10\"\n114:             data-testid=\"A-01-landing-nav-signin\"\n115:           >\n116:             {t('landing.nav.signIn', 'Sign In')}\n117:           </Link>\n118:           <Link\n119:             to=\"/register\"\n120:             className=\"inline-flex items-center justify-center font-semibold cursor-pointer border-none transition-all font-[inherit] no-underline bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] text-white h-[48px] px-[24px] rounded-[12px] text-[14px] hover:shadow-[0_0_24px_rgba(74,144,217,0.3)] hover:-translate-y-[1px]\"\n121:             data-testid=\"A-01-landing-nav-join-now\"\n122:           >\n123:             {t('landing.nav.joinNow', 'Join Now')}\n124:           </Link>\n125:         </div>\n126:       </nav>\n127: \n128:       <section className=\"pt-[80px] px-[48px] pb-[64px] text-center\">\n129:         <h1 clas