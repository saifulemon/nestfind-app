oard', 'Pricing', 'Resources'],\n  },\n  {\n    title: 'Support',\n    links: ['Help Center', 'Contact Us', 'Privacy Policy', 'Terms of Service'],\n  },\n];\n\nfunction chipTestId(label: string): string {\n  return `A-01-landing-chip-${label.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;\n}\n\nfunction footerLinkTestId(label: string): string {\n  return `A-01-landing-footer-${label.toLowerCase().replace(/\\s+/g, '-')}`;\n}\n\nexport default function LandingPage() {\n  const { t } = useTranslation();\n\n  return (\n    <div className=\"max-w-[1440px] mx-auto\">\n      <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n        <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n          {t('landing.nav.brand', 'NestFind')}\n        </div>\n        <div className=\"flex gap-[32px] items-center\">\n          <Link\n            to=\"/search\"\n            className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n            data-testid=\"A-01-landing-nav-browse\"\n          >\n            {t('landing.nav.browse', 'Browse')}\n          </Link>\n          <a\n            href=\"#how-it-works\"\n            className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n            data-testid=\"A-01-landing-nav-how-it-works\"\n            onClick={(e) => { e.preventDefault(); document.getElementById('how-it-works')?.scrollIntoView({ behavior: 'smooth' }); }}\n          >\n            {t('landing.nav.howItWorks', 'How It Works')}\n          </a>\n          <a\n            href=\"#\"\n            className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\"\n            data-testid=\"A-01-landing-nav-for-owners\"\n            onClick={(e) => { e.preventDefault(); /* TODO */ }}\n          >\n            {t('la