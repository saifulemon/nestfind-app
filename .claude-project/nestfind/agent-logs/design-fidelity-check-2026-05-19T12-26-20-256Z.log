\n    mode: 'onChange',\n  });\n\n  useEffect(() => {\n    if (state?.error) {\n      const errors = JSON.parse(state.error);\n      Object.keys(errors).forEach((key) => {\n        form.setError(key as keyof LoginFormData, {\n          message: errors[key],\n        });\n      });\n    }\n  }, [state, form]);\n\n  return (\n    <div className=\"bg-[#0B0F1A] min-h-screen text-[#F1F5F9]\">\n      <div className=\"flex items-center justify-center min-h-[calc(100vh-73px)] p-6\">\n        <div className=\"w-full max-w-[420px] bg-[rgba(255,255,255,0.04)] backdrop-blur-[12px] border border-[rgba(255,255,255,0.08)] rounded-[16px] p-[40px]\">\n          <h2 className=\"text-[28px] font-bold mb-2 tracking-[-0.02em]\">\n            {t('auth.welcomeBack')}\n          </h2>\n          <p className=\"text-sm text-[#94A3B8] mb-8 leading-relaxed\">\n            {t('auth.signInSubtitle')}\n          </p>\n\n          <form action={formAction}>\n            <div className=\"mb-4\">\n              <label\n                htmlFor=\"login-email\"\n                className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\"\n              >\n                {t('auth.emailAddress')}\n              </label>\n              <input\n                id=\"login-email\"\n                type=\"email\"\n                placeholder={t('auth.emailPlaceholder')}\n                data-testid=\"login-email\"\n                {...form.register('email')}\n                className={inputClass}\n              />\n              {form.formState.errors.email && (\n                <p className=\"text-[#F87171] text-xs mt-1\">\n                  {form.formState.errors.email.message}\n                </p>\n              )}\n            </div>\n\n            <div className=\"mb-4\">\n              <div className=\"flex justify-between items-center mb-[6px]\">\n                <label\n                  htmlFor=\"login-password\"\n                  className=\"block text-[13px] font-medium text-[#94A3B8] mb-0\"\n                >\n                  {t('auth.password')}\n                </label>\n                <Link\n                  to=\"/forgot-password\"\n                  className=\"text-[#4A90D9] text-[13px] font-medium no-underline hover:text-[#5BA0E9]\"\n                  data-testid=\"login-forgot-password\"\n                >\n                  {t('auth.forgotPassword')}\n                </Link>\n              </div>\n              <input\n                id=\"login-password\"\n                type=\"password\"\n                placeholder={t('auth.passwordPlaceholder')}\n                data-testid=\"login-password\"\n                {...form.register('password')}\n                className={inputClass}\n              />\n              {form.formState.errors.password && (\n                <p className=\"text-[#F87171] text-xs mt-1\">\n                  {form.formState.errors.password.message}\n                </p>\n              )}\n            </div>\n\n            <div className=\"mb-4\">\n              <label className=\"flex items-center gap-2 text-[13px] text-[#94A3B8] cursor-pointer\">\n                <input\n                  type=\"checkbox\"\n                  checked={rememberMe}\n                  onChange={(e) => setRememberMe(e.target.checked)}\n                  className=\"w-4 h-4 accent-[#4A90D9] cursor-pointer\"\n                  data-testid=\"login-remember\"\n                />\n                {t('auth.rememberMe')}\n              </label>\n            </div>\n\n            <button type=\"submit\" data-testid=\"login-submit\" className={btnPrimaryClass}>\n              {t('auth.login')}\n            </button>\n          </form>\n\n          <div className=\"flex items-center gap-3 text-[#64748B] text-xs my-6\">\n            <span className=\"flex-1 h-px bg-[rgba(255,255,255,0.08)]\" />\n            {t('auth.orDivider')}\n            <span className=\"flex-1 h-px bg-[rgba(255,255,255,0.08)]\" />\n          </div>\n\n          <div cl