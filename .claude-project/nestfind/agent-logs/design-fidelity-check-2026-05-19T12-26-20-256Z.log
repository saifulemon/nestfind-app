35deg,rgba(74,144,217,0.3),rgba(124,58,237,0.3))}\n.prop-body{padding:20px}\n.prop-price{font-size:22px;font-weight:700}\n.prop-addr{color:#94A3B8;font-size:14px;margin:4px 0 8px}\n.prop-meta{display:flex;gap:16px;font-size:13px;color:#64748B}\n.badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:600;margin-bottom:8px}\n.badge-new{color:#4ADE80;box-shadow:0 0 8px rgba(74,222,128,0.3)}\n.features{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}\n.feat-card{text-align:center;padding:24px}\n.feat-icon{width:48px;height:48px;border-radius:12px;background:rgba(74,144,217,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:#4A90D9}\n.feat-card h4{font-size:16px;font-weight:600;margin-bottom:6px}\n.feat-card p{color:#94A3B8;font-size:13px}\nfooter{border-top:1px solid rgba(255,255,255,0.08);padding:48px;display:flex;justify-content:space-between}\n.footer-col h5{font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:16px;color:#64748B}\n.footer-col a{display:block;color:#94A3B8;text-decoration:none;font-size:14px;margin-bottom:8px;transition:color 0.2s}\n.footer-col a:hover{color:#F1F5F9}\n.var-nav-bar{position:fixed;top:12px;right:12px;display:flex;gap:6px;background:rgba(8,11,20,0.9);backdrop-filter:blur(16px);padding:6px 10px;border-radius:10px;z-index:9999;border:1px solid rgba(255,255,255,0.1);font-size:11px;flex-wrap:wrap;max-width:95vw}\n.var-nav-bar a{color:#64748B;text-decoration:none;font-size:10px;font-weight:600;padding:3px 7px;border-radius:5px;transition:all 0.2s;white-space:nowrap}\n.var-nav-bar a.active{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff}\n.var-nav-bar a:hover:not(.active){color:#F1F5F9;background:rgba(255,255,255,0.06)}\n.var-nav-bar .sep{color:rgba(255,255,255,0.15);font-size:10px}\n</style>\n</head>\n<body>\n<nav class=\"var-nav-bar\">\n<a href=\"A-01-landing.html\" class=\"active\">Landing</a><span class=\"sep\">|</span>\n<a href=\"A-02-admin-dashboard.html\">Dashboard</a><span class=\"sep\">|</span>\n<a href=\"A-03-detail.html\">Detail</a><span class=\"sep\">|</span>\n<a href=\"A-04-search.html\">Search</a><span class=\"sep\">|</span>\n<a href=\"A-05-login.html\">Login</a><span class=\"sep\">|</span>\n<a href=\"A-06-register.html\">Register</a><span class=\"sep\">|</span>\n<a href=\"A-07-forgot-password.html\">Reset</a><span class=\"sep\">|</span>\n<a href=\"A-08-favorites.html\">Favorites</a><span class=\"sep\">|</span>\n<a href=\"A-09-profile.html\">Profile</a><span class=\"sep\">|</span>\n<a href=\"A-10-admin-properties.html\">Properties</a><span class=\"sep\">|</span>\n<a href=\"A-11-admin-property-form.html\">PropForm</a><span class=\"sep\">|</span>\n<a href=\"A-12-admin-inquiries.html\">Inquiries</a><span class=\"sep\">|</span>\n<a href=\"A-13-admin-inquiry-detail.html\">InqDet</a><span class=\"sep\">|</span>\n<a href=\"A-14-admin-users.html\">Users</a><span class=\"sep\">|</span>\n<a href=\"A-15-admin-user-detail.html\">UsrDet</a>\n</nav>\n<div class=\"root\">\n<nav class=\"navbar\">\n<div class=\"nav-logo\">NestFind</div>\n<div class=\"nav-links\">\n<a href=\"A-04-search.html\">Browse</a>\n<a href=\"#\">How It Works</a>\n<a href=\"#\">For Owners</a>\n<a href=\"A-05-login.html\" class=\"btn btn-ghost\">Sign In</a>\n<a href=\"A-06-register.html\" class=\"btn btn-primary\">Join Now</a>\n</div>\n</nav>\n<section class=\"hero\">\n<h1>Find Your <span>Perfect Nest</span>,<br>Without the Noise</h1>\n<p>Browse thousands of verified rental properties. Clean, ad-free, and focused on what matters — finding your next home.</p>\n<div class=\"search-bar\">\n<input type=\"text\" placeholder=\"Enter city, neighborhood, or ZIP code...\">\n<button class=\"btn btn-primary\">Search Properties</button>\n</div>\n<div class=\"chip-row\">\n<span class=\"chip\">Apartments</span>\n<span class=\"chip\">Houses</span>\n<span class=\"chip\">Condos</span>\n<span class=\"chip\">Pet-Friendly</span>\n<span class=\"chip\">Under $2,000</span>\n</div>\n</section>\n<section class=\"section\">\n<div class=\"section-label\">How It Works</div>\n<h2>Three steps to your next home</h2>\n<p class=\"sub\">NestFind makes rental hunting simple. No ads, no clutter, just homes you'll love.</p>\n<div class=\"steps\">\n<div class=\"step-card\">\n<div class=\"step-num\">1</div>\n<h4>Search & Filter</h4>\n<p>Enter your preferred location and refine by price, beds, and property type. Results update instantly.</p>\n</div>\n<div class=\"step-card\">\n<div class=\"step-num\">2</div>\n<h4>Explore & Save</h4>\n<p>Browse photos, check amenities, and view locations on the map. Save favorites with one click.</p>\n</div>\n<div class=\"step-card\">\n<div class=\"step-num\">3</div>\n<h4>Inquire & Move</h4>\n<p>Send an inquiry directly to the property manager. Simple form, no lengthy applications.</p>\n</div>\n</div>\n</section>\n<section class=\"section\">\n<div class=\"section-label\">Featured Properties</div>\n<h2>Homes you might love</h2>\n<p class=\"sub\">Hand-picked listings from our curated collection.</p>\n<div class=\"property-grid\">\n<div class=\"prop-card\">\n<div class=\"prop-img\" style=\"background:linear-gradient(135deg,#1e3a5f,#2d1b69);display:flex;align-items:center;justify-content:center;font-size:48px;color:rgba(255,255,255,0.1)\">🏠</div>\n<div class=\"prop-body\">\n<span class=\"badge badge-new\">Available Now</span>\n<div class=\"prop-price\">$1,850<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n<div class=\"prop-addr\">1420 Pine Street, San Francisco, CA</div>\n<div class=\"prop-meta\"><span>2 bd</span><span>1 ba</span><span>850 sqft</span><span>Apartment</span></div>\n</div>\n</div>\n<div class=\"prop-card\">\n<div class=\"prop-img\" style=\"background:linear-gradient(135deg,#3d266b,#1a3a5c);display:flex;align-items:center;justify-content:center;font-size:48px;color:rgba(255,255,255,0.1)\">🏡</div>\n<div class=\"prop-body\">\n<span class=\"badge badge-new\">Available Now</span>\n<div class=\"prop-price\">$2,950<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n<div class=\"prop-addr\">381 Oak Avenue, Austin, TX</div>\n<div class=\"prop-meta\"><span>3 bd</span><span>2 ba</span><span>1,200 sqft</span><span>House</span></div>\n</div>\n</div>\n<div class=\"prop-card\">\n<div class=\"prop-img\" style=\"background:linear-gradient(135deg,#1a3a5c,#3d266b);display:flex;align-items:center;justify-content:center;font-size:48px;color:rgba(255,255,255,0.1)\">🏢</div>\n<div class=\"prop-body\">\n<span class=\"badge badge-new\">Available Now</span>\n<div class=\"prop-price\">$2,200<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n<div class=\"prop-addr\">750 Market Street, Portland, OR</div>\n<div class=\"prop-meta\"><span>1 bd</span><span>1 ba</span><span>720 sqft</span><span>Condo</span></div>\n</div>\n</div>\n</div>\n</section>\n<section class=\"section\">\n<div class=\"section-label\">Why NestFind</div>\n<h2>Built for renters, not advertisers</h2>\n<p class=\"sub\">We focused on what actually matters when finding a rental.</p>\n<div class=\"features\">\n<div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:eye-off-outline\" width=\"24\"></iconify-icon></div><h4>Ad-Free Browsing</h4><p>No sponsored listings cluttering your search. Every result is organic.</p></div>\n<div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:lightning-bolt\" width=\"24\"></iconify-icon></div><h4>Instant Filters</h4><p>Real-time filtering by price, beds, and type. No page reloads.</p></div>\n<div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:heart-outline\" width=\"24\"></iconify-icon></div><h4>Quick Favorites</h4><p>Save properties with one click. Access your favorites from anywhere.</p></div>\n<div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:map-marker-outline\" width=\"24\"></iconify-icon></div><h4>Map View</h4><p>See exactly where each property is. Integrated Google Maps on every listing.</p></div>\n</div>\n</section>\n<footer>\n<div class=\"footer-col\"><h5>NestFind</h5><a href=\"#\">About</a><a href=\"#\">Careers</a><a href=\"#\">Press</a><a href=\"#\">Blog</a></div>\n<div class=\"footer-col\"><h5>Renters</h5><a href=\"A-04-search.html\">Browse Properties</a><a href=\"#\">How It Works</a><a href=\"#\">Renter Guide</a><a href=\"#\">Safety Tips</a></div>\n<div class=\"footer-col\"><h5>Owners</h5><a href=\"#\">List a Property</a><a href=\"#\">Owner Dashboard</a><a href=\"#\">Pricing</a><a href=\"#\">Resources</a></div>\n<div class=\"footer-col\"><h5>Support</h5><a href=\"#\">Help Center</a><a href=\"#\">Contact Us</a><a href=\"#\">Privacy Policy</a><a href=\"#\">Terms of Service</a></div>\n</footer>\n</div>\n</body>\n</html>\n```\n\n---\n\n## A-02-login.html (131 lines)\n\n```html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>NestFind — Sign In</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/@iconify/iconify@2.2.1/dist/iconify.min.js\"></script>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{font-family:'Inter',system-ui,sans-serif;background:#0B0F1A;color:#F1F5F9;line-height:1.6}\n.root{max-width:1440px;margin:0 auto}\n.navbar{display:flex;justify-content:space-between;align-items:center;padding:16px 48px;border-bottom:1px solid rgba(255,255,255,0.08)}\n.nav-logo{font-size:24px;font-weight:700;background:linear-gradient(135deg,#4A90D9,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent}\n.nav-links{display:flex;gap:32px;align-items:center}\n.nav-links a{color:#94A3B8;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}\n.nav-links a:hover{color:#F1F5F9}\n.btn{display:inline-flex;align-items:center;justify-content:center;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;font-family:inherit;text-decoration:none}\n.btn-primary{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff;height:48px;padding:0 24px;border-radius:12px;font-size:14px}\n.btn-primary:hover{box-shadow:0 0 24px rgba(74,144,217,0.3);transform:translateY(-1px)}\n.btn-ghost{background:transparent;color:#F1F5F9;height:40px;padding:0 16px;border-radius:8px;font-size:14px}\n.btn-ghost:hover{background:rgba(255,255,255,0.06)}\n.btn-secondary{background:rgba(255,255,255,0.06);color:#F1F5F9;height:48px;padding:0 24px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);font-size:14px}\n.btn-secondary:hover{background:rgba(255,255,255,0.1)}\n.btn-danger{background:rgba(248,113,113,0.15);color:#F87171;height:40px;padding:0 16px;border-radius:8px;border:1px solid rgba(248,113,113,0.2);font-size:13px}\n.btn-danger:hover{background:rgba(248,113,113,0.25)}\n.card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:24px}\n.card:hover{box-shadow:0 0 20px rgba(74,144,217,0.15);background:rgba(255,255,255,0.06)}\ninput[type=\"text\"],input[type=\"email\"],input[type=\"password\"],input[type=\"tel\"],textarea,select{height:48px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0 16px;color:#F1F5F9;font-size:14px;font-family:inherit;outline:none;width:100%}\ninput:focus,textarea:focus,select:focus{border-color:rgba(74,144,217,0.5);box-shadow:0 0 0 3px rgba(74,144,217,0.1)}\ninput::placeholder,textarea::placeholder{color:#64748B}\ntextarea{height:auto;padding:12px 16px;resize:vertical;min-height:100px}\nlabel{display:block;font-size:13px;font-weight:500;color:#94A3B8;margin-bottom:6px}\n.form-group{margin-bottom:16px}\n.form-link{color:#4A90D9;font-size:13px;text-decoration:none;font-weight:500}\n.form-link:hover{color:#5BA0E9}\n.badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:600}\n.badge-success{color:#4ADE80;box-shadow:0 0 8px rgba(74,222,128,0.3)}\n.badge-warning{color:#FBBF24;box-shadow:0 0 8px rgba(251,191,36,0.3)}\n.badge-error{color:#F87171;box-shadow:0 0 8px rgba(248,113,113,0.3)}\n.var-nav-bar{position:fixed;top:12px;right:12px;display:flex;gap:6px;background:rgba(8,11,20,0.9);backdrop-filter:blur(16px);padding:6px 10px;border-radius:10px;z-index:9999;border:1px solid rgba(255,255,255,0.1);font-size:11px;flex-wrap:wrap;max-width:95vw}\n.var-nav-bar a{color:#64748B;text-decoration:none;font-size:10px;font-weight:600;padding:3px 7px;border-radius:5px;transition:all 0.2s;white-space:nowrap}\n.var-nav-bar a.active{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff}\n.var-nav-bar a:hover:not(.active){color:#F1F5F9;background:rgba(255,255,255,0.06)}\n.var-nav-bar .sep{color:rgba(255,255,255,0.15);font-size:10px}\n.error-text{color:#F87171;font-size:12px;margin-top:4px}\n.divider{height:1px;background:rgba(255,255,255,0.08);margin:24px 0}\n.auth-wrapper{display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 73px);padding:24px}\n.auth-card{width:100%;max-width:420px;background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px}\n.auth-card h2{font-size:28px;font-weight:700;margin-bottom:8px;letter-spacing:-0.02em}\n.auth-card .subtitle{color:#94A3B8;font-size:14px;margin-bottom:32px;line-height:1.5}\n.form-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}\n.form-check{display:flex;align-items:center;gap:8px;font-size:13px;color:#94A3B8}\n.form-check input[type=\"checkbox\"]{width:16px;height:16px;accent-color:#4A90D9;cursor:pointer}\n.divider-text{display:flex;align-items:center;gap:12px;color:#64748B;font-size:12px;margin:24px 0}\n.divider-text::before,.divider-text::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.08)}\n.auth-footer{text-align:center;font-size:13px;color:#94A3B8;margin-top:24px}\n.auth-footer a{color:#4A90D9;text-decoration:none;font-weight:500}\n.auth-footer a:hover{color:#5BA0E9}\n.terms-text{color:#64748B;font-size:12px;text-align:center;margin-top:24px;line-height:1.5}\n.terms-text a{color:#4A90D9;text-decoration:none}\n.terms-text a:hover{color:#5BA0E9}\n</style>\n</head>\n<body>\n<nav class=\"var-nav-bar\">\n<a href=\"A-01-landing.html\">Landing</a><span class=\"sep\">|</span>\n<a href=\"A-02-login.html\" class=\"active\">Login</a><span class=\"sep\">|</span>\n<a href=\"A-03-signup.html\">Signup</a><span class=\"sep\">|</span>\n<a href=\"A-04-forgot-password.html\">Forgot</a><span class=\"sep\">|</span>\n<a href=\"A-05-reset-password.html\">Reset</a><span class=\"sep\">|</span>\n<a href=\"A-06-search.html\">Search</a><span class=\"sep\">|</span>\n<a href=\"A-07-detail.html\">Detail</a><span class=\"sep\">|</span>\n<a href=\"A-08-favorites.html\">Favs</a><span class=\"sep\">|</span>\n<a href=\"A-09-inquiries.html\">Inq</a><span class=\"sep\">|</span>\n<a href=\"A-10-profile.html\">Prof</a><span class=\"sep\">|</span>\n<a href=\"A-11-admin-login.html\">AdLog</a><span class=\"sep\">|</span>\n<a href=\"A-12-admin-dashboard.html\">AdDash</a><span class=\"sep\">|</span>\n<a href=\"A-13-admin-properties.html\">AdProp</a><span class=\"sep\">|</span>\n<a href=\"A-14-admin-property-form.html\">AdForm</a><span class=\"sep\">|</span>\n<a href=\"A-15-admin-inquiries.html\">AdInq</a><span class=\"sep\">|</span>\n<a href=\"A-16-admin-users.html\">AdUsr</a>\n</nav>\n<div class=\"root\">\n<nav class=\"navbar\">\n  <div class=\"nav-logo\">NestFind</div>\n  <div class=\"nav-links\">\n    <a href=\"A-06-search.html\">Browse</a>\n    <a href=\"A-01-landing.html\">Home</a>\n  </div>\n</nav>\n<div class=\"auth-wrapper\">\n  <div class=\"auth-card\">\n    <h2>Welcome back</h2>\n    <p class=\"subtitle\">Sign in to your account</p>\n\n    <div class=\"form-group\">\n      <label for=\"email\">Email address</label>\n      <input type=\"email\" id=\"email\" placeholder=\"you@example.com\">\n    </div>\n\n    <div class=\"form-group\">\n      <div class=\"form-row\">\n        <label for=\"password\" style=\"margin-bottom:0\">Password</label>\n        <a href=\"A-04-forgot-password.html\" class=\"form-link\">Forgot password?</a>\n      </div>\n      <input type=\"password\" id=\"password\" placeholder=\"Enter your password\">\n    </div>\n\n    <div class=\"form-group\">\n      <label class=\"form-check\">\n        <input type=\"checkbox\">\n        Remember me\n      </label>\n    </div>\n\n    <button type=\"submit\" class=\"btn btn-primary\" style=\"width:100%\">Sign In</button>\n\n    <div class=\"divider-text\">or</div>\n\n    <div class=\"auth-footer\">\n      Don't have an account? <a href=\"A-03-signup.html\">Sign up</a>\n    </div>\n\n    <p class=\"terms-text\">By signing in you agree to our <a href=\"#\">Terms</a> and <a href=\"#\">Privacy Policy</a></p>\n  </div>\n</div>\n</div>\n</body>\n</html>\n```\n\n---\n\n## A-03-signup.html (143 lines)\n\n```html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>NestFind — Create Account</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/@iconify/iconify@2.2.1/dist/iconify.min.js\"></script>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{font-family:'Inter',system-ui,sans-serif;background:#0B0F1A;color:#F1F5F9;line-height:1.6}\n.root{max-width:1440px;margin:0 auto}\n.navbar{display:flex;justify-content:space-between;align-items:center;padding:16px 48px;border-bottom:1px solid rgba(255,255,255,0.08)}\n.nav-logo{font-size:24px;font-weight:700;background:linear-gradient(135deg,#4A90D9,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent}\n.nav-links{display:flex;gap:32px;align-items:center}\n.nav-links a{color:#94A3B8;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}\n.nav-links a:hover{color:#F1F5F9}\n.btn{display:inline-flex;align-items:center;justify-content:center;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;font-family:inherit;text-decoration:none}\n.btn-primary{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff;height:48px;padding:0 24px;border-radius:12px;font-size:14px}\n.btn-primary:hover{box-shadow:0 0 24px rgba(74,144,217,0.3);transform:translateY(-1px)}\n.btn-ghost{background:transparent;color:#F1F5F9;height:40px;padding:0 16px;border-radius:8px;font-size:14px}\n.btn-ghost:hover{background:rgba(255,255,255,0.06)}\n.btn-secondary{background:rgba(255,255,255,0.06);color:#F1F5F9;height:48px;padding:0 24px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);font-size:14px}\n.btn-secondary:hover{background:rgba(255,255,255,0.1)}\n.btn-danger{background:rgba(248,113,113,0.15);color:#F87171;height:40px;padding:0 16px;border-radius:8px;border:1px solid rgba(248,113,113,0.2);font-size:13px}\n.btn-danger:hover{background:rgba(248,113,113,0.25)}\n.card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:24px}\n.card:hover{box-shadow:0 0 20px rgba(74,144,217,0.15);background:rgba(255,255,255,0.06)}\ninput[type=\"text\"],input[type=\"email\"],input[type=\"password\"],input[type=\"tel\"],textarea,select{height:48px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0 16px;color:#F1F5F9;font-size:14px;font-family:inherit;outline:none;width:100%}\ninput:focus,textarea:focus,select:focus{border-color:rgba(74,144,217,0.5);box-shadow:0 0 0 3px rgba(74,144,217,0.1)}\ninput::placeholder,textarea::placeholder{color:#64748B}\ntextarea{height:auto;padding:12px 16px;resize:vertical;min-height:100px}\nlabel{display:block;font-size:13px;font-weight:500;color:#94A3B8;margin-bottom:6px}\n.form-group{margin-bottom:16px}\n.form-link{color:#4A90D9;font-size:13px;text-decoration:none;font-weight:500}\n.form-link:hover{color:#5BA0E9}\n.badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:600}\n.badge-success{color:#4ADE80;box-shadow:0 0 8px rgba(74,222,128,0.3)}\n.badge-warning{color:#FBBF24;box-shadow:0 0 8px rgba(251,191,36,0.3)}\n.badge-error{color:#F87171;box-shadow:0 0 8px rgba(248,113,113,0.3)}\n.var-nav-bar{position:fixed;top:12px;right:12px;display:flex;gap:6px;background:rgba(8,11,20,0.9);backdrop-filter:blur(16px);padding:6px 10px;border-radius:10px;z-index:9999;border:1px solid rgba(255,255,255,0.1);font-size:11px;flex-wrap:wrap;max-width:95vw}\n.var-nav-bar a{color:#64748B;text-decoration:none;font-size:10px;font-weight:600;padding:3px 7px;border-radius:5px;transition:all 0.2s;white-space:nowrap}\n.var-nav-bar a.active{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff}\n.var-nav-bar a:hover:not(.active){color:#F1F5F9;background:rgba(255,255,255,0.06)}\n.var-nav-bar .sep{color:rgba(255,255,255,0.15);font-size:10px}\n.error-text{color:#F87171;font-size:12px;margin-top:4px}\n.divider{height:1px;background:rgba(255,255,255,0.08);margin:24px 0}\n.auth-wrapper{display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 73px);padding:24px}\n.auth-card{width:100%;max-width:420px;background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px}\n.auth-card h2{font-size:28px;font-weight:700;margin-bottom:8px;letter-spacing:-0.02em}\n.auth-card .subtitle{color:#94A3B8;font-size:14px;margin-bottom:32px;line-height:1.5}\n.form-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}\n.form-check{display:flex;align-items:center;gap:8px;font-size:13px;color:#94A3B8}\n.form-check input[type=\"checkbox\"]{width:16px;height:16px;accent-color:#4A90D9;cursor:pointer}\n.divider-text{display:flex;align-items:center;gap:12px;color:#64748B;font-size:12px;margin:24px 0}\n.divider-text::before,.divider-text::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.08)}\n.auth-footer{text-align:center;font-size:13px;color:#94A3B8;margin-top:24px}\n.auth-footer a{color:#4A90D9;text-decoration:none;font-weight:500}\n.auth-footer a:hover{color:#5BA0E9}\n.label-row{display:flex;align-items:center;gap:8px;margin-bottom:6px}\n.label-row label{margin-bottom:0}\n</style>\n</head>\n<body>\n<nav class=\"var-nav-bar\">\n<a href=\"A-01-landing.html\">Landing</a><span class=\"sep\">|</span>\n<a href=\"A-02-login.html\">Login</a><span class=\"sep\">|</span>\n<a href=\"A-03-signup.html\" class=\"active\">Signup</a><span class=\"sep\">|</span>\n<a href=\"A-04-forgot-password.html\">Forgot</a><span class=\"sep\">|</span>\n<a href=\"A-05-reset-password.html\">Reset</a><span class=\"sep\">|</span>\n<a href=\"A-06-search.html\">Search</a><span class=\"sep\">|</span>\n<a href=\"A-07-detail.html\">Detail</a><span class=\"sep\">|</span>\n<a href=\"A-08-favorites.html\">Favs</a><span class=\"sep\">|</span>\n<a href=\"A-09-inquiries.html\">Inq</a><span class=\"sep\">|</span>\n<a href=\"A-10-profile.html\">Prof</a><span class=\"sep\">|</span>\n<a href=\"A-11-admin-login.html\">AdLog</a><span class=\"sep\">|</span>\n<a href=\"A-12-admin-dashboard.html\">AdDash</a><span class=\"sep\">|</span>\n<a href=\"A-13-admin-properties.html\">AdProp</a><span class=\"sep\">|</span>\n<a href=\"A-14-admin-property-form.html\">AdForm</a><span class=\"sep\">|</span>\n<a href=\"A-15-admin-inquiries.html\">AdInq</a><span class=\"sep\">|</span>\n<a href=\"A-16-admin-users.html\">AdUsr</a>\n</nav>\n<div class=\"root\">\n<nav class=\"navbar\">\n  <div class=\"nav-logo\">NestFind</div>\n  <div clas