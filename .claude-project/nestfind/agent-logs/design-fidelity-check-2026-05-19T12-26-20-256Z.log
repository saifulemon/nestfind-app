"width=device-width, initial-scale=1.0\">\n<title>NestFind - My Profile</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<script src=\"https://code.iconify.design/3/3.1.1/iconify.min.js\"></script>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nbody{font-family:'Inter',system-ui,sans-serif;background:#0B0F1A;color:#F1F5F9;line-height:1.6}\n.root{max-width:1440px;margin:0 auto}\n.navbar{display:flex;justify-content:space-between;align-items:center;padding:16px 48px;border-bottom:1px solid rgba(255,255,255,0.08)}\n.nav-logo{font-size:24px;font-weight:700;background:linear-gradient(135deg,#4A90D9,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent}\n.nav-links{display:flex;gap:32px;align-items:center}\n.nav-links a{color:#94A3B8;text-decoration:none;font-size:14px;font-weight:500;transition:color 0.2s}\n.nav-links a:hover{color:#F1F5F9}\n.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;font-family:inherit;text-decoration:none}\n.btn-primary{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff;height:48px;padding:0 24px;border-radius:12px;font-size:14px}\n.btn-primary:hover{box-shadow:0 0 24px rgba(74,144,217,0.3);transform:translateY(-1px)}\n.btn-ghost{background:transparent;color:#F1F5F9;height:40px;padding:0 16px;border-radius:8px;font-size:14px}\n.btn-ghost:hover{background:rgba(255,255,255,0.06)}\n.btn-secondary{background:rgba(255,255,255,0.06);color:#F1F5F9;height:48px;padding:0 24px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);font-size:14px}\n.btn-secondary:hover{background:rgba(255,255,255,0.1)}\n.btn-sm{height:36px;padding:0 14px;border-radius:8px;font-size:13px}\n.btn-danger{background:rgba(248,113,113,0.15);color:#F87171;height:40px;padding:0 16px;border-radius:8px;border:1px solid rgba(248,113,113,0.2);font-size:13px}\n.btn-danger:hover{background:rgba(248,113,113,0.25)}\n.card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:24px}\ninput[type=\"text\"],input[type=\"email\"],input[type=\"password\"],input[type=\"tel\"],input[type=\"number\"],textarea,select{height:48px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0 16px;color:#F1F5F9;font-size:14px;font-family:inherit;outline:none;width:100%}\ninput:focus,textarea:focus,select:focus{border-color:rgba(74,144,217,0.5);box-shadow:0 0 0 3px rgba(74,144,217,0.1)}\ninput::placeholder,textarea::placeholder{color:#64748B}\ntextarea{height:auto;padding:12px 16px;resize:vertical;min-height:100px}\nlabel{display:block;font-size:13px;font-weight:500;color:#94A3B8;margin-bottom:6px}\n.form-group{margin-bottom:16px}\n.badge{display:inline-block;padding:2px 10px;border-radius:9999px;font-size:11px;font-weight:600}\n.badge-success{color:#4ADE80;box-shadow:0 0 8px rgba(74,222,128,0.3)}\n.badge-warning{color:#FBBF24;box-shadow:0 0 8px rgba(251,191,36,0.3)}\n.badge-error{color:#F87171;box-shadow:0 0 8px rgba(248,113,113,0.3)}\n.badge-primary{color:#4A90D9;box-shadow:0 0 8px rgba(74,144,217,0.3)}\n.avatar{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#4A90D9,#7C3AED);display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;color:#fff}\n.avatar-sm{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#4A90D9,#7C3AED);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;color:#fff}\n.prop-card{background:rgba(255,255,255,0.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;overflow:hidden;transition:all 0.3s}\n.prop-card:hover{box-shadow:0 0 20px rgba(74,144,217,0.15);transform:translateY(-2px)}\n.prop-img{width:100%;height:200px;object-fit:cover;background:linear-gradient(135deg,rgba(74,144,217,0.3),rgba(124,58,237,0.3))}\n.prop-body{padding:20px}\n.prop-price{font-size:22px;font-weight:700}\n.prop-addr{color:#94A3B8;font-size:14px;margin:4px 0 8px}\n.prop-meta{display:flex;gap:16px;font-size:13px;color:#64748B;flex-wrap:wrap}\n.section{padding:48px}\n.section-header{margin-bottom:32px}\nh2{font-size:32px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px}\n.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:8px}\n.status-new{background:#4ADE80;box-shadow:0 0 6px rgba(74,222,128,0.4)}\n.status-read{background:#64748B}\n.status-responded{background:#4A90D9;box-shadow:0 0 6px rgba(74,144,217,0.4)}\ntable{width:100%;border-collapse:collapse}\nth{text-align:left;padding:12px 16px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#64748B;border-bottom:1px solid rgba(255,255,255,0.08)}\ntd{padding:14px 16px;font-size:14px;border-bottom:1px solid rgba(255,255,255,0.04);color:#F1F5F9}\ntr:hover td{background:rgba(255,255,255,0.02)}\n.sidebar{width:240px;min-height:100vh;background:#080B14;border-right:1px solid rgba(255,255,255,0.08);padding:24px 16px;position:fixed;top:0;left:0;bottom:0;overflow-y:auto}\n.sidebar-nav{display:flex;flex-direction:column;gap:2px}\n.sidebar-item{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:8px;color:#94A3B8;text-decoration:none;font-size:14px;font-weight:500;transition:all 0.15s}\n.sidebar-item:hover{color:#F1F5F9;background:rgba(255,255,255,0.04)}\n.sidebar-item.active{color:#F1F5F9;background:rgba(74,144,217,0.1);border-left:3px solid #4A90D9}\n.sidebar-divider{height:1px;background:rgba(255,255,255,0.08);margin:12px 0}\n.sidebar-section{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#64748B;padding:8px 14px 4px}\n.main-content{margin-left:240px;min-height: