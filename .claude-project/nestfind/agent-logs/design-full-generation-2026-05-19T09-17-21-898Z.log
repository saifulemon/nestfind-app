nter;font-weight:600;cursor:pointer;border:none;transition:all 0.2s;font-family:inherit;text-decoration:none}\n.btn-primary{background:linear-gradient(135deg,#4A90D9,#7C3AED);color:#fff;height:48px;padding:0 24px;border-radius:12px;font-size:14px}","truncated":true,"loaded":[]},"title":".claude-project/nestfind/design/html/frontend/A-01-landing.html","time":{"start":1779182356982,"end":1779182357328}},"id":"prt_e3f884146001XomUbT0B69o59E","sessionID":"ses_1c079733dfferixSTRfU3JRAe8","messageID":"msg_e3f87be3000170qRB75ao01Qug"}}
