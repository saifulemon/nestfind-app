   .prop-badge { display: inline-block; padding: 2px 10px; border-radius: 9999px; font-size: 11px; font-weight: 600; margin-bottom: 8px; }\n55:     .badge-new { color: #4ADE80; background: rgba(74,222,128,0.1); box-shadow: 0 0 8px rgba(74,222,128,0.2); }\n56:     .features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }\n57:     .feat-card { text-align: center; padding: 24px; }\n58:     .feat-icon { width: 48px; height: 48px; border-radius: 12px; background: rgba(74,144,217,0.1); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; color: #4A90D9; }\n59:     .feat-card h4 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }\n60:     .feat-card p { color: #94A3B8; font-size: 13px; }\n61:     footer { border-top: 1px solid rgba(255,255,255,0.08); padding: 48px; display: flex; justify-content: space-between; }\n62:     .footer-col h5 { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; color: #64748B; }\n63:     .footer-col a { display: block; color: #94A3B8; text-decoration: none; font-size: 14px; margin-bottom: 8px; transition: color 0.2s; }\n64:     .footer-col a:hover { color: #F1F5F9; }\n65:     .var-nav-bar { position: fixed; top: 16px; right: 16px; display: flex; gap: 8px; background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); padding: 8px 14px; border-radius: 10px; z-index: 9999; border: 1px solid rgba(255,255,255,0.1); }\n66:     .var-nav-bar a { color: #94A3B8; text-decoration: none; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; transition: all 0.2s; }\n67:     .var-nav-bar a.active { background: linear-gradient(135deg, #4A90D9, #7C3AED); color: #fff; }\n68:     .var-nav-bar a:hover:not(.active) { color: #F1F5F9; background: rgba(255,255,255,0.08); }\n69:     .var-nav-bar .sep { color: rgba(255,255,255,0.2); font-size: 12px; line-height: 1.8; }\n70:   </style>\n71: </head>\n72: <body>\n73: <nav class=\"var-nav-bar\">\