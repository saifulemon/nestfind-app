A1A1A] text-gray-300 z-50 hidden lg:flex flex-col transition-all duration-300\">\n47:         <!-- Logo -->\n48:         <div class=\"h-16 flex items-center px-6 border-b border-gray-800\">\n49:             <div class=\"flex items-center gap-3\">\n50:                 <div class=\"w-8 h-8 bg-[#0066CC] rounded-lg flex items-center justify-center text-white\">\n\n(Showing lines 1-50 of 460. Use offset=51 to continue.)\n</content>","metadata":{"preview":"<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Admin Dashboard - NestFind</title>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://code.iconify.design/3/3.1.0/iconify.min.js\"></script>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\">\n<style>\nbody {\nfont-family: 'Inter', sans-serif;\nbackground-color: #F3F4F6; /* Gray 100 */\n}\n/* Custom Scrollbar */\n::-webkit-scrollbar {\nwidth: 6px;\nheight: 6px;\n}\n::-webkit-scrollbar-track {","truncated":true,"loaded":[]},"title":"HTML/11-admin-dashboard.html","time":{"start":1779182428172,"end":1779182428456}},"id":"prt_e3f895925001vTrGCYZHXTG6iA","sessionID":"ses_1c079733dfferixSTRfU3JRAe8","messageID":"msg_e3f88571b001P813k2Vj1CC6va"}}
