    .btn-secondary:hover { background: #F1F5F9; }\n    .hero { padding: 80px 48px 64px; text-align: center; }\n    .hero h1 { font-size: 44px; font-weight: 600; line-height: 1.15; margin-bottom: 16px; letter-spacing: -0.01em; color: #1E293B; }\n    .hero h1 span { color: #4A90D9; }\n    .hero p { color: #64748B; font-size: 18px; max-width: 560px; margin: 0 auto 32px; }\n    .search-bar { display: flex; max-width: 640px; margin: 0 auto; gap: 0; }\n    .search-bar input { flex: 1; height: 56px; background: #FFFFFF; border: 1px solid #F0E7DB; border-right: none; border-radius: 9999px 0 0 9999px; padding: 0 24px; color: #1E293B; font-size: 16px; font-family: inherit; outline: none; }\n    .search-bar input:focus { border-color: #4A90D9; box-shadow: 0 0 0 3px rgba(74,144,217,0.1); }\n    .search-bar input::placeholder { color: #94A3B8; }\n    .search-bar .btn-primary { border-radius: 0 9999px 9999px 0; height: 56px; padding: 0 32px; font-size: 16px; }\n    .chip-row { display: flex; gap: 10px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }\n    .chip { padding: 8px 18px; background: #FFFFFF; border: 1px solid #F0E7DB; border-radius: 9999px; font-size: 13px; color: #64748B; cursor: pointer; transition: all 0.2s; font-weight: 500; }\n    .chip:hover { border-color: #4A90D9; color: #4A90D9; background: #EFF6FF; }\n    .section { padding: 64px 48px; }\n    .section-label { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #F97068; margin-bottom: 8px; }\n    .section h2 { font-size: 32px; font-weight: 600; margin-bottom: 12px; letter-spacing: -0.01em; color: #1E293B; }\n    .section p.sub { color: #64748B; font-size: 16px; max-width: 560px; margin-bottom: 48px; }\n    .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }\n    .step-card { background: #FFFFFF; border: 1px solid #F0E7DB; border-radius: 20px; padding: 32px 28px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: all 0.3s; }\n    .step-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }\n    .step-num { width: 52px; height: 52px; border-radius: 9999px; background: #EFF6FF; color: #4A90D9; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 700; margin: 0 auto 16px; }\n    .step-card h4 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }\n    .step-card p { color: #64748B; font-size: 14px; }\n    .property-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }\n    .prop-card { background: #FFFFFF; border: 1px solid #F0E7DB; border-radius: 20px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: all 0.3s; }\n    .prop-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }\n    .prop-img { width: 100%; height: 200px; object-fit: cover; background: linear-gradient(135deg, #DBEAFE, #EDE9FE); display:flex;align-items:center;justify-content:center;font-size:48px; }\n    .prop-body { padding: 24px; }\n    .prop-price { font-size: 24px; font-weight: 700; color: #1E293B; }\n    .prop-addr { color: #64748B; font-size: 14px; margin: 4px 0 10px; }\n    .prop-meta { display: flex; gap: 16px; font-size: 13px; color: #94A3B8; font-weight: 500; }\n    .prop-badge { display: inline-block; padding: 4px 12px; border-radius: 9999px; font-size: 11px; font-weight: 600; margin-bottom: 8px; }\n    .badge-new { color: #059669; background: #D1FAE5; }\n    .features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }\n    .feat-card { text-align: center; padding: 28px; background: #FFFFFF; border: 1px solid #F0E7DB; border-radius: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: all 0.3s; }\n    .feat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: translateY(-2px); }\n    .feat-icon { width: 52px; height: 52px; border-radius: 16px; background: #EFF6FF; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; color: #4A90D9; }\n    .feat-card h4 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }\n    .feat-card p { color: #64748B; font-size: 13px; }\n    footer { border-top: 1px solid #F0E7DB; padding: 48px; display: flex; justify-content: space-between; }\n    .footer-col h5 { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; color: #94A3B8; }\n    .footer-col a { display: block; color: #64748B; text-decoration: none; font-size: 14px; margin-bottom: 8px; transition: color 0.2s; }\n    .footer-col a:hover { color: #4A90D9; }\n    .var-nav-bar { position: fixed; top: 16px; right: 16px; display: flex; gap: 8px; background: rgba(0,0,0,0.8); backdrop-filter: blur(12px); padding: 8px 14px; border-radius: 10px; z-index: 9999; border: 1px solid rgba(255,255,255,0.1); }\n    .var-nav-bar a { color: #94A3B8; text-decoration: none; font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 6px; transition: all 0.2s; }\n    .var-nav-bar a.active { background: #4A90D9; color: #fff; }\n    .var-nav-bar a:hover:not(.active) { color: #fff; background: rgba(255,255,255,0.1); }\n    .var-nav-bar .sep { color: rgba(255,255,255,0.2); font-size: 12px; line-height: 1.8; }\n  </style>\n</head>\n<body>\n<nav class=\"var-nav-bar\">\n  <a href=\"A-01-landing.html\">A</a>\n  <a href=\"B-01-landing.html\" class=\"active\">B</a>\n  <a href=\"C-01-landing.html\">C</a>\n  <span class=\"sep\">|</span>\n  <span style=\"color:#94A3B8;font-size:11px;padding:4px 4px;\">Landing</span>\n</nav>\n\n<div class=\"root\">\n  <nav class=\"navbar\">\n    <div class=\"nav-logo\">NestFind</div>\n    <div class=\"nav-links\">\n      <a href=\"#\">Browse</a>\n      <a href=\"#\">How It Works</a>\n      <a href=\"#\">For Owners</a>\n      <button class=\"btn btn-secondary\">Sign In</button>\n      <button class=\"btn btn-primary\">Join Now</button>\n    </div>\n  </nav>\n\n  <section class=\"hero\">\n    <h1>Find Your <span>Perfect Nest</span>,<br>Without the Noise</h1>\n    <p>Browse thousands of verified rental properties. Clean, ad-free, and focused on what matters — finding your next home.</p>\n    <div class=\"search-bar\">\n      <input type=\"text\" placeholder=\"Enter city, neighborhood, or ZIP code...\">\n      <button class=\"btn btn-primary\">Search Properties</button>\n    </div>\n    <div class=\"chip-row\">\n      <span class=\"chip\">Apartments</span>\n      <span class=\"chip\">Houses</span>\n      <span class=\"chip\">Condos</span>\n      <span class=\"chip\">Pet-Friendly</span>\n      <span class=\"chip\">Under $2,000</span>\n    </div>\n  </section>\n\n  <section class=\"section\">\n    <div class=\"section-label\">How It Works</div>\n    <h2>Three steps to your next home</h2>\n    <p class=\"sub\">NestFind makes rental hunting simple. No ads, no clutter, just homes you'll love.</p>\n    <div class=\"steps\">\n      <div class=\"step-card\">\n        <div class=\"step-num\">1</div>\n        <h4>Search & Filter</h4>\n        <p>Enter your preferred location and refine by price, beds, and property type. Results update instantly.</p>\n      </div>\n      <div class=\"step-card\">\n        <div class=\"step-num\">2</div>\n        <h4>Explore & Save</h4>\n        <p>Browse photos, check amenities, and view locations on the map. Save favorites with one click.</p>\n      </div>\n      <div class=\"step-card\">\n        <div class=\"step-num\">3</div>\n        <h4>Inquire & Move</h4>\n        <p>Send an inquiry directly to the property manager. Simple form, no lengthy applications.</p>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\">\n    <div class=\"section-label\">Featured Properties</div>\n    <h2>Homes you might love</h2>\n    <p class=\"sub\">Hand-picked listings from our curated collection.</p>\n    <div class=\"property-grid\">\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background: linear-gradient(135deg, #DBEAFE, #C7D2FE);\">🏠</div>\n        <div class=\"prop-body\">\n          <span class=\"prop-badge badge-new\">Available Now</span>\n          <div class=\"prop-price\">$1,850<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n          <div class=\"prop-addr\">1420 Pine Street, San Francisco, CA</div>\n          <div class=\"prop-meta\"><span>2 bd</span><span>1 ba</span><span>850 sqft</span><span>Apartment</span></div>\n        </div>\n      </div>\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background: linear-gradient(135deg, #FEF3C7, #FDE68A);\">🏡</div>\n        <div class=\"prop-body\">\n          <span class=\"prop-badge badge-new\">Available Now</span>\n          <div class=\"prop-price\">$2,950<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n          <div class=\"prop-addr\">381 Oak Avenue, Austin, TX</div>\n          <div class=\"prop-meta\"><span>3 bd</span><span>2 ba</span><span>1,200 sqft</span><span>House</span></div>\n        </div>\n      </div>\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background: linear-gradient(135deg, #D1FAE5, #A7F3D0);\">🏢</div>\n        <div class=\"prop-body\">\n          <span class=\"prop-badge badge-new\">Available Now</span>\n          <div class=\"prop-price\">$2,200<span style=\"font-size:14px;font-weight:400;color:#94A3B8\">/mo</span></div>\n          <div class=\"prop-addr\">750 Market Street, Portland, OR</div>\n          <div class=\"prop-meta\"><span>1 bd</span><span>1 ba</span><span>720 sqft</span><span>Condo</span></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\">\n    <div class=\"section-label\">Why NestFind</div>\n    <h2>Built for renters, not advertisers</h2>\n    <p class=\"sub\">We focused on what actually matters when finding a rental.</p>\n    <div class=\"features\">\n      <div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:eye-off-outline\" width=\"24\"></iconify-icon></div><h4>Ad-Free Browsing</h4><p>No sponsored listings cluttering your search. Every result is organic.</p></div>\n      <div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:lightning-bolt\" width=\"24\"></iconify-icon></div><h4>Instant Filters</h4><p>Real-time filtering by price, beds, and type. No page reloads.</p></div>\n      <div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:heart-outline\" width=\"24\"></iconify-icon></div><h4>Quick Favorites</h4><p>Save properties with one click. Access your favorites from anywhere.</p></div>\n      <div class=\"feat-card\"><div class=\"feat-icon\"><iconify-icon icon=\"mdi:map-marker-outline\" width=\"24\"></iconify-icon></div><h4>Map View</h4><p>See exactly where each property is. Integrated Google Maps on every listing.</p></div>\n    </div>\n  </section>\n\n  <footer>\n    <div class=\"footer-col\"><h5>NestFind</h5><a href=\"#\">About</a><a href=\"#\">Careers</a><a href=\"#\">Press</a><a href=\"#\">Blog</a></div>\n    <div class=\"footer-col\"><h5>Renters</h5><a href=\"#\">Browse Properties</a><a href=\"#\">How It Works</a><a href=\"#\">Renter Guide</a><a href=\"#\">Safety Tips</a></div>\n    <div class=\"footer-col\"><h5>Owners</h5><a href=\"#\">List a Property</a><a href=\"#\">Owner Dashboard</a><a href=\"#\">Pricing</a><a href=\"#\">Resources</a></div>\n    <div class=\"footer-col\"><h5>Support</h5><a href=\"#\">Help Center</a><a href=\"#\">Contact Us</a><a href=\"#\">Privacy Policy</a><a href=\"#\">Terms of Service</a></div>\n  </footer>\n</div>\n</body>\n</html>\n","filePath":"/Users/saifulpotential/Potential/nestfind-sample/.claude-project/nestfind/design/variations/B-01-landing.html"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/.claude-project/nestfind/design/variations/B-01-landing.html","exists":true,"truncated":false},"title":".claude-project/nestfind/design/variations/B-01-landing.html","time":{"start":1779179176206,"end":1779179176533}},"id":"prt_e3f557005001qBm3rF8nrsgANm","sessionID":"ses_1c0b7aabcffeYZ3PyoUxDZ443y","messageID":"msg_e3f4d8e570019bQ0biggmJt52X"}}
