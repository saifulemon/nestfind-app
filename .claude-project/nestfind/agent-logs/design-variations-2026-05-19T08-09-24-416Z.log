ansform:translateY(-2px)}\n.vp-icon{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px}\n.vp-card:nth-child(1) .vp-icon{background:#EFF6FF;color:#4A90D9}\n.vp-card:nth-child(2) .vp-icon{background:#FEF3C7;color:#D97706}\n.vp-card:nth-child(3) .vp-icon{background:#D1FAE5;color:#059669}\n.vp-card:nth-child(4) .vp-icon{background:#EDE9FE;color:#8B5CF6}\n.vp-card h4{font-size:16px;font-weight:600;margin-bottom:6px}\n.vp-card p{font-size:14px;color:#64748B;line-height:1.5}\nfooter{padding:48px;border-top:1px solid #F0E7DB;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px}\nfooter .f-col h4{font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#94A3B8;margin-bottom:16px}\nfooter .f-col a{display:block;color:#64748B;text-decoration:none;font-size:14px;margin-bottom:12px;transition:color .2s}\nfooter .f-col a:hover{color:#1E293B}\n.f-brand{font-size:24px;font-weight:600;color:#4A90D9;display:inline-flex;align-items:center;gap:8px;margin-bottom:12px}\n.f-brand+.brand-desc{font-size:14px;color:#64748B;line-height:1.5}\n.f-bottom{border-top:1px solid #F0E7DB;padding:18px 48px;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:#94A3B8}\n.var-nav-bar{position:fixed;top:16px;right:16px;display:flex;gap:8px;background:rgba(26,22,37,0.9);backdrop-filter:blur(8px);padding:6px 12px;border-radius:9999px;font-size:12px;z-index:999}\n.var-nav-bar a{color:#94A3B8;text-decoration:none;padding:3px 10px;border-radius:9999px;transition:all .2s}\n.var-nav-bar a.active{background:#4A90D9;color:#fff}\n.var-nav-bar a:hover{color:#fff}\n.var-nav-bar .showcase-link{border-left:1px solid rgba(255,255,255,0.2);padding-left:10px;margin-left:4px}\n</style>\n</head>\n<body>\n<nav class=\"var-nav-bar\">\n  <a href=\"A-01-landing.html\">A</a>\n  <a href=\"B-01-landing.html\" class=\"active\">B</a>\n  <a href=\"C-01-landing.html\">C</a>\n  <a href=\"showcase-ALL.html\" class=\"showcase-link\">All</a>\n</nav>\n<div class=\"page-wrapper\">\n  <header>\n    <div class=\"logo\"><span class=\"logo-icon\">N</span> NestFind</div>\n    <nav>\n      <a href=\"#\">Browse</a>\n      <a href=\"#\">How It Works</a>\n      <a href=\"#\">For Owners</a>\n      <button class=\"btn-ghost\">Sign In</button>\n      <button class=\"btn-primary\">Join Now</button>\n    </nav>\n  </header>\n  <section class=\"hero\">\n    <h1>Find your nest, feel at home</h1>\n    <p>Browse thousands of verified rental properties. Clean, fast, and ad-free — the way apartment hunting should be.</p>\n    <div class=\"search-box\">\n      <input type=\"text\" placeholder=\"Enter city, neighborhood, or ZIP code...\">\n      <button>Search</button>\n    </div>\n    <div class=\"quick-chips\">\n      <span class=\"chip\">Apartments</span><span class=\"chip\">Houses</span><span class=\"chip\">Condos</span><span class=\"chip\">Pet-Friendly</span><span class=\"chip\">Parking</span><span class=\"chip\">Under $2,000</span>\n    </div>\n  </section>\n  <section class=\"section\" style=\"text-align:center\">\n    <div class=\"section-tag\">How It Works</div>\n    <h2>Three simple steps to your next home</h2>\n    <p class=\"sub\">Finding the right rental shouldn't be complicated. We keep it simple.</p>\n    <div class=\"steps\">\n      <div class=\"step-card\">\n        <div class=\"step-icon\">&#128269;</div>\n        <h4>Search & Filter</h4>\n        <p>Enter a city or neighborhood, set your budget and preferences. See matching properties instantly.</p>\n      </div>\n      <div class=\"step-card\">\n        <div class=\"step-icon\">&#9829;</div>\n        <h4>Explore & Save</h4>\n        <p>Browse photos, check amenities, view on map. Save your favorites with one tap.</p>\n      </div>\n      <div class=\"step-card\">\n        <div class=\"step-icon\">&#9993;</div>\n        <h4>Inquire & Move In</h4>\n        <p>Send an inquiry directly from the listing page. The property manager responds quickly.</p>\n      </div>\n    </div>\n  </section>\n  <section class=\"featured-sect\">\n    <h2>Featured Properties</h2>\n    <p class=\"sub\">Hand-picked listings to get you started</p>\n    <div class=\"prop-grid\">\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background:linear-gradient(135deg,#DBEAFE,#EDE9FE)\">\n          <span class=\"badge-avail\">Available Now</span>\n          <span class=\"prop-price\">$1,850/mo</span>\n        </div>\n        <div class=\"prop-info\">\n          <h4>Sunset Heights Apt 4B</h4>\n          <div class=\"prop-loc\">San Francisco, CA 94117</div>\n          <div class=\"prop-meta\">\n            <span>2 bd</span><span>1 ba</span><span>850 sqft</span>\n            <span style=\"margin-left:auto;color:#F97068;cursor:pointer\">&#9825;</span>\n          </div>\n        </div>\n      </div>\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background:linear-gradient(135deg,#FEF3C7,#DBEAFE)\">\n          <span class=\"badge-avail\">Available Now</span>\n          <span class=\"prop-price\">$2,400/mo</span>\n        </div>\n        <div class=\"prop-info\">\n          <h4>Downtown Loft Studio</h4>\n          <div class=\"prop-loc\">Austin, TX 78701</div>\n          <div class=\"prop-meta\">\n            <span>Studio</span><span>1 ba</span><span>520 sqft</span>\n            <span style=\"margin-left:auto;color:#F97068;cursor:pointer\">&#9825;</span>\n          </div>\n        </div>\n      </div>\n      <div class=\"prop-card\">\n        <div class=\"prop-img\" style=\"background:linear-gradient(135deg,#D1FAE5,#EFF6FF)\">\n          <span class=\"badge-avail\">Available Now</span>\n          <span class=\"prop-price\">$3,200/mo</span>\n        </div>\n        <div class=\"prop-info\">\n          <h4>Park View Townhouse</h4>\n          <div class=\"prop-loc\">Portland, OR 97205</div>\n          <div class=\"prop-meta\">\n            <span>3 bd</span><span>2 ba</span><span>1,350 sqft</span>\n            <span style=\"margin-left:auto;color:#F97068;cursor:pointer\">&#9825;</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n  <section class=\"section\" style=\"text-align:center\">\n    <div class=\"section-tag\">Why NestFind</div>\n    <h2>Built for renters, not for advertisers</h2>\n    <p class=\"sub\">We designed NestFind from the ground up to be the most pleasant rental search experience.</p>\n    <div class=\"value-props\">\n      <div class=\"vp-card\">\n        <div class=\"vp-icon\">&#9989;</div>\n        <h4>Verified Listings</h4>\n        <p>Every property is reviewed before it goes live. No bait-and-switch listings.</p>\n      </div>\n      <div class=\"vp-card\">\n        <div class=\"vp-icon\">&#9889;</div>\n        <h4>Lightning Fast</h4>\n        <p>Search results load in under 500ms. No bloated tracking scripts here.</p>\n      </div>\n      <div class=\"vp-card\">\n        <div class=\"vp-icon\">&#128065;</div>\n        <h4>Ad-Free Browsing</h4>\n        <p>Zero ads, zero distractions. Your results show only what matters — properties.</p>\n      </div>\n      <div class=\"vp-card\">\n        <div class=\"vp-icon\">&#128274;</div>\n        <h4>Direct Inquiries</h4>\n        <p>Message property managers directly. No middlemen, no hidden fees.</p>\n      </div>\n    </div>\n  </section>\n  <footer>\n    <div class=\"f-col\">\n      <div class=\"f-brand\"><span style=\"width:28px;height:28px;border-radius:8px;background:#4A90D9;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:14px;font-weight:600;margin-right:6px\">N</span>NestFind</div>\n      <div class=\"brand-desc\">Find your perfect rental. Clean, fast, and ad-free.</div>\n    </div>\n    <div class=\"f-col\">\n      <h4>Explore</h4>\n      <a href=\"#\">Browse Properties</a><a href=\"#\">Popular Cities</a><a href=\"#\">Search by Type</a><a href=\"#\">New Listings</a>\n    </div>\n    <div cla