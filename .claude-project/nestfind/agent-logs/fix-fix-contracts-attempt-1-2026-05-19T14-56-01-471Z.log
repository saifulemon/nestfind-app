ding, isError, error } = usePropertySearch(filters);\n31:   const addFav = useAddFavorite();\n32:   const removeFav = useRemoveFavorite();\n33:   const [favoritedIds, setFavoritedIds] = useState<Set<string>>(new Set());\n34: \n35:   const properties = data?.items ?? [];\n36:   const meta = data?.meta;\n37:   const chips = [\n38:     filters.city && `${filters.city}`,\n39:     filters.minPrice && filters.maxPrice\n40:       ? `$${filters.minPrice} - $${filters.maxPrice}`\n41:       : filters.minPrice\n42:         ? `$${filters.minPrice}+`\n43:         : filters.maxPrice\n44:           ? `Up to $${filters.maxPrice}`\n45:           : null,\n46:     filters.bedrooms ? `${filters.bedrooms}+ Beds` : null,\n47:     filters.propertyType ? filters.propertyType.charAt(0).toUpperCase() + filters.propertyType.slice(1) : null,\n48:   ].filter(Boolean) as string[];\n49: \n50:   const handleSearch = useCallback(() => {\n51:     setFilters((prev) => ({ ...prev, search: searchText || undefined, page: 1 }));\n52:   }, [searchText]);\n53: \n54:   const handleKeyDown = useCallback(\n55:     (e: React.KeyboardEvent) => {\n56:       if (e.key === 'Enter') handleSearch();\n57:     },\n58:     [handleSearch],\n59:   );\n60: \n61:   const updateFilter = useCallback((key: keyof PropertySearchParams, value: string) => {\n62:     setFilters((prev) => {\n63:       const next = { ...prev, page: 1 };\n64:       if (key === 'propertyType') {\n65:         next.propertyType = (value as PropertyTypeEnum) || undefined;\n66:       } else if (key === 'bedrooms') {\n67:         next.bedrooms = value ? parseInt(value, 10) : undefined;\n68:       } else if (key === 'sortBy') {\n69:         next.sortBy = SORT_MAP[value] || 'newest';\n70:       } else if (key === 'minPrice') {\n71:         if (value === '500-1000') { next.minPrice = 500; next.maxPrice = 1000; }\n72:         else if (value === '1000-1500') { next.minPrice = 1000; next.maxPrice = 1500; }\n73:         else if (value === '1500-2000') { next.minP