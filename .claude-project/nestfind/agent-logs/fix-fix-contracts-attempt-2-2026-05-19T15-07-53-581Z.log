Filter(s); setPage(1); }}\n41:             className={`px-3 py-1 text-sm border rounded ${statusFilter === s ? 'bg-primary text-primary-foreground border-primary' : 'hover:bg-muted'}`}\n42:           >\n43:             {s || 'All'}\n44:           </button>\n45:         ))}\n46:       </div>\n47: \n48:       {isLoading && <div className=\"mt-6 text-muted-foreground\">Loading inquiries...</div>}\n49:       {isError && <div className=\"mt-6 text-destructive\">{(error as Error)?.message || 'Failed to load inquiries'}</div>}\n50: \n51:       {!isLoading && !isError && inquiries.length === 0 && (\n52:         <div className=\"mt-6 text-muted-foreground\">No inquiries found.</div>\n53:       )}\n54: \n55:       {!isLoading && !isError && inquiries.length > 0 && (\n56:         <>\n57:           <div className=\"mt-6 overflow-x-auto\">\n58:             <table className=\"w-full border-collapse\">\n59:               <thead>\n60:                 <tr className=\"border-b border-border\">\n61:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">Property</th>\n62:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">From</th>\n63:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">Message</th>\n64:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">Status</th>\n65:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">Date</th>\n66:                   <th className=\"text-left px-4 py-3 text-xs font-semibold uppercase text-muted-foreground\">Actions</th>\n67:                 </tr>\n68:               </thead>\n69:               <tbody>\n70:                 {inquiries.map((inq: InquiryItem) => (\n71:                   <tr key={inq.id} className=\"border-b border-border hover:bg-muted/50\">\n72:     