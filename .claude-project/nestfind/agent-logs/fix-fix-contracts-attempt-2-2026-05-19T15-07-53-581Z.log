DESC',\n25:     page: 1,\n26:     limit: 20,\n27:   });\n28: \n29:   const { data, isLoading, isError, error } = usePropertySearch(filters);\n30:   const addFav = useAddFavorite();\n31:   const removeFav = useRemoveFavorite();\n32:   const [favoritedIds, setFavoritedIds] = useState<Set<string>>(new Set());\n33: \n34:   const properties = data?.items ?? [];\n35:   const meta = data?.meta;\n36:   const chips = [\n37:     filters.city && `${filters.city}`,\n38:     filters.minPrice && filters.maxPrice\n39:       ? `$${filters.minPrice} - $${filters.maxPrice}`\n40:       : filters.minPrice\n41:         ? `$${filters.minPrice}+`\n42:         : filters.maxPrice\n43:           ? `Up to $${filters.maxPrice}`\n44:           : null,\n45:     filters.bedrooms ? `${filters.bedrooms}+ Beds` : null,\n46:     filters.propertyType ? filters.propertyType.charAt(0).toUpperCase() + filters.propertyType.slice(1) : null,\n47:   ].filter(Boolean) as string[];\n48: \n49:   const handleSearch = useCallback(() => {\n50:     setFilters((prev) => ({ ...prev, search: searchText || undefined, page: 1 }));\n51:   }, [searchText]);\n52: \n53:   const handleKeyDown = useCallback(\n54:     (e: React.KeyboardEvent) => {\n55:       if (e.key === 'Enter') handleSearch();\n56:     },\n57:     [handleSearch],\n58:   );\n59: \n60:   const updateFilter = useCallback((key: keyof PropertySearchParams, value: string) => {\n61:     setFilters((prev) => {\n62:       const next = { ...prev, page: 1 };\n63:       if (key === 'propertyType') {\n64:         next.propertyType = (value as PropertyTypeEnum) || undefined;\n65:       } else if (key === 'bedrooms') {\n66:         next.bedrooms = value ? parseInt(value, 10) : undefined;\n67:       } else if (key === 'sortBy') {\n68:         const opt = SORT_OPTIONS[value];\n69:         if (opt) {\n70:           next.sortBy = opt.sortBy;\n71:           next.sortOrder = opt.sortOrder;\n72:         }\n73:       } else if (key === 'minPrice') {\n74:         if (value === '500-1000') { next.minPrice = 500; next.maxPrice = 1000; }\n75:         else if (value === '1000-1500') { next.minPrice = 1000; next.maxPrice = 1500; }\n76:         else if (value === '1500-2000') { next.minPrice = 1500; next.maxPrice = 2000; }\n77:         else if (value === '2000-3000') { next.minPrice = 2000; next.maxPrice = 3000; }\n78:         else if (value === '3000+') { next.minPrice = 3000; next.maxPrice = undefined; }\n79:         else { next.minPrice = undefined; next.maxPrice = undefined; }\n80:       }\n81:       return next;\n82:     });\n83:   }, []);\n84: \n85:   const setPage = useCallback((page: number) => {\n86:     setFilters((prev) => ({ ...prev, page }));\n87:   }, []);\n88: \n89:   const toggleFav = (propertyId: string, e: React.MouseEvent) => {\n90:     e.preventDefault();\n91:     e.stopPropagation();\n92:     const isFav = favoritedIds.has(propertyId);\n93:     setFavoritedIds((prev) => {\n94:       const next = new Set(prev);\n95:       if (isFav) {\n96:         next.delete(propertyId);\n97:         removeFav.mutate(propertyId);\n98:       } else {\n99:         next.add(propertyId);\n100:         addFav.mutate({ propertyId });\n101:       }\n102:       return next;\n103:     });\n104:   };\n105: \n106:   return (\n107:     <div className=\"max-w-[1440px] mx-auto\">\n108:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n109:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n110:           NestFind\n111:         </div>\n112:         <div className=\"flex gap-[32px] items-center\">\n113:           <Link to=\"/search\" className=\"text-[#F1F5F9] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-browse\">Browse</Link>\n114:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-favorites\">Favorites</Link>\n115:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-inquiries\">My Inquiries</Link>\n116:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-profile\">Profile</Link>\n117:         </div>\n118:       </nav>\n119: \n120:       <section className=\"p-[48px]\">\n121:         <div className=\"flex gap-[12px] items-center mb-[24px] flex-wrap\">\n122:           <div className=\"flex-1 min-w-[280px] relative\">\n123:             <Search className=\"absolute left-[16px] top-1/2 -translate-y-1/2 text-[#64748B] w-[20px] h-[20px]\" />\n124:             <input\n125:               type=\"text\"\n126:               placeholder=\"Search by city, neighborhood, or ZIP...\"\n127:               className={`${inputClass} !pl-[44px]`}\n128:               data-testid=\"A-06-search-input\"\n129:               value={searchText}\n130:               onChange={(e) => setSearchText(e.target.value)}\n131:               onKeyDown={handleKeyDown}\n132:             />\n133:           </div>\n134:           <select\n135:             className={`${selectClass} w-[170px]`}\n136:             data-testid=\"A-06-search-price-range\"\n137:             onChange={(e) => updateFilter('minPrice', e.target.value)}\n138:           >\n139:             <option value=\"\">Price Range</option>\n140:             <option value=\"500-1000\">$500 - $1,000</option>\n141:             <option value=\"1000-1500\">$1,000 - $1,500</option>\n142:             <option value=\"1500-2000\">$1,500 - $2,000</option>\n143:             <option value=\"2000-3000\">$2,000 - $3,000</option>\n144:             <option value=\"3000+\">$3,000+</option>\n145:           </select>\n146:           <select className={`${selectClass} w-[150px]`} data-t