: \n30:   return (\n31:     <div className=\"bg-[#0B0F1A] min-h-screen text-[#F1F5F9]\">\n32:       <div className=\"flex items-center justify-center min-h-[calc(100vh-73px)] p-6\">\n33:         <div className=\"w-full max-w-[420px] bg-[rgba(255,255,255,0.04)] backdrop-blur-[12px] border border-[rgba(255,255,255,0.08)] rounded-[16px] p-[40px]\">\n34:           <h2 className=\"text-[28px] font-bold mb-2 tracking-[-0.02em]\">\n35:             {t('auth.welcomeBack')}\n36:           </h2>\n37:           <p className=\"text-sm text-[#94A3B8] mb-8 leading-relaxed\">\n38:             {t('auth.signInSubtitle')}\n39:           </p>\n40: \n41:           {login.isError && (\n42:             <div className=\"mb-4 p-3 rounded bg-[rgba(248,113,113,0.1)] border border-[rgba(248,113,113,0.3)] text-[#F87171] text-sm\">\n43:               {(login.error as Error)?.message || 'Login failed'}\n44:             </div>\n45:           )}\n46: \n47:           <form onSubmit={form.handleSubmit(onSubmit)}>\n48:             <div className=\"mb-4\">\n49:               <label htmlFor=\"login-email\" className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\">\n50:                 {t('auth.emailAddress')}\n51:               </label>\n52:               <input\n53:                 id=\"login-email\"\n54:                 type=\"email\"\n55:                 placeholder={t('auth.emailPlaceholder')}\n56:                 data-testid=\"login-email\"\n57:                 {...form.register('email')}\n58:                 className={inputClass}\n59:               />\n60:               {form.formState.errors.email && (\n61:                 <p className=\"text-[#F87171] text-xs mt-1\">{form.formState.errors.email.message}</p>\n62:               )}\n63:             </div>\n64: \n65:             <div className=\"mb-4\">\n66:               <div className=\"flex justify-between items-center mb-[6px]\">\n67:                 <label htmlFor=\"login-password\" className=\"block text-[13px] font-medium text-[#94