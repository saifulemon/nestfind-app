ync () => {\n419:       const res = await request(app.getHttpServer())\n420:         .post(`/api/properties/${property.id}/inquiries`)\n421:         .set(authHeader(renterToken))\n422:         .send({ message: 'Response inquiry test message.' })\n423:         .expect(201);\n424:       inquiryId = res.body.data.id;\n425:     });\n426: \n427:     it('should return 200 when admin responds to inquiry', async () => {\n428:       const res = await request(app.getHttpServer())\n429:         .post(`/api/inquiries/${inquiryId}/respond`)\n430:         .set(authHeader(adminToken))\n431:         .send({ response: 'Thank you for your interest. The property is available.' })\n432:         .expect(200);\n433: \n434:       expect(res.body.success).toBe(true);\n435:       expect(res.body.statusCode).toBe(200);\n436:       expect(res.body.message).toBe('Response sent successfully');\n437:       expect(res.body.data).toHaveProperty('id', inquiryId);\n438:       expect(res.body.data).toHaveProperty('status', 'responded');\n439:       expect(res.body.data).toHaveProperty('response');\n440:       expect(res.body.data).toHaveProperty('respondedAt');\n441:       expect(res.body.data).toHaveProperty('updatedAt');\n442:     });\n443: \n444:     it('should return 400 when response is missing', async () => {\n445:       await request(app.getHttpServer())\n446:         .post(`/api/inquiries/${inquiryId}/respond`)\n447:         .set(authHeader(adminToken))\n448:         .send({})\n449:         .expect(400);\n450:     });\n451: \n452:     it('should return 400 when response is too short (< 10 chars)', async () => {\n453:       await request(app.getHttpServer())\n454:         .post(`/api/inquiries/${inquiryId}/respond`)\n455:         .set(authHeader(adminToken))\n456:         .send({ response: 'Short' })\n457:         .expect(400);\n458:     });\n459: \n460:     it('should return 400 when response is too long (> 5000 chars)', async () => {\n461:       await request(app.getHttpServer())\n462:         .post(`/api/inquiries/${inquiryId}/respond`)\n463:         .set(authHeader(adminToken))\n464:         .send({ response: 'X'.repeat(5001) })\n465:         .expect(400);\n466:     });\n467: \n468:     it('should return 400 for invalid UUID', async () => {\n469:       await request(app.getHttpServer())\n470:         .post('/api/inquiries/not-a-uuid/respond')\n471:         .set(authHeader(adminToken))\n472:         .send({ response: 'Valid response text here.' })\n473:         .expect(400);\n474:     });\n475: \n476:     it('should return 401 when not authenticated', async () => {\n477:       await request(app.getHttpServer())\n478:         .post(`/api/inquiries/${inquiryId}/respond`)\n479:         .send({ response: 'Unauthenticated response.' })\n480:         .expect(401);\n481:     });\n482: \n483:     it('should return 403 when authenticated as renter', async () => {\n484:       await request(app.getHttpServer())\n485:         .post(`/api/inquiries/${inquiryId}/respond`)\n486:         .set(authHeader(renterToken))\n487:         .send({ response: 'Renter cannot respond.' })\n488:         .expect(403);\n489:     });\n490: \n491:     it('should return 404 when inquiry not found', async () => {\n492:       await request(app.getHttpServer())\n493:         .post('/api/inquiries/00000000-0000-0000-0000-000000000000/respond')\n494:         .set(authHeader(adminToken))\n495:         .send({ response: 'Valid response text here.' })\n496:         .expect(404);\n497:     });\n498:   });\n499: });\n\n(End of file - total 499 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport {