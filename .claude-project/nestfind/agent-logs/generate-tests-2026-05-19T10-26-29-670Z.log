isFavorited=false for unauthenticated user', async () => {\n280:       const res = await request(app.getHttpServer())\n281:         .get(`/api/properties/${property.id}`)\n282:         .expect(200);\n283: \n284:       expect(res.body.data.isFavorited).toBe(false);\n285:     });\n286:   });\n287: \n288:   // ─── POST /properties (Create) ─────────────────────────────────────\n289:   describe('POST /api/properties', () => {\n290:     const validBody = {\n291:       title: 'New Test Property',\n292:       description: 'A newly created test property for e2e testing purposes.',\n293:       price: 1800.0,\n294:       bedrooms: 2,\n295:       bathrooms: 1,\n296:       squareFeet: 850,\n297:       propertyType: 'condo',\n298:       address: {\n299:         street: '100 Test Blvd',\n300:         city: 'San Francisco',\n301:         state: 'CA',\n302:         zipCode: '94105',\n303:         latitude: 37.774929,\n304:         longitude: -122.419418,\n305:       },\n306:       availableFrom: '2026-08-01',\n307:       amenityIds: [],\n308:     };\n309: \n310:     it('should return 201 with created property (admin only)', async () => {\n311:       const res = await request(app.getHttpServer())\n312:         .post('/api/properties')\n313:         .set(authHeader(adminToken))\n314:         .send(validBody)\n315:         .expect(201);\n316: \n317:       expect(res.body.success).toBe(true);\n318:       expect(res.body.statusCode).toBe(201);\n319:       expect(res.body.message).toBe('Property created successfully');\n320:       expect(res.body.data).toHaveProperty('id');\n321:       expect(res.body.data).toHaveProperty('title', 'New Test Property');\n322:       expect(res.body.data).toHaveProperty('price', 1800);\n323:       expect(res.body.data).toHaveProperty('address');\n324:       expect(res.body.data.address).toHaveProperty('city', 'San Francisco');\n325:       expect(res.body.data).toHaveProperty('photos');\n326:       expect(res.body.data).toHaveProperty('amenities');\n327:    