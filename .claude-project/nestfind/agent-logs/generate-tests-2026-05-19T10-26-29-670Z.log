\n219: \n220:     it('should support filtering by status', async () => {\n221:       const res = await request(app.getHttpServer())\n222:         .get('/api/inquiries?status=new')\n223:         .set(authHeader(adminToken))\n224:         .expect(200);\n225: \n226:       for (const item of res.body.data.items) {\n227:         expect(item.status).toBe('new');\n228:       }\n229:     });\n230: \n231:     it('should support filtering by propertyId', async () => {\n232:       const res = await request(app.getHttpServer())\n233:         .get(`/api/inquiries?propertyId=${property.id}`)\n234:         .set(authHeader(adminToken))\n235:         .expect(200);\n236: \n237:       for (const item of res.body.data.items) {\n238:         expect(item.property.id).toBe(property.id);\n239:       }\n240:     });\n241: \n242:     it('should support search by name or email', async () => {\n243:       await request(app.getHttpServer())\n244:         .get(`/api/inquiries?search=${encodeURIComponent(renterUser.name)}`)\n245:         .set(authHeader(adminToken))\n246:         .expect(200);\n247:     });\n248: \n249:     it('should support sorting', async () => {\n250:       const res = await request(app.getHttpServer())\n251:         .get('/api/inquiries?sortBy=newest')\n252:         .set(authHeader(adminToken))\n253:         .expect(200);\n254: \n255:       expect(res.body.success).toBe(true);\n256:     });\n257: \n258:     it('should support pagination', async () => {\n259:       const res = await request(app.getHttpServer())\n260:         .get('/api/inquiries?page=1&limit=10')\n261:         .set(authHeader(adminToken))\n262:         .expect(200);\n263: \n264:       expect(res.body.data.meta.page).toBe(1);\n265:       expect(res.body.data.meta.limit).toBe(10);\n266:     });\n267: \n268:     it('should return 401 when not authenticated', async () => {\n269:       await request(app.getHttpServer())\n270:         .get('/api/inquiries')\n271:         .expect(401);\n272:     });\n273: \n274:     it('should return 403 when authenticated as renter (admin only)', async () => {\n275:       await request(app.getHttpServer())\n276:         .get('/api/inquiries')\n277:         .set(authHeader(renterToken))\n278:         .expect(403);\n279:     });\n280:   });\n281: \n282:   // ─── GET /inquiries/:id (Detail - Admin) ─────────────────────────\n283:   describe('GET /api/inquiries/:id', () => {\n284:     let inquiryId: string;\n285: \n286:     beforeEach(async () => {\n287:       const res = await request(app.getHttpServer())\n288:         .post(`/api/properties/${property.id}/inquiries`)\n289:         .set(authHeader(renterToken))\n290:         .send({ message: 'Detail inquiry test message.' })\n291:         .expect(201);\n292:       inquiryId = res.body.data.id;\n293:     });\n294: \n295:     it('should return 200 with inquiry detail (admin only)', async () => {\n296:       const res = await request(app.getHttpServer())\n297:         .get(`/api/inquiries/${inquiryId}`)\n298:         .set(authHeader(adminToken))\n299:         .expect(200);\n300: \n301:       expect(res.body.success).toBe(true);\n302:       expect(res.body.statusCode).toBe(200);\n303:       expect(res.body.message).toBe('Inquiry retrieved successfully');\n304:       expect(res.body.data).toHaveProperty('id', inquiryId);\n305:       expect(res.body.data).toHaveProperty('property');\n306:       expect(res.body.data).toHaveProperty('renter');\n307:       expect(res.body.data).toHaveProperty('name');\n308:       expect(res.body.data).toHaveProperty('email');\n309:       expect(res.body.data).toHaveProperty('message');\n310:       expect(res.body.data).toHaveProperty('status', 'new');\n311:       expect(res.body.data).toHaveProperty('response');\n312:       expect(res.body.data).toHaveProperty('respondedAt');\n313:       expect(res.body.data).toHaveProperty('createdAt');\n314:       expect(res.body.data).toHaveProperty('updatedAt');\n315:     });\n316: \n317:     it('should return 400 for invalid UUID', 