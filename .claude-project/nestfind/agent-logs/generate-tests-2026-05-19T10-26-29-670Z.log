 {\n530:       await request(app.getHttpServer())\n531:         .delete('/api/properties/00000000-0000-0000-0000-000000000000')\n532:         .set(authHeader(adminToken))\n533:         .expect(404);\n534:     });\n535: \n536:     it('should make property inaccessible via GET after archiving', async () => {\n537:       // Archive the property\n538:       await request(app.getHttpServer())\n539:         .delete(`/api/properties/${property.id}`)\n540:         .set(authHeader(adminToken))\n541:         .expect(200);\n542: \n543:       // Should now return 404 for public access\n544:       await request(app.getHttpServer())\n545:         .get(`/api/properties/${property.id}`)\n546:         .expect(404);\n547:     });\n548:   });\n549: \n550:   // ─── POST /properties/:id/photos (Upload) ─────────────────────────\n551:   describe('POST /api/properties/:id/photos', () => {\n552:     let property: Property;\n553: \n554:     beforeEach(async () => {\n555:       const seeded = await seedTestProperties(dataSource);\n556:       property = seeded.downtownApt;\n557:     });\n558: \n559:     it('should return 201 with uploaded photo data (admin only)', async () => {\n560:       const res = await request(app.getHttpServer())\n561:         .post(`/api/properties/${property.id}/photos`)\n562:         .set(authHeader(adminToken))\n563:         .attach('files', Buffer.from('fake-image-content'), 'test-photo.jpg')\n564:         .expect(201);\n565: \n566:       expect(res.body.success).toBe(true);\n567:       expect(res.body.statusCode).toBe(201);\n568:       expect(res.body.message).toBe('Photos uploaded successfully');\n569:       expect(Array.isArray(res.body.data)).toBe(true);\n570:       if (res.body.data.length > 0) {\n571:         const photo = res.body.data[0];\n572:         expect(photo).toHaveProperty('id');\n573:         expect(photo).toHaveProperty('url');\n574:         expect(photo).toHaveProperty('isPrimary');\n575:         expect(photo).toHaveProperty('sortOrder');\n576:  