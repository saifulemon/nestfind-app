{\n38:     await closeTestApp({ app, module });\n39:   });\n40: \n41:   beforeEach(async () => {\n42:     await cleanDatabase(dataSource);\n43:     const seededUsers = await seedTestUsers(dataSource);\n44:     adminUser = seededUsers.admin;\n45:     renterUser = seededUsers.renter;\n46:     renter2User = seededUsers.renter2;\n47:     adminToken = generateAccessToken(adminUser);\n48:     renterToken = generateAccessToken(renterUser);\n49:     renter2Token = generateAccessToken(renter2User);\n50: \n51:     const seededProps = await seedTestProperties(dataSource);\n52:     property1 = seededProps.downtownApt;\n53:     property2 = seededProps.suburbanHouse;\n54:   });\n55: \n56:   // ─── GET /favorites (List) ──────────────────────────────────────\n57:   describe('GET /api/favorites', () => {\n58:     it('should return 200 with paginated favorites list (renter only)', async () => {\n59:       const res = await request(app.getHttpServer())\n60:         .get('/api/favorites')\n61:         .set(authHeader(renterToken))\n62:         .expect(200);\n63: \n64:       expect(res.body.success).toBe(true);\n65:       expect(res.body.statusCode).toBe(200);\n66:       expect(res.body.message).toBe('Favorites retrieved successfully');\n67:       expect(res.body.data).toHaveProperty('items');\n68:       expect(res.body.data).toHaveProperty('meta');\n69:       expect(res.body.data.meta).toHaveProperty('total');\n70:       expect(res.body.data.meta).toHaveProperty('page');\n71:       expect(res.body.data.meta).toHaveProperty('limit');\n72:       expect(res.body.data.meta).toHaveProperty('totalPages');\n73:       expect(Array.isArray(res.body.data.items)).toBe(true);\n74:     });\n75: \n76:     it('should return favorite items with correct shape', async () => {\n77:       // First add a favorite so the list isn't empty\n78:       await request(app.getHttpServer())\n79:         .post('/api/favorites')\n80:         .set(authHeader(renterToken))\n81:         .send({ propertyId: property1.id })\n82:         .expect(201);\n83: \n84:       const res = await request(app.getHttpServer())\n85:         .get('/api/favorites')\n86:         .set(authHeader(renterToken))\n87:         .expect(200);\n88: \n89:       if (res.body.data.items.length > 0) {\n90:         const item = res.body.data.items[0];\n91:         expect(item).toHaveProperty('id');\n92:         expect(item).toHaveProperty('property');\n93:         expect(item.property).toHaveProperty('id');\n94:         expect(item.property).toHaveProperty('title');\n95:         expect(item.property).toHaveProperty('price');\n96:         expect(item.property).toHaveProperty('bedrooms');\n97:         expect(item.property).toHaveProperty('bathrooms');\n98:         expect(item.property).toHaveProperty('propertyType');\n99:         expect(item.property).toHaveProperty('address');\n100:         expect(item.property.address).toHaveProperty('city');\n101:         expect(item.property.address).toHaveProperty('state');\n102:         expect(item.property).toHaveProperty('primaryPhoto');\n103:         expect(item).toHaveProperty('createdAt');\n104:       }\n105:     });\n106: \n107:     it('should support pagination with page and limit', async () => {\n108:       const res = await request(app.getHttpServer())\n109:         .get('/api/favorites?page=1&limit=10')\n110:         .set(authHeader(renterToken))\n111:         .expect(200);\n112: \n113:       expect(res.body.data.meta.page).toBe(1);\n114:       expect(res.body.data.meta.limit).toBe(10);\n115:     });\n116: \n117:     it('should return 401 when not authenticated', async () => {\n118:       await request(app.getHttpServer())\n119:         .get('/api/favorites')\n120:         .expect(401);\n121:     });\n122: \n123:     it('should return 401 with invalid token', async () => {\n124:       await request(app.getHttpServer())\n125:         .get('/api/favorites')\n126:         .set(authHeader('invalid-token'))\n127:         .expect(401);\n128:     });\n129: \n130:     it('should return 403 when authenticated as admin (renter only)', async () => {\n131:       await request(app.getHttpServer())\n132:         .get('/api/favorites')\n133:         .set(authHeader(adminToken))\n134:         .expect(403);\n135:     });\n136: \n137:     it('should only return favorites for the authenticated renter', async () => {\n138:       // Renter1 favorites property1\n139:       await request(app.getHttpServer())\n140:         .post('/api/favorites')\n141:         .set(authHeader(renterToken))\n142:         .send({ propertyId: property1.id })\n143:         .expect(201);\n144: \n145:       // Renter2 favorites property2\n146:       await request(app.getHttpServer())\n147:         .post('/api/favorites')\n148:         .set(authHeader(renter2Token))\n149:         .send({ propertyId: property2.id })\n150:         .expect(201);\n151: \n152:       // Renter1's favorites should only include property1\n153:       const res = await request(app.getHttpServer())\n154:         .get('/api/favorites')\n155:         .set(authHeader(renterToken))\n156:         .expect(200);\n157: \n158:       const propertyIds = res.body.data.items.map((i: any) => i.property.id);\n159:       expect(propertyIds).toContain(property1.id);\n160:       expect(propertyIds).not.toContain(property2.id);\n161:     });\n162:   });\n163: \n164:   // ─── POST /favorites (Add) ─────────────────────────────────────\n165:   describe('POST /api/favorites', () => {\n166:     it('should return 201 when property added to favorites (renter only)', async () => {\n167:       const res = await request(app.getHttpServer())\n168:         .post('/api/favorites')\n169:         .set(authHeader(renterToken))\n170:         .send({ propertyId: property1.id })\n171:         .expect(201);\n172: \n173:       expect(res.body.success).toBe(true);\n174:       expect(res.body.statusCode).toBe(201);\n175:       expect(res.body.message).toBe('Property added to favorites');\n176:       expect(res.body.data).toHaveProperty('id');\n177:       expect(res.body.data).toHaveProperty('propertyId', property1.id);\n178:       expect(res.body.data).toHaveProperty('createdAt');\n179:     });\n180: \n181:     it('should be idempotent — adding same property twice returns existing record', async () => {\n182:       // First add\n183:       const first = await request(app.getHttpServer())\n184:         .post('/api/favorites')\n185:         .set(authHeader(renterToken))\n186:         .send({ propertyId: property1.id })\n187:         .expect(201);\n188: \n189:       // Second add (same renter, same property)\n190:       const second = await request(app.getHttpServer())\n191:         .post('/api/favorites')\n192:         .set(authHeader(renterToken))\n193:         .send({ propertyId: property1.id })\n194:         .expect(201);\n195: \n196:       // Should return same or equivalent response\n197:       expect(second.body.data.propertyId).toBe(property1.id);\n198:     });\n199: \n200:     it('should return 400 when propertyId is missing', async () => {\n201:       await request(app.getHttpServer())\n202:         .post('/api/favorites')\n203:         .set(authHeader(renterToken))\n204:         .send({})\n205:         .expect(400);\n206:     });\n207: \n208:     it('should return 400 when propertyId is invalid UUID format', async () => {\n209:       await request(app.getHttpServer())\n210:         .post('/api/favorites')\n211:         .set(authHeader(renterToken))\n212:         .send({ propertyId: 'not-a-uuid' })\n213:         .expect(400);\n214:     });\n215: \n216:     it('should return 401 when not authenticated', async () => {\n217:       await request(app.getHttpServer())\n218:         .post('/api/favorites')\n219:         .send({ propertyId: property1.id })\n220:         .expect(401);\n221:     });\n222: \n223:     it('should return 403 when authenticated as admin (renter only)', async () => {\n224:       await request(app.getHttpServer())\n225:         .post('/api/favorites')\n226:         .set(authHeader(adminToken))\n227:         .send({ propertyId: property1.id })\n228:         .expect(403);\n229:     });\n230: \n231:     it('should return 404 when property does not exist', async () => {\n232:       await request(app.getHttpServer())\n233:         .post('/api/favorites')\n234:         .set(authHeader(renterToken))\n235:         .send({ propertyId: '00000000-0000-0000-0000-000000000000' })\n236:         .expect(404);\n237:     });\n238:   });\n239: \n240:   // ─── DELETE /favorites/:propertyId (Remove) ─────────────────────\n241:   describe('DELETE /api/favorites/:propertyId', () => {\n242:     beforeEach(async () => {\n243:       // Add a favorite first so we can remove it\n244:       await request(app.getHttpServer())\n245:         .post('/api/favorites')\n246:         .set(authHeader(renterToken))\n247:         .send({ propertyId: property1.id })\n248:         .expect(201);\n249:     });\n250: \n251:     it('should return 200 when favorite removed (renter only)', async () => {\n252:       const res = await request(app.getHttpServer())\n253:         .delete(`/api/favorites/${property1.id}`)\n254:         .set(authHeader(renterToken))\n255:         .expect(200);\n256: \n257:       expect(res.body.success).toBe(true);\n258:       expect(res.body.statusCode).toBe(200);\n259:       expect(res.body.message).toBe('Property removed from favorites');\n260:       expect(res.body.data).toBeNull();\n261:     });\n262: \n263:     it('should return 400 when propertyId is invalid UUID format', async () => {\n264:       await request(app.getHttpServer())\n265:         .delete('/api/favorites/not-a-uuid')\n266:         .set(authHeader(renterToken))\n267:         .expect(400);\n268:     });\n269: \n270:     it('should return 401 when not authenticated', async () => {\n271:       await request(app.getHttpServer())\n272:         .delete(`/api/favorites/${property1.id}`)\n273:         .expect(401);\n274:     });\n275: \n276:     it('should return 403 when authenticated as admin (renter only)', async () => {\n277:       await request(app.getHttpServer())\n278:         .delete(`/api/favorites/${property1.id}`)\n279:         .set(authHeader(adminToken))\n280:         .expect(403);\n281:     });\n282: \n283:     it('should return 404 when favorite not found', async () => {\n284:       // Property exists but is not favorited by this renter\n285:       await request(app.getHttpServer())\n286:         .delete(`/api/favorites/${property2.id}`)\n287:         .set(authHeader(renterToken))\n288:         .expect(404);\n289:     });\n290: \n291:     it('should return 404 when removing a favorite that belongs to another renter', async () => {\n292:       // Renter2 tries to remove renter1's favorite\n293:       await request(app.getHttpServer())\n294:         .delete(`/api/favorites/${property1.id}`)\n295:         .set(authHeader(renter2Token))\n296:         .expect(404);\n297:     });\n298:   });\n299: });\n\n(End of file - total 299 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\nimport { seedTestProperties } from '../fixtures/property.fixture';\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { Property } from '../../src/modules/properties/entities/property.entity';\n\n// RED PHASE: These imports will fail because modules don't exist yet.\n// import { FavoritesModule } from '../../src/modules/favorites/favorites.module';\n\ndescribe('Favorites E2E', () => {\n  let app: INestApplication;\n  let module: TestingModule;\n  let dataSource: DataSource;","t