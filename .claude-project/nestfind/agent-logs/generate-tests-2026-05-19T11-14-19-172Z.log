mary`)\n709:         .set(authHeader(adminToken))\n710:         .expect(404);\n711:     });\n712:   });\n713: \n714:   // ─── PATCH /properties/:id/photos/reorder ─────────────────────────\n715:   describe('PATCH /api/properties/:id/photos/reorder', () => {\n716:     it('should return 200 when photos reordered (admin only)', async () => {\n717:       // Requires photos to exist. In GREEN phase: upload photos, reorder.\n718:       await request(app.getHttpServer())\n719:         .patch('/api/properties/00000000-0000-0000-0000-000000000001/photos/reorder')\n720:         .set(authHeader(adminToken))\n721:         .send({ photoIds: [] })\n722:         .expect(404);\n723:       // NOTE: Will be 200 in GREEN phase with seeded photo data\n724:     });\n725: \n726:     it('should return 400 for invalid UUID format', async () => {\n727:       await request(app.getHttpServer())\n728:         .patch('/api/properties/bad-uuid/photos/reorder')\n729:         .set(authHeader(adminToken))\n730:         .send({ photoIds: ['not-a-uuid'] })\n731:         .expect(400);\n732:     });\n733: \n734:     it('should return 401 when not authenticated', async () => {\n735:       await request(app.getHttpServer())\n736:         .patch('/api/properties/some-id/photos/reorder')\n737:         .send({ photoIds: [] })\n738:         .expect(401);\n739:     });\n740: \n741:     it('should return 403 when authenticated as renter', async () => {\n742:       await request(app.getHttpServer())\n743:         .patch('/api/properties/some-id/photos/reorder')\n744:         .set(authHeader(renterToken))\n745:         .send({ photoIds: [] })\n746:         .expect(403);\n747:     });\n748: \n749:     it('should return 404 when property not found', async () => {\n750:       await request(app.getHttpServer())\n751:         .patch('/api/properties/00000000-0000-0000-0000-000000000000/photos/reorder')\n752:         .set(authHeader(adminToken))\n753:         .send({ photoIds: [] })\n754:         .expect(404);\n755:  