).toBe(200);\n431:       expect(res.body.message).toBe('Property updated successfully');\n432:       expect(res.body.data).toHaveProperty('id', property.id);\n433:       expect(res.body.data).toHaveProperty('title', 'Updated Title');\n434:       expect(res.body.data).toHaveProperty('price', 2800);\n435:     });\n436: \n437:     it('should return 200 updating only one field', async () => {\n438:       const res = await request(app.getHttpServer())\n439:         .patch(`/api/properties/${property.id}`)\n440:         .set(authHeader(adminToken))\n441:         .send({ price: 3000 })\n442:         .expect(200);\n443: \n444:       expect(res.body.data.price).toBe(3000);\n445:       expect(res.body.data.title).toBe(property.title);\n446:     });\n447: \n448:     it('should return 400 for invalid UUID', async () => {\n449:       await request(app.getHttpServer())\n450:         .patch('/api/properties/not-a-uuid')\n451:         .set(authHeader(adminToken))\n452:         .send({ title: 'Bad UUID' })\n453:         .expect(400);\n454:     });\n455: \n456:     it('should return 400 when title is too short (< 5 chars)', async () => {\n457:       await request(app.getHttpServer())\n458:         .patch(`/api/properties/${property.id}`)\n459:         .set(authHeader(adminToken))\n460:         .send({ title: 'AB' })\n461:         .expect(400);\n462:     });\n463: \n464:     it('should return 401 when not authenticated', async () => {\n465:       await request(app.getHttpServer())\n466:         .patch(`/api/properties/${property.id}`)\n467:         .send({ title: 'No Auth' })\n468:         .expect(401);\n469:     });\n470: \n471:     it('should return 403 when authenticated as renter (not admin)', async () => {\n472:       await request(app.getHttpServer())\n473:         .patch(`/api/properties/${property.id}`)\n474:         .set(authHeader(renterToken))\n475:         .send({ title: 'Renter Update' })\n476:         .expect(403);\n477:     });\n478: \n479:     it('should return 404 when property not found', async () => {\n480:       await request(app.getHttpServer())\n481:         .patch('/api/properties/00000000-0000-0000-0000-000000000000')\n482:         .set(authHeader(adminToken))\n483:         .send({ title: 'Not Found' })\n484:         .expect(404);\n485:     });\n486:   });\n487: \n488:   // ─── DELETE /properties/:id (Archive) ──────────────────────────────\n489:   describe('DELETE /api/properties/:id', () => {\n490:     let property: Property;\n491: \n492:     beforeEach(async () => {\n493:       const seeded = await seedTestProperties(dataSource);\n494:       property = seeded.downtownApt;\n495:     });\n496: \n497:     it('should return 200 and archive property (admin only)', async () => {\n498:       const res = await request(app.getHttpServer())\n499:         .delete(`/api/properties/${property.id}`)\n500:         .set(authHeader(adminToken))\n501:         .expect(200);\n502: \n503:       expect(res.body.success).toBe(true);\n504:       expect(res.body.statusCode).toBe(200);\n505:       expect(res.body.message).toBe('Property archived successfully');\n506:       expect(res.body.data).toBeNull();\n507:     });\n508: \n509:     it('should return 400 for invalid UUID', async () => {\n510:       await request(app.getHttpServer())\n511:         .delete('/api/properties/not-a-uuid')\n512:         .set(authHeader(adminToken))\n513:         .expect(400);\n514:     });\n515: \n516:     it('should return 401 when not authenticated', async () => {\n517:       await request(app.getHttpServer())\n518:         .delete(`/api/properties/${property.id}`)\n519:         .expect(401);\n520:     });\n521: \n522:     it('should return 403 when authenticated as renter (not admin)', async () => {\n523:       await request(app.getHttpServer())\n524:         .delete(`/api/properties/${property.id}`)\n525:         .set(authHeader(renterToken))\n526:         .expect(403);\n527:     });\n528: \n529:     it('should return 404 when property not found', async () => {\n530:       await request(app.getHttpServer())\n531:         .delete('/api/properties/00000000-0000-0000-0000-000000000000')\n532:         .set(authHeader(adminToken))\n533:         .expect(404);\n534:     });\n535: \n536:     it('should make property inaccessible via GET after archiving', async () => {\n537:       // Archive the property\n538:       await request(app.getHttpServer())\n539:         .delete(`/api/properties/${property.id}`)\n540:         .set(authHeader(adminToken))\n541:         .expect(200);\n542: \n543:       // Should now return 404 for public access\n544:       await request(app.getHttpServer())\n545:         .get(`/api/properties/${property.id}`)\n546:         .expect(404);\n547:     });\n548:   });\n549: \n550:   // ─── POST /properties/:id/photos (Upload) ─────────────────────────\n551:   describe('POST /api/properties/:id/photos', () => {\n552:     let property: Property;\n553: \n554:     beforeEach(async () => {\n555:       const seeded = await seedTestProperties(dataSource);\n556:       property = seeded.downtownApt;\n557:     });\n558: \n559:     it('should return 201 with uploaded photo data (admin only)', async () => {\n560:       const res = await request(app.getHttpServer())\n561:         .post(`/api/properties/${property.id}/photos`)\n562:         .set(authHeader(adminToken))\n563:         .attach('files', Buffer.from('fake-image-content'), 'test-photo.jpg')\n564:         .expect(201);\n565: \n566:       expect(res.body.success).toBe(true);\n567:       expect(res.body.statusCode).toBe(201);\n568:       expect(res.body.message).toBe('Photos uploaded successfully');\n569:       expect(Array.isArray(res.body.data)).toBe(true);\n570:       if (res.body.data.length > 0) {\n571:         const photo = res.body.data[0];\n572:         expect(photo).toHaveProperty('id');\n573:         expect(photo).toHaveProperty('url');\n574:         expect(photo).toHaveProperty('isPrimary');\n575:         expect(photo).toHaveProperty('sortOrder');\n576:       }\n577:     });\n578: \n579:     it('should return 400 when no file provided', async () => {\n580:       await request(app.getHttpServer())\n581:         .post(`/api/properties/${property.id}/photos`)\n582:         .set(authHeader(adminToken))\n583:         .expect(400);\n584:     });\n585: \n586:     it('should return 401 when not authenticated', async () => {\n587:       await request(app.getHttpServer())\n588:         .post(`/api/properties/${property.id}/photos`)\n589:         .attach('files', Buffer.from('fake'), 'test.jpg')\n590:         .expect(401);\n591:     });\n592: \n593:     it('should return 403 when authenticated as renter', async () => {\n594:       await request(app.getHttpServer())\n595:         .post(`/api/properties/${property.id}/photos`)\n596:         .set(authHeader(renterToken))\n597:         .attach('files', Buffer.from('fake'), 'test.jpg')\n598:         .expect(403);\n599:     });\n600: \n601:     it('should return 404 when property not found', async () => {\n602:       await request(app.getHttpServer())\n603:         .post('/api/properties/00000000-0000-0000-0000-000000000000/photos')\n604:         .set(authHeader(adminToken))\n605:         .attach('files', Buffer.from('fake'), 'test.jpg')\n606:         .expect(404);\n607:     });\n608:   });\n609: \n610:   // ─── DELETE /properties/:id/photos/:photoId ────────────────────────\n611:   describe('DELETE /api/properties/:id/photos/:photoId', () => {\n612:     it('should return 200 when photo deleted (admin only)', async () => {\n613:       // This test requires a photo to exist first.\n614:       // In GREEN phase: upload a photo, then delete it.\n615:       // For RED phase, test the auth/validation contract.\n616:       const photoId = '00000000-0000-0000-0000-000000000001';\n617:       const propertyId = '00000000-0000-0000-0000-000000000002';\n618: \n619:       // Will 404 because neither photo nor property exists in RED phase\n620:       await request(app.getHttpServer())\n621:     