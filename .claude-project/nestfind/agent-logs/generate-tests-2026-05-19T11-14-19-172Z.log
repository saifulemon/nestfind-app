wait closeTestApp({ app, module });\n37:   });\n38: \n39:   beforeEach(async () => {\n40:     await cleanDatabase(dataSource);\n41:     const seededUsers = await seedTestUsers(dataSource);\n42:     adminUser = seededUsers.admin;\n43:     renterUser = seededUsers.renter;\n44:     adminToken = generateAccessToken(adminUser);\n45:     renterToken = generateAccessToken(renterUser);\n46: \n47:     const seededProps = await seedTestProperties(dataSource);\n48:     property = seededProps.downtownApt;\n49:   });\n50: \n51:   // ─── POST /properties/:id/inquiries (Submit) ────────────────────\n52:   describe('POST /api/properties/:id/inquiries', () => {\n53:     const validBody = {\n54:       message: 'I am interested in this property. Is it still available?',\n55:     };\n56: \n57:     it('should return 201 with inquiry data (renter only)', async () => {\n58:       const res = await request(app.getHttpServer())\n59:         .post(`/api/properties/${property.id}/inquiries`)\n60:         .set(authHeader(renterToken))\n61:         .send(validBody)\n62:         .expect(201);\n63: \n64:       expect(res.body.success).toBe(true);\n65:       expect(res.body.statusCode).toBe(201);\n66:       expect(res.body.message).toBe('Inquiry submitted successfully');\n67:       expect(res.body.data).toHaveProperty('id');\n68:       expect(res.body.data).toHaveProperty('propertyId');\n69:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n70:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n71:       expect(res.body.data).toHaveProperty('phone');\n72:       expect(res.body.data).toHaveProperty('message', validBody.message);\n73:       expect(res.body.data).toHaveProperty('status', 'new');\n74:       expect(res.body.data).toHaveProperty('response', null);\n75:       expect(res.body.data).toHaveProperty('respondedAt', null);\n76:       expect(res.body.data).toHaveProperty('createdAt');\n77:     });\n78: \n79:     it('should denormalize user profile data into the inquiry', async () => {\n80:       const res = await request(app.getHttpServer())\n81:         .post(`/api/properties/${property.id}/inquiries`)\n82:         .set(authHeader(renterToken))\n83:         .send(validBody)\n84:         .expect(201);\n85: \n86:       expect(res.body.data.name).toBe(renterUser.name);\n87:       expect(res.body.data.email).toBe(renterUser.email);\n88:     });\n89: \n90:     it('should allow overriding name, email, phone in request body', async () => {\n91:       const res = await request(app.getHttpServer())\n92:         .post(`/api/properties/${property.id}/inquiries`)\n93:         .set(authHeader(renterToken))\n94:         .send({\n95:           ...validBody,\n96:           name: 'Custom Name',\n97:           email: 'custom@example.com',\n98:           phone: '+15559999999',\n99:         })\n100:         .expect(201);\n101: \n102:       expect(res.body.data.name).toBe('Custom Name');\n103:       expect(res.body.data.email).toBe('custom@example.com');\n104:       expect(res.body.data.phone).toBe('+15559999999');\n105:     });\n106: \n107:     it('should return 400 when message is missing', async () => {\n108:       await request(app.getHttpServer())\n109:         .post(`/api/properties/${property.id}/inquiries`)\n110:         .set(authHeader(renterToken))\n111:         .send({})\n112:         .expect(400);\n113:     });\n114: \n115:     it('should return 400 when message is too short (< 10 chars)', async () => {\n116:       await request(app.getHttpServer())\n117:         .post(`/api/properties/${property.id}/inquiries`)\n118:         .set(authHeader(renterToken))\n119:         .send({ message: 'Short' })\n120:         .expect(400);\n121:     });\n122: \n123:     it('should return 400 when message is too long (> 2000 chars)', async () => {\n124:       await request(app.getHttpServer())\n125:         .post(`/api/properties/${property.id}/inquiries`)\n126:         .set(authHeader(renterToken))\n127:         .send({ message: 'X'.repeat(2001) })\n128:         .expect(400);\n129:     });\n130: \n131:     it('should return 400 for invalid property UUID', async () => {\n132:       await request(app.getHttpServer())\n133:         .post('/api/properties/not-a-uuid/inquiries')\n134:         .set(authHeader(renterToken))\n135:         .send(validBody)\n136:         .expect(400);\n137:     });\n138: \n139:     it('should return 401 when not authenticated', async () => {\n140:       await request(app.getHttpServer())\n141:         .post(`/api/properties/${property.id}/inquiries`)\n142:         .send(validBody)\n143:         .expect(401);\n144:     });\n145: \n146:     it('should return 403 when authenticated as admin (renter only)', async () => {\n147:       await request(app.getHttpServer())\n148:         .post(`/api/properties/${property.id}/inquiries`)\n149:         .set(authHeader(adminToken))\n150:         .send(validBody)\n151:         .expect(403);\n152:     });\n153: \n154:     it('should return 404 when property not found', async () => {\n155:       await request(app.getHttpServer())\n156:         .post('/api/properties/00000000-0000-0000-0000-000000000000/inquiries')\n157:         .set(authHeader(renterToken))\n158:         .send(validBody)\n159:         .expect(404);\n160:     });\n161:   });\n162: \n163:   // ─── GET /inquiries (List All - Admin) ────────────────────────────\n164:   describe('GET /api/inquiries', () => {\n165:     beforeEach(async () => {\n166:       // Submit an inquiry so the list is not empty\n167:       await request(app.getHttpServer())\n168:         .post(`/api/properties/${property.id}/inquiries`)\n169:         .set(authHeader(renterToken))\n170:         .send({ message: 'Test inquiry for listing.' })\n171:         .expect(201);\n172:     });\n173: \n174:     it('should return 200 with paginated inquiries list (admin only)', async () => {\n175:       const res = await request(app.getHttpServer())\n176:         .get('/api/inquiries')\n177:         .set(authHeader(adminToken))\n178:         .expect(200);\n179: \n180:       expect(res.body.success).toBe(true);\n181:       expect(res.body.statusCode).toBe(200);\n182:       expect(res.body.message).toBe('Inquiries retrieved successfully');\n183:       expect(res.body.data).toHaveProperty('items');\n184:       expect(res.body.data).toHaveProperty('meta');\n185:       expect(res.body.data.meta).toHaveProperty('total');\n186:       expect(res.body.data.meta).toHaveProperty('page');\n187:       expect(res.body.data.meta).toHaveProperty('limit');\n188:       expect(res.body.data.meta).toHaveProperty('totalPages');\n189:       expect(Array.isArray(res.body.data.items)).toBe(true);\n190:     });\n191: \n192:     it('should return inquiry items with correct shape', async () => {\n193:       const res = await request(app.getHttpServer())\n194:         .get('/api/inquiries')\n195:         .set(authHeader(adminToken))\n196:         .expect(200);\n197: \n198:       if (res.body.data.items.length > 0) {\n199:         const item = res.body.data.items[0];\n200:         expect(item).toHaveProperty('id');\n201:         expect(item).toHaveProperty('property');\n202:         expect(item.property).toHaveProperty('id');\n203:         expect(item.property).toHaveProperty('title');\n204:         expect(item).toHaveProperty('renter');\n205:         expect(item.renter).toHaveProperty('id');\n206:         expect(item.renter).toHaveProperty('name');\n207:         expect(item.renter).toHaveProperty('email');\n208:         expect(item).toHaveProperty('name');\n209:         expect(item).toHaveProperty('email');\n210:         expect(item).toHaveProperty('phone');\n211:         expect(item).toHaveProperty('message');\n212:         expect(item).toHaveProperty('status');\n213:         expect(item).toHaveProperty('response');\n214:         expect(item).toHaveProperty('respondedAt');\n215:         expect(item).toHaveProperty('createdAt');\n216:         expect(item).toHaveProperty('updatedAt');\n217:       }\n218:     });\n219: \n220:     it('should support filtering by status', async () => {\n221:       const res = await request(app.getHttpServer())\n222:         .get('/api/inquiries?status=new')\n223:         .set(authHeader(adminToken))\n224:         .expect(200);\n225: \n226:       for (const item of res.body.data.items) {\n227:         expect(item.status).toBe('new');\n228:       }\n229:     });\n230: \n231:     it('should support filtering by propertyId', async () => {\n232:       const res = await request(app.getHttpServer())\n233:         .get(`/api/inquiries?propertyId=${property.id}`)\n234:         .set(authHeader(adminToken))\n235:         .expect(200);\n236: \n237:       for (const item of res.body.data.items) {\n238:         expect(item.property.id).toBe(property.id);\n239:       }\n240:     });\n241: \n242:     it('should support search by name or email', async () => {\n243:       await request(app.getHttpServer())\n244:         .get(`/api/inquiries?search=${encodeURIComponent(renterUser.name)}`)\n245:         .set(authHeader(adminToken))\n246:         .expect(200);\n247:     });\n248: \n249:     it('should support sorting', async () => {\n250:       const res = await request(app.getHttpServer())\n251:         .get('/api/inquiries?sortBy=newest')\n252:         .set(authHeader(adminToken))\n253:         .expect(200);\n254: \n255:       expect(res.body.success).toBe(true);\n256:     });\n257: \n258:     it('should support pagination', async () => {\n259:       const res = await request(app.getHttpServer())\n260:         .get('/api/inquiries?page=1&limit=10')\n261:         .set(authHeader(adminToken))\n262:         .expect(200);\n263: \n264:       expect(res.body.data.meta.page).toBe(1);\n265:       expect(res.body.data.meta.limit).toBe(10);\n266:     });\n267: \n268:     it('should return 401 when not authenticated', async () => {\n269:       await request(app.getHttpServer())\n270:         .get('/api/inquiries')\n271:         .expect(401);\n272:     });\n273: \n274:    