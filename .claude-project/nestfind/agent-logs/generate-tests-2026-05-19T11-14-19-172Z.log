terToken = generateAccessToken(seeded.renter);\n39:   });\n40: \n41:   // ─── GET /admin/dashboard ──────────────────────────────────────────\n42:   describe('GET /api/admin/dashboard', () => {\n43:     beforeEach(async () => {\n44:       await seedTestProperties(dataSource);\n45:     });\n46: \n47:     it('should return 200 with dashboard statistics (admin only)', async () => {\n48:       const res = await request(app.getHttpServer())\n49:         .get('/api/admin/dashboard')\n50:         .set(authHeader(adminToken))\n51:         .expect(200);\n52: \n53:       expect(res.body.success).toBe(true);\n54:       expect(res.body.statusCode).toBe(200);\n55:       expect(res.body.message).toBe('Dashboard statistics retrieved');\n56:       expect(res.body.data).toHaveProperty('totalProperties');\n57:       expect(res.body.data).toHaveProperty('totalInquiries');\n58:       expect(res.body.data).toHaveProperty('newInquiries');\n59:       expect(res.body.data).toHaveProperty('totalUsers');\n60:       expect(res.body.data).toHaveProperty('recentInquiries');\n61:       expect(res.body.data).toHaveProperty('recentProperties');\n62:       expect(res.body).toHaveProperty('timestamp');\n63:       expect(res.body).toHaveProperty('path', '/api/admin/dashboard');\n64:     });\n65: \n66:     it('should return non-negative integer values for aggregate counts', async () => {\n67:       const res = await request(app.getHttpServer())\n68:         .get('/api/admin/dashboard')\n69:         .set(authHeader(adminToken))\n70:         .expect(200);\n71: \n72:       expect(typeof res.body.data.totalProperties).toBe('number');\n73:       expect(res.body.data.totalProperties).toBeGreaterThanOrEqual(0);\n74:       expect(typeof res.body.data.totalInquiries).toBe('number');\n75:       expect(res.body.data.totalInquiries).toBeGreaterThanOrEqual(0);\n76:       expect(typeof res.body.data.newInquiries).toBe('number');\n77:       expect(res.body.data.newInquiries).toBeGreaterThanOrEqual(0);\n78:       expect(typeof res.body.data.totalUsers).toBe('number');\n79:       expect(res.body.data.totalUsers).toBeGreaterThanOrEqual(0);\n80:     });\n81: \n82:     it('should return count matching seeded properties', async () => {\n83:       const res = await request(app.getHttpServer())\n84:         .get('/api/admin/dashboard')\n85:         .set(authHeader(adminToken))\n86:         .expect(200);\n87: \n88:       // 3 properties seeded via seedTestProperties\n89:       expect(res.body.data.totalProperties).toBe(3);\n90:     });\n91: \n92:     it('should return recent properties as an array', async () => {\n93:       const res = await request(app.getHttpServer())\n94:         .get('/api/admin/dashboard')\n95:         .set(authHeader(adminToken))\n96:         .expect(200);\n97: \n98:       expect(Array.isArray(res.body.data.recentProperties)).toBe(true);\n99:       if (res.body.data.recentProperties.length > 0) {\n100:         const item = res.body.data.recentProperties[0];\n101:         expect(item).toHaveProperty('id');\n102:         expect(item).toHaveProperty('title');\n103:         expect(item).toHaveProperty('price');\n104:         expect(item).toHaveProperty('propertyType');\n105:         expect(item).toHaveProperty('createdAt');\n106:       }\n107:     });\n108: \n109:     it('should return recent inquiries as an array (empty if none)', async () => {\n110:       const res = await request(app.getHttpServer())\n111:         .get('/api/admin/dashboard')\n112:         .set(authHeader(adminToken))\n113:         .expect(200);\n114: \n115:       expect(Array.isArray(res.body.data.recentInquiries)).toBe(true);\n116:       if (res.body.data.recentInquiries.length > 0) {\n117:         const item = res.body.data.recentInquiries[0];\n118:         expect(item).toHaveProperty('id');\n119:         expect(item).toHaveProperty('name');\n120:         expect(item).toHaveProperty('email');\n121:         expect(item).toHaveProperty('propertyTitle');\n122:         expect(item).toHaveProperty('status');\n123:         expect(item).toHaveProperty('createdAt');\n124:       }\n125:     });\n126: \n127:     it('should return 0 for counts when database is empty', async () => {\n128:       // beforeEach cleaned the DB, but this test doesn't seed properties\n129:       // We need to ensure clean state\n130:       await cleanDatabase(dataSource);\n131:       const seeded = await seedTestUsers(dataSource);\n132:       const cleanAdminToken = generateAccessToken(seeded.admin);\n133: \n134:       const res = await request(app.getHttpServer())\n135:         .get('/api/admin/dashboard')\n136:         .set(authHeader(cleanAdminToken))\n137:         .expect(200);\n138: \n139:       expect(res.body.data.totalProperties).toBe(0);\n140:       expect(res.body.data.totalInquiries).toBe(0);\n141:       expect(res.body.data.newInquiries).toBe(0);\n142:     });\n143: \n144:     it('should return 401 when not authenticated', async () => {\n145:       await request(app.getHttpServer())\n146:         .get('/api/admin/dashboard')\n147:         .expect(401);\n148:     });\n149: \n150:     it('should return 401 with invalid token', async () => {\n151:       await request(app.getHttpServer())\n152:         .get('/api/admin/dashboard')\n153:         .set(authHeader('invalid-token'))\n154:         .expect(401);\n155:     });\n156: \n157:     it('should return 403 when authenticated as renter (admin only)', async () => {\n158:       await request(app.getHttpServer())\n159:         .get('/api/admin/dashboard')\n160:         .set(authHeader(renterToken))\n161:         .expect(403);\n162:     });\n163:   });\n164: });\n\n(End of file - total 164 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/tes