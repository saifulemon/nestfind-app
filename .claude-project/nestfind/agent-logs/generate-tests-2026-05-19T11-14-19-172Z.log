odule });\n44:   });\n45: \n46:   beforeEach(async () => {\n47:     await cleanDatabase(dataSource);\n48:   });\n49: \n50:   // ─── POST /auth/register ───────────────────────────────────────────\n51:   describe('POST /api/auth/register', () => {\n52:     const validBody = {\n53:       name: 'Jane Doe',\n54:       email: 'jane@example.com',\n55:       password: 'SecurePass123!',\n56:       phone: '+15551234567',\n57:     };\n58: \n59:     it('should return 201 with user data on successful registration', async () => {\n60:       const res = await request(app.getHttpServer())\n61:         .post('/api/auth/register')\n62:         .send(validBody)\n63:         .expect(201);\n64: \n65:       expect(res.body.success).toBe(true);\n66:       expect(res.body.statusCode).toBe(201);\n67:       expect(res.body.message).toBe('User registered successfully');\n68:       expect(res.body.data).toHaveProperty('id');\n69:       expect(res.body.data).toHaveProperty('name', 'Jane Doe');\n70:       expect(res.body.data).toHaveProperty('email', 'jane@example.com');\n71:       expect(res.body.data).toHaveProperty('role', 'renter');\n72:       expect(res.body.data).toHaveProperty('status', 'active');\n73:       expect(res.body.data).toHaveProperty('createdAt');\n74:       expect(res.body.data).toHaveProperty('updatedAt');\n75:       expect(res.body).toHaveProperty('timestamp');\n76:       expect(res.body).toHaveProperty('path', '/api/auth/register');\n77:       // Should not expose password\n78:       expect(res.body.data).not.toHaveProperty('password');\n79:     });\n80: \n81:     it('should return 201 without optional phone field', async () => {\n82:       const { phone, ...bodyWithoutPhone } = validBody;\n83:       const res = await request(app.getHttpServer())\n84:         .post('/api/auth/register')\n85:         .send(bodyWithoutPhone)\n86:         .expect(201);\n87: \n88:       expect(res.body.data.phone).toBeNull();\n89:     });\n90: \n91:     it('should return 400 when name is missing', async () => {\n92:       const { name, ...body } = validBody;\n93:       await request(app.getHttpServer())\n94:         .post('/api/auth/register')\n95:         .send(body)\n96:         .expect(400);\n97:     });\n98: \n99:     it('should return 400 when name is too short (< 2 chars)', async () => {\n100:       await request(app.getHttpServer())\n101:         .post('/api/auth/register')\n102:         .send({ ...validBody, name: 'A' })\n103:         .expect(400);\n104:     });\n105: \n106:     it('should return 400 when name is too long (> 100 chars)', async () => {\n107:       await request(app.getHttpServer())\n108:         .post('/api/auth/register')\n109:         .send({ ...validBody, name: 'A'.repeat(101) })\n110:         .expect(400);\n111:     });\n112: \n113:     it('should return 400 when email is missing', async () => {\n114:       const { email, ...body } = validBody;\n115:       await request(app.getHttpServer())\n116:         .post('/api/auth/register')\n117:         .send(body)\n118:         .expect(400);\n119:     });\n120: \n121:     it('should return 400 when email is invalid format', async () => {\n122:       await request(app.getHttpServer())\n123:         .post('/api/auth/register')\n124:         .send({ ...validBody, email: 'not-an-email' })\n125:         .expect(400);\n126:     });\n127: \n128:     it('should return 400 when password is missing', async () => {\n129:       const { password, ...body } = validBody;\n130:       await request(app.getHttpServer())\n131:         .post('/api/auth/register')\n132:         .send(body)\n133:         .expect(400);\n134:     });\n135: \n136:     it('should return 400 when password is too short (< 8 chars)', async () => {\n137:       await request(app.getHttpServer())\n138:         .post('/api/auth/register')\n139:         .send({ ...validBody, password: 'Short1!' })\n140:         .expect(400);\n141:     });\n142: \n143:     it('should return 400 when phone exceeds max length (> 20 chars)', async () => {\n144:       await request(app.getHttpServer())\n145:         .post('/api/auth/register')\n146:         .send({ ...validBody, phone: '+1'.repeat(11) })\n147:         .expect(400);\n148:     });\n149: \n150:     it('should return 409 when email is already registered', async () => {\n151:       await createTestUser(dataSource, testUsers.renter);\n152:       await request(app.getHttpServer())\n153:         .post('/api/auth/register')\n154:         .send({ ...validBody, email: testUsers.renter.email })\n155:         .expect(409);\n156:     });\n157:   });\n158: \n159:   // ─── POST /auth/login ──────────────────────────────────────────────\n160:   describe('POST /api/auth/login', () => {\n161:     let testUser: User;\n162: \n163:     beforeEach(async () => {\n164:       testUser = await createTestUser(dataSource, testUsers.renter);\n165:     });\n166: \n167:     const validCredentials = {\n168:       email: testUsers.renter.email,\n169:       password: TEST_PASSWORD,\n170:     };\n171: \n172:     it('should return 200 with user data on successful login', async () => {\n173:       const res = await request(app.getHttpServer())\n174:         .post('/api/auth/login')\n175:         .send(validCredentials)\n176:         .expect(200);\n177: \n178:       expect(res.body.success).toBe(true);\n179:       expect(res.body.statusCode).toBe(200);\n180:       expect(res.body.message).toBe('Login successful');\n181:       expect(res.body.data).toHaveProperty('user');\n182:       expect(res.body.data.user).toHaveProperty('id');\n183:       expect(res.body.data.user).toHaveProperty('name');\n184:       expect(res.body.data.user).toHaveProperty('email');\n185:       expect(res.body.data.user).toHaveProperty('role');\n186:       expect(res.body.data.user).toHaveProperty('status');\n187:       expect(res.body.data.user).not.toHaveProperty('password');\n188:       expect(res.body).toHaveProperty('timestamp');\n189:       expect(res.body).toHaveProperty('path', '/api/auth/login');\n190:     });\n191: \n192:     it('should set access_token and refresh_token httpOnly cookies', async () => {\n193:       const res = await request(app.getHttpServer())\n194:         .post('/api/auth/login')\n195:         .send(validCredentials)\n196:         .expect(200);\n197: \n198:       const cookies = res.headers['set-cookie'];\n199:       expect(cookies).toBeDefined();\n200:       const cookieStr = Array.isArray(cookies) ? cookies.join('; ') : cookies;\n201:       expect(cookieStr).toContain('access_token');\n202:       expect(cookieStr).toContain('refresh_token');\n203:     });\n204: \n205:     it('should return 400 when email is missing', async () => {\n206:       await request(app.getHttpServer())\n207:         .post('/api/auth/login')\n208:         .send({ password: TEST_PASSWORD })\n209:         .expect(400);\n210:     });\n211: \n212:     it('should return 400 when password is missing', async () => {\n213:       await request(app.getHttpServer())\n214:         .post('/api/auth/login')\n215:         .send({ email: testUsers.renter.email })\n216:         .expect(400);\n217:     });\n218: \n219:     it('should return 401 with invalid email', async () => {\n220:       await request(app.getHttpServer())\n221:         .post('/api/auth/login')\n222:         .send({ email: 'wrong@test.com', password: TEST_PASSWORD })\n223:         .expect(401);\n224:     });\n225: \n226:     it('should return 401 with invalid password', async () => {\n227:       await request(app.getHttpServer())\n228:         .post('/api/auth/login')\n229:         .send({ email: testUsers.renter.email, password: 'WrongPass1!' })\n230:         .expect(401);\n231:     });\n232: \n233:     it('should return 403 when account is suspended', async () => {\n234:       const suspended = await createTestUser(dataSource, testUsers.suspendedRenter);\n235:       await request(app.getHttpServer())\n236:         .post('/api/auth/login')\n237:         .send({ email: suspended.email, password: TEST_PASSWORD })\n238:         .expect(403);\n239:     });\n240:   });\n241: \n242:   // ─── POST /auth/logout ─────────────────────────────────────────────\n243:   describe('POST /api/auth/logout', () => {\n244:     it('should return 200 and clear cookies on successful logout', async () => {\n245:       const user = await createTestUser(dataSource, testUsers.renter);\n246:       const token = generateAccessToken(user);\n247: \n248:       const res = await request(app.getHttpServer())\n249:         .post('/api/auth/logout')\n250:         .set(authHeader(token))\n251:         .expect(200);\n252: \n253:       expect(res.body.success).toBe(true);\n254:       expect(res.body.statusCode).toBe(200);\n255:       expect(res.body.message).toBe('Logged out successfully');\n256:       expect(res.body.data).toBeNull();\n257:       expect(res.body).toHaveProperty('timestamp');\n258:       expect(res.body).toHaveProperty('path', '/api/auth/logout');\n259: \n260:       // Cookies should be cleared\n261:       const cookies = res.headers['set-cookie'];\n262:       expect(cookies).toBeDefined();\n263:     });\n264: \n265:     it('should return 401 when not authenticated', async () => {\n266:       await request(app.getHttpServer())\n267:         .post('/api/auth/logout')\n268:         .expect(401);\n269:     });\n270: \n271:     it('should return 401 with invalid token', async () => {\n272:       await request(app.getHttpServer())\n273:         .post('/api/auth/logout')\n274:         .set(authHeader('invalid-token'))\n275:         .expect(401);\n276:     });\n277:   });\n278: \n279:   // ─── POST /auth/refresh ────────────────────────────────────────────\n280:   describe('POST /api/auth/refresh', () => {\n281:     it('should return 200 with new tokens on successful refresh', async () => {\n282:       const user = await createTestUser(dataSource, testUsers.renter);\n283:       const refreshToken = generateRefreshToken(user);\n284: \n285:       const res = await request(app.getHttpServer())\n286:         .post('/api/auth/refresh')\n287:         .set(refreshCookieHeader(refreshToken))\n288:         .expect(200);\n289: \n290:       expect(res.body.success).toBe(true);\n291:       expect(res.body.statusCode).toBe(200);\n292:       expect(res.body.message).toBe('Token refreshed successfully');\n293:       expect(res.body.data).toHaveProperty('user');\n294:       expect(res.body.data.user).toHaveProperty('id', user.id);\n295:       expect(res.body.data.user).toHaveProperty('name');\n296:       expect(res.body.data.user).toHaveProperty('email');\n297:       expect(res.body.data.user).toHaveProperty('role');\n298:       expect(res.body.data.user).not.toHaveProperty('password');\n299:     });\n300: \n301:     it('should return 401 when no refresh token cookie provided', async () => {\n302:       await request(app.getHttpServer())\n303:         .post('/api/auth/refresh')\n304:         .expect(401);\n305:     });\n306: \n307:     it('should return 401 with invalid refresh token', async () => {\n308:       await request(app.getHttpServer())\n309:         .post('/api/auth/refresh')\n310:         .set(refreshCookieHeader('invalid-refresh-token'))\n311:         .expect(401);\n312:     });\n313: \n314:     it('should return 401 with revoked refresh token', async () => {\n315:       const user = await createTestUser(dataSource, testUsers.renter);\n316:       const refreshToken = generateRefreshToken(user);\n317: \n318:       // First refresh rotates the token (revokes old one)\n319:       await request(app.getHttpServer())\n320:         .post('/api/auth/refresh')\n321:         .set(refreshCookieHeader(refreshToken))\n322:         .expect(200);\n323: \n324:       // Second refresh with same (now revoked) token should fail\n325:       await request(app.getHttpServer())\n326:         .post('/api/auth/refresh')\n327:         .set(refreshCookieHeader(refreshToken))\n328:         .expect(401);\n329:     });\n330:   });\n331: \n332:   // ─── POST /auth/forgot-password ────────────────────────────────────\n333:   describe('POST /api/auth/forgot-password', () => {\n334:     it('should return 200 even for unknown email (prevents enumeration)', async () => {\n335:       const res = await request(app.getHttpServer())\n336:         .post('/api/auth/forgot-password')\n337:         .send({ email: 'unknown@test.com' })\n338:         .expect(200);\n339: \n340:       expect(res.body.success).toBe(true);\n341:       expect(res.body.statusCode).toBe(200);\n342:       expect(res.body.message).toContain('If an account with that email exists');\n343:       expect(res.body.data).toBeNull();\n344:     });\n345: \n346:     it('should return 200 for existing user email', async () => {\n347:       await createTestUser(dataSource, testUsers.renter);\n348: \n349:       const res = await request(app.getHttpServer())\n350:         .post('/api/auth/forgot-password')\n351:         .send({ email: testUsers.renter.email })\n352:         .expect(200);\n353: \n354:       expect(res.body.success).toBe(true);\n355:       expect(res.body.statusCode).toBe(200);\n356:       expect(res.body.data).toBeNull();\n357:     });\n358: \n359:     it('should return 400 when email is missing', async () => {\n360:       await request(app.getHttpServer())\n361:         .post('/api/auth/forgot-password')\n362:         .send({})\n363:         .expect(400);\n364:     });\n365: \n366:     it('should return 400 when email is invalid format', async () => {\n367:       await request(app.getHttpServer())\n368:         .post('/api/auth/forgot-password')\n369:         .send({ email: 'not-an-email' })\n370:         .expect(400);\n371:     });\n372:   });\n373: \n374:   // ─── POST /auth/reset-password ─────────────────────────────────────\n375:   describe('POST /api/auth/reset-password', () => {\n376:     let testUser: User;\n377: \n378:     beforeEach(async () => {\n379:       testUser = await createTestUser(dataSource, testUsers.renter);\n380:     });\n381: \n382:     it('should return 200 on successful password reset', async () => {\n383:       const resetToken = generatePasswordResetToken(testUser);\n384: \n385:       const res = await request(app.getHttpServer())\n386:         .post('/api/auth/reset-password')\n387:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n388:         .expect(200);\n389: \n390:       expect(res.body.success).toBe(true);\n391:       expect(res.body.statusCode).toBe(200);\n392:       expect(res.body.message).toBe('Password reset successfully');\n393:       expect(res.body.data).toBeNull();\n394:     });\n395: \n396:     it('should return 400 when token is missing', async () => {\n397:       await request(app.getHttpServer())\n398:         .post('/api/auth/reset-password')\n399:         .send({ password: 'NewSecurePass456!' })\n400:         .expect(400);\n401:     });\n402: \n403:     it('should return 400 when password is missing', async () => {\n404:       const resetToken = generatePasswordResetToken(testUser);\n405:       await request(app.getHttpServer())\n406:         .post('/api/auth/reset-password')\n407:         .send({ token: resetToken })\n408:         .expect(400);\n409:     });\n410: \n411:     it('should return 400 when password is too short (< 8 chars)', async () => {\n412:       const resetToken = generatePasswordResetToken(testUser);\n413:       await request(app.getHttpServer())\n414:         .post('/api/auth/reset-password')\n415:         .send({ token: resetToken, password: 'Short1!' })\n416:         .expect(400);\n417:     });\n418: \n419:     it('should return 404 when token is invalid/not found', async () => {\n420:       await request(app.getHttpServer())\n421:         .post('/api/auth/reset-password')\n422:         .send({ token: 'invalid-reset-token', password: 'NewSecurePass456!' })\n423:         .expect(404);\n424:     });\n425: \n426:     it('should return 400 when token is expired', async () => {\n427:       // Token expiry is handled by the implementation;\n428:       // tests will need DB-level token manipulation in GREEN phase\n429:       const resetToken = generatePasswordResetToken(testUser);\n430:       // In GREEN phase, manually set expiresAt to the past\n431:       await request(app.getHttpServer())\n432:         .post('/api/auth/reset-password')\n433:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n434:         .expect(200);\n435:       // NOTE: This test will need refinement in GREEN phase to\n436:       // create an expired PasswordResetToken in the database\n437:     });\n438:   });\n439: \n440:   // ─── GET /auth/me ─────────────────────────────────────────────────\n441:   describe('GET /api/auth/me', () => {\n442:     it('should return 200 with current user profile', async () => {\n443:       const user = await createTestUser(dataSource, testUsers.renter);\n444:       const token = generateAccessToken(user);\n445: \n446:       const res = await request(app.getHttpServer())\n447:         .get('/api/auth/me')\n448:         .set(authHeader(token))\n449:         .expect(200);\n450: \n451:       expect(res.body.success).toBe(true);\n452:       expect(res.body.statusCode).toBe(200);\n453:       expect(res.body.message).toBe('User retrieved successfully');\n454:       expect(res.body.data).toHaveProperty('id', user.id);\n455:       expect(res.body.data).toHaveProperty('name', user.name);\n456:       expect(res.body.data).toHaveProperty('email', user.email);\n457:       expect(res.body.data).toHaveProperty('role', user.role);\n458:       expect(res.body.data).toHaveProperty('status', user.status);\n459:       expect(res.body.data).toHaveProperty('emailVerifiedAt');\n460:       expect(res.body.data).toHaveProperty('createdAt');\n461:       expect(res.body.data).toHaveProperty('updatedAt');\n462:       expect(res.body.data).not.toHaveProperty('password');\n463:     });\n464: \n465:     it('should return 401 when not authenticated', async () => {\n466:       await request(app.getHttpServer())\n467:         .get('/api/auth/me')\n468:         .expect(401);\n469:     });\n470: \n471:     it('should return 401 with invalid token', async () => {\n472:       await request(app.getHttpServer())\n473:         .get('/api/auth/me')\n474:         .set(authHeader('invalid-token'))\n475:         .expect(401);\n476:     });\n477: \n478:     it('should return correct role for admin user', async () => {\n479:       const admin = await createTestUser(dataSource, testUsers.admin);\n480:       const token = generateAccessToken(admin);\n481: \n482:       const res = await request(app.getHttpServer())\n483:         .get('/api/auth/me')\n484:         .set(authHeader(token))\n485:         .expect(200);\n486: \n487:       expect(res.body.data.role).toBe('admin');\n488:     });\n489:   });\n490: });\n\n(End of file - total 490 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport {\n  createTestUser,\n  seedTestUsers,\n  testUsers,\n  TEST_PASSWORD,\n  TestUserData,\n} from '../fixtures/user.fixture';\nimport {\n  generateAccessToken,\n  generateRefreshToken,\n  generatePasswordResetToken,\n  authHeader,\n  refreshCookieHeader,","truncated":false,"loaded":[]},"title":"backend/test/e2e/auth.e2e-spec.ts","time":{"start":1779189601935,"end":1779189602295}},"id":"prt_e3ff6d12c001QaWvhYZp5PL587","sessionID":"ses_1c00e5fd8ffeVx140qy7L9eaMz","messageID":"msg_e3ff682a60013LLiGdKLZpRTuu"}}
