odule;\n43:     dataSource = getDataSource(module);\n44:   });\n45: \n46:   afterAll(async () => {\n47:     await closeTestApp({ app, module });\n48:   });\n49: \n50:   beforeEach(async () => {\n51:     await cleanDatabase(dataSource);\n52:     const seeded = await seedTestUsers(dataSource);\n53:     adminUser = seeded.admin;\n54:     renterUser = seeded.renter;\n55:     adminToken = generateAccessToken(adminUser);\n56:     renterToken = generateAccessToken(renterUser);\n57:     await seedTestAmenities(dataSource);\n58:   });\n59: \n60:   // ─── GET /properties (Search) ──────────────────────────────────────\n61:   describe('GET /api/properties', () => {\n62:     beforeEach(async () => {\n63:       await seedTestProperties(dataSource);\n64:     });\n65: \n66:     it('should return 200 with paginated property list', async () => {\n67:       const res = await request(app.getHttpServer())\n68:         .get('/api/properties')\n69:         .expect(200);\n70: \n71:       expect(res.body.success).toBe(true);\n72:       expect(res.body.statusCode).toBe(200);\n73:       expect(res.body.message).toBe('Properties retrieved successfully');\n74:       expect(res.body.data).toHaveProperty('items');\n75:       expect(res.body.data).toHaveProperty('meta');\n76:       expect(res.body.data.meta).toHaveProperty('total');\n77:       expect(res.body.data.meta).toHaveProperty('page', 1);\n78:       expect(res.body.data.meta).toHaveProperty('limit');\n79:       expect(res.body.data.meta).toHaveProperty('totalPages');\n80:       expect(Array.isArray(res.body.data.items)).toBe(true);\n81:     });\n82: \n83:     it('should return property items with correct shape', async () => {\n84:       const res = await request(app.getHttpServer())\n85:         .get('/api/properties')\n86:         .expect(200);\n87: \n88:       if (res.body.data.items.length > 0) {\n89:         const item = res.body.data.items[0];\n90:         expect(item).toHaveProperty('id');\n91:         expect(item).toHaveProperty('t