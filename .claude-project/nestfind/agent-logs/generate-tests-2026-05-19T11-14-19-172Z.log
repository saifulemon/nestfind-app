s.body.data).toHaveProperty('squareFeet');\n238:       expect(res.body.data).toHaveProperty('propertyType');\n239:       expect(res.body.data).toHaveProperty('address');\n240:       expect(res.body.data.address).toHaveProperty('street');\n241:       expect(res.body.data.address).toHaveProperty('city');\n242:       expect(res.body.data.address).toHaveProperty('state');\n243:       expect(res.body.data.address).toHaveProperty('zipCode');\n244:       expect(res.body.data).toHaveProperty('availableFrom');\n245:       expect(res.body.data).toHaveProperty('photos');\n246:       expect(res.body.data).toHaveProperty('amenities');\n247:       expect(res.body.data).toHaveProperty('isFavorited');\n248:       expect(res.body.data).toHaveProperty('createdAt');\n249:       expect(res.body.data).toHaveProperty('updatedAt');\n250:     });\n251: \n252:     it('should be accessible without authentication (public)', async () => {\n253:       await request(app.getHttpServer())\n254:         .get(`/api/properties/${property.id}`)\n255:         .expect(200);\n256:     });\n257: \n258:     it('should return 400 for invalid UUID format', async () => {\n259:       await request(app.getHttpServer())\n260:         .get('/api/properties/not-a-uuid')\n261:         .expect(400);\n262:     });\n263: \n264:     it('should return 404 for non-existent property', async () => {\n265:       await request(app.getHttpServer())\n266:         .get('/api/properties/00000000-0000-0000-0000-000000000000')\n267:         .expect(404);\n268:     });\n269: \n270:     it('should return 404 for archived property', async () => {\n271:       // In GREEN phase: archive the property first, then verify 404\n272:       // For now, this tests the general 404 path\n273:       await request(app.getHttpServer())\n274:         .get(`/api/properties/${property.id}`)\n275:         .expect(200);\n276:       // NOTE: Full archive-then-404 test needs property archive implementation\n277:     });\n278: \n279:     it('should return isFavorited=false for unauthenticated user', async () => {\n280:       const res = await request(app.getHttpServer())\n281:         .get(`/api/properties/${property.id}`)\n282:         .expect(200);\n283: \n284:       expect(res.body.data.isFavorited).toBe(false);\n285:     });\n286:   });\n287: \n288:   // ─── POST /properties (Create) ─────────────────────────────────────\n289:   describe('POST /api/properties', () => {\n290:     const validBody = {\n291:       title: 'New Test Property',\n292:       description: 'A newly created test property for e2e testing purposes.',\n293:       price: 1800.0,\n294:       bedrooms: 2,\n295:       bathrooms: 1,\n296:       squareFeet: 850,\n297:       propertyType: 'condo',\n298:       address: {\n299:         street: '100 Test Blvd',\n300:         city: 'San Francisco',\n301:         state: 'CA',\n302:         zipCode: '94105',\n303:         latitude: 37.774929,\n304:         longitude: -122.419418,\n305:       },\n306:       availableFrom: '2026-08-01',\n307:       amenityIds: [],\n308:     };\n309: \n310:     it('should return 201 with created property (admin only)', async () => {\n311:       const res = await request(app.getHttpServer())\n312:         .post('/api/properties')\n313:         .set(authHeader(adminToken))\n314:         .send(validBody)\n315:         .expect(201);\n316: \n317:       expect(res.body.success).toBe(true);\n318:       expect(res.body.statusCode).toBe(201);\n319:       expect(res.body.message).toBe('Property created successfully');\n320:       expect(res.body.data).toHaveProperty('id');\n321:       expect(res.body.data).toHaveProperty('title', 'New Test Property');\n322:       expect(res.body.data).toHaveProperty('price', 1800);\n323:       expect(res.body.data).toHaveProperty('address');\n324:       expect(res.body.data.address).toHaveProperty('city', 'San Francisco');\n325:       expect(res.body.data).toHaveProperty('photos');\n326:       expect(res.body.data).toHaveProperty('amenities');\n327:       expect(res.body.data).toHaveProperty('createdAt');\n328:       expect(res.body.data).toHaveProperty('updatedAt');\n329:     });\n330: \n331:     it('should return 400 when title is missing', async () => {\n332:       const { title, ...body } = validBody;\n333:       await request(app.getHttpServer())\n334:         .post('/api/properties')\n335:         .set(authHeader(adminToken))\n336:         .send(body)\n337:         .expect(400);\n338:     });\n339: \n340:     it('should return 400 when title is too short (< 5 chars)', async () => {\n341:       await request(app.getHttpServer())\n342:         .post('/api/properties')\n343:         .set(authHeader(adminToken))\n344:         .send({ ...validBody, title: 'AB' })\n345:         .expect(400);\n346:     });\n347: \n348:     it('should return 400 when description is too short (< 20 chars)', async () => {\n349:       await request(app.getHttpServer())\n350:         .post('/api/properties')\n351:         .set(authHeader(adminToken))\n352:         .send({ ...validBody, description: 'Short desc' })\n353:         .expect(400);\n354:     });\n355: \n356:     it('should return 400 when price is missing', async () => {\n357:       const { price, ...body } = validBody;\n358:       await request(app.getHttpServer())\n359:         .post('/api/properties')\n360:         .set(authHeader(adminToken))\n361:         .send(body)\n362:         .expect(400);\n363:     });\n364: \n365:     it('should return 400 when price is 0 or negative', async () => {\n366:       await request(app.getHttpServer())\n367:         .post('/api/properties')\n368:         .set(authHeader(adminToken))\n369:         .send({ ...validBody, price: 0 })\n370:         .expect(400);\n371:     });\n372: \n373:     it('should return 400 when bedrooms is negative', async () => {\n374:       await request(app.getHttpServer())\n375:         .post('/api/properties')\n376:         .set(authHeader(adminToken))\n377:         .send({ ...validBody, bedrooms: -1 })\n378:     