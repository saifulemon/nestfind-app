aSource);\n38:     adminToken = generateAccessToken(seeded.admin);\n39:     renterToken = generateAccessToken(seeded.renter);\n40:   });\n41: \n42:   // ─── GET /amenities (List) ─────────────────────────────────────────\n43:   describe('GET /api/amenities', () => {\n44:     beforeEach(async () => {\n45:       await seedTestAmenities(dataSource);\n46:     });\n47: \n48:     it('should return 200 with list of all amenities (public)', async () => {\n49:       const res = await request(app.getHttpServer())\n50:         .get('/api/amenities')\n51:         .expect(200);\n52: \n53:       expect(res.body.success).toBe(true);\n54:       expect(res.body.statusCode).toBe(200);\n55:       expect(res.body.message).toBe('Amenities retrieved successfully');\n56:       expect(Array.isArray(res.body.data)).toBe(true);\n57:       expect(res.body).toHaveProperty('timestamp');\n58:       expect(res.body).toHaveProperty('path', '/api/amenities');\n59:     });\n60: \n61:     it('should return amenity items with correct shape', async () => {\n62:       const res = await request(app.getHttpServer())\n63:         .get('/api/amenities')\n64:         .expect(200);\n65: \n66:       if (res.body.data.length > 0) {\n67:         const item = res.body.data[0];\n68:         expect(item).toHaveProperty('id');\n69:         expect(item).toHaveProperty('name');\n70:         expect(item).toHaveProperty('icon');\n71:       }\n72:     });\n73: \n74:     it('should be accessible without authentication', async () => {\n75:       await request(app.getHttpServer())\n76:         .get('/api/amenities')\n77:         .expect(200);\n78:     });\n79: \n80:     it('should return empty array when no amenities exist', async () => {\n81:       const res = await request(app.getHttpServer())\n82:         .get('/api/amenities')\n83:         .expect(200);\n84: \n85:       expect(res.body.data).toEqual([]);\n86:     });\n87: \n88:     it('should return all seeded amenities', async () => {\n89:       const res = await request(app.getHttpServer())\n90:         .get('/api/amenities')\n91:         .expect(200);\n92: \n93:       expect(res.body.data.length).toBe(4);\n94:       const names = res.body.data.map((a: any) => a.name);\n95:       expect(names).toContain('Parking');\n96:       expect(names).toContain('Gym');\n97:       expect(names).toContain('Pool');\n98:       expect(names).toContain('Pet Friendly');\n99:     });\n100:   });\n101: \n102:   // ─── POST /amenities (Create) ─────────────────────────────────────\n103:   describe('POST /api/amenities', () => {\n104:     const validBody = {\n105:       name: 'Rooftop Access',\n106:       icon: 'rooftop',\n107:     };\n108: \n109:     it('should return 201 with created amenity (admin only)', async () => {\n110:       const res = await request(app.getHttpServer())\n111:         .post('/api/amenities')\n112:         .set(authHeader(adminToken))\n113:         .send(validBody)\n114:         .expect(201);\n115: \n116:       expect(res.body.success).toBe(true);\n117:       expect(res.body.statusCode).toBe(201);\n118:       expect(res.body.message).toBe('Amenity created successfully');\n119:       expect(res.body.data).toHaveProperty('id');\n120:       expect(res.body.data).toHaveProperty('name', 'Rooftop Access');\n121:       expect(res.body.data).toHaveProperty('icon', 'rooftop');\n122:       expect(res.body.data).toHaveProperty('createdAt');\n123:       expect(res.body.data).toHaveProperty('updatedAt');\n124:       expect(res.body).toHaveProperty('timestamp');\n125:       expect(res.body).toHaveProperty('path', '/api/amenities');\n126:     });\n127: \n128:     it('should return 400 when name is missing', async () => {\n129:       await request(app.getHttpServer())\n130:         .post('/api/amenities')\n131:         .set(authHeader(adminToken))\n132:         .send({ icon: 'rooftop' })\n133:         .expect(400);\n134:     });\n135: \n136:     it('should return 400 when name is empty string', async () => {\n137:       await request(app.getHttpServer())\n138:         .post('/api/amenities')\n139:         .set(authHeader(adminToken))\n140:         .send({ name: '', icon: 'rooftop' })\n141:         .expect(400);\n142:     });\n143: \n144:     it('should return 400 when name exceeds 50 chars', async () => {\n145:       await request(app.getHttpServer())\n146:         .post('/api/amenities')\n147:         .set(authHeader(adminToken))\n148:         .send({ name: 'A'.repeat(51), icon: 'rooftop' })\n149:         .expect(400);\n150:     });\n151: \n152:     it('should return 400 when icon is missing', async () => {\n153:       await request(app.getHttpServer())\n154:         .post('/api/amenities')\n155:         .set(authHeader(adminToken))\n156:         .send({ name: 'Rooftop Access' })\n157:         .expect(400);\n158:     });\n159: \n160:     it('should return 400 when icon exceeds 50 chars', async () => {\n161:       await request(app.getHttpServer())\n162:         .post('/api/amenities')\n163:         .set(authHeader(adminToken))\n164:         .send({ name: 'Rooftop Access', icon: 'A'.repeat(51) })\n165:         .expect(400);\n166:     });\n167: \n168:     it('should return 401 when not authenticated', async () => {\n169:       await request(app.getHttpServer())\n170:         .post('/api/amenities')\n171:         .send(validBody)\n172:         .expect(401);\n173:     });\n174: \n175:     it('should return 403 when authenticated as renter (not admin)', async () => {\n176:       await request(app.getHttpServer())\n177:         .post('/api/amenities')\n178:         .set(authHeader(renterToken))\n179:         .send(validBody)\n180:         .expect(403);\n181:     });\n182: \n183:     it('should return 409 when amenity name already exists', async () => {\n184:       await seedTestAmenities(dataSource);\n185: \n186:       await request(app.getHttpServer())\n187:         .post('/api/amenities')\n188:         .set(authHeader(adminToken))\n189:         .send({ name: 'Parking', icon: 'parking-v2' })\n190:         .