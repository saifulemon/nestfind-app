dy.message).toBe('Property updated successfully');\n481:       expect(res.body.data).toHaveProperty('id', property.id);\n482:       expect(res.body.data).toHaveProperty('title', 'Updated Title');\n483:       expect(res.body.data).toHaveProperty('price', 2800);\n484:     });\n485: \n486:     it('should return 200 updating only one field', async () => {\n487:       const res = await request(app.getHttpServer())\n488:         .patch(`/api/properties/${property.id}`)\n489:         .set(authHeader(adminToken))\n490:         .send({ price: 3000 })\n491:         .expect(200);\n492: \n493:       expect(res.body.data.price).toBe(3000);\n494:       expect(res.body.data.title).toBe(property.title);\n495:     });\n496: \n497:     it('should return 400 for invalid UUID', async () => {\n498:       await request(app.getHttpServer())\n499:         .patch('/api/properties/not-a-uuid')\n500:         .set(authHeader(adminToken))\n501:         .send({ title: 'Bad UUID' })\n502:         .expect(400);\n503:     });\n504: \n505:     it('should return 400 when title is too short (< 5 chars)', async () => {\n506:       await request(app.getHttpServer())\n507:         .patch(`/api/properties/${property.id}`)\n508:         .set(authHeader(adminToken))\n509:         .send({ title: 'AB' })\n510:         .expect(400);\n511:     });\n512: \n513:     it('should return 400 when description is too short (< 20 chars)', async () => {\n514:       await request(app.getHttpServer())\n515:         .patch(`/api/properties/${property.id}`)\n516:         .set(authHeader(adminToken))\n517:         .send({ description: 'Short desc' })\n518:         .expect(400);\n519:     });\n520: \n521:     it('should return 401 when not authenticated', async () => {\n522:       await request(app.getHttpServer())\n523:         .patch(`/api/properties/${property.id}`)\n524:         .send({ title: 'No Auth' })\n525:         .expect(401);\n526:     });\n527: \n528:     it('should return 403 when authenticated as renter (not admin)', async () => {\n529:       await request(app.getHttpServer())\n530:         .patch(`/api/properties/${property.id}`)\n531:         .set(authHeader(renterToken))\n532:         .send({ title: 'Renter Update' })\n533:         .expect(403);\n534:     });\n535: \n536:     it('should return 404 when property not found', async () => {\n537:       await request(app.getHttpServer())\n538:         .patch('/api/properties/00000000-0000-0000-0000-000000000000')\n539:         .set(authHeader(adminToken))\n540:         .send({ title: 'Not Found' })\n541:         .expect(404);\n542:     });\n543:   });\n544: \n545:   // ─── DELETE /properties/:id (Archive) ──────────────────────────────\n546:   describe('DELETE /api/properties/:id', () => {\n547:     let property: Property;\n548: \n549:     beforeEach(async () => {\n550:       const seeded = await seedTestProperties(dataSource);\n551:       property = seeded.downtownApt;\n552:     });\n553: \n554:     it('should return 200 and archive property (admin only)', async () => {\n555:       const res = await request(app.getHttpServer())\n556:         .delete(`/api/properties/${property.id}`)\n557:         .set(authHeader(adminToken))\n558:         .expect(200);\n559: \n560:       expect(res.body.success).toBe(true);\n561:       expect(res.body.statusCode).toBe(200);\n562:       expect(res.body.message).toBe('Property archived successfully');\n563:       expect(res.body.data).toBeNull();\n564:     });\n565: \n566:     it('should return 400 for invalid UUID', async () => {\n567:       await request(app.getHttpServer())\n568:         .delete('/api/properties/not-a-uuid')\n569:         .set(authHeader(adminToken))\n570:         .expect(400);\n571:     });\n572: \n573:     it('should return 401 when not authenticated', async () => {\n574:       await request(app.getHttpServer())\n575:         .delete(`/api/properties/${property.id}`)\n576:         .expect(401);\n577:     });\n578: \n579:     it('should return 403 when authenticated as re