aSource);\n38:     adminToken = generateAccessToken(seeded.admin);\n39:     renterToken = generateAccessToken(seeded.renter);\n40:   });\n41: \n42:   // ─── GET /amenities (List) ─────────────────────────────────────────\n43:   describe('GET /api/amenities', () => {\n44:     beforeEach(async () => {\n45:       await seedTestAmenities(dataSource);\n46:     });\n47: \n48:     it('should return 200 with list of all amenities (public)', async () => {\n49:       const res = await request(app.getHttpServer())\n50:         .get('/api/amenities')\n51:         .expect(200);\n52: \n53:       expect(res.body.success).toBe(true);\n54:       expect(res.body.statusCode).toBe(200);\n55:       expect(res.body.message).toBe('Amenities retrieved successfully');\n56:       expect(Array.isArray(res.body.data)).toBe(true);\n57:       expect(res.body).toHaveProperty('timestamp');\n58:       expect(res.body).toHaveProperty('path', '/api/amenities');\n59:     });\n60: \n61:     it('should return amenity items with correct shape', async () => {\n62:       const res = await request(app.getHttpServer())\n63:         .get('/api/amenities')\n64:         .expect(200);\n65: \n66:       if (res.body.data.length > 0) {\n67:         const item = res.body.data[0];\n68:         expect(item).toHaveProperty('id');\n69:         expect(item).toHaveProperty('name');\n70:         expect(item).toHaveProperty('icon');\n71:       }\n72:     });\n73: \n74:     it('should be accessible without authentication', async () => {\n75:       await request(app.getHttpServer())\n76:         .get('/api/amenities')\n77:         .expect(200);\n78:     });\n79: \n80:     it('should return empty array when no amenities exist', async () => {\n81:       const res = await request(app.getHttpServer())\n82:         .get('/api/amenities')\n83:         .expect(200);\n84: \n85:       expect(res.body.data).toEqual([]);\n86:     });\n87: \n88:     it('should return all seeded amenities', async () => {\n89:       const res = await request(app.getHttpServer())\n90:         .get('/api/amenities')\n91:         .expect(200);\n92: \n93:       expect(res.body.data.length).toBe(4);\n94:       const names = res.body.data.map((a: any) => a.name);\n95:       expect(names).toContain('Parking');\n96:       expect(names).toContain('Gym');\n97:       expect(names).toContain('Pool');\n98:       expect(names).toContain('Pet Friendly');\n99:     });\n100:   });\n101: \n102:   // ─── POST /amenities (Create) ─────────────────────────────────────\n103:   describe('POST /api/amenities', () => {\n104:     const validBody = {\n105:       name: 'Rooftop Access',\n106:       icon: 'rooftop',\n107:     };\n108: \n109:     it('should return 201 with created amenity (admin only)', async () => {\n110:       const res = await request(app.getHttpServer())\n111:         .post('/api/amenities')\n112:         .set(authHeader(adminToken))\n113:         .send(validBody)\n114:         .expect(201);\n115: \n116:       expect(res.body.success).toBe(true);\n117:       expect(res.body.statusCode).toBe(201);\n118:       expect(res.body.message).toBe('Amenity created successfully');\n119:       expect(res.body.data).toHaveProperty('id');\n120:       expect(res.body.data).toHaveProperty('name', 'Rooftop Access');\n121:       expect(res.body.data).toHaveProperty('icon', 'rooftop');\n122:       expect(res.body.data).toHaveProperty('createdAt');\n123:       expect(res.body.data).toHaveProperty('updatedAt');\n124:       expect(res.body).toHaveProperty('timestamp');\n125:       expect(res.body).toHaveProperty('path', '/api/amenities');\n126:     });\n127: \n128:     it('should return 400 when name is missing', async () => {\n129:       await request(app.getHttpServer())\n130:         .post('/api/amenities')\n131:         .set(authHeader(adminToken))\n132:         .send({ icon: 'rooftop' })\n133:         .expect(400);\n134:     });\n135: \n136:     it('should return 400 when name is empty string', async () => {\n137:       await request(app.getHttpServer())\n138:         .post('/api/amenities')\n139:         .set(authHeader(adminToken))\n140:         .send({ name: '', icon: 'rooftop' })\n141:         .expect(400);\n142:     });\n143: \n144:     it('should return 400 when name exceeds 50 chars', async () => {\n145:       await request(app.getHttpServer())\n146:         .post('/api/amenities')\n147:         .set(authHeader(adminToken))\n148:         .send({ name: 'A'.repeat(51), icon: 'rooftop' })\n149:         .expect(400);\n150:     });\n151: \n152:     it('should return 400 when icon is missing', async () => {\n153:       await request(app.getHttpServer())\n154:         .post('/api/amenities')\n155:         .set(authHeader(adminToken))\n156:         .send({ name: 'Rooftop Access' })\n157:         .expect(400);\n158:     });\n159: \n160:     it('should return 400 when icon exceeds 50 chars', async () => {\n161:       await request(app.getHttpServer())\n162:         .post('/api/amenities')\n163:         .set(authHeader(adminToken))\n164:         .send({ name: 'Rooftop Access', icon: 'A'.repeat(51) })\n165:         .expect(400);\n166:     });\n167: \n168:     it('should return 401 when not authenticated', async () => {\n169:       await request(app.getHttpServer())\n170:         .post('/api/amenities')\n171:         .send(validBody)\n172:         .expect(401);\n173:     });\n174: \n175:     it('should return 403 when authenticated as renter (not admin)', async () => {\n176:       await request(app.getHttpServer())\n177:         .post('/api/amenities')\n178:         .set(authHeader(renterToken))\n179:         .send(validBody)\n180:         .expect(403);\n181:     });\n182: \n183:     it('should return 409 when amenity name already exists', async () => {\n184:       await seedTestAmenities(dataSource);\n185: \n186:       await request(app.getHttpServer())\n187:         .post('/api/amenities')\n188:         .set(authHeader(adminToken))\n189:         .send({ name: 'Parking', icon: 'parking-v2' })\n190:         .expect(409);\n191:     });\n192:   });\n193: \n194:   // ─── PATCH /amenities/:id (Update) ────────────────────────────────\n195:   describe('PATCH /api/amenities/:id', () => {\n196:     let amenity: Amenity;\n197: \n198:     beforeEach(async () => {\n199:       const amenities = await seedTestAmenities(dataSource);\n200:       amenity = amenities[0]; // Parking\n201:     });\n202: \n203:     it('should return 200 with updated amenity (admin only)', async () => {\n204:       const res = await request(app.getHttpServer())\n205:         .patch(`/api/amenities/${amenity.id}`)\n206:         .set(authHeader(adminToken))\n207:         .send({ name: 'Updated Amenity' })\n208:         .expect(200);\n209: \n210:       expect(res.body.success).toBe(true);\n211:       expect(res.body.statusCode).toBe(200);\n212:       expect(res.body.message).toBe('Amenity updated successfully');\n213:       expect(res.body.data).toHaveProperty('id', amenity.id);\n214:       expect(res.body.data).toHaveProperty('name', 'Updated Amenity');\n215:       expect(res.body.data).toHaveProperty('updatedAt');\n216:     });\n217: \n218:     it('should return 200 updating icon only', async () => {\n219:       const res = await request(app.getHttpServer())\n220:         .patch(`/api/amenities/${amenity.id}`)\n221:         .set(authHeader(adminToken))\n222:         .send({ icon: 'new-icon' })\n223:         .expect(200);\n224: \n225:       expect(res.body.data.icon).toBe('new-icon');\n226:       expect(res.body.data.name).toBe(amenity.name);\n227:     });\n228: \n229:     it('should return 400 for invalid UUID', async () => {\n230:       await request(app.getHttpServer())\n231:         .patch('/api/amenities/not-a-uuid')\n232:         .set(authHeader(adminToken))\n233:         .send({ name: 'Bad UUID' })\n234:         .expect(400);\n235:     });\n236: \n237:     it('should return 400 when name exceeds 50 chars', async () => {\n238:       await request(app.getHttpServer())\n239:         .patch(`/api/amenities/${amenity.id}`)\n240:         .set(authHeader(adminToken))\n241:         .send({ name: 'A'.repeat(51) })\n242:         .expect(400);\n243:     });\n244: \n245:     it('should return 400 when icon exceeds 50 chars', async () => {\n246:       await request(app.getHttpServer())\n247:         .patch(`/api/amenities/${amenity.id}`)\n248:         .set(authHeader(adminToken))\n249:         .send({ icon: 'A'.repeat(51) })\n250:         .expect(400);\n251:     });\n252: \n253:     it('should return 401 when not authenticated', async () => {\n254:       await request(app.getHttpServer())\n255:         .patch(`/api/amenities/${amenity.id}`)\n256:         .send({ name: 'No Auth' })\n257:         .expect(401);\n258:     });\n259: \n260:     it('should return 403 when authenticated as renter (not admin)', async () => {\n261:       await request(app.getHttpServer())\n262:         .patch(`/api/amenities/${amenity.id}`)\n263:         .set(authHeader(renterToken))\n264:         .send({ name: 'Renter Update' })\n265:         .expect(403);\n266:     });\n267: \n268:     it('should return 404 when amenity not found', async () => {\n269:       await request(app.getHttpServer())\n270:         .patch('/api/amenities/00000000-0000-0000-0000-000000000000')\n271:         .set(authHeader(adminToken))\n272:         .send({ name: 'Not Found' })\n273:         .expect(404);\n274:     });\n275: \n276:     it('should return 409 when updating to an existing amenity name', async () => {\n277:       const amenities = await seedTestAmenities(dataSource);\n278:       const otherName = amenities[1].name; // Gym\n279: \n280:       await request(app.getHttpServer())\n281:         .patch(`/api/amenities/${amenity.id}`)\n282:         .set(authHeader(adminToken))\n283:         .send({ name: otherName })\n284:         .expect(409);\n285:     });\n286:   });\n287: \n288:   // ─── DELETE /amenities/:id ─────────────────────────────────────────\n289:   describe('DELETE /api/amenities/:id', () => {\n290:     let amenity: Amenity;\n291: \n292:     beforeEach(async () => {\n293:       const amenities = await seedTestAmenities(dataSource);\n294:       amenity = amenities[0]; // Parking\n295:     });\n296: \n297:     it('should return 200 and soft-delete amenity (admin only)', async () => {\n298:       const res = await request(app.getHttpServer())\n299:         .delete(`/api/amenities/${amenity.id}`)\n300:         .set(authHeader(adminToken))\n301:         .expect(200);\n302: \n303:       expect(res.body.success).toBe(true);\n304:       expect(res.body.statusCode).toBe(200);\n305:       expect(res.body.message).toBe('Amenity deleted successfully');\n306:       expect(res.body.data).toBeNull();\n307:       expect(res.body).toHaveProperty('timestamp');\n308:       expect(res.body).toHaveProperty('path', `/api/amenities/${amenity.id}`);\n309:     });\n310: \n311:     it('should return 400 for invalid UUID', async () => {\n312:       await request(app.getHttpServer())\n313:         .delete('/api/amenities/not-a-uuid')\n314:         .set(authHeader(adminToken))\n315:         .expect(400);\n316:     });\n317: \n318:     it('should return 401 when not authenticated', async () => {\n319:       await request(app.getHttpServer())\n320:         .delete(`/api/amenities/${amenity.id}`)\n321:         .expect(401);\n322:     });\n323: \n324:     it('should return 403 when authenticated as renter (not admin)', async () => {\n325:       await request(app.getHttpServer())\n326:         .delete(`/api/amenities/${amenity.id}`)\n327:         .set(authHeader(renterToken))\n328:         .expect(403);\n329:     });\n330: \n331:     it('should return 404 when amenity not found', async () => {\n332:       await request(app.getHttpServer())\n333:         .delete('/api/amenities/00000000-0000-0000-0000-000000000000')\n334:         .set(authHeader(adminToken))\n335:         .expect(404);\n336:     });\n337: \n338:     it('should remove amenity from listing but retain for associated properties', async () => {\n339:       // Soft-delete the amenity\n340:       await request(app.getHttpServer())\n341:         .delete(`/api/amenities/${amenity.id}`)\n342:         .set(authHeader(adminToken))\n343:         .expect(200);\n344: \n345:       // Amenity should no longer appear in the list\n346:       const res = await request(app.getHttpServer())\n347:         .get('/api/amenities')\n348:         .expect(200);\n349: \n350:       const ids = res.body.data.map((a: any) => a.id);\n351:       expect(ids).not.toContain(amenity.id);\n352:     });\n353:   });\n354: });\n\n(End of file - total 354 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\nimport { seedTestAmenities } from '../fixtures/property.fixture';\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { Amenity } from '../../src/modules/properties/entities/amenity.entity';\n\n// RED PHASE: These imports will fail because modules don't exist yet.\n// import { AmenitiesModule } from '../../src/modules/properties/amenities.module';\n\ndescribe('Amenities E2E', () => {\n  let app: INestApplication;\n  let module: TestingModule;\n  let dataSource: DataSource;","truncated":false,"loaded":[]},"title":"backend/test/e2e/amenities.e2e-spec.ts","time":{"start":1779246084953,"end":1779246085265}},"id":"prt_e4354ad97001Wnff1HNRXKAsOF","sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","messageID":"msg_e435476e5001k05tPaNG7hOASt"}}
{"type":"tool_use","timestamp":1779246087274,"sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","part":{"type":"tool","tool":"read","callID":"call_05_JlqFhd33ESlIGQrsEVCD0697","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-dashboard.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-dashboard.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\n9: import { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\n10: import { seedTestProperties } from '../fixtures/property.fixture';\n11: import { User } from '../../src/modules/users/entities/user.entity';\n12: \n13: // RED PHASE: These imports will fail because modules don't exist yet.\n14: // import { AdminModule } from '../../src/modules/admin/admin.module';\n15: \n16: describe('Admin Dashboard E2E', () => {\n17:   let app: INestApplication;\n18:   let module: TestingModule;\n19:   let dataSource: DataSource;\n20:   let adminToken: string;\n21:   let renterToken: string;\n22: \n23:   beforeAll(async () => {\n24:     const context = await createTestApp();\n25:     app = context.app;\n26:     module = context.module;\n27:     dataSource = getDataSource(module);\n28:   });\n29: \n30:   afterAll(async () => {\n31:     await closeTestApp({ app, module });\n32:   });\n33: \n34:   beforeEach(async () => {\n35:     await cleanDatabase(dataSource);\n36:     const seeded = await seedTestUsers(dataSource);\n37:     adminToken = generateAccessToken(seeded.admin);\n38:     renterToken = generateAccessToken(seeded.renter);\n39:   });\n40: \n41:   // ─── GET /admin/dashboard ──────────────────────────────────────────\n42:   describe('GET /api/admin/dashboard', () => {\n43:     beforeEach(async () => {\n44:       await seedTestProperties(dataSource);\n45:     });\n46: \n47:     it('should return 200 with dashboard statistics (admin only)', async () => {\n48:       const res = await request(app.getHttpServer())\n49:         .get('/api/admin/dashboard')\n50:         .set(authHeader(adminToken))\n51:         .expect(200);\n52: \n53:       expect(res.body.success).toBe(true);\n54:       expect(res.body.statusCode).toBe(200);\n55:       expect(res.body.message).toBe('Dashboard statistics retrieved');\n56:       expect(res.body.data).toHaveProperty('totalProperties');\n57:       expect(res.body.data).toHaveProperty('totalInquiries');\n58:       expect(res.body.data).toHaveProperty('newInquiries');\n59:       expect(res.body.data).toHaveProperty('totalUsers');\n60:       expect(res.body.data).toHaveProperty('recentInquiries');\n61:       expect(res.body.data).toHaveProperty('recentProperties');\n62:       expect(res.body).toHaveProperty('timestamp');\n63:       expect(res.body).toHaveProperty('path', '/api/admin/dashboard');\n64:     });\n65: \n66:     it('should return non-negative integer values for aggregate counts', async () => {\n67:       const res = await request(app.getHttpServer())\n68:         .get('/api/admin/dashboard')\n69:         .set(authHeader(adminToken))\n70:         .expect(200);\n71: \n72:       expect(typeof res.body.data.totalProperties).toBe('number');\n73:       expect(res.body.data.totalProperties).toBeGreaterThanOrEqual(0);\n74:       expect(typeof res.body.data.totalInquiries).toBe('number');\n75:       expect(res.body.data.totalInquiries).toBeGreaterThanOrEqual(0);\n76:       expect(typeof res.body.data.newInquiries).toBe('number');\n77:       expect(res.body.data.newInquiries).toBeGreaterThanOrEqual(0);\n78:       expect(typeof res.body.data.totalUsers).toBe('number');\n79:       expect(res.body.data.totalUsers).toBeGreaterThanOrEqual(0);\n80:     });\n81: \n82:     it('should return count matching seeded properties', async () => {\n83:       const res = await request(app.getHttpServer())\n84:         .get('/api/admin/dashboard')\n85:         .set(authHeader(adminToken))\n86:         .expect(200);\n87: \n88:       // 3 properties seeded via seedTestProperties\n89:       expect(res.body.data.totalProperties).toBe(3);\n90:     });\n91: \n92:     it('should return recent properties as an array', async () => {\n93:       const res = await request(app.getHttpServer())\n94:         .get('/api/admin/dashboard')\n95:         .set(authHeader(adminToken))\n96:         .expect(200);\n97: \n98:       expect(Array.isArray(res.body.data.recentProperties)).toBe(true);\n99:       if (res.body.data.recentProperties.length > 0) {\n100:         const item = res.body.data.recentProperties[0];\n101:         expect(item).toHaveProperty('id');\n102:         expect(item).toHaveProperty('title');\n103:         expect(item).toHaveProperty('price');\n104:         expect(item).toHaveProperty('propertyType');\n105:         expect(item).toHaveProperty('createdAt');\n106:       }\n107:     });\n108: \n109:     it('should return recent inquiries as an array (empty if none)', async () => {\n110:       const res = await request(app.getHttpServer())\n111:         .get('/api/admin/dashboard')\n112:         .set(authHeader(adminToken))\n113:         .expect(200);\n114: \n115:       expect(Array.isArray(res.body.data.recentInquiries)).toBe(true);\n116:       if (res.body.data.recentInquiries.length > 0) {\n117:         const item = res.body.data.recentInquiries[0];\n118:         expect(item).toHaveProperty('id');\n119:         expect(item).toHaveProperty('name');\n120:         expect(item).toHaveProperty('email');\n121:         expect(item).toHaveProperty('propertyTitle');\n122:         expect(item).toHaveProperty('status');\n123:         expect(item).toHaveProperty('createdAt');\n124:       }\n125:     });\n126: \n127:     it('should return 0 for counts when database is empty', async () => {\n128:       // beforeEach cleaned the DB, but this test doesn't seed properties\n129:       // We need to ensure clean state\n130:       await cleanDatabase(dataSource);\n131:       const seeded = await seedTestUsers(dataSource);\n132:       const cleanAdminToken = generateAccessToken(seeded.admin);\n133: \n134:       const res = await request(app.getHttpServer())\n135:         .get('/api/admin/dashboard')\n136:         .set(authHeader(cleanAdminToken))\n137:         .expect(200);\n138: \n139:       expect(res.body.data.totalProperties).toBe(0);\n140:       expect(res.body.data.totalInquiries).toBe(0);\n141:       expect(res.body.data.newInquiries).toBe(0);\n142:     });\n143: \n144:     it('should return 401 when not authenticated', async () => {\n145:       await request(app.getHttpServer())\n146:         .get('/api/admin/dashboard')\n147:         .expect(401);\n148:     });\n149: \n150:     it('should return 401 with invalid token', async () => {\n151:       await request(app.getHttpServer())\n152:         .get('/api/admin/dashboard')\n153:         .set(authHeader('invalid-token'))\n154:         .expect(401);\n155:     });\n156: \n157:     it('should return 403 when authenticated as renter (admin only)', async () => {\n158:       await request(app.getHttpServer())\n159:         .get('/api/admin/dashboard')\n160:         .set(authHeader(renterToken))\n161:         .expect(403);\n162:     });\n163:   });\n164: });\n\n(End of file - total 164 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/tes