escription: 'A newly created test property for e2e testing purposes.',\n331:       price: 1800.0,\n332:       bedrooms: 2,\n333:       bathrooms: 1,\n334:       squareFeet: 850,\n335:       propertyType: 'condo',\n336:       address: {\n337:         street: '100 Test Blvd',\n338:         city: 'San Francisco',\n339:         state: 'CA',\n340:         zipCode: '94105',\n341:         latitude: 37.774929,\n342:         longitude: -122.419418,\n343:       },\n344:       availableFrom: '2026-08-01',\n345:       amenityIds: [],\n346:     };\n347: \n348:     it('should return 201 with created property (admin only)', async () => {\n349:       const res = await request(app.getHttpServer())\n350:         .post('/api/properties')\n351:         .set(authHeader(adminToken))\n352:         .send(validBody)\n353:         .expect(201);\n354: \n355:       expect(res.body.success).toBe(true);\n356:       expect(res.body.statusCode).toBe(201);\n357:       expect(res.body.message).toBe('Property created successfully');\n358:       expect(res.body.data).toHaveProperty('id');\n359:       expect(res.body.data).toHaveProperty('title', 'New Test Property');\n360:       expect(res.body.data).toHaveProperty('price', 1800);\n361:       expect(res.body.data).toHaveProperty('address');\n362:       expect(res.body.data.address).toHaveProperty('city', 'San Francisco');\n363:       expect(res.body.data).toHaveProperty('photos');\n364:       expect(res.body.data).toHaveProperty('amenities');\n365:       expect(res.body.data).toHaveProperty('createdAt');\n366:       expect(res.body.data).toHaveProperty('updatedAt');\n367:     });\n368: \n369:     it('should return 400 when title is missing', async () => {\n370:       const { title, ...body } = validBody;\n371:       await request(app.getHttpServer())\n372:         .post('/api/properties')\n373:         .set(authHeader(adminToken))\n374:         .send(body)\n375:         .expect(400);\n376:     });\n377: \n378:     it('should return 400 when title is too short (< 5 chars)', async () => {\n379:       await request(app.getHttpServer())\n380:         .post('/api/properties')\n381:         .set(authHeader(adminToken))\n382:         .send({ ...validBody, title: 'AB' })\n383:         .expect(400);\n384:     });\n385: \n386:     it('should return 400 when description is too short (< 20 chars)', async () => {\n387:       await request(app.getHttpServer())\n388:         .post('/api/properties')\n389:         .set(authHeader(adminToken))\n390:         .send({ ...validBody, description: 'Short desc' })\n391:         .expect(400);\n392:     });\n393: \n394:     it('should return 400 when price is missing', async () => {\n395:       const { price, ...body } = validBody;\n396:       await request(app.getHttpServer())\n397:         .post('/api/properties')\n398:         .set(authHeader(adminToken))\n399:         .send(body)\n400:         .expect(400);\n401:     });\n402: \n403:     it('should return 400 when price is 0 or negative', async () => {\n404:       await request(app.getHttpServer())\n405:         .post('/api/properties')\n406:         .set(authHeader(adminToken))\n407:         .send({ ...validBody, price: 0 })\n408:         .expect(400);\n409:     });\n410: \n411:     it('should return 400 when bedrooms is negative', async () => {\n412:       await request(app.getHttpServer())\n413:         .post('/api/properties')\n414:         .set(authHeader(adminToken))\n415:         .send({ ...validBody, bedrooms: -1 })\n416:         .expect(400);\n417:     });\n418: \n419:     it('should accept bedrooms=0 and bathrooms=0 (studio)', async () => {\n420:       const res = await request(app.getHttpServer())\n421:         .post('/api/properties')\n422:         .set(authHeader(adminToken))\n423:         .send({ ...validBody, bedrooms: 0, bathrooms: 0, propertyType: 'studio' })\n424:         .expect(201);\n425: \n426:       expect(res.body.data.bedrooms).toBe(0);\n427:       expect(res.body.data.bathrooms).toBe(0);\n428:     });\n429: 