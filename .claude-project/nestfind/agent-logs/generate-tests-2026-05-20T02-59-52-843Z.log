res.body.data.meta.total).toBe(2);\n    });\n\n    it('should not allow renter to see other renters inquiries via GET /inquiries', async () => {\n      const res = await request(app.getHttpServer())\n        .get('/api/inquiries')\n        .set(authHeader(renterToken))\n        .expect(200);\n\n      const messages = res.body.data.items.map((i: any) => i.message);\n      expect(messages).not.toContain('Scoped inquiry from renter2.');\n    });\n  });\n});","newString":"});"},"output":"Edit applied successfully.","metadata":{"diagnostics":{},"diff":"Index: /Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/inquiries-my.e2e-spec.ts\n===================================================================\n--- /Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/inquiries-my.e2e-spec.ts\n+++ /Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/inquiries-my.e2e-spec.ts\n@@ -265,61 +265,5 @@\n       }\n     });\n   });\n \n-  // ─── GET /inquiries (Scoped by Role) ───────────────────────────────\n-  // Per MISSING_ENDPOINTS.yaml: GET /inquiries scoped by role —\n-  // admin sees all, renter sees their own.\n-  describe('GET /api/inquiries (Role-Scoped)', () => {\n-    beforeEach(async () => {\n-      // Renter1 submits inquiry on property1\n-      await request(app.getHttpServer())\n-        .post(`/api/properties/${property1.id}/inquiries`)\n-        .set(authHeader(renterToken))\n-        .send({ message: 'Scoped inquiry from renter1.' })\n-        .expect(201);\n-\n-      // Renter2 submits inquiry on property2\n-      await request(app.getHttpServer())\n-        .post(`/api/properties/${property2.id}/inquiries`)\n-        .set(authHeader(renter2Token))\n-        .send({ message: 'Scoped inquiry from renter2.' })\n-        .expect(201);\n-    });\n-\n-    it('should allow renter to see their own inquiries via GET /inquiries', async () => {\n-      const res = await request(app.getHttpServer())\n-        .get('/api/inquiries')\n-     