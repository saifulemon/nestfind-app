wait closeTestApp({ app, module });\n37:   });\n38: \n39:   beforeEach(async () => {\n40:     await cleanDatabase(dataSource);\n41:     const seededUsers = await seedTestUsers(dataSource);\n42:     adminUser = seededUsers.admin;\n43:     renterUser = seededUsers.renter;\n44:     adminToken = generateAccessToken(adminUser);\n45:     renterToken = generateAccessToken(renterUser);\n46: \n47:     const seededProps = await seedTestProperties(dataSource);\n48:     property = seededProps.downtownApt;\n49:   });\n50: \n51:   // ─── POST /properties/:id/inquiries (Submit) ────────────────────\n52:   describe('POST /api/properties/:id/inquiries', () => {\n53:     const validBody = {\n54:       message: 'I am interested in this property. Is it still available?',\n55:     };\n56: \n57:     it('should return 201 with inquiry data (renter only)', async () => {\n58:       const res = await request(app.getHttpServer())\n59:         .post(`/api/properties/${property.id}/inquiries`)\n60:         .set(authHeader(renterToken))\n61:         .send(validBody)\n62:         .expect(201);\n63: \n64:       expect(res.body.success).toBe(true);\n65:       expect(res.body.statusCode).toBe(201);\n66:       expect(res.body.message).toBe('Inquiry submitted successfully');\n67:       expect(res.body.data).toHaveProperty('id');\n68:       expect(res.body.data).toHaveProperty('propertyId');\n69:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n70:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n71:       expect(res.body.data).toHaveProperty('phone');\n72:       expect(res.body.data).toHaveProperty('message', validBody.message);\n73:       expect(res.body.data).toHaveProperty('status', 'new');\n74:       expect(res.body.data).toHaveProperty('response', null);\n75:       expect(res.body.data).toHaveProperty('respondedAt', null);\n76:       expect(res.body.data).toHaveProperty('createdAt');\n77:     });\n78: \n79:     it('should denormalize user profile data into the inquiry', async () => {\n80:       const res = await request(app.getHttpServer())\n81:         .post(`/api/properties/${property.id}/inquiries`)\n82:         .set(authHeader(renterToken))\n83:         .send(validBody)\n84:         .expect(201);\n85: \n86:       expect(res.body.data.name).toBe(renterUser.name);\n87:       expect(res.body.data.email).toBe(renterUser.email);\n88:     });\n89: \n90:     it('should allow overriding name, email, phone in request body', async () => {\n91:       const res = await request(app.getHttpServer())\n92:         .post(`/api/properties/${property.id}/inquiries`)\n93:         .set(authHeader(renterToken))\n94:         .send({\n95:           ...validBody,\n96:           name: 'Custom Name',\n97:           email: 'custom@example.com',\n98:           phone: '+15559999999',\n99:         })\n100:         .expect(201);\n101: \n102:       expect(res.body.data.name).toBe('Custom Name');\n103:       expect(res.body.data.email).toBe('custom@example.com');\n104:       expect(res.body.data.phone).toBe('+15559999999');\n105:     });\n106: \n107:     it('should return 400 when message is missing', async () => {\n108:       await request(app.getHttpServer())\n109:         .post(`/api/properties/${property.id}/inquiries`)\n110:         .set(authHeader(renterToken))\n111:         .send({})\n112:         .expect(400);\n113:     });\n114: \n115:     it('should return 400 when message is too short (< 10 chars)', async () => {\n116:       await request(app.getHttpServer())\n117:         .post(`/api/properties/${property.id}/inquiries`)\n118:         .set(authHeader(renterToken))\n119:         .send({ message: 'Short' })\n120:         .expect(400);\n121:     });\n122: \n123:     it('should return 400 when message is too long (> 2000 chars)', async () => {\n124:       await request(app.getHttpServer())\n125:         .post(`/api/properties/${property.id}/inquiries`)\n126:         .set(authHeader(renterToken))\n127:         .send({ message: 'X'.repea