oto not found', async () => {\n761:       const seeded = await seedTestProperties(dataSource);\n762:       const property = seeded.downtownApt;\n763: \n764:       await request(app.getHttpServer())\n765:         .patch(`/api/properties/${property.id}/photos/00000000-0000-0000-0000-000000000000/primary`)\n766:         .set(authHeader(adminToken))\n767:         .expect(404);\n768:     });\n769:   });\n770: \n771:   // ─── PATCH /properties/:id/photos/reorder ─────────────────────────\n772:   describe('PATCH /api/properties/:id/photos/reorder', () => {\n773:     it('should return 200 when photos reordered (admin only)', async () => {\n774:       // Requires photos to exist. In GREEN phase: upload photos, reorder.\n775:       await request(app.getHttpServer())\n776:         .patch('/api/properties/00000000-0000-0000-0000-000000000001/photos/reorder')\n777:         .set(authHeader(adminToken))\n778:         .send({ photoIds: [] })\n779:         .expect(404);\n780:       // NOTE: Will be 200 in GREEN phase with seeded photo data\n781:     });\n782: \n783:     it('should return 400 for invalid UUID format', async () => {\n784:       await request(app.getHttpServer())\n785:         .patch('/api/properties/bad-uuid/photos/reorder')\n786:         .set(authHeader(adminToken))\n787:         .send({ photoIds: ['not-a-uuid'] })\n788:         .expect(400);\n789:     });\n790: \n791:     it('should return 401 when not authenticated', async () => {\n792:       await request(app.getHttpServer())\n793:         .patch('/api/properties/some-id/photos/reorder')\n794:         .send({ photoIds: [] })\n795:         .expect(401);\n796:     });\n797: \n798:     it('should return 403 when authenticated as renter', async () => {\n799:       await request(app.getHttpServer())\n800:         .patch('/api/properties/some-id/photos/reorder')\n801:         .set(authHeader(renterToken))\n802:         .send({ photoIds: [] })\n803:         .expect(403);\n804:     });\n805: \n806:     it('should return 4