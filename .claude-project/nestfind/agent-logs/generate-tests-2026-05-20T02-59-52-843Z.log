{"type":"tool_use","timestamp":1779246089077,"sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","part":{"type":"tool","tool":"read","callID":"call_06_ivyOnA8AM89VODKU2MiP8044","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-users.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-users.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\n9: import { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\n10: import { User } from '../../src/modules/users/entities/user.entity';\n11: import { RoleEnum } from '../../src/common/enums/role.enum';\n12: import { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n13: \n14: // RED PHASE: These imports will fail because modules don't exist yet.\n15: // import { AdminModule } from '../../src/modules/admin/admin.module';\n16: \n17: describe('Admin Users E2E', () => {\n18:   let app: INestApplication;\n19:   let module: TestingModule;\n20:   let dataSource: DataSource;\n21:   let adminToken: string;\n22:   let renterToken: string;\n23:   let adminUser: User;\n24:   let renterUser: User;\n25: \n26:   beforeAll(async () => {\n27:     const context = await createTestApp();\n28:     app = context.app;\n29:     module = context.module;\n30:     dataSource = getDataSource(module);\n31:   });\n32: \n33:   afterAll(async () => {\n34:     await closeTestApp({ app, module });\n35:   });\n36: \n37:   beforeEach(async () => {\n38:     await cleanDatabase(dataSource);\n39:     const seeded = await seedTestUsers(dataSource);\n40:     adminUser = seeded.admin;\n41:     renterUser = seeded.renter;\n42:     adminToken = generateAccessToken(adminUser);\n43:     renterToken = generateAccessToken(renterUser);\n44:   });\n45: \n46:   // ─── GET /admin/users (List) ───────────────────────────────────────\n47:   describe('GET /api/admin/users', () => {\n48:     it('should return 200 with paginated users list (admin only)', async () => {\n49:       const res = await request(app.getHttpServer())\n50:         .get('/api/admin/users')\n51:         .set(authHeader(adminToken))\n52:         .expect(200);\n53: \n54:       expect(res.body.success).toBe(true);\n55:       expect(res.body.statusCode).toBe(200);\n56:       expect(res.body.message).toBe('Users retrieved successfully');\n57:       expect(res.body.data).toHaveProperty('items');\n58:       expect(res.body.data).toHaveProperty('meta');\n59:       expect(res.body.data.meta).toHaveProperty('total');\n60:       expect(res.body.data.meta).toHaveProperty('page', 1);\n61:       expect(res.body.data.meta).toHaveProperty('limit');\n62:       expect(res.body.data.meta).toHaveProperty('totalPages');\n63:       expect(Array.isArray(res.body.data.items)).toBe(true);\n64:       expect(res.body).toHaveProperty('timestamp');\n65:       expect(res.body).toHaveProperty('path', '/api/admin/users');\n66:     });\n67: \n68:     it('should return user items with correct shape', async () => {\n69:       const res = await request(app.getHttpServer())\n70:         .get('/api/admin/users')\n71:         .set(authHeader(adminToken))\n72:         .expect(200);\n73: \n74:       if (res.body.data.items.length > 0) {\n75:         const item = res.body.data.items[0];\n76:         expect(item).toHaveProperty('id');\n77:         expect(item).toHaveProperty('name');\n78:         expect(item).toHaveProperty('email');\n79:         expect(item).toHaveProperty('phone');\n80:         expect(item).toHaveProperty('role');\n81:         expect(item).toHaveProperty('status');\n82:         expect(item).toHaveProperty('emailVerifiedAt');\n83:         expect(item).toHaveProperty('createdAt');\n84:         // Admin user list should NOT expose passwords\n85:         expect(item).not.toHaveProperty('password');\n86:       }\n87:     });\n88: \n89:     it('should include all seeded users in list', async () => {\n90:       const res = await request(app.getHttpServer())\n91:         .get('/api/admin/users')\n92:         .set(authHeader(adminToken))\n93:         .expect(200);\n94: \n95:       // 4 users: renter, renter2, admin, suspendedRenter\n96:       expect(res.body.data.meta.total).toBe(4);\n97:     });\n98: \n99:     it('should support filtering by role', async () => {\n100:       const res = await request(app.getHttpServer())\n101:         .get('/api/admin/users?role=renter')\n102:         .set(authHeader(adminToken))\n103:         .expect(200);\n104: \n105:       for (const item of res.body.data.items) {\n106:         expect(item.role).toBe('renter');\n107:       }\n108:     });\n109: \n110:     it('should support filtering by status', async () => {\n111:       const res = await request(app.getHttpServer())\n112:         .get('/api/admin/users?status=active')\n113:         .set(authHeader(adminToken))\n114:         .expect(200);\n115: \n116:       for (const item of res.body.data.items) {\n117:         expect(item.status).toBe('active');\n118:       }\n119:     });\n120: \n121:     it('should support filtering by status=suspended', async () => {\n122:       const res = await request(app.getHttpServer())\n123:         .get('/api/admin/users?status=suspended')\n124:         .set(authHeader(adminToken))\n125:         .expect(200);\n126: \n127:       for (const item of res.body.data.items) {\n128:         expect(item.status).toBe('suspended');\n129:       }\n130:     });\n131: \n132:     it('should support search by name or email', async () => {\n133:       const res = await request(app.getHttpServer())\n134:         .get(`/api/admin/users?search=${encodeURIComponent(renterUser.name)}`)\n135:         .set(authHeader(adminToken))\n136:         .expect(200);\n137: \n138:       expect(res.body.data.items.length).toBeGreaterThanOrEqual(1);\n139:     });\n140: \n141:     it('should support sorting by newest', async () => {\n142:       await request(app.getHttpServer())\n143:         .get('/api/admin/users?sortBy=newest')\n144:         .set(authHeader(adminToken))\n145:         .expect(200);\n146:     });\n147: \n148:     it('should support sorting by oldest', async () => {\n149:       await request(app.getHttpServer())\n150:         .get('/api/admin/users?sortBy=oldest')\n151:         .set(authHeader(adminToken))\n152:         .expect(200);\n153:     });\n154: \n155:     it('should support sorting by name_asc', async () => {\n156:       await request(app.getHttpServer())\n157:         .get('/api/admin/users?sortBy=name_asc')\n158:         .set(authHeader(adminToken))\n159:         .expect(200);\n160:     });\n161: \n162:     it('should support sorting by name_desc', async () => {\n163:       await request(app.getHttpServer())\n164:         .get('/api/admin/users?sortBy=name_desc')\n165:         .set(authHeader(adminToken))\n166:         .expect(200);\n167:     });\n168: \n169:     it('should support pagination with page and limit', async () => {\n170:       const res = await request(app.getHttpServer())\n171:         .get('/api/admin/users?page=1&limit=2')\n172:         .set(authHeader(adminToken))\n173:         .expect(200);\n174: \n175:       expect(res.body.data.meta.page).toBe(1);\n176:       expect(res.body.data.meta.limit).toBe(2);\n177:     });\n178: \n179:     it('should return 401 when not authenticated', async () => {\n180:       await request(app.getHttpServer())\n181:         .get('/api/admin/users')\n182:         .expect(401);\n183:     });\n184: \n185:     it('should return 403 when authenticated as renter (admin only)', async () => {\n186:       await request(app.getHttpServer())\n187:         .get('/api/admin/users')\n188:         .set(authHeader(renterToken))\n189:         .expect(403);\n190:     });\n191:   });\n192: \n193:   // ─── GET /admin/users/:id (Detail) ─────────────────────────────────\n194:   describe('GET /api/admin/users/:id', () => {\n195:     it('should return 200 with full user detail (admin only)', async () => {\n196:       const res = await request(app.getHttpServer())\n197:         .get(`/api/admin/users/${renterUser.id}`)\n198:         .set(authHeader(adminToken))\n199:         .expect(200);\n200: \n201:       expect(res.body.success).toBe(true);\n202:       expect(res.body.statusCode).toBe(200);\n203:       expect(res.body.message).toBe('User retrieved successfully');\n204:       expect(res.body.data).toHaveProperty('id', renterUser.id);\n205:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n206:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n207:       expect(res.body.data).toHaveProperty('phone');\n208:       expect(res.body.data).toHaveProperty('role', renterUser.role);\n209:       expect(res.body.data).toHaveProperty('status', renterUser.status);\n210:       expect(res.body.data).toHaveProperty('emailVerifiedAt');\n211:       expect(res.body.data).toHaveProperty('activity');\n212:       expect(res.body.data.activity).toHaveProperty('totalFavorites');\n213:       expect(res.body.data.activity).toHaveProperty('totalInquiries');\n214:       expect(res.body.data.activity).toHaveProperty('lastLoginAt');\n215:       expect(res.body.data).toHaveProperty('createdAt');\n216:       expect(res.body.data).toHaveProperty('updatedAt');\n217:       expect(res.body.data).not.toHaveProperty('password');\n218:     });\n219: \n220:     it('should return non-negative integers for activity counts', async () => {\n221:       const res = await request(app.getHttpServer())\n222:         .get(`/api/admin/users/${renterUser.id}`)\n223:         .set(authHeader(adminToken))\n224:         .expect(200);\n225: \n226:       expect(typeof res.body.data.activity.totalFavorites).toBe('number');\n227:       expect(res.body.data.activity.totalFavorites).toBeGreaterThanOrEqual(0);\n228:       expect(typeof res.body.data.activity.totalInquiries).toBe('number');\n229:       expect(res.body.data.activity.totalInquiries).toBeGreaterThanOrEqual(0);\n230:     });\n231: \n232:     it('should show admin user correctly', async () => {\n233:       const res = await request(app.getHttpServer())\n234:         .get(`/api/admin/users/${adminUser.id}`)\n235:         .set(authHeader(adminToken))\n236:         .expect(200);\n237: \n238:       expect(res.body.data.role).toBe('admin');\n239:       expect(res.body.data.status).toBe('active');\n240:     });\n241: \n242:     it('should show suspended user correctly', async () => {\n243:       const suspended = await createTestUser(dataSource, testUsers.suspendedRenter);\n244: \n245:       const res = await request(app.getHttpServer())\n246:         .get(`/api/admin/users/${suspended.id}`)\n247:         .set(authHeader(adminToken))\n248:         .expect(200);\n249: \n250:       expect(res.body.data.status).toBe('suspended');\n251:     });\n252: \n253:     it('should return 400 for invalid UUID', async () => {\n254:       await request(app.getHttpServer())\n255:         .get('/api/admin/users/not-a-uuid')\n256:         .set(authHeader(adminToken))\n257:         .expect(400);\n258:     });\n259: \n260:     it('should return 401 when not authenticated', async () => {\n261:       await request(app.getHttpServer())\n262:         .get(`/api/admin/users/${renterUser.id}`)\n263:         .expect(401);\n264:     });\n265: \n266:     it('should return 403 when authenticated as renter (admin only)', async () => {\n267:       await request(app.getHttpServer())\n268:         .get(`/api/admin/users/${renterUser.id}`)\n269:         .set(authHeader(renterToken))\n270:         .expect(403);\n271:     });\n272: \n273:     it('should return 404 when user not found', async () => {\n274:       await request(app.getHttpServer())\n275:         .get('/api/admin/users/00000000-0000-0000-0000-000000000000')\n276:         .set(authHeader(adminToken))\n277:         .expect(404);\n278:     });\n279:   });\n280: \n281:   // ─── PATCH /admin/users/:id/status ─────────────────────────────────\n282:   describe('PATCH /api/admin/users/:id/status', () => {\n283:     it('should return 200 when suspending a user (admin only)', async () => {\n284:       const res = await request(app.getHttpServer())\n285:         .patch(`/api/admin/users/${renterUser.id}/status`)\n286:         .set(authHeader(adminToken))\n287:         .send({ status: 'suspended' })\n288:         .expect(200);\n289: \n290:       expect(res.body.success).toBe(true);\n291:       expect(res.body.statusCode).toBe(200);\n292:       expect(res.body.message).toBe(\"User status updated to 'suspended'\");\n293:       expect(res.body.data).toHaveProperty('id', renterUser.id);\n294:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n295:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n296:       expect(res.body.data).toHaveProperty('status', 'suspended');\n297:       expect(res.body.data).toHaveProperty('updatedAt');\n298:     });\n299: \n300:     it('should return 200 when reactivating a suspended user', async () => {\n301:       // First suspend\n302:       await request(app.getHttpServer())\n303:         .patch(`/api/admin/users/${renterUser.id}/status`)\n304:         .set(authHeader(adminToken))\n305:         .send({ status: 'suspended' })\n306:         .expect(200);\n307: \n308:       // Then reactivate\n309:       const res = await request(app.getHttpServer())\n310:         .patch(`/api/admin/users/${renterUser.id}/status`)\n311:         .set(authHeader(adminToken))\n312:         .send({ status: 'active' })\n313:         .expect(200);\n314: \n315:       expect(res.body.data.status).toBe('active');\n316:       expect(res.body.message).toBe(\"User status updated to 'active'\");\n317:     });\n318: \n319:     it('should return 400 when status is missing', async () => {\n320:       await request(app.getHttpServer())\n321:         .patch(`/api/admin/users/${renterUser.id}/status`)\n322:         .set(authHeader(adminToken))\n323:         .send({})\n324:         .expect(400);\n325:     });\n326: \n327:     it('should return 400 when status is invalid value', async () => {\n328:       await request(app.getHttpServer())\n329:         .patch(`/api/admin/users/${renterUser.id}/status`)\n330:         .set(authHeader(adminToken))\n331:         .send({ status: 'invalid-status' })\n332:         .expect(400);\n333:     });\n334: \n335:     it('should return 400 when admin tries to suspend their own account', async () => {\n336:       await request(app.getHttpServer())\n337:         .patch(`/api/admin/users/${adminUser.id}/status`)\n338:         .set(authHeader(adminToken))\n339:         .send({ status: 'suspended' })\n340:         .expect(400);\n341:     });\n342: \n343:     it('should return 400 for invalid UUID', async () => {\n344:       await request(app.getHttpServer())\n345:         .patch('/api/admin/users/not-a-uuid/status')\n346:         .set(authHeader(adminToken))\n347:         .send({ status: 'active' })\n348:         .expect(400);\n349:     });\n350: \n351:     it('should return 401 when not authenticated', async () => {\n352:       await request(app.getHttpServer())\n353:         .patch(`/api/admin/users/${renterUser.id}/status`)\n354:         .send({ status: 'suspended' })\n355:         .expect(401);\n356:     });\n357: \n358:     it('should return 403 when authenticated as renter (admin only)', async () => {\n359:       await request(app.getHttpServer())\n360:         .patch(`/api/admin/users/${renterUser.id}/status`)\n361:         .set(authHeader(renterToken))\n362:         .send({ status: 'suspended' })\n363:         .expect(403);\n364:     });\n365: \n366:     it('should return 404 when user not found', async () => {\n367:       await request(app.getHttpServer())\n368:         .patch('/api/admin/users/00000000-0000-0000-0000-000000000000/status')\n369:         .set(authHeader(adminToken))\n370:         .send({ status: 'active' })\n371:         .expect(404);\n372:     });\n373:   });\n374: });\n\n(End of file - total 374 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { RoleEnum } from '../../src/common/enums/role.enum';\nimport { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n\n// RED PHASE: These imports will fail because modules don't exist yet.\n// import { AdminModule } from '../../src/modules/admin/admin.module';\n\ndescribe('Admin Users E2E', () => {\n  let app: INestApplication;\n  let module: TestingModule;\n  let dataSource: DataSource;","truncated":false,"loaded":[]},"title":"backend/test/e2e/admin-users.e2e-spec.ts","time":{"start":1779246088740,"end":1779246089075}},"id":"prt_e4354bc64001qIL9VwDKR9U4a3","sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","messageID":"msg_e435476e5001k05tPaNG7hOASt"}}
