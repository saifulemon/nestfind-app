\n41:   return {\n42:     Cookie: `access_token=${accessToken}; refresh_token=${refreshToken}`,\n43:   };\n44: }\n\n(End of file - total 44 lines)\n</content>","metadata":{"preview":"import { User } from '../../src/modules/users/entities/user.entity';\n\n/**\n * Builds a mock JWT access token string for testing.\n * NOTE: In RED phase, this is a placeholder — actual JWT signing\n * requires the auth module implementation. Tests that require valid\n * tokens will FAIL until the auth controller/service is implemented.\n *\n * For tests that need to simulate an authenticated request, use\n * the `authHeader` helper which sets the cookie header.\n */\nexport function generateAccessToken(user: User): string {\n  // Placeholder token — real implementation will sign with jwt service\n  return `mock-access-token-${user.id}-${user.role}`;\n}\n\nexport function generateRefreshToken(user: User): string {\n  return `mock-refresh-token-${user.id}`;\n}\n","truncated":false,"loaded":[]},"title":"backend/test/fixtures/auth.fixture.ts","time":{"start":1779246064677,"end":1779246064986}},"id":"prt_e43545ec4001fhQ7OC1eS5ndsv","sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","messageID":"msg_e4354317e00168GirOe3kvO6TD"}}
{"type":"tool_use","timestamp":1779246066917,"sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","part":{"type":"tool","tool":"read","callID":"call_04_1wRE5FMzDAcvvXE2dlYU0158","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/fixtures/property.fixture.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/fixtures/property.fixture.ts</path>\n<type>file</type>\n<content>\n1: import { DataSource } from 'typeorm';\n2: import { Property } from '../../src/modules/properties/entities/property.entity';\n3: import { PropertyTypeEnum } from '../../src/common/enums/property-type.enum';\n4: import { Amenity } from '../../src/modules/properties/entities/amenity.entity';\n5: \n6: export interface TestPropertyData {\n7:   title: string;\n8:   description: string;\n9:   price: number;\n10:   bedrooms: number;\n11:   bathrooms: number;\n12:   squareFeet?: number;\n13:   propertyType: PropertyTypeEnum;\n14:   addressStreet: string;\n15:   addressCity: string;\n16:   addressState: string;\n17:   addressZipCode: string;\n18:   addressLatitude?: number;\n19:   addressLongitude?: number;\n20:   availableFrom?: string;\n21: }\n22: \n23: export const testProperties: Record<string, TestPropertyData> = {\n24:   downtownApt: {\n25:     title: 'Downtown Luxury Apartment',\n26:     description: 'A beautiful luxury apartment in the heart of downtown with stunning city views.',\n27:     price: 2500.0,\n28:     bedrooms: 2,\n29:     bathrooms: 1,\n30:     squareFeet: 950,\n31:     propertyType: PropertyTypeEnum.APARTMENT,\n32:     addressStreet: '123 Main St',\n33:     addressCity: 'New York',\n34:     addressState: 'NY',\n35:     addressZipCode: '10001',\n36:     addressLatitude: 40.7127753,\n37:     addressLongitude: -74.0059728,\n38:     availableFrom: '2026-06-01',\n39:   },\n40:   suburbanHouse: {\n41:     title: 'Spacious Suburban House',\n42:     description: 'A large family home in a quiet suburban neighborhood with a big backyard.',\n43:     price: 3200.0,\n44:     bedrooms: 4,\n45:     bathrooms: 2,\n46:     squareFeet: 2100,\n47:     propertyType: PropertyTypeEnum.HOUSE,\n48:     addressStreet: '456 Oak Ave',\n49:     addressCity: 'Austin',\n50:     addressState: 'TX',\n51:     addressZipCode: '78701',\n52:     addressLatitude: 30.267153,\n53:     addressLongitude: -97.743057,\n54:     availableFrom: '2026-07-01',\n55:   },\n56:   cheapStudio: {\n57:     title: 'Budget Studio',\n58:     description: 'A compact and affordable studio apartment perfect for singles.',\n59:     price: 900.0,\n60:     bedrooms: 0,\n61:     bathrooms: 1,\n62:     squareFeet: 400,\n63:     propertyType: PropertyTypeEnum.STUDIO,\n64:     addressStreet: '789 Pine Rd',\n65:     addressCity: 'Chicago',\n66:     addressState: 'IL',\n67:     addressZipCode: '60601',\n68:     addressLatitude: 41.878113,\n69:     addressLongitude: -87.629799,\n70:   },\n71: };\n72: \n73: export async function createTestProperty(\n74:   dataSource: DataSource,\n75:   data: TestPropertyData,\n76: ): Promise<Property> {\n77:   const repository = dataSource.getRepository(Property);\n78:   const property = repository.create(data);\n79:   return repository.save(property);\n80: }\n81: \n82: export async function seedTestProperties(\n83:   dataSource: DataSource,\n84: ): Promise<Record<string, Property>> {\n85:   const downtownApt = await createTestProperty(dataSource, testProperties.downtownApt);\n86:   const suburbanHouse = await createTestProperty(dataSource, testProperties.suburbanHouse);\n87:   const cheapStudio = await createTestProperty(dataSource, testProperties.cheapStudio);\n88:   return { downtownApt, suburbanHouse, cheapStudio };\n89: }\n90: \n91: export const testAmenities: Array<{ name: string; icon: string }> = [\n92:   { name: 'Parking', icon: 'parking' },\n93:   { name: 'Gym', icon: 'gym' },\n94:   { name: 'Pool', icon: 'pool' },\n95:   { name: 'Pet Friendly', icon: 'pet' },\n96: ];\n97: \n98: export async function seedTestAmenities(\n99:   dataSource: DataSource,\n100: ): Promise<Amenity[]> {\n101:   const repository = dataSource.getRepository(Amenity);\n102:   const amenities = repository.create(testAmenities);\n103:   return repository.save(amenities);\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"import { DataSource } from 'typeorm';\nimport { Property } from '../../src/modules/properties/entities/property.entity';\nimport { PropertyTypeEnum } from '../../src/common/enums/property-type.enum';\nimport { Amenity } from '../../src/modules/properties/entities/amenity.entity';\n\nexport interface TestPropertyData {\n  title: string;\n  description: string;\n  price: number;\n  bedrooms: number;\n  bathrooms: number;\n  squareFeet?: number;\n  propertyType: PropertyTypeEnum;\n  addressStreet: string;\n  addressCity: string;\n  addressState: string;\n  addressZipCode: string;\n  addressLatitude?: number;\n  addressLongitude?: number;\n  availableFrom?: string;","truncated":false,"loaded":[]},"title":"backend/test/fixtures/property.fixture.ts","time":{"start":1779246066606,"end":1779246066916}},"id":"prt_e43546596001Bv4trc9JTQyGK6","sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","messageID":"msg_e4354317e00168GirOe3kvO6TD"}}
{"type":"tool_use","timestamp":1779246068637,"sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","part":{"type":"tool","tool":"read","callID":"call_05_ZEqPJgL2LTqQzaVLLVHq0802","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/auth.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/auth.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import {\n9:   createTestUser,\n10:   seedTestUsers,\n11:   testUsers,\n12:   TEST_PASSWORD,\n13:   TestUserData,\n14: } from '../fixtures/user.fixture';\n15: import {\n16:   generateAccessToken,\n17:   generateRefreshToken,\n18:   generatePasswordResetToken,\n19:   authHeader,\n20:   refreshCookieHeader,\n21: } from '../fixtures/auth.fixture';\n22: import { User } from '../../src/modules/users/entities/user.entity';\n23: import { RoleEnum } from '../../src/common/enums/role.enum';\n24: import { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n25: \n26: // RED PHASE: These imports will fail because modules don't exist yet.\n27: // The tests define the expected API contract per PROJECT_API.md.\n28: // import { AuthModule } from '../../src/modules/auth/auth.module';\n29: \n30: describe('Auth E2E', () => {\n31:   let app: INestApplication;\n32:   let module: TestingModule;\n33:   let dataSource: DataSource;\n34: \n35:   beforeAll(async () => {\n36:     const context = await createTestApp();\n37:     app = context.app;\n38:     module = context.module;\n39:     dataSource = getDataSource(module);\n40:   });\n41: \n42:   afterAll(async () => {\n43:     await closeTestApp({ app, module });\n44:   });\n45: \n46:   beforeEach(async () => {\n47:     await cleanDatabase(dataSource);\n48:   });\n49: \n50:   // ─── POST /auth/register ───────────────────────────────────────────\n51:   describe('POST /api/auth/register', () => {\n52:     const validBody = {\n53:       name: 'Jane Doe',\n54:       email: 'jane@example.com',\n55:       password: 'SecurePass123!',\n56:       phone: '+15551234567',\n57:     };\n58: \n59:     it('should return 201 with user data on successful registration', async () => {\n60:       const res = await request(app.getHttpServer())\n61:         .post('/api/auth/register')\n62:         .send(validBody)\n63:         .expect(201);\n64: \n65:       expect(res.body.success).toBe(true);\n66:       expect(res.body.statusCode).toBe(201);\n67:       expect(res.body.message).toBe('User registered successfully');\n68:       expect(res.body.data).toHaveProperty('id');\n69:       expect(res.body.data).toHaveProperty('name', 'Jane Doe');\n70:       expect(res.body.data).toHaveProperty('email', 'jane@example.com');\n71:       expect(res.body.data).toHaveProperty('role', 'renter');\n72:       expect(res.body.data).toHaveProperty('status', 'active');\n73:       expect(res.body.data).toHaveProperty('createdAt');\n74:       expect(res.body.data).toHaveProperty('updatedAt');\n75:       expect(res.body).toHaveProperty('timestamp');\n76:       expect(res.body).toHaveProperty('path', '/api/auth/register');\n77:       // Should not expose password\n78:       expect(res.body.data).not.toHaveProperty('password');\n79:     });\n80: \n81:     it('should return 201 without optional phone field', async () => {\n82:       const { phone, ...bodyWithoutPhone } = validBody;\n83:       const res = await request(app.getHttpServer())\n84:         .post('/api/auth/register')\n85:         .send(bodyWithoutPhone)\n86:         .expect(201);\n87: \n88:       expect(res.body.data.phone).toBeNull();\n89:     });\n90: \n91:     it('should return 400 when name is missing', async () => {\n92:       const { name, ...body } = validBody;\n93:       await request(app.getHttpServer())\n94:         .post('/api/auth/register')\n95:         .send(body)\n96:         .expect(400);\n97:     });\n98: \n99:     it('should return 400 when name is too short (< 2 chars)', async () => {\n100:       await request(app.getHttpServer())\n101:         .post('/api/auth/register')\n102:         .send({ ...validBody, name: 'A' })\n103:         .expect(400);\n104:     });\n105: \n106:     it('should return 400 when name is too long (> 100 chars)', async () => {\n107:       await request(app.getHttpServer())\n108:         .post('/api/auth/register')\n109:         .send({ ...validBody, name: 'A'.repeat(101) })\n110:         .expect(400);\n111:     });\n112: \n113:     it('should return 400 when email is missing', async () => {\n114:       const { email, ...body } = validBody;\n115:       await request(app.getHttpServer())\n116:         .post('/api/auth/register')\n117:         .send(body)\n118:         .expect(400);\n119:     });\n120: \n121:     it('should return 400 when email is invalid format', async () => {\n122:       await request(app.getHttpServer())\n123:         .post('/api/auth/register')\n124:         .send({ ...validBody, email: 'not-an-email' })\n125:         .expect(400);\n126:     });\n127: \n128:     it('should return 400 when password is missing', async () => {\n129:       const { password, ...body } = validBody;\n130:       await request(app.getHttpServer())\n131:         .post('/api/auth/register')\n132:         .send(body)\n133:         .expect(400);\n134:     });\n135: \n136:     it('should return 400 when password is too short (< 8 chars)', async () => {\n137:       await request(app.getHttpServer())\n138:         .post('/api/auth/register')\n139:         .send({ ...validBody, password: 'Short1!' })\n140:         .expect(400);\n141:     });\n142: \n143:     it('should return 400 when phone exceeds max length (> 20 chars)', async () => {\n144:       await request(app.getHttpServer())\n145:         .post('/api/auth/register')\n146:         .send({ ...validBody, phone: '+1'.repeat(11) })\n147:         .expect(400);\n148:     });\n149: \n150:     it('should return 409 when email is already registered', async () => {\n151:       await createTestUser(dataSource, testUsers.renter);\n152:       await request(app.getHttpServer())\n153:         .post('/api/auth/register')\n154:         .send({ ...validBody, email: testUsers.renter.email })\n155:         .expect(409);\n156:     });\n157:   });\n158: \n159:   // ─── POST /auth/login ──────────────────────────────────────────────\n160:   describe('POST /api/auth/login', () => {\n161:     let testUser: User;\n162: \n163:     beforeEach(async () => {\n164:       testUser = await createTestUser(dataSource, testUsers.renter);\n165:     });\n166: \n167:     const validCredentials = {\n168:       email: testUsers.renter.email,\n169:       password: TEST_PASSWORD,\n170:     };\n171: \n172:     it('should return 200 with user data on successful login', async () => {\n173:       const res = await request(app.getHttpServer())\n174:         .post('/api/auth/login')\n175:         .send(validCredentials)\n176:         .expect(200);\n177: \n178:       expect(res.body.success).toBe(true);\n179:       expect(res.body.statusCode).toBe(200);\n180:       expect(res.body.message).toBe('Login successful');\n181:       expect(res.body.data).toHaveProperty('user');\n182:       expect(res.body.data.user).toHaveProperty('id');\n183:       expect(res.body.data.user).toHaveProperty('name');\n184:       expect(res.body.data.user).toHaveProperty('email');\n185:       expect(res.body.data.user).toHaveProperty('role');\n186:       expect(res.body.data.user).toHaveProperty('status');\n187:       expect(res.body.data.user).not.toHaveProperty('password');\n188:       expect(res.body).toHaveProperty('timestamp');\n189:       expect(res.body).toHaveProperty('path', '/api/auth/login');\n190:     });\n191: \n192:     it('should set access_token and refresh_token httpOnly cookies', async () => {\n193:       const res = await request(app.getHttpServer())\n194:         .post('/api/auth/login')\n195:         .send(validCredentials)\n196:         .expect(200);\n197: \n198:       const cookies = res.headers['set-cookie'];\n199:       expect(cookies).toBeDefined();\n200:       const cookieStr = Array.isArray(cookies) ? cookies.join('; ') : cookies;\n201:       expect(cookieStr).toContain('access_token');\n202:       expect(cookieStr).toContain('refresh_token');\n203:     });\n204: \n205:     it('should return 400 when email is missing', async () => {\n206:       await request(app.getHttpServer())\n207:         .post('/api/auth/login')\n208:         .send({ password: TEST_PASSWORD })\n209:         .expect(400);\n210:     });\n211: \n212:     it('should return 400 when password is missing', async () => {\n213:       await request(app.getHttpServer())\n214:         .post('/api/auth/login')\n215:         .send({ email: testUsers.renter.email })\n216:         .expect(400);\n217:     });\n218: \n219:     it('should return 400 when body is empty', async () => {\n220:       await request(app.getHttpServer())\n221:         .post('/api/auth/login')\n222:         .send({})\n223:         .expect(400);\n224:     });\n225: \n226:     it('should return 401 with invalid email', async () => {\n227:       await request(app.getHttpServer())\n228:         .post('/api/auth/login')\n229:         .send({ email: 'wrong@test.com', password: TEST_PASSWORD })\n230:         .expect(401);\n231:     });\n232: \n233:     it('should return 401 with invalid password', async () => {\n234:       await request(app.getHttpServer())\n235:         .post('/api/auth/login')\n236:         .send({ email: testUsers.renter.email, password: 'WrongPass1!' })\n237:         .expect(401);\n238:     });\n239: \n240:     it('should return 403 when account is suspended', async () => {\n241:       const suspended = await createTestUser(dataSource, testUsers.suspendedRenter);\n242:       await request(app.getHttpServer())\n243:         .post('/api/auth/login')\n244:         .send({ email: suspended.email, password: TEST_PASSWORD })\n245:         .expect(403);\n246:     });\n247:   });\n248: \n249:   // ─── POST /auth/logout ─────────────────────────────────────────────\n250:   describe('POST /api/auth/logout', () => {\n251:     it('should return 200 and clear cookies on successful logout', async () => {\n252:       const user = await createTestUser(dataSource, testUsers.renter);\n253:       const token = generateAccessToken(user);\n254: \n255:       const res = await request(app.getHttpServer())\n256:         .post('/api/auth/logout')\n257:         .set(authHeader(token))\n258:         .expect(200);\n259: \n260:       expect(res.body.success).toBe(true);\n261:       expect(res.body.statusCode).toBe(200);\n262:       expect(res.body.message).toBe('Logged out successfully');\n263:       expect(res.body.data).toBeNull();\n264:       expect(res.body).toHaveProperty('timestamp');\n265:       expect(res.body).toHaveProperty('path', '/api/auth/logout');\n266: \n267:       // Cookies should be cleared\n268:       const cookies = res.headers['set-cookie'];\n269:       expect(cookies).toBeDefined();\n270:     });\n271: \n272:     it('should return 401 when not authenticated', async () => {\n273:       await request(app.getHttpServer())\n274:         .post('/api/auth/logout')\n275:         .expect(401);\n276:     });\n277: \n278:     it('should return 401 with invalid token', async () => {\n279:       await request(app.getHttpServer())\n280:         .post('/api/auth/logout')\n281:         .set(authHeader('invalid-token'))\n282:         .expect(401);\n283:     });\n284:   });\n285: \n286:   // ─── POST /auth/refresh ────────────────────────────────────────────\n287:   describe('POST /api/auth/refresh', () => {\n288:     it('should return 200 with new tokens on successful refresh', async () => {\n289:       const user = await createTestUser(dataSource, testUsers.renter);\n290:       const refreshToken = generateRefreshToken(user);\n291: \n292:       const res = await request(app.getHttpServer())\n293:         .post('/api/auth/refresh')\n294:         .set(refreshCookieHeader(refreshToken))\n295:         .expect(200);\n296: \n297:       expect(res.body.success).toBe(true);\n298:       expect(res.body.statusCode).toBe(200);\n299:       expect(res.body.message).toBe('Token refreshed successfully');\n300:       expect(res.body.data).toHaveProperty('user');\n301:       expect(res.body.data.user).toHaveProperty('id', user.id);\n302:       expect(res.body.data.user).toHaveProperty('name');\n303:       expect(res.body.data.user).toHaveProperty('email');\n304:       expect(res.body.data.user).toHaveProperty('role');\n305:       expect(res.body.data.user).not.toHaveProperty('password');\n306:     });\n307: \n308:     it('should return 401 when no refresh token cookie provided', async () => {\n309:       await request(app.getHttpServer())\n310:         .post('/api/auth/refresh')\n311:         .expect(401);\n312:     });\n313: \n314:     it('should return 401 with invalid refresh token', async () => {\n315:       await request(app.getHttpServer())\n316:         .post('/api/auth/refresh')\n317:         .set(refreshCookieHeader('invalid-refresh-token'))\n318:         .expect(401);\n319:     });\n320: \n321:     it('should return 401 with revoked refresh token', async () => {\n322:       const user = await createTestUser(dataSource, testUsers.renter);\n323:       const refreshToken = generateRefreshToken(user);\n324: \n325:       // First refresh rotates the token (revokes old one)\n326:       await request(app.getHttpServer())\n327:         .post('/api/auth/refresh')\n328:         .set(refreshCookieHeader(refreshToken))\n329:         .expect(200);\n330: \n331:       // Second refresh with same (now revoked) token should fail\n332:       await request(app.getHttpServer())\n333:         .post('/api/auth/refresh')\n334:         .set(refreshCookieHeader(refreshToken))\n335:         .expect(401);\n336:     });\n337:   });\n338: \n339:   // ─── POST /auth/forgot-password ────────────────────────────────────\n340:   describe('POST /api/auth/forgot-password', () => {\n341:     it('should return 200 even for unknown email (prevents enumeration)', async () => {\n342:       const res = await request(app.getHttpServer())\n343:         .post('/api/auth/forgot-password')\n344:         .send({ email: 'unknown@test.com' })\n345:         .expect(200);\n346: \n347:       expect(res.body.success).toBe(true);\n348:       expect(res.body.statusCode).toBe(200);\n349:       expect(res.body.message).toContain('If an account with that email exists');\n350:       expect(res.body.data).toBeNull();\n351:     });\n352: \n353:     it('should return 200 for existing user email', async () => {\n354:       await createTestUser(dataSource, testUsers.renter);\n355: \n356:       const res = await request(app.getHttpServer())\n357:         .post('/api/auth/forgot-password')\n358:         .send({ email: testUsers.renter.email })\n359:         .expect(200);\n360: \n361:       expect(res.body.success).toBe(true);\n362:       expect(res.body.statusCode).toBe(200);\n363:       expect(res.body.data).toBeNull();\n364:     });\n365: \n366:     it('should return 400 when email is missing', async () => {\n367:       await request(app.getHttpServer())\n368:         .post('/api/auth/forgot-password')\n369:         .send({})\n370:         .expect(400);\n371:     });\n372: \n373:     it('should return 400 when email is invalid format', async () => {\n374:       await request(app.getHttpServer())\n375:         .post('/api/auth/forgot-password')\n376:         .send({ email: 'not-an-email' })\n377:         .expect(400);\n378:     });\n379:   });\n380: \n381:   // ─── POST /auth/reset-password ─────────────────────────────────────\n382:   describe('POST /api/auth/reset-password', () => {\n383:     let testUser: User;\n384: \n385:     beforeEach(async () => {\n386:       testUser = await createTestUser(dataSource, testUsers.renter);\n387:     });\n388: \n389:     it('should return 200 on successful password reset', async () => {\n390:       const resetToken = generatePasswordResetToken(testUser);\n391: \n392:       const res = await request(app.getHttpServer())\n393:         .post('/api/auth/reset-password')\n394:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n395:         .expect(200);\n396: \n397:       expect(res.body.success).toBe(true);\n398:       expect(res.body.statusCode).toBe(200);\n399:       expect(res.body.message).toBe('Password reset successfully');\n400:       expect(res.body.data).toBeNull();\n401:     });\n402: \n403:     it('should return 400 when token is missing', async () => {\n404:       await request(app.getHttpServer())\n405:         .post('/api/auth/reset-password')\n406:         .send({ password: 'NewSecurePass456!' })\n407:         .expect(400);\n408:     });\n409: \n410:     it('should return 400 when password is missing', async () => {\n411:       const resetToken = generatePasswordResetToken(testUser);\n412:       await request(app.getHttpServer())\n413:         .post('/api/auth/reset-password')\n414:         .send({ token: resetToken })\n415:         .expect(400);\n416:     });\n417: \n418:     it('should return 400 when password is too short (< 8 chars)', async () => {\n419:       const resetToken = generatePasswordResetToken(testUser);\n420:       await request(app.getHttpServer())\n421:         .post('/api/auth/reset-password')\n422:         .send({ token: resetToken, password: 'Short1!' })\n423:         .expect(400);\n424:     });\n425: \n426:     it('should return 404 when token is invalid/not found', async () => {\n427:       await request(app.getHttpServer())\n428:         .post('/api/auth/reset-password')\n429:         .send({ token: 'invalid-reset-token', password: 'NewSecurePass456!' })\n430:         .expect(404);\n431:     });\n432: \n433:     it('should return 400 when token is expired', async () => {\n434:       // Token expiry is handled by the implementation;\n435:       // tests will need DB-level token manipulation in GREEN phase\n436:       const resetToken = generatePasswordResetToken(testUser);\n437:       // In GREEN phase, manually set expiresAt to the past\n438:       await request(app.getHttpServer())\n439:         .post('/api/auth/reset-password')\n440:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n441:         .expect(200);\n442:       // NOTE: This test will need refinement in GREEN phase to\n443:       // create an expired PasswordResetToken in the database\n444:     });\n445:   });\n446: \n447:   // ─── GET /auth/me ─────────────────────────────────────────────────\n448:   describe('GET /api/auth/me', () => {\n449:     it('should return 200 with current user profile', async () => {\n450:       const user = await createTestUser(dataSource, testUsers.renter);\n451:       const token = generateAccessToken(user);\n452: \n453:       const res = await request(app.getHttpServer())\n454:         .get('/api/auth/me')\n455:         .set(authHeader(token))\n456:         .expect(200);\n457: \n458:       expect(res.body.success).toBe(true);\n459:       expect(res.body.statusCode).toBe(200);\n460:       expect(res.body.message).toBe('User retrieved successfully');\n461:       expect(res.body.data).toHaveProperty('id', user.id);\n462:       expect(res.body.data).toHaveProperty('name', user.name);\n463:       expect(res.body.data).toHaveProperty('email', user.email);\n464:       expect(res.body.data).toHaveProperty('role', user.role);\n465:       expect(res.body.data).toHaveProperty('status', user.status);\n466:       expect(res.body.data).toHaveProperty('emailVerifiedAt');\n467:       expect(res.body.data).toHaveProperty('createdAt');\n468:       expect(res.body.data).toHaveProperty('updatedAt');\n469:       expect(res.body.data).not.toHaveProperty('password');\n470:     });\n471: \n472:     it('should return 401 when not authenticated', async () => {\n473:       await request(app.getHttpServer())\n474:         .get('/api/auth/me')\n475:         .expect(401);\n476:     });\n477: \n478:     it('should return 401 with invalid token', async () => {\n479:       await request(app.getHttpServer())\n480:         .get('/api/auth/me')\n481:         .set(authHeader('invalid-token'))\n482:         .expect(401);\n483:     });\n484: \n485:     it('should return correct role for admin user', async () => {\n486:       const admin = await createTestUser(dataSource, testUsers.admin);\n487:       const token = generateAccessToken(admin);\n488: \n489:       const res = await request(app.getHttpServer())\n490:         .get('/api/auth/me')\n491:         .set(authHeader(token))\n492:         .expect(200);\n493: \n494:       expect(res.body.data.role).toBe('admin');\n495:     });\n496:   });\n497: });\n\n(End of file - total 497 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport {\n  createTestUser,\n  seedTestUsers,\n  testUsers,\n  TEST_PASSWORD,\n  TestUserData,\n} from '../fixtures/user.fixture';\nimport {\n  generateAccessToken,\n  generateRefreshToken,\n  generatePasswordResetToken,\n  authHeader,\n  refreshCookieHeader,","truncated":false,"loaded":[]},"title":"backend/test/e2e/auth.e2e-spec.ts","time":{"start":1779246068225,"end":1779246068634}},"id":"prt_e43546c52001xohlDSFYyN1QzB","sessionID":"ses_1bcacaf85ffekWeHxJzinOBzsU","messageID":"msg_e4354317e00168GirOe3kvO6TD"}}
