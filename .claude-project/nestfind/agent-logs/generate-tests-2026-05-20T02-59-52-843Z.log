:   return bcrypt.hash(password, 10);\n52: }\n53: \n54: export async function createTestUser(\n55:   dataSource: DataSource,\n56:   userData: TestUserData,\n57: ): Promise<User> {\n58:   const repository = dataSource.getRepository(User);\n59:   const hashedPassword = await hashPassword(userData.password);\n60:   const user = repository.create({\n61:     ...userData,\n62:     password: hashedPassword,\n63:   });\n64:   return repository.save(user);\n65: }\n66: \n67: export async function seedTestUsers(\n68:   dataSource: DataSource,\n69: ): Promise<Record<string, User>> {\n70:   const renter = await createTestUser(dataSource, testUsers.renter);\n71:   const renter2 = await createTestUser(dataSource, testUsers.renter2);\n72:   const admin = await createTestUser(dataSource, testUsers.admin);\n73:   const suspended = await createTestUser(dataSource, testUsers.suspendedRenter);\n74:   return { renter, renter2, admin, suspended };\n75: }\n76: \n77: export async function createUsers(\n78:   dataSource: DataSource,\n79:   users: TestUserData[],\n80: ): Promise<User[]> {\n81:   return Promise.all(users.map((u) => createTestUser(dataSource, u)));\n82: }\n\n(End of file - total 82 lines)\n</content>","metadata":{"preview":"import { DataSource } from 'typeorm';\nimport * as bcrypt from 'bcrypt';\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { RoleEnum } from '../../src/common/enums/role.enum';\nimport { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n\nexport const TEST_PASSWORD = 'TestPass123!';\n\nexport interface TestUserData {\n  name: string;\n  email: string;\n  password: string;\n  phone?: string;\n  role: RoleEnum;\n  status: UserStatusEnum;\n}\n\nexport const testUsers: Record<string, TestUserData> = {\n  renter: {\n    name: 'Test Renter',","truncated":false,"loaded":[]},"title":"backend/test/fixtures/user.fixture.ts","time":{"start":1779246062975,"end":1779246063285}},"id":"prt_e435458ce001OeaWevOXyQBl1p","sessionID":