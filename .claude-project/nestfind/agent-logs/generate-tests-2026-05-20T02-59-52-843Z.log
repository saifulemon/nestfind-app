 (res.body.data.length > 0) {\n628:         const photo = res.body.data[0];\n629:         expect(photo).toHaveProperty('id');\n630:         expect(photo).toHaveProperty('url');\n631:         expect(photo).toHaveProperty('isPrimary');\n632:         expect(photo).toHaveProperty('sortOrder');\n633:       }\n634:     });\n635: \n636:     it('should return 400 when no file provided', async () => {\n637:       await request(app.getHttpServer())\n638:         .post(`/api/properties/${property.id}/photos`)\n639:         .set(authHeader(adminToken))\n640:         .expect(400);\n641:     });\n642: \n643:     it('should return 401 when not authenticated', async () => {\n644:       await request(app.getHttpServer())\n645:         .post(`/api/properties/${property.id}/photos`)\n646:         .attach('files', Buffer.from('fake'), 'test.jpg')\n647:         .expect(401);\n648:     });\n649: \n650:     it('should return 403 when authenticated as renter', async () => {\n651:       await request(app.getHttpServer())\n652:         .post(`/api/properties/${property.id}/photos`)\n653:         .set(authHeader(renterToken))\n654:         .attach('files', Buffer.from('fake'), 'test.jpg')\n655:         .expect(403);\n656:     });\n657: \n658:     it('should return 404 when property not found', async () => {\n659:       await request(app.getHttpServer())\n660:         .post('/api/properties/00000000-0000-0000-0000-000000000000/photos')\n661:         .set(authHeader(adminToken))\n662:         .attach('files', Buffer.from('fake'), 'test.jpg')\n663:         .expect(404);\n664:     });\n665:   });\n666: \n667:   // ─── DELETE /properties/:id/photos/:photoId ────────────────────────\n668:   describe('DELETE /api/properties/:id/photos/:photoId', () => {\n669:     it('should return 200 when photo deleted (admin only)', async () => {\n670:       // This test requires a photo to exist first.\n671:       // In GREEN phase: upload a photo, then delete it.\n672:       // For RED phase, test the auth/validation contract.\n673:       const photoId = '00000000-0000-0000-0000-000000000001';\n674:       const propertyId = '00000000-0000-0000-0000-000000000002';\n675: \n676:       // Will 404 because neither photo nor property exists in RED phase\n677:       await request(app.getHttpServer())\n678:         .delete(`/api/properties/${propertyId}/photos/${photoId}`)\n679:         .set(authHeader(adminToken))\n680:         .expect(404);\n681:       // NOTE: In GREEN phase, change to expect(200) with real seeded data\n682:     });\n683: \n684:     it('should return 400 for invalid UUID format', async () => {\n685:       await request(app.getHttpServer())\n686:         .delete('/api/properties/not-a-uuid/photos/not-a-uuid')\n687:         .set(authHeader(adminToken))\n688:         .expect(400);\n689:     });\n690: \n691:     it('should return 401 when not authenticated', async () => {\n692:       await request(app.getHttpServer())\n693:         .delete('/api/properties/some-id/photos/some-photo-id')\n694:         .expect(401);\n695:     });\n696: \n697:     it('should return 403 when authenticated as renter', async () => {\n698:       await request(app.getHttpServer())\n699:         .delete('/api/properties/some-id/photos/some-photo-id')\n700:         .set(authHeader(renterToken))\n701:         .expect(403);\n702:     });\n703: \n704:     it('should return 404 when property not found', async () => {\n705:       await request(app.getHttpServer())\n706:         .delete('/api/properties/00000000-0000-0000-0000-000000000000/photos/00000000-0000-0000-0000-000000000001')\n707:         .set(authHeader(adminToken))\n708:         .expect(404);\n709:     });\n710: \n711:     it('should return 404 when photo not found for existing property', async () => {\n712:       const seeded = await seedTestProperties(dataSource);\n713:       const property = seeded.downtownApt;\n714: \n715:       await request(app.getHttpServer())\n716:         .delete(`/api/properties/${property.id}/photos/00000000