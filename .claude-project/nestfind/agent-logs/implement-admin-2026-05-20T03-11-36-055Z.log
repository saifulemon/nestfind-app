{"type":"tool_use","timestamp":1779246741186,"sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","part":{"type":"tool","tool":"read","callID":"call_01_sPOeS25VAIUlO2bU9NYd0895","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/admin/admin.controller.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/admin/admin.controller.ts</path>\n<type>file</type>\n<content>\n1: import { Controller, Get } from '@nestjs/common';\n2: import { InjectDataSource } from '@nestjs/typeorm';\n3: import { DataSource } from 'typeorm';\n4: import { Roles } from '../../core/decorators/roles.decorator';\n5: import { Property } from '../properties/entities/property.entity';\n6: import { Inquiry } from '../inquiries/entities/inquiry.entity';\n7: import { User } from '../users/entities/user.entity';\n8: \n9: @Controller('admin')\n10: @Roles('admin')\n11: export class AdminController {\n12:   constructor(@InjectDataSource() private readonly dataSource: DataSource) {}\n13: \n14:   @Get('dashboard/stats')\n15:   async dashboardStats() {\n16:     const [totalProperties, totalInquiries, totalUsers] = await Promise.all([\n17:       this.dataSource.getRepository(Property).count(),\n18:       this.dataSource.getRepository(Inquiry).count(),\n19:       this.dataSource.getRepository(User).count(),\n20:     ]);\n21: \n22:     return {\n23:       message: 'Dashboard stats retrieved successfully',\n24:       data: { totalProperties, totalInquiries, totalUsers },\n25:     };\n26:   }\n27: }\n\n(End of file - total 27 lines)\n</content>","metadata":{"preview":"import { Controller, Get } from '@nestjs/common';\nimport { InjectDataSource } from '@nestjs/typeorm';\nimport { DataSource } from 'typeorm';\nimport { Roles } from '../../core/decorators/roles.decorator';\nimport { Property } from '../properties/entities/property.entity';\nimport { Inquiry } from '../inquiries/entities/inquiry.entity';\nimport { User } from '../users/entities/user.entity';\n\n@Controller('admin')\n@Roles('admin')\nexport class AdminController {\n  constructor(@InjectDataSource() private readonly dataSource: DataSource) {}\n\n  @Get('dashboard/stats')\n  async dashboardStats() {\n    const [totalProperties, totalInquiries, totalUsers] = await Promise.all([\n      this.dataSource.getRepository(Property).count(),\n      this.dataSource.getRepository(Inquiry).count(),\n      this.dataSource.getRepository(User).count(),\n    ]);","truncated":false,"loaded":[]},"title":"backend/src/modules/admin/admin.controller.ts","time":{"start":1779246740909,"end":1779246741185}},"id":"prt_e435eb08b001ARjkwfAreCp71Z","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435e92eb001Skkv63Ht1xAgN4"}}
{"type":"tool_use","timestamp":1779246743021,"sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","part":{"type":"tool","tool":"read","callID":"call_02_wfwMMCc4BpTyVU6Lr4KQ4989","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-users.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-users.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\n9: import { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\n10: import { User } from '../../src/modules/users/entities/user.entity';\n11: import { RoleEnum } from '../../src/common/enums/role.enum';\n12: import { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n13: \n14: // RED PHASE: These imports will fail because modules don't exist yet.\n15: // import { AdminModule } from '../../src/modules/admin/admin.module';\n16: \n17: describe('Admin Users E2E', () => {\n18:   let app: INestApplication;\n19:   let module: TestingModule;\n20:   let dataSource: DataSource;\n21:   let adminToken: string;\n22:   let renterToken: string;\n23:   let adminUser: User;\n24:   let renterUser: User;\n25: \n26:   beforeAll(async () => {\n27:     const context = await createTestApp();\n28:     app = context.app;\n29:     module = context.module;\n30:     dataSource = getDataSource(module);\n31:   });\n32: \n33:   afterAll(async () => {\n34:     await closeTestApp({ app, module });\n35:   });\n36: \n37:   beforeEach(async () => {\n38:     await cleanDatabase(dataSource);\n39:     const seeded = await seedTestUsers(dataSource);\n40:     adminUser = seeded.admin;\n41:     renterUser = seeded.renter;\n42:     adminToken = generateAccessToken(adminUser);\n43:     renterToken = generateAccessToken(renterUser);\n44:   });\n45: \n46:   // ─── GET /admin/users (List) ───────────────────────────────────────\n47:   describe('GET /api/admin/users', () => {\n48:     it('should return 200 with paginated users list (admin only)', async () => {\n49:       const res = await request(app.getHttpServer())\n50:         .get('/api/admin/users')\n51:         .set(authHeader(adminToken))\n52:         .expect(200);\n53: \n54:       expect(res.body.success).toBe(true);\n55:       expect(res.body.statusCode).toBe(200);\n56:       expect(res.body.message).toBe('Users retrieved successfully');\n57:       expect(res.body.data).toHaveProperty('items');\n58:       expect(res.body.data).toHaveProperty('meta');\n59:       expect(res.body.data.meta).toHaveProperty('total');\n60:       expect(res.body.data.meta).toHaveProperty('page', 1);\n61:       expect(res.body.data.meta).toHaveProperty('limit');\n62:       expect(res.body.data.meta).toHaveProperty('totalPages');\n63:       expect(Array.isArray(res.body.data.items)).toBe(true);\n64:       expect(res.body).toHaveProperty('timestamp');\n65:       expect(res.body).toHaveProperty('path', '/api/admin/users');\n66:     });\n67: \n68:     it('should return user items with correct shape', async () => {\n69:       const res = await request(app.getHttpServer())\n70:         .get('/api/admin/users')\n71:         .set(authHeader(adminToken))\n72:         .expect(200);\n73: \n74:       if (res.body.data.items.length > 0) {\n75:         const item = res.body.data.items[0];\n76:         expect(item).toHaveProperty('id');\n77:         expect(item).toHaveProperty('name');\n78:         expect(item).toHaveProperty('email');\n79:         expect(item).toHaveProperty('phone');\n80:         expect(item).toHaveProperty('role');\n81:         expect(item).toHaveProperty('status');\n82:         expect(item).toHaveProperty('emailVerifiedAt');\n83:         expect(item).toHaveProperty('createdAt');\n84:         // Admin user list should NOT expose passwords\n85:         expect(item).not.toHaveProperty('password');\n86:       }\n87:     });\n88: \n89:     it('should include all seeded users in list', async () => {\n90:       const res = await request(app.getHttpServer())\n91:         .get('/api/admin/users')\n92:         .set(authHeader(adminToken))\n93:         .expect(200);\n94: \n95:       // 4 users: renter, renter2, admin, suspendedRenter\n96:       expect(res.body.data.meta.total).toBe(4);\n97:     });\n98: \n99:     it('should support filtering by role', async () => {\n100:       const res = await request(app.getHttpServer())\n101:         .get('/api/admin/users?role=renter')\n102:         .set(authHeader(adminToken))\n103:         .expect(200);\n104: \n105:       for (const item of res.body.data.items) {\n106:         expect(item.role).toBe('renter');\n107:       }\n108:     });\n109: \n110:     it('should support filtering by status', async () => {\n111:       const res = await request(app.getHttpServer())\n112:         .get('/api/admin/users?status=active')\n113:         .set(authHeader(adminToken))\n114:         .expect(200);\n115: \n116:       for (const item of res.body.data.items) {\n117:         expect(item.status).toBe('active');\n118:       }\n119:     });\n120: \n121:     it('should support filtering by status=suspended', async () => {\n122:       const res = await request(app.getHttpServer())\n123:         .get('/api/admin/users?status=suspended')\n124:         .set(authHeader(adminToken))\n125:         .expect(200);\n126: \n127:       for (const item of res.body.data.items) {\n128:         expect(item.status).toBe('suspended');\n129:       }\n130:     });\n131: \n132:     it('should support search by name or email', async () => {\n133:       const res = await request(app.getHttpServer())\n134:         .get(`/api/admin/users?search=${encodeURIComponent(renterUser.name)}`)\n135:         .set(authHeader(adminToken))\n136:         .expect(200);\n137: \n138:       expect(res.body.data.items.length).toBeGreaterThanOrEqual(1);\n139:     });\n140: \n141:     it('should support sorting by newest', async () => {\n142:       await request(app.getHttpServer())\n143:         .get('/api/admin/users?sortBy=newest')\n144:         .set(authHeader(adminToken))\n145:         .expect(200);\n146:     });\n147: \n148:     it('should support sorting by oldest', async () => {\n149:       await request(app.getHttpServer())\n150:         .get('/api/admin/users?sortBy=oldest')\n151:         .set(authHeader(adminToken))\n152:         .expect(200);\n153:     });\n154: \n155:     it('should support sorting by name_asc', async () => {\n156:       await request(app.getHttpServer())\n157:         .get('/api/admin/users?sortBy=name_asc')\n158:         .set(authHeader(adminToken))\n159:         .expect(200);\n160:     });\n161: \n162:     it('should support sorting by name_desc', async () => {\n163:       await request(app.getHttpServer())\n164:         .get('/api/admin/users?sortBy=name_desc')\n165:         .set(authHeader(adminToken))\n166:         .expect(200);\n167:     });\n168: \n169:     it('should support pagination with page and limit', async () => {\n170:       const res = await request(app.getHttpServer())\n171:         .get('/api/admin/users?page=1&limit=2')\n172:         .set(authHeader(adminToken))\n173:         .expect(200);\n174: \n175:       expect(res.body.data.meta.page).toBe(1);\n176:       expect(res.body.data.meta.limit).toBe(2);\n177:     });\n178: \n179:     it('should return 401 when not authenticated', async () => {\n180:       await request(app.getHttpServer())\n181:         .get('/api/admin/users')\n182:         .expect(401);\n183:     });\n184: \n185:     it('should return 403 when authenticated as renter (admin only)', async () => {\n186:       await request(app.getHttpServer())\n187:         .get('/api/admin/users')\n188:         .set(authHeader(renterToken))\n189:         .expect(403);\n190:     });\n191:   });\n192: \n193:   // ─── GET /admin/users/:id (Detail) ─────────────────────────────────\n194:   describe('GET /api/admin/users/:id', () => {\n195:     it('should return 200 with full user detail (admin only)', async () => {\n196:       const res = await request(app.getHttpServer())\n197:         .get(`/api/admin/users/${renterUser.id}`)\n198:         .set(authHeader(adminToken))\n199:         .expect(200);\n200: \n201:       expect(res.body.success).toBe(true);\n202:       expect(res.body.statusCode).toBe(200);\n203:       expect(res.body.message).toBe('User retrieved successfully');\n204:       expect(res.body.data).toHaveProperty('id', renterUser.id);\n205:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n206:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n207:       expect(res.body.data).toHaveProperty('phone');\n208:       expect(res.body.data).toHaveProperty('role', renterUser.role);\n209:       expect(res.body.data).toHaveProperty('status', renterUser.status);\n210:       expect(res.body.data).toHaveProperty('emailVerifiedAt');\n211:       expect(res.body.data).toHaveProperty('activity');\n212:       expect(res.body.data.activity).toHaveProperty('totalFavorites');\n213:       expect(res.body.data.activity).toHaveProperty('totalInquiries');\n214:       expect(res.body.data.activity).toHaveProperty('lastLoginAt');\n215:       expect(res.body.data).toHaveProperty('createdAt');\n216:       expect(res.body.data).toHaveProperty('updatedAt');\n217:       expect(res.body.data).not.toHaveProperty('password');\n218:     });\n219: \n220:     it('should return non-negative integers for activity counts', async () => {\n221:       const res = await request(app.getHttpServer())\n222:         .get(`/api/admin/users/${renterUser.id}`)\n223:         .set(authHeader(adminToken))\n224:         .expect(200);\n225: \n226:       expect(typeof res.body.data.activity.totalFavorites).toBe('number');\n227:       expect(res.body.data.activity.totalFavorites).toBeGreaterThanOrEqual(0);\n228:       expect(typeof res.body.data.activity.totalInquiries).toBe('number');\n229:       expect(res.body.data.activity.totalInquiries).toBeGreaterThanOrEqual(0);\n230:     });\n231: \n232:     it('should show admin user correctly', async () => {\n233:       const res = await request(app.getHttpServer())\n234:         .get(`/api/admin/users/${adminUser.id}`)\n235:         .set(authHeader(adminToken))\n236:         .expect(200);\n237: \n238:       expect(res.body.data.role).toBe('admin');\n239:       expect(res.body.data.status).toBe('active');\n240:     });\n241: \n242:     it('should show suspended user correctly', async () => {\n243:       const suspended = await createTestUser(dataSource, testUsers.suspendedRenter);\n244: \n245:       const res = await request(app.getHttpServer())\n246:         .get(`/api/admin/users/${suspended.id}`)\n247:         .set(authHeader(adminToken))\n248:         .expect(200);\n249: \n250:       expect(res.body.data.status).toBe('suspended');\n251:     });\n252: \n253:     it('should return 400 for invalid UUID', async () => {\n254:       await request(app.getHttpServer())\n255:         .get('/api/admin/users/not-a-uuid')\n256:         .set(authHeader(adminToken))\n257:         .expect(400);\n258:     });\n259: \n260:     it('should return 401 when not authenticated', async () => {\n261:       await request(app.getHttpServer())\n262:         .get(`/api/admin/users/${renterUser.id}`)\n263:         .expect(401);\n264:     });\n265: \n266:     it('should return 403 when authenticated as renter (admin only)', async () => {\n267:       await request(app.getHttpServer())\n268:         .get(`/api/admin/users/${renterUser.id}`)\n269:         .set(authHeader(renterToken))\n270:         .expect(403);\n271:     });\n272: \n273:     it('should return 404 when user not found', async () => {\n274:       await request(app.getHttpServer())\n275:         .get('/api/admin/users/00000000-0000-0000-0000-000000000000')\n276:         .set(authHeader(adminToken))\n277:         .expect(404);\n278:     });\n279:   });\n280: \n281:   // ─── PATCH /admin/users/:id/status ─────────────────────────────────\n282:   describe('PATCH /api/admin/users/:id/status', () => {\n283:     it('should return 200 when suspending a user (admin only)', async () => {\n284:       const res = await request(app.getHttpServer())\n285:         .patch(`/api/admin/users/${renterUser.id}/status`)\n286:         .set(authHeader(adminToken))\n287:         .send({ status: 'suspended' })\n288:         .expect(200);\n289: \n290:       expect(res.body.success).toBe(true);\n291:       expect(res.body.statusCode).toBe(200);\n292:       expect(res.body.message).toBe(\"User status updated to 'suspended'\");\n293:       expect(res.body.data).toHaveProperty('id', renterUser.id);\n294:       expect(res.body.data).toHaveProperty('name', renterUser.name);\n295:       expect(res.body.data).toHaveProperty('email', renterUser.email);\n296:       expect(res.body.data).toHaveProperty('status', 'suspended');\n297:       expect(res.body.data).toHaveProperty('updatedAt');\n298:     });\n299: \n300:     it('should return 200 when reactivating a suspended user', async () => {\n301:       // First suspend\n302:       await request(app.getHttpServer())\n303:         .patch(`/api/admin/users/${renterUser.id}/status`)\n304:         .set(authHeader(adminToken))\n305:         .send({ status: 'suspended' })\n306:         .expect(200);\n307: \n308:       // Then reactivate\n309:       const res = await request(app.getHttpServer())\n310:         .patch(`/api/admin/users/${renterUser.id}/status`)\n311:         .set(authHeader(adminToken))\n312:         .send({ status: 'active' })\n313:         .expect(200);\n314: \n315:       expect(res.body.data.status).toBe('active');\n316:       expect(res.body.message).toBe(\"User status updated to 'active'\");\n317:     });\n318: \n319:     it('should return 400 when status is missing', async () => {\n320:       await request(app.getHttpServer())\n321:         .patch(`/api/admin/users/${renterUser.id}/status`)\n322:         .set(authHeader(adminToken))\n323:         .send({})\n324:         .expect(400);\n325:     });\n326: \n327:     it('should return 400 when status is invalid value', async () => {\n328:       await request(app.getHttpServer())\n329:         .patch(`/api/admin/users/${renterUser.id}/status`)\n330:         .set(authHeader(adminToken))\n331:         .send({ status: 'invalid-status' })\n332:         .expect(400);\n333:     });\n334: \n335:     it('should return 400 when admin tries to suspend their own account', async () => {\n336:       await request(app.getHttpServer())\n337:         .patch(`/api/admin/users/${adminUser.id}/status`)\n338:         .set(authHeader(adminToken))\n339:         .send({ status: 'suspended' })\n340:         .expect(400);\n341:     });\n342: \n343:     it('should return 400 for invalid UUID', async () => {\n344:       await request(app.getHttpServer())\n345:         .patch('/api/admin/users/not-a-uuid/status')\n346:         .set(authHeader(adminToken))\n347:         .send({ status: 'active' })\n348:         .expect(400);\n349:     });\n350: \n351:     it('should return 401 when not authenticated', async () => {\n352:       await request(app.getHttpServer())\n353:         .patch(`/api/admin/users/${renterUser.id}/status`)\n354:         .send({ status: 'suspended' })\n355:         .expect(401);\n356:     });\n357: \n358:     it('should return 403 when authenticated as renter (admin only)', async () => {\n359:       await request(app.getHttpServer())\n360:         .patch(`/api/admin/users/${renterUser.id}/status`)\n361:         .set(authHeader(renterToken))\n362:         .send({ status: 'suspended' })\n363:         .expect(403);\n364:     });\n365: \n366:     it('should return 404 when user not found', async () => {\n367:       await request(app.getHttpServer())\n368:         .patch('/api/admin/users/00000000-0000-0000-0000-000000000000/status')\n369:         .set(authHeader(adminToken))\n370:         .send({ status: 'active' })\n371:         .expect(404);\n372:     });\n373:   });\n374: });\n\n(End of file - total 374 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { RoleEnum } from '../../src/common/enums/role.enum';\nimport { UserStatusEnum } from '../../src/common/enums/user-status.enum';\n\n// RED PHASE: These imports will fail because modules don't exist yet.\n// import { AdminModule } from '../../src/modules/admin/admin.module';\n\ndescribe('Admin Users E2E', () => {\n  let app: INestApplication;\n  let module: TestingModule;\n  let dataSource: DataSource;","truncated":false,"loaded":[]},"title":"backend/test/e2e/admin-users.e2e-spec.ts","time":{"start":1779246742745,"end":1779246743020}},"id":"prt_e435eb6f50014UwtM0phOk5y64","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435e92eb001Skkv63Ht1xAgN4"}}
{"type":"tool_use","timestamp":1779246744875,"sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","part":{"type":"tool","tool":"read","callID":"call_03_93EseMT4MGqdmuuUXXn64025","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-dashboard.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/admin-dashboard.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\n9: import { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\n10: import { seedTestProperties } from '../fixtures/property.fixture';\n11: import { User } from '../../src/modules/users/entities/user.entity';\n12: \n13: // RED PHASE: These imports will fail because modules don't exist yet.\n14: // import { AdminModule } from '../../src/modules/admin/admin.module';\n15: \n16: describe('Admin Dashboard E2E', () => {\n17:   let app: INestApplication;\n18:   let module: TestingModule;\n19:   let dataSource: DataSource;\n20:   let adminToken: string;\n21:   let renterToken: string;\n22: \n23:   beforeAll(async () => {\n24:     const context = await createTestApp();\n25:     app = context.app;\n26:     module = context.module;\n27:     dataSource = getDataSource(module);\n28:   });\n29: \n30:   afterAll(async () => {\n31:     await closeTestApp({ app, module });\n32:   });\n33: \n34:   beforeEach(async () => {\n35:     await cleanDatabase(dataSource);\n36:     const seeded = await seedTestUsers(dataSource);\n37:     adminToken = generateAccessToken(seeded.admin);\n38:     renterToken = generateAccessToken(seeded.renter);\n39:   });\n40: \n41:   // ─── GET /admin/dashboard ──────────────────────────────────────────\n42:   describe('GET /api/admin/dashboard', () => {\n43:     beforeEach(async () => {\n44:       await seedTestProperties(dataSource);\n45:     });\n46: \n47:     it('should return 200 with dashboard statistics (admin only)', async () => {\n48:       const res = await request(app.getHttpServer())\n49:         .get('/api/admin/dashboard')\n50:         .set(authHeader(adminToken))\n51:         .expect(200);\n52: \n53:       expect(res.body.success).toBe(true);\n54:       expect(res.body.statusCode).toBe(200);\n55:       expect(res.body.message).toBe('Dashboard statistics retrieved');\n56:       expect(res.body.data).toHaveProperty('totalProperties');\n57:       expect(res.body.data).toHaveProperty('totalInquiries');\n58:       expect(res.body.data).toHaveProperty('newInquiries');\n59:       expect(res.body.data).toHaveProperty('totalUsers');\n60:       expect(res.body.data).toHaveProperty('recentInquiries');\n61:       expect(res.body.data).toHaveProperty('recentProperties');\n62:       expect(res.body).toHaveProperty('timestamp');\n63:       expect(res.body).toHaveProperty('path', '/api/admin/dashboard');\n64:     });\n65: \n66:     it('should return non-negative integer values for aggregate counts', async () => {\n67:       const res = await request(app.getHttpServer())\n68:         .get('/api/admin/dashboard')\n69:         .set(authHeader(adminToken))\n70:         .expect(200);\n71: \n72:       expect(typeof res.body.data.totalProperties).toBe('number');\n73:       expect(res.body.data.totalProperties).toBeGreaterThanOrEqual(0);\n74:       expect(typeof res.body.data.totalInquiries).toBe('number');\n75:       expect(res.body.data.totalInquiries).toBeGreaterThanOrEqual(0);\n76:       expect(typeof res.body.data.newInquiries).toBe('number');\n77:       expect(res.body.data.newInquiries).toBeGreaterThanOrEqual(0);\n78:       expect(typeof res.body.data.totalUsers).toBe('number');\n79:       expect(res.body.data.totalUsers).toBeGreaterThanOrEqual(0);\n80:     });\n81: \n82:     it('should return count matching seeded properties', async () => {\n83:       const res = await request(app.getHttpServer())\n84:         .get('/api/admin/dashboard')\n85:         .set(authHeader(adminToken))\n86:         .expect(200);\n87: \n88:       // 3 properties seeded via seedTestProperties\n89:       expect(res.body.data.totalProperties).toBe(3);\n90:     });\n91: \n92:     it('should return recent properties as an array', async () => {\n93:       const res = await request(app.getHttpServer())\n94:         .get('/api/admin/dashboard')\n95:         .set(authHeader(adminToken))\n96:         .expect(200);\n97: \n98:       expect(Array.isArray(res.body.data.recentProperties)).toBe(true);\n99:       if (res.body.data.recentProperties.length > 0) {\n100:         const item = res.body.data.recentProperties[0];\n101:         expect(item).toHaveProperty('id');\n102:         expect(item).toHaveProperty('title');\n103:         expect(item).toHaveProperty('price');\n104:         expect(item).toHaveProperty('propertyType');\n105:         expect(item).toHaveProperty('createdAt');\n106:       }\n107:     });\n108: \n109:     it('should return recent inquiries as an array (empty if none)', async () => {\n110:       const res = await request(app.getHttpServer())\n111:         .get('/api/admin/dashboard')\n112:         .set(authHeader(adminToken))\n113:         .expect(200);\n114: \n115:       expect(Array.isArray(res.body.data.recentInquiries)).toBe(true);\n116:       if (res.body.data.recentInquiries.length > 0) {\n117:         const item = res.body.data.recentInquiries[0];\n118:         expect(item).toHaveProperty('id');\n119:         expect(item).toHaveProperty('name');\n120:         expect(item).toHaveProperty('email');\n121:         expect(item).toHaveProperty('propertyTitle');\n122:         expect(item).toHaveProperty('status');\n123:         expect(item).toHaveProperty('createdAt');\n124:       }\n125:     });\n126: \n127:     it('should return 0 for counts when database is empty', async () => {\n128:       // beforeEach cleaned the DB, but this test doesn't seed properties\n129:       // We need to ensure clean state\n130:       await cleanDatabase(dataSource);\n131:       const seeded = await seedTestUsers(dataSource);\n132:       const cleanAdminToken = generateAccessToken(seeded.admin);\n133: \n134:       const res = await request(app.getHttpServer())\n135:         .get('/api/admin/dashboard')\n136:         .set(authHeader(cleanAdminToken))\n137:         .expect(200);\n138: \n139:       expect(res.body.data.totalProperties).toBe(0);\n140:       expect(res.body.data.totalInquiries).toBe(0);\n141:       expect(res.body.data.newInquiries).toBe(0);\n142:     });\n143: \n144:     it('should return 401 when not authenticated', async () => {\n145:       await request(app.getHttpServer())\n146:         .get('/api/admin/dashboard')\n147:         .expect(401);\n148:     });\n149: \n150:     it('should return 401 with invalid token', async () => {\n151:       await request(app.getHttpServer())\n152:         .get('/api/admin/dashboard')\n153:         .set(authHeader('invalid-token'))\n154:         .expect(401);\n155:     });\n156: \n157:     it('should return 403 when authenticated as renter (admin only)', async () => {\n158:       await request(app.getHttpServer())\n159:         .get('/api/admin/dashboard')\n160:         .set(authHeader(renterToken))\n161:         .expect(403);\n162:     });\n163:   });\n164: });\n\n(End of file - total 164 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport { createTestUser, seedTestUsers, testUsers } from '../fixtures/user.fixture';\nimport { generateAccessToken, authHeader } from '../fixtures/auth.fixture';\nimport { seedTestProperties } from '../fixtures/property.fixture';\nimport { User } from '../../src/modules/users/entities/user.entity';\n\n// RED PHASE: These imports will fail because modules don't exist yet.\n// import { AdminModule } from '../../src/modules/admin/admin.module';\n\ndescribe('Admin Dashboard E2E', () => {\n  let app: INestApplication;\n  let module: TestingModule;\n  let dataSource: DataSource;\n  let adminToken: string;","truncated":false,"loaded":[]},"title":"backend/test/e2e/admin-dashboard.e2e-spec.ts","time":{"start":1779246744600,"end":1779246744874}},"id":"prt_e435ebe220011hRJJuNQAJ9m88","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435e92eb001Skkv63Ht1xAgN4"}}
{"type":"tool_use","timestamp":1779246746425,"sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","part":{"type":"tool","tool":"read","callID":"call_04_h21SBI793P1ICBj3yVyv0163","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/base"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/base</path>\n<type>directory</type>\n<entries>\nbase.controller.ts\nbase.entity.ts\nbase.repository.ts\nbase.service.ts\nindex.ts\n\n(5 entries)\n</entries>","metadata":{"preview":"base.controller.ts\nbase.entity.ts\nbase.repository.ts\nbase.service.ts\nindex.ts","truncated":false,"loaded":[]},"title":"backend/src/core/base","time":{"start":1779246746149,"end":1779246746424}},"id":"prt_e435ec589001QZ9M6kIBihQ5zx","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435e92eb001Skkv63Ht1xAgN4"}}
{"type":"tool_use","timestamp":1779246748199,"sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","part":{"type":"tool","tool":"read","callID":"call_05_pA9GoLGKToJ28YO9ybMp6775","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/.claude-project/nestfind/docs/PROJECT_API.md"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/.claude-project/nestfind/docs/PROJECT_API.md</path>\n<type>file</type>\n<content>\n1: # PROJECT_API\n2: \n3: NestFind API Contract — canonical reference for all API endpoints.\n4: \n5: **Base URL:** `http://localhost:3000/api`\n6: \n7: ---\n8: \n9: ## Endpoints\n10: \n11: ---\n12: \n13: ### Authentication\n14: \n15: ---\n16: \n17: #### Register\n18: \n19: | Method | Path | Auth |\n20: |--------|------|------|\n21: | `POST` | `/auth/register` | Public |\n22: \n23: **Description:** Self-service registration. Creates a new user account with the `renter` role. Returns user data and sets httpOnly cookies for access + refresh tokens.\n24: \n25: **Request Body:**\n26: ```json\n27: {\n28:   \"name\": \"string (2–100 chars, required)\",\n29:   \"email\": \"string (valid email, required)\",\n30:   \"password\": \"string (min 8 chars, required)\",\n31:   \"phone\": \"string (optional, max 20 chars)\"\n32: }\n33: ```\n34: \n35: **Success Response** `201 Created`:\n36: ```json\n37: {\n38:   \"success\": true,\n39:   \"statusCode\": 201,\n40:   \"message\": \"User registered successfully\",\n41:   \"data\": {\n42:     \"id\": \"uuid\",\n43:     \"name\": \"string\",\n44:     \"email\": \"string\",\n45:     \"phone\": \"string | null\",\n46:     \"role\": \"renter\",\n47:     \"status\": \"active\",\n48:     \"createdAt\": \"ISO 8601 timestamp\",\n49:     \"updatedAt\": \"ISO 8601 timestamp\"\n50:   },\n51:   \"timestamp\": \"ISO 8601 timestamp\",\n52:   \"path\": \"/api/auth/register\"\n53: }\n54: ```\n55: \n56: **Error Responses:**\n57: - `400` — Validation failed (missing fields, invalid email, weak password)\n58: - `409` — Email already registered\n59: \n60: ---\n61: \n62: #### Login\n63: \n64: | Method | Path | Auth |\n65: |--------|------|------|\n66: | `POST` | `/auth/login` | Public |\n67: \n68: **Description:** Authenticate with email and password. Sets httpOnly cookies: `access_token` (1h) and `refresh_token` (7d).\n69: \n70: **Request Body:**\n71: ```json\n72: {\n73:   \"email\": \"string (required)\",\n74:   \"password\": \"string (required)\"\n75: }\n76: ```\n77: \n78: **Success Response** `200 OK`:\n79: ```json\n80: {\n81:   \"success\": true,\n82:   \"statusCode\": 200,\n83:   \"message\": \"Login successful\",\n84:   \"data\": {\n85:     \"user\": {\n86:       \"id\": \"uuid\",\n87:       \"name\": \"string\",\n88:       \"email\": \"string\",\n89:       \"phone\": \"string | null\",\n90:       \"role\": \"renter | admin\",\n91:       \"status\": \"active | suspended\"\n92:     }\n93:   },\n94:   \"timestamp\": \"ISO 8601 timestamp\",\n95:   \"path\": \"/api/auth/login\"\n96: }\n97: ```\n98: \n99: **Error Responses:**\n100: - `400` — Validation failed\n101: - `401` — Invalid email or password\n102: - `403` — Account suspended\n103: \n104: ---\n105: \n106: #### Logout\n107: \n108: | Method | Path | Auth |\n109: |--------|------|------|\n110: | `POST` | `/auth/logout` | Authenticated |\n111: \n112: **Description:** Revokes the current refresh token and clears auth cookies.\n113: \n114: **Request Body:** none\n115: \n116: **Success Response** `200 OK`:\n117: ```json\n118: {\n119:   \"success\": true,\n120:   \"statusCode\": 200,\n121:   \"message\": \"Logged out successfully\",\n122:   \"data\": null,\n123:   \"timestamp\": \"ISO 8601 timestamp\",\n124:   \"path\": \"/api/auth/logout\"\n125: }\n126: ```\n127: \n128: **Error Responses:**\n129: - `401` — Not authenticated\n130: \n131: ---\n132: \n133: #### Refresh Token\n134: \n135: | Method | Path | Auth |\n136: |--------|------|------|\n137: | `POST` | `/auth/refresh` | Public (requires refresh cookie) |\n138: \n139: **Description:** Rotates the refresh token and issues a new access token. Old refresh token is revoked.\n140: \n141: **Request Body:** none (reads `refresh_token` from httpOnly cookie)\n142: \n143: **Success Response** `200 OK`:\n144: ```json\n145: {\n146:   \"success\": true,\n147:   \"statusCode\": 200,\n148:   \"message\": \"Token refreshed successfully\",\n149:   \"data\": {\n150:     \"user\": {\n151:       \"id\": \"uuid\",\n152:       \"name\": \"string\",\n153:       \"email\": \"string\",\n154:       \"role\": \"renter | admin\"\n155:     }\n156:   },\n157:   \"timestamp\": \"ISO 8601 timestamp\",\n158:   \"path\": \"/api/auth/refresh\"\n159: }\n160: ```\n161: \n162: **Error Responses:**\n163: - `401` — Missing, expired, or revoked refresh token\n164: \n165: ---\n166: \n167: #### Forgot Password\n168: \n169: | Method | Path | Auth |\n170: |--------|------|------|\n171: | `POST` | `/auth/forgot-password` | Public |\n172: \n173: **Description:** Sends a password reset email with a secure reset token. Always returns 200 regardless of whether the email exists (prevents enumeration).\n174: \n175: **Request Body:**\n176: ```json\n177: {\n178:   \"email\": \"string (required)\"\n179: }\n180: ```\n181: \n182: **Success Response** `200 OK`:\n183: ```json\n184: {\n185:   \"success\": true,\n186:   \"statusCode\": 200,\n187:   \"message\": \"If an account with that email exists, a password reset link has been sent\",\n188:   \"data\": null,\n189:   \"timestamp\": \"ISO 8601 timestamp\",\n190:   \"path\": \"/api/auth/forgot-password\"\n191: }\n192: ```\n193: \n194: **Error Responses:**\n195: - `400` — Invalid email format\n196: \n197: ---\n198: \n199: #### Reset Password\n200: \n201: | Method | Path | Auth |\n202: |--------|------|------|\n203: | `POST` | `/auth/reset-password` | Public |\n204: \n205: **Description:** Resets the user's password using a valid reset token.\n206: \n207: **Request Body:**\n208: ```json\n209: {\n210:   \"token\": \"string (required)\",\n211:   \"password\": \"string (min 8 chars, required)\"\n212: }\n213: ```\n214: \n215: **Success Response** `200 OK`:\n216: ```json\n217: {\n218:   \"success\": true,\n219:   \"statusCode\": 200,\n220:   \"message\": \"Password reset successfully\",\n221:   \"data\": null,\n222:   \"timestamp\": \"ISO 8601 timestamp\",\n223:   \"path\": \"/api/auth/reset-password\"\n224: }\n225: ```\n226: \n227: **Error Responses:**\n228: - `400` — Validation failed or expired token\n229: - `404` — Invalid token\n230: \n231: ---\n232: \n233: #### Get Current User\n234: \n235: | Method | Path | Auth |\n236: |--------|------|------|\n237: | `GET` | `/auth/me` | Authenticated |\n238: \n239: **Description:** Returns the currently authenticated user's profile.\n240: \n241: **Success Response** `200 OK`:\n242: ```json\n243: {\n244:   \"success\": true,\n245:   \"statusCode\": 200,\n246:   \"message\": \"User retrieved successfully\",\n247:   \"data\": {\n248:     \"id\": \"uuid\",\n249:     \"name\": \"string\",\n250:     \"email\": \"string\",\n251:     \"phone\": \"string | null\",\n252:     \"role\": \"renter | admin\",\n253:     \"status\": \"active | suspended\",\n254:     \"emailVerifiedAt\": \"ISO 8601 timestamp | null\",\n255:     \"createdAt\": \"ISO 8601 timestamp\",\n256:     \"updatedAt\": \"ISO 8601 timestamp\"\n257:   },\n258:   \"timestamp\": \"ISO 8601 timestamp\",\n259:   \"path\": \"/api/auth/me\"\n260: }\n261: ```\n262: \n263: **Error Responses:**\n264: - `401` — Not authenticated\n265: \n266: ---\n267: \n268: ### Profile\n269: \n270: ---\n271: \n272: #### Get Profile\n273: \n274: | Method | Path | Auth |\n275: |--------|------|------|\n276: | `GET` | `/profile` | Authenticated |\n277: \n278: **Description:** Returns the authenticated user's profile details.\n279: \n280: **Success Response** `200 OK`:\n281: ```json\n282: {\n283:   \"success\": true,\n284:   \"statusCode\": 200,\n285:   \"message\": \"Profile retrieved successfully\",\n286:   \"data\": {\n287:     \"id\": \"uuid\",\n288:     \"name\": \"string\",\n289:     \"email\": \"string\",\n290:     \"phone\": \"string | null\",\n291:     \"role\": \"renter | admin\",\n292:     \"status\": \"active | suspended\",\n293:     \"emailVerifiedAt\": \"ISO 8601 timestamp | null\",\n294:     \"createdAt\": \"ISO 8601 timestamp\",\n295:     \"updatedAt\": \"ISO 8601 timestamp\"\n296:   },\n297:   \"timestamp\": \"ISO 8601 timestamp\",\n298:   \"path\": \"/api/profile\"\n299: }\n300: ```\n301: \n302: **Error Responses:**\n303: - `401` — Not authenticated\n304: \n305: ---\n306: \n307: #### Update Profile\n308: \n309: | Method | Path | Auth |\n310: |--------|------|------|\n311: | `PATCH` | `/profile` | Authenticated |\n312: \n313: **Description:** Updates the authenticated user's profile fields.\n314: \n315: **Request Body:**\n316: ```json\n317: {\n318:   \"name\": \"string (2–100 chars, optional)\",\n319:   \"phone\": \"string (max 20 chars, optional)\"\n320: }\n321: ```\n322: \n323: **Success Response** `200 OK`:\n324: ```json\n325: {\n326:   \"success\": true,\n327:   \"statusCode\": 200,\n328:   \"message\": \"Profile updated successfully\",\n329:   \"data\": {\n330:     \"id\": \"uuid\",\n331:     \"name\": \"string\",\n332:     \"email\": \"string\",\n333:     \"phone\": \"string | null\",\n334:     \"role\": \"renter | admin\",\n335:     \"status\": \"active | suspended\",\n336:     \"createdAt\": \"ISO 8601 timestamp\",\n337:     \"updatedAt\": \"ISO 8601 timestamp\"\n338:   },\n339:   \"timestamp\": \"ISO 8601 timestamp\",\n340:   \"path\": \"/api/profile\"\n341: }\n342: ```\n343: \n344: **Error Responses:**\n345: - `400` — Validation failed\n346: - `401` — Not authenticated\n347: \n348: ---\n349: \n350: ### Properties\n351: \n352: ---\n353: \n354: #### Search Properties\n355: \n356: | Method | Path | Auth |\n357: |--------|------|------|\n358: | `GET` | `/properties` | Public |\n359: \n360: **Description:** Search and filter rental property listings. Returns paginated results. Only returns non-archived (non-soft-deleted) properties.\n361: \n362: **Query Parameters:**\n363: | Param | Type | Required | Description |\n364: |-------|------|----------|-------------|\n365: | `search` | string | no | Full-text search across title, description, city, state |\n366: | `propertyType` | enum | no | Filter: `apartment`, `house`, `condo`, `townhouse`, `studio` |\n367: | `minPrice` | number | no | Minimum monthly rent |\n368: | `maxPrice` | number | no | Maximum monthly rent |\n369: | `bedrooms` | number | no | Minimum number of bedrooms |\n370: | `bathrooms` | number | no | Minimum number of bathrooms |\n371: | `city` | string | no | Filter by city |\n372: | `state` | string | no | Filter by state |\n373: | `latitude` | number | no | Latitude for geolocation search |\n374: | `longitude` | number | no | Longitude for geolocation search |\n375: | `radius` | number | no | Search radius in miles (requires lat/lon) |\n376: | `sortBy` | enum | no | `price_asc`, `price_desc`, `newest`, `oldest` |\n377: | `page` | number | no | Page number (default: 1) |\n378: | `limit` | number | no | Items per page (default: 20, max: 100) |\n379: \n380: **Success Response** `200 OK`:\n381: ```json\n382: {\n383:   \"success\": true,\n384:   \"statusCode\": 200,\n385:   \"message\": \"Properties retrieved successfully\",\n386:   \"data\": {\n387:     \"items\": [\n388:       {\n389:         \"id\": \"uuid\",\n390:         \"title\": \"string\",\n391:         \"description\": \"string\",\n392:         \"price\": 2500.00,\n393:         \"bedrooms\": 2,\n394:         \"bathrooms\": 1,\n395:         \"squareFeet\": 950,\n396:         \"propertyType\": \"apartment\",\n397:         \"address\": {\n398:           \"street\": \"string\",\n399:           \"city\": \"string\",\n400:           \"state\": \"string\",\n401:           \"zipCode\": \"string\",\n402:           \"latitude\": 40.7127753,\n403:           \"longitude\": -74.0059728\n404:         },\n405:         \"availableFrom\": \"2026-06-01\",\n406:         \"primaryPhoto\": \"string (URL) | null\",\n407:         \"amenities\": [\n408:           { \"id\": \"uuid\", \"name\": \"Parking\", \"icon\": \"parking\" }\n409:         ],\n410:         \"createdAt\": \"ISO 8601 timestamp\"\n411:       }\n412:     ],\n413:     \"meta\": {\n414:       \"total\": 150,\n415:       \"page\": 1,\n416:       \"limit\": 20,\n417:       \"totalPages\": 8\n418:     }\n419:   },\n420:   \"timestamp\": \"ISO 8601 timestamp\",\n421:   \"path\": \"/api/properties\"\n422: }\n423: ```\n424: \n425: **Error Responses:**\n426: - `400` — Invalid query parameters\n427: \n428: ---\n429: \n430: #### Get Property Detail\n431: \n432: | Method | Path | Auth |\n433: |--------|------|------|\n434: | `GET` | `/properties/:id` | Public |\n435: \n436: **Description:** Returns full property details including all photos, amenities, and address.\n437: \n438: **Success Response** `200 OK`:\n439: ```json\n440: {\n441:   \"success\": true,\n442:   \"statusCode\": 200,\n443:   \"message\": \"Property retrieved successfully\",\n444:   \"data\": {\n445:     \"id\": \"uuid\",\n446:     \"title\": \"string\",\n447:     \"description\": \"string\",\n448:     \"price\": 2500.00,\n449:     \"bedrooms\": 2,\n450:     \"bathrooms\": 1,\n451:     \"squareFeet\": 950,\n452:     \"propertyType\": \"apartment\",\n453:     \"address\": {\n454:       \"street\": \"string\",\n455:       \"city\": \"string\",\n456:       \"state\": \"string\",\n457:       \"zipCode\": \"string\",\n458:       \"latitude\": 40.7127753,\n459:       \"longitude\": -74.0059728\n460:     },\n461:     \"availableFrom\": \"2026-06-01\",\n462:     \"photos\": [\n463:       {\n464:         \"id\": \"uuid\",\n465:         \"url\": \"string\",\n466:         \"isPrimary\": true,\n467:         \"sortOrder\": 0\n468:       }\n469:     ],\n470:     \"amenities\": [\n471:       { \"id\": \"uuid\", \"name\": \"Parking\", \"icon\": \"parking\" }\n472:     ],\n473:     \"isFavorited\": false,\n474:     \"createdAt\": \"ISO 8601 timestamp\",\n475:     \"updatedAt\": \"ISO 8601 timestamp\"\n476:   },\n477:   \"timestamp\": \"ISO 8601 timestamp\",\n478:   \"path\": \"/api/properties/uuid\"\n479: }\n480: ```\n481: \n482: **Error Responses:**\n483: - `400` — Invalid UUID format\n484: - `404` — Property not found or archived\n485: \n486: ---\n487: \n488: #### Create Property\n489: \n490: | Method | Path | Auth |\n491: |--------|------|------|\n492: | `POST` | `/properties` | Admin |\n493: \n494: **Description:** Create a new rental property listing.\n495: \n496: **Request Body:**\n497: ```json\n498: {\n499:   \"title\": \"string (5–200 chars, required)\",\n500:   \"description\": \"string (20–5000 chars, required)\",\n501:   \"price\": \"number (>0, required)\",\n502:   \"bedrooms\": \"number (>=0, required)\",\n503:   \"bathrooms\": \"number (>=0, required)\",\n504:   \"squareFeet\": \"number (>0, optional)\",\n505:   \"propertyType\": \"enum (apartment | house | condo | townhouse | studio, required)\",\n506:   \"address\": {\n507:     \"street\": \"string (required, max 200)\",\n508:     \"city\": \"string (required, max 100)\",\n509:     \"state\": \"string (required, max 100)\",\n510:     \"zipCode\": \"string (required, max 10)\",\n511:     \"latitude\": \"number (-90 to 90, optional)\",\n512:     \"longitude\": \"number (-180 to 180, optional)\"\n513:   },\n514:   \"availableFrom\": \"date string (ISO date format, optional)\",\n515:   \"amenityIds\": [\"uuid\", \"uuid\"]\n516: }\n517: ```\n518: \n519: **Success Response** `201 Created`:\n520: ```json\n521: {\n522:   \"success\": true,\n523:   \"statusCode\": 201,\n524:   \"message\": \"Property created successfully\",\n525:   \"data\": {\n526:     \"id\": \"uuid\",\n527:     \"title\": \"string\",\n528:     \"description\": \"string\",\n529:     \"price\": 2500.00,\n530:     \"bedrooms\": 2,\n531:     \"bathrooms\": 1,\n532:     \"squareFeet\": 950,\n533:     \"propertyType\": \"apartment\",\n534:     \"address\": {\n535:       \"street\": \"string\",\n536:       \"city\": \"string\",\n537:       \"state\": \"string\",\n538:       \"zipCode\": \"string\",\n539:       \"latitude\": 40.7127753,\n540:       \"longitude\": -74.0059728\n541:     },\n542:     \"availableFrom\": \"2026-06-01\",\n543:     \"amenities\": [\n544:       { \"id\": \"uuid\", \"name\": \"Parking\", \"icon\": \"parking\" }\n545:     ],\n546:     \"photos\": [],\n547:     \"createdAt\": \"ISO 8601 timestamp\",\n548:     \"updatedAt\": \"ISO 8601 timestamp\"\n549:   },\n550:   \"timestamp\": \"ISO 8601 timestamp\",\n551:   \"path\": \"/api/properties\"\n552: }\n553: ```\n554: \n555: **Error Responses:**\n556: - `400` — Validation failed\n557: - `401` — Not authenticated\n558: - `403` — Insufficient permissions (not admin)\n559: \n560: ---\n561: \n562: #### Update Property\n563: \n564: | Method | Path | Auth |\n565: |--------|------|------|\n566: | `PATCH` | `/properties/:id` | Admin |\n567: \n568: **Description:** Update an existing property listing. Only provided fields are updated.\n569: \n570: **Request Body (all fields optional):**\n571: ```json\n572: {\n573:   \"title\": \"string (5–200 chars)\",\n574:   \"description\": \"string (20–5000 chars)\",\n575:   \"price\": \"number (>0)\",\n576:   \"bedrooms\": \"number (>=0)\",\n577:   \"bathrooms\": \"number (>=0)\",\n578:   \"squareFeet\": \"number (>0)\",\n579:   \"propertyType\": \"enum (apartment | house | condo | townhouse | studio)\",\n580:   \"address\": {\n581:     \"street\": \"string (max 200)\",\n582:     \"city\": \"string (max 100)\",\n583:     \"state\": \"string (max 100)\",\n584:     \"zipCode\": \"string (max 10)\",\n585:     \"latitude\": \"number (-90 to 90)\",\n586:     \"longitude\": \"number (-180 to 180)\"\n587:   },\n588:   \"availableFrom\": \"date string (ISO date format)\",\n589:   \"amenityIds\": [\"uuid\", \"uuid\"]\n590: }\n591: ```\n592: \n593: **Success Response** `200 OK`:\n594: ```json\n595: {\n596:   \"success\": true,\n597:   \"statusCode\": 200,\n598:   \"message\": \"Property updated successfully\",\n599:   \"data\": {\n600:     \"id\": \"uuid\",\n601:     \"title\": \"string\",\n602:     \"description\": \"string\",\n603:     \"price\": 2500.00,\n604:     \"bedrooms\": 2,\n605:     \"bathrooms\": 1,\n606:     \"squareFeet\": 950,\n607:     \"propertyType\": \"apartment\",\n608:     \"address\": {\n609:       \"street\": \"string\",\n610:       \"city\": \"string\",\n611:       \"state\": \"string\",\n612:       \"zipCode\": \"string\",\n613:       \"latitude\": 40.7127753,\n614:       \"longitude\": -74.0059728\n615:     },\n616:     \"availableFrom\": \"2026-06-01\",\n617:     \"amenities\": [\n618:       { \"id\": \"uuid\", \"name\": \"Parking\", \"icon\": \"parking\" }\n619:     ],\n620:     \"photos\": [\n621:       {\n622:         \"id\": \"uuid\",\n623:         \"url\": \"string\",\n624:         \"isPrimary\": true,\n625:         \"sortOrder\": 0\n626:       }\n627:     ],\n628:     \"createdAt\": \"ISO 8601 timestamp\",\n629:     \"updatedAt\": \"ISO 8601 timestamp\"\n630:   },\n631:   \"timestamp\": \"ISO 8601 timestamp\",\n632:   \"path\": \"/api/properties/uuid\"\n633: }\n634: ```\n635: \n636: **Error Responses:**\n637: - `400` — Validation failed or invalid UUID\n638: - `401` — Not authenticated\n639: - `403` — Insufficient permissions (not admin)\n640: - `404` — Property not found\n641: \n642: ---\n643: \n644: #### Delete (Archive) Property\n645: \n646: | Method | Path | Auth |\n647: |--------|------|------|\n648: | `DELETE` | `/properties/:id` | Admin |\n649: \n650: **Description:** Soft-deletes (archives) a property listing. The property is removed from public search results but retained in the database.\n651: \n652: **Success Response** `200 OK`:\n653: ```json\n654: {\n655:   \"success\": true,\n656:   \"statusCode\": 200,\n657:   \"message\": \"Property archived successfully\",\n658:   \"data\": null,\n659:   \"timestamp\": \"ISO 8601 timestamp\",\n660:   \"path\": \"/api/properties/uuid\"\n661: }\n662: ```\n663: \n664: **Error Responses:**\n665: - `400` — Invalid UUID format\n666: - `401` — Not authenticated\n667: - `403` — Insufficient permissions (not admin)\n668: - `404` — Property not found\n669: \n670: ---\n671: \n672: #### Upload Property Photos\n673: \n674: | Method | Path | Auth |\n675: |--------|------|------|\n676: | `POST` | `/properties/:id/photos` | Admin |\n677: \n678: **Description:** Upload one or more photos for a property. The first photo uploaded is automatically set as primary if no primary exists.\n679: \n680: **Request:** `multipart/form-data`\n681: | Field | Type | Required | Description |\n682: |-------|------|----------|-------------|\n683: | `files` | file[] | yes | Image files (max 10 per request, accepted: jpg, jpeg, png, webp; max 5MB each) |\n684: \n685: **Success Response** `201 Created`:\n686: ```json\n687: {\n688:   \"success\": true,\n689:   \"statusCode\": 201,\n690:   \"message\": \"Photos uploaded successfully\",\n691:   \"data\": [\n692:     {\n693:       \"id\": \"uuid\",\n694:       \"url\": \"string\",\n695:       \"isPrimary\": true,\n696:       \"sortOrder\": 0\n697:     }\n698:   ],\n699:   \"timestamp\": \"ISO 8601 timestamp\",\n700:   \"path\": \"/api/properties/uuid/photos\"\n701: }\n702: ```\n703: \n704: **Error Responses:**\n705: - `400` — Invalid file type, file too large, or no file provided\n706: - `401` — Not authenticated\n707: - `403` — Insufficient permissions (not admin)\n708: - `404` — Property not found\n709: \n710: ---\n711: \n712: #### Delete Property Photo\n713: \n714: | Method | Path | Auth |\n715: |--------|------|------|\n716: | `DELETE` | `/properties/:id/photos/:photoId` | Admin |\n717: \n718: **Description:** Delete a specific photo from a property.\n719: \n720: **Success Response** `200 OK`:\n721: ```json\n722: {\n723:   \"success\": true,\n724:   \"statusCode\": 200,\n725:   \"message\": \"Photo deleted successfully\",\n726:   \"data\": null,\n727:   \"timestamp\": \"ISO 8601 timestamp\",\n728:   \"path\": \"/api/properties/uuid/photos/uuid\"\n729: }\n730: ```\n731: \n732: **Error Responses:**\n733: - `400` — Invalid UUID format\n734: - `401` — Not authenticated\n735: - `403` — Insufficient permissions (not admin)\n736: - `404` — Property or photo not found\n737: \n738: ---\n739: \n740: #### Set Primary Photo\n741: \n742: | Method | Path | Auth |\n743: |--------|------|------|\n744: | `PATCH` | `/properties/:id/photos/:photoId/primary` | Admin |\n745: \n746: **Description:** Set a specific photo as the primary/thumbnail photo for the property. The previous primary is unset.\n747: \n748: **Success Response** `200 OK`:\n749: ```json\n750: {\n751:   \"success\": true,\n752:   \"statusCode\": 200,\n753:   \"message\": \"Primary photo updated successfully\",\n754:   \"data\": {\n755:     \"id\": \"uuid\",\n756:     \"url\": \"string\",\n757:     \"isPrimary\": true,\n758:     \"sortOrder\": 0\n759:   },\n760:   \"timestamp\": \"ISO 8601 timestamp\",\n761:   \"path\": \"/api/properties/uuid/photos/uuid/primary\"\n762: }\n763: ```\n764: \n765: **Error Responses:**\n766: - `400` — Invalid UUID format\n767: - `401` — Not authenticated\n768: - `403` — Insufficient permissions (not admin)\n769: - `404` — Property or photo not found\n770: \n771: ---\n772: \n773: #### Reorder Property Photos\n774: \n775: | Method | Path | Auth |\n776: |--------|------|------|\n777: | `PATCH` | `/properties/:id/photos/reorder` | Admin |\n778: \n779: **Description:** Reorder the display order of photos for a property.\n780: \n781: **Request Body:**\n782: ```json\n783: {\n784:   \"photoIds\": [\"uuid\", \"uuid\", \"uuid\"]\n785: }\n786: ```\n787: \n788: **Success Response** `200 OK`:\n789: ```json\n790: {\n791:   \"success\": true,\n792:   \"statusCode\": 200,\n793:   \"message\": \"Photo order updated successfully\",\n794:   \"data\": [\n795:     {\n796:       \"id\": \"uuid\",\n797:       \"url\": \"string\",\n798:       \"isPrimary\": true,\n799:       \"sortOrder\": 0\n800:     },\n801:     {\n802:       \"id\": \"uuid\",\n803:       \"url\": \"string\",\n804:       \"isPrimary\": false,\n805:       \"sortOrder\": 1\n806:     }\n807:   ],\n808:   \"timestamp\": \"ISO 8601 timestamp\",\n809:   \"path\": \"/api/properties/uuid/photos/reorder\"\n810: }\n811: ```\n812: \n813: **Error Responses:**\n814: - `400` — Invalid photo IDs or missing photos in array\n815: - `401` — Not authenticated\n816: - `403` — Insufficient permissions (not admin)\n817: - `404` — Property not found\n818: \n819: ---\n820: \n821: ### Favorites\n822: \n823: ---\n824: \n825: #### List Favorites\n826: \n827: | Method | Path | Auth |\n828: |--------|------|------|\n829: | `GET` | `/favorites` | Renter |\n830: \n831: **Description:** List all properties favorited by the authenticated renter. Returns paginated results.\n832: \n833: **Query Parameters:**\n834: | Param | Type | Required | Description |\n835: |-------|------|----------|-------------|\n836: | `page` | number | no | Page number (default: 1) |\n837: | `limit` | number | no | Items per page (default: 20, max: 100) |\n838: \n839: **Success Response** `200 OK`:\n840: ```json\n841: {\n842:   \"success\": true,\n843:   \"statusCode\": 200,\n844:   \"message\": \"Favorites retrieved successfully\",\n845:   \"data\": {\n846:     \"items\": [\n847:       {\n848:         \"id\": \"uuid (favorite record ID)\",\n849:         \"property\": {\n850:           \"id\": \"uuid\",\n851:           \"title\": \"string\",\n852:           \"price\": 2500.00,\n853:           \"bedrooms\": 2,\n854:           \"bathrooms\": 1,\n855:           \"propertyType\": \"apartment\",\n856:           \"address\": {\n857:             \"city\": \"string\",\n858:             \"state\": \"string\"\n859:           },\n860:           \"primaryPhoto\": \"string (URL) | null\"\n861:         },\n862:         \"createdAt\": \"ISO 8601 timestamp\"\n863:       }\n864:     ],\n865:     \"meta\": {\n866:       \"total\": 12,\n867:       \"page\": 1,\n868:       \"limit\": 20,\n869:       \"totalPages\": 1\n870:     }\n871:   },\n872:   \"timestamp\": \"ISO 8601 timestamp\",\n873:   \"path\": \"/api/favorites\"\n874: }\n875: ```\n876: \n877: **Error Responses:**\n878: - `401` — Not authenticated\n879: \n880: ---\n881: \n882: #### Add to Favorites\n883: \n884: | Method | Path | Auth |\n885: |--------|------|------|\n886: | `POST` | `/favorites` | Renter |\n887: \n888: **Description:** Add a property to the authenticated renter's favorites. Idempotent — adding a duplicate returns the existing record without error.\n889: \n890: **Request Body:**\n891: ```json\n892: {\n893:   \"propertyId\": \"uuid (required)\"\n894: }\n895: ```\n896: \n897: **Success Response** `201 Created`:\n898: ```json\n899: {\n900:   \"success\": true,\n901:   \"statusCode\": 201,\n902:   \"message\": \"Property added to favorites\",\n903:   \"data\": {\n904:     \"id\": \"uuid\",\n905:     \"propertyId\": \"uuid\",\n906:     \"createdAt\": \"ISO 8601 timestamp\"\n907:   },\n908:   \"timestamp\": \"ISO 8601 timestamp\",\n909:   \"path\": \"/api/favorites\"\n910: }\n911: ```\n912: \n913: **Error Responses:**\n914: - `400` — Invalid property ID or validation failed\n915: - `401` — Not authenticated\n916: - `404` — Property not found\n917: \n918: ---\n919: \n920: #### Remove from Favorites\n921: \n922: | Method | Path | Auth |\n923: |--------|------|------|\n924: | `DELETE` | `/favorites/:propertyId` | Renter |\n925: \n926: **Description:** Remove a property from the authenticated renter's favorites.\n927: \n928: **Success Response** `200 OK`:\n929: ```json\n930: {\n931:   \"success\": true,\n932:   \"statusCode\": 200,\n933:   \"message\": \"Property removed from favorites\",\n934:   \"data\": null,\n935:   \"timestamp\": \"ISO 8601 timestamp\",\n936:   \"path\": \"/api/favorites/uuid\"\n937: }\n938: ```\n939: \n940: **Error Responses:**\n941: - `400` — Invalid UUID format\n942: - `401` — Not authenticated\n943: - `404` — Favorite not found\n944: \n945: ---\n946: \n947: ### Inquiries\n948: \n949: ---\n950: \n951: #### Submit Inquiry\n952: \n953: | Method | Path | Auth |\n954: |--------|------|------|\n955: | `POST` | `/properties/:id/inquiries` | Renter |\n956: \n957: **Description:** Submit an inquiry about a specific property. Name, email, and phone are denormalized from the authenticated user's profile at submission time.\n958: \n959: **Request Body:**\n960: ```json\n961: {\n962:   \"message\": \"string (10–2000 chars, required)\",\n963:   \"name\": \"string (optional, defaults to user's name)\",\n964:   \"email\": \"string (optional, defaults to user's email)\",\n965:   \"phone\": \"string (optional, defaults to user's phone)\"\n966: }\n967: ```\n968: \n969: **Success Response** `201 Created`:\n970: ```json\n971: {\n972:   \"success\": true,\n973:   \"statusCode\": 201,\n974:   \"message\": \"Inquiry submitted successfully\",\n975:   \"data\": {\n976:     \"id\": \"uuid\",\n977:     \"propertyId\": \"uuid\",\n978:     \"name\": \"string\",\n979:     \"email\": \"string\",\n980:     \"phone\": \"string | null\",\n981:     \"message\": \"string\",\n982:     \"status\": \"new\",\n983:     \"response\": null,\n984:     \"respondedAt\": null,\n985:     \"createdAt\": \"ISO 8601 timestamp\"\n986:   },\n987:   \"timestamp\": \"ISO 8601 timestamp\",\n988:   \"path\": \"/api/properties/uuid/inquiries\"\n989: }\n990: ```\n991: \n992: **Error Responses:**\n993: - `400` — Validation failed or invalid UUID\n994: - `401` — Not authenticated\n995: - `404` — Property not found\n996: \n997: ---\n998: \n999: #### List All Inquiries (Admin)\n1000: \n1001: | Method | Path | Auth |\n1002: |--------|------|------|\n1003: | `GET` | `/inquiries` | Admin |\n1004: \n1005: **Description:** Admin endpoint to view all inquiries with filtering and pagination.\n1006: \n1007: **Query Parameters:**\n1008: | Param | Type | Required | Description |\n1009: |-------|------|----------|-------------|\n1010: | `status` | enum | no | Filter: `new`, `read`, `responded` |\n1011: | `propertyId` | uuid | no | Filter by property |\n1012: | `search` | string | no | Search by name or email |\n1013: | `sortBy` | enum | no | `newest` (default), `oldest` |\n1014: | `page` | number | no | Page number (default: 1) |\n1015: | `limit` | number | no | Items per page (default: 20, max: 100) |\n1016: \n1017: **Success Response** `200 OK`:\n1018: ```json\n1019: {\n1020:   \"success\": true,\n1021:   \"statusCode\": 200,\n1022:   \"message\": \"Inquiries retrieved successfully\",\n1023:   \"data\": {\n1024:     \"items\": [\n1025:       {\n1026:         \"id\": \"uuid\",\n1027:         \"property\": {\n1028:           \"id\": \"uuid\",\n1029:           \"title\": \"string\"\n1030:         },\n1031:         \"renter\": {\n1032:           \"id\": \"uuid\",\n1033:           \"name\": \"string\",\n1034:           \"email\": \"string\"\n1035:         },\n1036:         \"name\": \"string\",\n1037:         \"email\": \"string\",\n1038:         \"phone\": \"string | null\",\n1039:         \"message\": \"string\",\n1040:         \"status\": \"new | read | responded\",\n1041:         \"response\": \"string | null\",\n1042:         \"respondedAt\": \"ISO 8601 timestamp | null\",\n1043:         \"createdAt\": \"ISO 8601 timestamp\",\n1044:         \"updatedAt\": \"ISO 8601 timestamp\"\n1045:       }\n1046:     ],\n1047:     \"meta\": {\n1048:       \"total\": 45,\n1049:       \"page\": 1,\n1050:       \"limit\": 20,\n1051:       \"totalPages\": 3\n1052:     }\n1053:   },\n1054:   \"timestamp\": \"ISO 8601 timestamp\",\n1055:   \"path\": \"/api/inquiries\"\n1056: }\n1057: ```\n1058: \n1059: **Error Responses:**\n1060: - `401` — Not authenticated\n1061: - `403` — Insufficient permissions (not admin)\n1062: \n1063: ---\n1064: \n1065: #### Get Inquiry Detail\n1066: \n1067: | Method | Path | Auth |\n1068: |--------|------|------|\n1069: | `GET` | `/inquiries/:id` | Admin |\n1070: \n1071: **Description:** Get full details of a single inquiry.\n1072: \n1073: **Success Response** `200 OK`:\n1074: ```json\n1075: {\n1076:   \"success\": true,\n1077:   \"statusCode\": 200,\n1078:   \"message\": \"Inquiry retrieved successfully\",\n1079:   \"data\": {\n1080:     \"id\": \"uuid\",\n1081:     \"property\": {\n1082:       \"id\": \"uuid\",\n1083:       \"title\": \"string\"\n1084:     },\n1085:     \"renter\": {\n1086:       \"id\": \"uuid\",\n1087:       \"name\": \"string\",\n1088:       \"email\": \"string\"\n1089:     },\n1090:     \"name\": \"string\",\n1091:     \"email\": \"string\",\n1092:     \"phone\": \"string | null\",\n1093:     \"message\": \"string\",\n1094:     \"status\": \"new | read | responded\",\n1095:     \"response\": \"string | null\",\n1096:     \"respondedAt\": \"ISO 8601 timestamp | null\",\n1097:     \"createdAt\": \"ISO 8601 timestamp\",\n1098:     \"updatedAt\": \"ISO 8601 timestamp\"\n1099:   },\n1100:   \"timestamp\": \"ISO 8601 timestamp\",\n1101:   \"path\": \"/api/inquiries/uuid\"\n1102: }\n1103: ```\n1104: \n1105: **Error Responses:**\n1106: - `400` — Invalid UUID\n1107: - `401` — Not authenticated\n1108: - `403` — Insufficient permissions (not admin)\n1109: - `404` — Inquiry not found\n1110: \n1111: ---\n1112: \n1113: #### Mark Inquiry as Read\n1114: \n1115: | Method | Path | Auth |\n1116: |--------|------|------|\n1117: | `PATCH` | `/inquiries/:id/read` | Admin |\n1118: \n1119: **Description:** Mark an inquiry as read. Only applicable to inquiries with `new` status.\n1120: \n1121: **Request Body:** none\n1122: \n1123: **Success Response** `200 OK`:\n1124: ```json\n1125: {\n1126:   \"success\": true,\n1127:   \"statusCode\": 200,\n1128:   \"message\": \"Inquiry marked as read\",\n1129:   \"data\": {\n1130:     \"id\": \"uuid\",\n1131:     \"status\": \"read\",\n1132:     \"updatedAt\": \"ISO 8601 timestamp\"\n1133:   },\n1134:   \"timestamp\": \"ISO 8601 timestamp\",\n1135:   \"path\": \"/api/inquiries/uuid/read\"\n1136: }\n1137: ```\n1138: \n1139: **Error Responses:**\n1140: - `400` — Invalid UUID or inquiry already read/responded\n1141: - `401` — Not authenticated\n1142: - `403` — Insufficient permissions (not admin)\n1143: - `404` — Inquiry not found\n1144: \n1145: ---\n1146: \n1147: #### Respond to Inquiry\n1148: \n1149: | Method | Path | Auth |\n1150: |--------|------|------|\n1151: | `POST` | `/inquiries/:id/respond` | Admin |\n1152: \n1153: **Description:** Admin responds to an inquiry. Sets status to `responded` and records the response and timestamp.\n1154: \n1155: **Request Body:**\n1156: ```json\n1157: {\n1158:   \"response\": \"string (10–5000 chars, required)\"\n1159: }\n1160: ```\n1161: \n1162: **Success Response** `200 OK`:\n1163: ```json\n1164: {\n1165:   \"success\": true,\n1166:   \"statusCode\": 200,\n1167:   \"message\": \"Response sent successfully\",\n1168:   \"data\": {\n1169:     \"id\": \"uuid\",\n1170:     \"status\": \"responded\",\n1171:     \"response\": \"string\",\n1172:     \"respondedAt\": \"ISO 8601 timestamp\",\n1173:     \"updatedAt\": \"ISO 8601 timestamp\"\n1174:   },\n1175:   \"timestamp\": \"ISO 8601 timestamp\",\n1176:   \"path\": \"/api/inquiries/uuid/respond\"\n1177: }\n1178: ```\n1179: \n1180: **Error Responses:**\n1181: - `400` — Validation failed or invalid UUID\n1182: - `401` — Not authenticated\n1183: - `403` — Insufficient permissions (not admin)\n1184: - `404` — Inquiry not found\n1185: \n1186: ---\n1187: \n1188: ### Amenities\n1189: \n1190: ---\n1191: \n1192: #### List Amenities\n1193: \n1194: | Method | Path | Auth |\n1195: |--------|------|------|\n1196: | `GET` | `/amenities` | Public |\n1197: \n1198: **Description:** List all available amenities. Used for property creation/editing forms and property detail display.\n1199: \n1200: **Success Response** `200 OK`:\n1201: ```json\n1202: {\n1203:   \"success\": true,\n1204:   \"statusCode\": 200,\n1205:   \"message\": \"Amenities retrieved successfully\",\n1206:   \"data\": [\n1207:     {\n1208:       \"id\": \"uuid\",\n1209:       \"name\": \"Parking\",\n1210:       \"icon\": \"parking\"\n1211:     },\n1212:     {\n1213:       \"id\": \"uuid\",\n1214:       \"name\": \"Gym\",\n1215:       \"icon\": \"gym\"\n1216:     }\n1217:   ],\n1218:   \"timestamp\": \"ISO 8601 timestamp\",\n1219:   \"path\": \"/api/amenities\"\n1220: }\n1221: ```\n1222: \n1223: **Error Responses:** none (always returns array, empty if no amenities exist)\n1224: \n1225: ---\n1226: \n1227: #### Create Amenity\n1228: \n1229: | Method | Path | Auth |\n1230: |--------|------|------|\n1231: | `POST` | `/amenities` | Admin |\n1232: \n1233: **Description:** Create a new amenity option.\n1234: \n1235: **Request Body:**\n1236: ```json\n1237: {\n1238:   \"name\": \"string (1–50 chars, required, unique)\",\n1239:   \"icon\": \"string (1–50 chars, required)\"\n1240: }\n1241: ```\n1242: \n1243: **Success Response** `201 Created`:\n1244: ```json\n1245: {\n1246:   \"success\": true,\n1247:   \"statusCode\": 201,\n1248:   \"message\": \"Amenity created successfully\",\n1249:   \"data\": {\n1250:     \"id\": \"uuid\",\n1251:     \"name\": \"Parking\",\n1252:     \"icon\": \"parking\",\n1253:     \"createdAt\": \"ISO 8601 timestamp\",\n1254:     \"updatedAt\": \"ISO 8601 timestamp\"\n1255:   },\n1256:   \"timestamp\": \"ISO 8601 timestamp\",\n1257:   \"path\": \"/api/amenities\"\n1258: }\n1259: ```\n1260: \n1261: **Error Responses:**\n1262: - `400` — Validation failed\n1263: - `401` — Not authenticated\n1264: - `403` — Insufficient permissions (not admin)\n1265: - `409` — Amenity name already exists\n1266: \n1267: ---\n1268: \n1269: #### Update Amenity\n1270: \n1271: | Method | Path | Auth |\n1272: |--------|------|------|\n1273: | `PATCH` | `/amenities/:id` | Admin |\n1274: \n1275: **Description:** Update an existing amenity name or icon.\n1276: \n1277: **Request Body (all fields optional):**\n1278: ```json\n1279: {\n1280:   \"name\": \"string (1–50 chars)\",\n1281:   \"icon\": \"string (1–50 chars)\"\n1282: }\n1283: ```\n1284: \n1285: **Success Response** `200 OK`:\n1286: ```json\n1287: {\n1288:   \"success\": true,\n1289:   \"statusCode\": 200,\n1290:   \"message\": \"Amenity updated successfully\",\n1291:   \"data\": {\n1292:     \"id\": \"uuid\",\n1293:     \"name\": \"Parking\",\n1294:     \"icon\": \"parking\",\n1295:     \"updatedAt\": \"ISO 8601 timestamp\"\n1296:   },\n1297:   \"timestamp\": \"ISO 8601 timestamp\",\n1298:   \"path\": \"/api/amenities/uuid\"\n1299: }\n1300: ```\n1301: \n1302: **Error Responses:**\n1303: - `400` — Validation failed or invalid UUID\n1304: - `401` — Not authenticated\n1305: - `403` — Insufficient permissions (not admin)\n1306: - `404` — Amenity not found\n1307: - `409` — Amenity name already exists\n1308: \n1309: ---\n1310: \n1311: #### Delete Amenity\n1312: \n1313: | Method | Path | Auth |\n1314: |--------|------|------|\n1315: | `DELETE` | `/amenities/:id` | Admin |\n1316: \n1317: **Description:** Soft-delete an amenity. Properties already associated retain the amenity but it no longer appears in the amenity list for new associations.\n1318: \n1319: **Success Response** `200 OK`:\n1320: ```json\n1321: {\n1322:   \"success\": true,\n1323:   \"statusCode\": 200,\n1324:   \"message\": \"Amenity deleted successfully\",\n1325:   \"data\": null,\n1326:   \"timestamp\": \"ISO 8601 timestamp\",\n1327:   \"path\": \"/api/amenities/uuid\"\n1328: }\n1329: ```\n1330: \n1331: **Error Responses:**\n1332: - `400` — Invalid UUID\n1333: - `401` — Not authenticated\n1334: - `403` — Insufficient permissions (not admin)\n1335: - `404` — Amenity not found\n1336: \n1337: ---\n1338: \n1339: ### Admin Dashboard\n1340: \n1341: ---\n1342: \n1343: #### Dashboard Statistics\n1344: \n1345: | Method | Path | Auth |\n1346: |--------|------|------|\n1347: | `GET` | `/admin/dashboard` | Admin |\n1348: \n1349: **Description:** Returns aggregate statistics for the admin dashboard overview.\n1350: \n1351: **Success Response** `200 OK`:\n1352: ```json\n1353: {\n1354:   \"success\": true,\n1355:   \"statusCode\": 200,\n1356:   \"message\": \"Dashboard statistics retrieved\",\n1357:   \"data\": {\n1358:     \"totalProperties\": 150,\n1359:     \"totalInquiries\": 45,\n1360:     \"newInquiries\": 12,\n1361:     \"totalUsers\": 520,\n1362:     \"recentInquiries\": [\n1363:       {\n1364:         \"id\": \"uuid\",\n1365:         \"name\": \"string\",\n1366:         \"email\": \"string\",\n1367:         \"propertyTitle\": \"string\",\n1368:         \"status\": \"new\",\n1369:         \"createdAt\": \"ISO 8601 timestamp\"\n1370:       }\n1371:     ],\n1372:     \"recentProperties\": [\n1373:       {\n1374:         \"id\": \"uuid\",\n1375:         \"title\": \"string\",\n1376:         \"price\": 2500.00,\n1377:         \"propertyType\": \"apartment\",\n1378:         \"createdAt\": \"ISO 8601 timestamp\"\n1379:       }\n1380:     ]\n1381:   },\n1382:   \"timestamp\": \"ISO 8601 timestamp\",\n1383:   \"path\": \"/api/admin/dashboard\"\n1384: }\n1385: ```\n1386: \n1387: **Error Responses:**\n1388: - `401` — Not authenticated\n1389: - `403` — Insufficient permissions (not admin)\n1390: \n1391: ---\n1392: \n1393: ### Admin User Management\n1394: \n1395: ---\n1396: \n1397: #### List Users\n1398: \n1399: | Method | Path | Auth |\n1400: |--------|------|------|\n1401: | `GET` | `/admin/users` | Admin |\n1402: \n1403: **Description:** List all registered users with filtering and pagination.\n1404: \n1405: **Query Parameters:**\n1406: | Param | Type | Required | Description |\n1407: |-------|------|----------|-------------|\n1408: | `role` | enum | no | Filter: `renter`, `admin` |\n1409: | `status` | enum | no | Filter: `active`, `suspended` |\n1410: | `search` | string | no | Search by name or email |\n1411: | `sortBy` | enum | no | `newest` (default), `oldest`, `name_asc`, `name_desc` |\n1412: | `page` | number | no | Page number (default: 1) |\n1413: | `limit` | number | no | Items per page (default: 20, max: 100) |\n1414: \n1415: **Success Response** `200 OK`:\n1416: ```json\n1417: {\n1418:   \"success\": true,\n1419:   \"statusCode\": 200,\n1420:   \"message\": \"Users retrieved successfully\",\n1421:   \"data\": {\n1422:     \"items\": [\n1423:       {\n1424:         \"id\": \"uuid\",\n1425:         \"name\": \"string\",\n1426:         \"email\": \"string\",\n1427:         \"phone\": \"string | null\",\n1428:         \"role\": \"renter\",\n1429:         \"status\": \"active\",\n1430:         \"emailVerifiedAt\": \"ISO 8601 timestamp | null\",\n1431:         \"createdAt\": \"ISO 8601 timestamp\"\n1432:       }\n1433:     ],\n1434:     \"meta\": {\n1435:       \"total\": 520,\n1436:       \"page\": 1,\n1437:       \"limit\": 20,\n1438:       \"totalPages\": 26\n1439:     }\n1440:   },\n1441:   \"timestamp\": \"ISO 8601 timestamp\",\n1442:   \"path\": \"/api/admin/users\"\n1443: }\n1444: ```\n1445: \n1446: **Error Responses:**\n1447: - `401` — Not authenticated\n1448: - `403` — Insufficient permissions (not admin)\n1449: \n1450: ---\n1451: \n1452: #### Get User Detail\n1453: \n1454: | Method | Path | Auth |\n1455: |--------|------|------|\n1456: | `GET` | `/admin/users/:id` | Admin |\n1457: \n1458: **Description:** Get full details of a specific user, including activity summary.\n1459: \n1460: **Success Response** `200 OK`:\n1461: ```json\n1462: {\n1463:   \"success\": true,\n1464:   \"statusCode\": 200,\n1465:   \"message\": \"User retrieved successfully\",\n1466:   \"data\": {\n1467:     \"id\": \"uuid\",\n1468:     \"name\": \"string\",\n1469:     \"email\": \"string\",\n1470:     \"phone\": \"string | null\",\n1471:     \"role\": \"renter | admin\",\n1472:     \"status\": \"active | suspended\",\n1473:     \"emailVerifiedAt\": \"ISO 8601 timestamp | null\",\n1474:     \"activity\": {\n1475:       \"totalFavorites\": 5,\n1476:       \"totalInquiries\": 3,\n1477:       \"lastLoginAt\": \"ISO 8601 timestamp | null\"\n1478:     },\n1479:     \"createdAt\": \"ISO 8601 timestamp\",\n1480:     \"updatedAt\": \"ISO 8601 timestamp\"\n1481:   },\n1482:   \"timestamp\": \"ISO 8601 timestamp\",\n1483:   \"path\": \"/api/admin/users/uuid\"\n1484: }\n1485: ```\n1486: \n1487: **Error Responses:**\n1488: - `400` — Invalid UUID\n1489: - `401` — Not authenticated\n1490: - `403` — Insufficient permissions (not admin)\n1491: - `404` — User not found\n1492: \n1493: ---\n1494: \n1495: #### Update User Status\n1496: \n1497: | Method | Path | Auth |\n1498: |--------|------|------|\n1499: | `PATCH` | `/admin/users/:id/status` | Admin |\n1500: \n1501: **Description:** Suspend or reactivate a user account. Admins cannot suspend their own account.\n1502: \n1503: **Request Body:**\n1504: ```json\n1505: {\n1506:   \"status\": \"enum (active | suspended, required)\"\n1507: }\n1508: ```\n1509: \n1510: **Success Response** `200 OK`:\n1511: ```json\n1512: {\n1513:   \"success\": true,\n1514:   \"statusCode\": 200,\n1515:   \"message\": \"User status updated to 'suspended'\",\n1516:   \"data\": {\n1517:     \"id\": \"uuid\",\n1518:     \"name\": \"string\",\n1519:     \"email\": \"string\",\n1520:     \"status\": \"suspended\",\n1521:     \"updatedAt\": \"ISO 8601 timestamp\"\n1522:   },\n1523:   \"timestamp\": \"ISO 8601 timestamp\",\n1524:   \"path\": \"/api/admin/users/uuid/status\"\n1525: }\n1526: ```\n1527: \n1528: **Error Responses:**\n1529: - `400` — Invalid status value or cannot suspend own account\n1530: - `401` — Not authenticated\n1531: - `403` — Insufficient permissions (not admin)\n1532: - `404` — User not found\n1533: \n1534: ---\n1535: \n1536: ## Standard Response Format\n1537: \n1538: All API responses follow this consistent envelope structure:\n1539: \n1540: ```json\n1541: {\n1542:   \"success\": true,\n1543:   \"statusCode\": 200,\n1544:   \"message\": \"Human-readable message\",\n1545:   \"data\": { ... } | [ ... ] | null,\n1546:   \"timestamp\": \"2026-05-19T12:00:00.000Z\",\n1547:   \"path\": \"/api/endpoint\"\n1548: }\n1549: ```\n1550: \n1551: ### Paginated Responses\n1552: \n1553: List endpoints return paginated data in this shape:\n1554: \n1555: ```json\n1556: {\n1557:   \"success\": true,\n1558:   \"statusCode\": 200,\n1559:   \"message\": \"...\",\n1560:   \"data\": {\n1561:     \"items\": [ ... ],\n1562:     \"meta\": {\n1563:       \"total\": 150,\n1564:       \"page\": 1,\n1565:       \"limit\": 20,\n1566:       \"totalPages\": 8\n1567:     }\n1568:   },\n1569:   \"timestamp\": \"...\",\n1570:   \"path\": \"/api/...\"\n1571: }\n1572: ```\n1573: \n1574: ### Error Responses\n1575: \n1576: ```json\n1577: {\n1578:   \"success\": false,\n1579:   \"statusCode\": 400,\n1580:   \"message\": \"Validation failed\",\n1581:   \"error\": \"Bad Request\",\n1582:   \"errors\": [\n1583:     { \"field\": \"email\", \"message\": \"email must be a valid email address\" }\n1584:   ],\n1585:   \"timestamp\": \"2026-05-19T12:00:00.000Z\",\n1586:   \"path\": \"/api/endpoint\"\n1587: }\n1588: ```\n1589: \n1590: ---\n1591: \n1592: ## Authentication\n1593: \n1594: All endpoints except those marked **Public** require authentication via JWT access token stored in an httpOnly cookie (`access_token`).\n1595: \n1596: - **Public endpoints** can be accessed without authentication\n1597: - **Authenticated** endpoints require a valid access token (any role)\n1598: - **Renter** endpoints require authentication + `renter` role\n1599: - **Admin** endpoints require authentication + `admin` role\n1600: \n1601: Rate limiting is applied to auth endpoints: login, register, forgot-password, reset-password (default: 10 requests per 60 seconds).\n1602: \n1603: ---\n1604: \n1605: ## HTTP Status Codes Summary\n1606: \n1607: | Code | Meaning |\n1608: |------|---------|\n1609: | 200 | OK — Success (read, update, delete, action) |\n1610: | 201 | Created — Resource created successfully |\n1611: | 400 | Bad Request — Validation failed, invalid input |\n1612: | 401 | Unauthorized — Missing or invalid access token |\n1613: | 403 | Forbidden — Insufficient role permissions |\n1614: | 404 | Not Found — Resource does not exist or is soft-deleted |\n1615: | 409 | Conflict — Duplicate resource (e.g., email, amenity name) |\n1616: | 413 | Payload Too Large — File upload exceeds size limit |\n1617: | 429 | Too Many Requests — Rate limit exceeded |\n1618: \n1619: ---\n1620: \n1621: *Generated: 2026-05-19 | Source: PROJECT_KNOWLEDGE.md + PROJECT_DATABASE.md*\n\n(End of file - total 1621 lines)\n</content>","metadata":{"preview":"# PROJECT_API\n\nNestFind API Contract — canonical reference for all API endpoints.\n\n**Base URL:** `http://localhost:3000/api`\n\n---\n\n## Endpoints\n\n---\n\n### Authentication\n\n---\n\n#### Register\n\n| Method | Path | Auth |\n|--------|------|------|","truncated":false,"loaded":[]},"title":".claude-project/nestfind/docs/PROJECT_API.md","time":{"start":1779246747917,"end":1779246748197}},"id":"prt_e435ecb690011eFX8gEkbkO0Oz","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435e92eb001Skkv63Ht1xAgN4"}}
