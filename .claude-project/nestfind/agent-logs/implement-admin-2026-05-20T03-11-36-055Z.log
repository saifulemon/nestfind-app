page') page?: number,\n47:         @Query('limit') limit?: number,\n48:     ): Promise<T[]> {\n49:         const options =\n50:             page && limit ? { skip: (page - 1) * limit, take: limit } : {};\n51:         return this.service.findAll(options);\n52:     }\n53: \n54:     @Get(':id')\n55:     @HttpCode(HttpStatus.OK)\n56:     @ApiOperation({ summary: 'Get a resource by ID' })\n57:     @ApiParam({ name: 'id', type: String, description: 'Resource UUID' })\n58:     @ApiResponse({ status: 200, description: 'Resource retrieved successfully' })\n59:     @ApiResponse({ status: 404, description: 'Resource not found' })\n60:     async findOne(@Param('id', ParseUUIDPipe) id: string): Promise<T> {\n61:         return this.service.findByIdOrFail(id);\n62:     }\n63: \n64:     @Patch(':id')\n65:     @HttpCode(HttpStatus.OK)\n66:     @ApiOperation({ summary: 'Update a resource' })\n67:     @ApiParam({ name: 'id', type: String, description: 'Resource UUID' })\n68:     @ApiResponse({ status: 200, description: 'Resource updated successfully' })\n69:     @ApiResponse({ status: 404, description: 'Resource not found' })\n70:     async update(\n71:         @Param('id', ParseUUIDPipe) id: string,\n72:         @Body() updateDto: UpdateDto,\n73:     ): Promise<T | null> {\n74:         return this.service.update(id, updateDto);\n75:     }\n76: \n77:     @Delete(':id')\n78:     @HttpCode(HttpStatus.OK)\n79:     @ApiOperation({ summary: 'Delete a resource' })\n80:     @ApiParam({ name: 'id', type: String, description: 'Resource UUID' })\n81:     @ApiResponse({ status: 200, description: 'Resource deleted successfully' })\n82:     @ApiResponse({ status: 404, description: 'Resource not found' })\n83:     async remove(@Param('id', ParseUUIDPipe) id: string): Promise<void> {\n84:         return this.service.remove(id);\n85:     }\n86: }\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"import {\n    Get,\n    Post,\n    Patch,\n    Delete,\n    Body,\n    Param,\n    Query,\n    HttpCode,\n    HttpStatus,\n    ParseUUIDPipe,\n} from '@nestjs/common';\nimport {\n    ApiOperation,\n    ApiResponse,\n    ApiParam,\n    ApiQuery,\n} from '@nestjs/swagger';\nimport { BaseService } from './base.service';\nimport { BaseEntity } from './base.entity';","truncated":false,"loaded":[]},"title":"backend/src/core/base/base.controller.ts","time":{"start":1779246785272,"end":1779246785546}},"id":"prt_e435f5e04001EHDYEAM65NjPw5","sessionID":"ses_1bca1f2c7ffeBQnsSbmHralvv5","messageID":"msg_e435ed602001WjNuf5JUarN9np"}}
