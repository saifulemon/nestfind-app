expect(409);\n191:     });\n192:   });\n193: \n194:   // ─── PATCH /amenities/:id (Update) ────────────────────────────────\n195:   describe('PATCH /api/amenities/:id', () => {\n196:     let amenity: Amenity;\n197: \n198:     beforeEach(async () => {\n199:       const amenities = await seedTestAmenities(dataSource);\n200:       amenity = amenities[0]; // Parking\n201:     });\n202: \n203:     it('should return 200 with updated amenity (admin only)', async () => {\n204:       const res = await request(app.getHttpServer())\n205:         .patch(`/api/amenities/${amenity.id}`)\n206:         .set(authHeader(adminToken))\n207:         .send({ name: 'Updated Amenity' })\n208:         .expect(200);\n209: \n210:       expect(res.body.success).toBe(true);\n211:       expect(res.body.statusCode).toBe(200);\n212:       expect(res.body.message).toBe('Amenity updated successfully');\n213:       expect(res.body.data).toHaveProperty('id', amenity.id);\n214:       expect(res.body.data).toHaveProperty('name', 'Updated Amenity');\n215:       expect(res.body.data).toHaveProperty('updatedAt');\n216:     });\n217: \n218:     it('should return 200 updating icon only', async () => {\n219:       const res = await request(app.getHttpServer())\n220:         .patch(`/api/amenities/${amenity.id}`)\n221:         .set(authHeader(adminToken))\n222:         .send({ icon: 'new-icon' })\n223:         .expect(200);\n224: \n225:       expect(res.body.data.icon).toBe('new-icon');\n226:       expect(res.body.data.name).toBe(amenity.name);\n227:     });\n228: \n229:     it('should return 400 for invalid UUID', async () => {\n230:       await request(app.getHttpServer())\n231:         .patch('/api/amenities/not-a-uuid')\n232:         .set(authHeader(adminToken))\n233:         .send({ name: 'Bad UUID' })\n234:         .expect(400);\n235:     });\n236: \n237:     it('should return 400 when name exceeds 50 chars', async () => {\n238:       await request(app.getHttpServer())\n239:         .patch(`/api/amenities/${amenity.id}`)\n240:         .set(authHeader(adminToken))\n241:         .send({ name: 'A'.repeat(51) })\n242:         .expect(400);\n243:     });\n244: \n245:     it('should return 400 when icon exceeds 50 chars', async () => {\n246:       await request(app.getHttpServer())\n247:         .patch(`/api/amenities/${amenity.id}`)\n248:         .set(authHeader(adminToken))\n249:         .send({ icon: 'A'.repeat(51) })\n250:         .expect(400);\n251:     });\n252: \n253:     it('should return 401 when not authenticated', async () => {\n254:       await request(app.getHttpServer())\n255:         .patch(`/api/amenities/${amenity.id}`)\n256:         .send({ name: 'No Auth' })\n257:         .expect(401);\n258:     });\n259: \n260:     it('should return 403 when authenticated as renter (not admin)', async () => {\n261:       await request(app.getHttpServer())\n262:         .patch(`/api/amenities/${amenity.id}`)\n263:         .set(authHeader(renterToken))\n264:         .send({ name: 'Renter Update' })\n265:         .expect(403);\n266:     });\n267: \n268:     it('should return 404 when amenity not found', async () => {\n269:       await request(app.getHttpServer())\n270:         .patch('/api/amenities/00000000-0000-0000-0000-000000000000')\n271:         .set(authHeader(adminToken))\n272:         .send({ name: 'Not Found' })\n273:         .expect(404);\n274:     });\n275: \n276:     it('should return 409 when updating to an existing amenity name', async () => {\n277:       const amenities = await seedTestAmenities(dataSource);\n278:       const otherName = amenities[1].name; // Gym\n279: \n280:       await request(app.getHttpServer())\n281:         .patch(`/api/amenities/${amenity.id}`)\n282:         .set(authHeader(adminToken))\n283:         .send({ name: otherName })\n284:         .expect(409);\n285:     });\n286:   });\n287: \n288:   // ─── DELETE /amenities/:id ─────────────────────────────────────────\n289:   describe('DELETE /api/amenities/:id', () => {\n290:     let 