    sameSite: 'strict',\n49:       maxAge: 604800000,\n50:       path: '/',\n51:     });\n52: \n53:     return {\n54:       message: 'Login successful',\n55:       data: {\n56:         user: { id: user.id, name: user.name, email: user.email, role: user.role, status: user.status },\n57:       },\n58:     };\n59:   }\n60: \n61:   @Public()\n62:   @Post('refresh')\n63:   @HttpCode(HttpStatus.OK)\n64:   async refresh(\n65:     @Req() req: Request,\n66:     @Res({ passthrough: true }) res: Response,\n67:   ) {\n68:     const refreshToken = req.cookies?.['refresh_token'];\n69:     if (!refreshToken) {\n70:       throw new Error('No refresh token provided');\n71:     }\n72: \n73:     const tokens = await this.authService.refresh(refreshToken);\n74: \n75:     res.cookie('access_token', tokens.accessToken, {\n76:       httpOnly: true,\n77:       secure: false,\n78:       sameSite: 'strict',\n79:       maxAge: 3600000,\n80:       path: '/',\n81:     });\n82: \n83:     res.cookie('refresh_token', tokens.refreshToken, {\n84:       httpOnly: true,\n85:       secure: false,\n86:       sameSite: 'strict',\n87:       maxAge: 604800000,\n88:       path: '/',\n89:     });\n90: \n91:     return { message: 'Token refreshed' };\n92:   }\n93: \n94:   @Post('logout')\n95:   @HttpCode(HttpStatus.OK)\n96:   async logout(\n97:     @Req() req: Request,\n98:     @Res({ passthrough: true }) res: Response,\n99:     @CurrentUser() user: any,\n100:   ) {\n101:     const refreshToken = req.cookies?.['refresh_token'];\n102:     if (refreshToken) {\n103:       await this.authService.logout(refreshToken);\n104:     }\n105: \n106:     res.clearCookie('access_token', { path: '/' });\n107:     res.clearCookie('refresh_token', { path: '/' });\n108: \n109:     return { message: 'Logged out successfully' };\n110:   }\n111: }\n\n(End of file - total 111 lines)\n</content>","metadata":{"preview":"import {\n  Controller,\n  Post,\n  Body,\n  Req,\n  Res,\n  HttpCode,\n  HttpStatus,\n} from '@nestjs/common';\ni