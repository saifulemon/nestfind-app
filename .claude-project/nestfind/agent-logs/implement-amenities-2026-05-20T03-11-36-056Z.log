tingModule;\n25: }\n26: \n27: /**\n28:  * Creates a NestJS test application with all entities registered against\n29:  * an in-memory SQLite database (no external PostgreSQL dependency for tests).\n30:  *\n31:  * Accepts optional feature modules to register. When modules don't exist yet\n32:  * (RED phase), pass an empty array — the test app will start but routes\n33:  * won't be registered, causing all requests to 404.\n34:  */\n35: export async function createTestApp(\n36:   featureModules: any[] = [],\n37: ): Promise<TestAppContext> {\n38:   const moduleFixture: TestingModule = await Test.createTestingModule({\n39:     imports: [\n40:       TypeOrmModule.forRoot({\n41:         type: 'better-sqlite3',\n42:         database: ':memory:',\n43:         entities: [\n44:           User,\n45:           RefreshToken,\n46:           PasswordResetToken,\n47:           Property,\n48:           PropertyPhoto,\n49:           Amenity,\n50:           PropertyAmenity,\n51:           Favorite,\n52:           Inquiry,\n53:         ],\n54:         synchronize: true,\n55:         dropSchema: true,\n56:         logging: false,\n57:       }),\n58:       TypeOrmModule.forFeature([\n59:         User,\n60:         RefreshToken,\n61:         PasswordResetToken,\n62:         Property,\n63:         PropertyPhoto,\n64:         Amenity,\n65:         PropertyAmenity,\n66:         Favorite,\n67:         Inquiry,\n68:       ]),\n69:       ...featureModules,\n70:     ],\n71:   }).compile();\n72: \n73:   const app = moduleFixture.createNestApplication();\n74: \n75:   app.setGlobalPrefix('api');\n76:   app.useGlobalPipes(\n77:     new ValidationPipe({\n78:       whitelist: true,\n79:       forbidNonWhitelisted: true,\n80:       transform: true,\n81:       transformOptions: { enableImplicitConversion: true },\n82:     }),\n83:   );\n84:   app.useGlobalFilters(new AllExceptionsFilter(), new HttpExceptionFilter());\n85:   app.useGlobalInterceptors(new LoggingInterceptor(), new TransformInterceptor());\