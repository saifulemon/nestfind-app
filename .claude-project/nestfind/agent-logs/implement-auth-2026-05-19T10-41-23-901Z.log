ord reset', async () => {\n383:       const resetToken = generatePasswordResetToken(testUser);\n384: \n385:       const res = await request(app.getHttpServer())\n386:         .post('/api/auth/reset-password')\n387:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n388:         .expect(200);\n389: \n390:       expect(res.body.success).toBe(true);\n391:       expect(res.body.statusCode).toBe(200);\n392:       expect(res.body.message).toBe('Password reset successfully');\n393:       expect(res.body.data).toBeNull();\n394:     });\n395: \n396:     it('should return 400 when token is missing', async () => {\n397:       await request(app.getHttpServer())\n398:         .post('/api/auth/reset-password')\n399:         .send({ password: 'NewSecurePass456!' })\n400:         .expect(400);\n401:     });\n402: \n403:     it('should return 400 when password is missing', async () => {\n404:       const resetToken = generatePasswordResetToken(testUser);\n405:       await request(app.getHttpServer())\n406:         .post('/api/auth/reset-password')\n407:         .send({ token: resetToken })\n408:         .expect(400);\n409:     });\n410: \n411:     it('should return 400 when password is too short (< 8 chars)', async () => {\n412:       const resetToken = generatePasswordResetToken(testUser);\n413:       await request(app.getHttpServer())\n414:         .post('/api/auth/reset-password')\n415:         .send({ token: resetToken, password: 'Short1!' })\n416:         .expect(400);\n417:     });\n418: \n419:     it('should return 404 when token is invalid/not found', async () => {\n420:       await request(app.getHttpServer())\n421:         .post('/api/auth/reset-password')\n422:         .send({ token: 'invalid-reset-token', password: 'NewSecurePass456!' })\n423:         .expect(404);\n424:     });\n425: \n426:     it('should return 400 when token is expired', async () => {\n427:       // Token expiry is handled by the implementation;\n428:       // tests will need DB-level token manipulation in GREEN phase\n429:       const resetToken = generatePasswordResetToken(testUser);\n430:       // In GREEN phase, manually set expiresAt to the past\n431:       await request(app.getHttpServer())\n432:         .post('/api/auth/reset-password')\n433:         .send({ token: resetToken, password: 'NewSecurePass456!' })\n434:         .expect(200);\n435:       // NOTE: This test will need refinement in GREEN phase to\n436:       // create an expired PasswordResetToken in the database\n437:     });\n438:   });\n439: \n440:   // ─── GET /auth/me ─────────────────────────────────────────────────\n441:   describe('GET /api/auth/me', () => {\n442:     it('should return 200 with current user profile', async () => {\n443:       const user = await createTestUser(dataSource, testUsers.renter);\n444:       const token = generateAccessToken(user);\n445: \n446:       const res = await request(app.getHttpServer())\n447:         .get('/api/auth/me')\n448:         .set(authHeader(token))\n449:         .expect(200);\n450: \n451:       expect(res.body.success).toBe(true);\n452:       expect(res.body.statusCode).toBe(200);\n453:       expect(res.body.message).toBe('User retrieved successfully');\n454:       expect(res.body.data).toHaveProperty('id', user.id);\n455:       expect(res.body.data).toHaveProperty('name', user.name);\n456:       expect(res.body.data).toHaveProperty('email', user.email);\n457:       expect(res.body.data).toHaveProperty('role', user.role);\n458:       expect(res.body.data).toHaveProperty('status', user.status);\n459:       expect(res.body.data).toHaveProperty('emailVerifiedAt');\n460:       expect(res.body.data).toHaveProperty('createdAt');\n461:       expect(res.body.data).toHaveProperty('updatedAt');\n462:       expect(res.body.data).not.toHaveProperty('password');\n463:     });\n464: \n465:     it('should return 401 when not authenticated', async () => {\n466:       await request(app.getHttpServer())\n467:         .get('/api/auth/me')\n468:         .expect(401);\n469:     });\n470: \n471:     it('should return 401 with invalid token', async () => {\n472:       await request(app.getHttpServer())\n473:         .get('/api/auth/me')\n474:         .set(authHeader('invalid-token'))\n475:         .expect(401);\n476:     });\n477: \n478:     it('should return correct role for admin user', async () => {\n479:       const admin = await createTestUser(dataSource, testUsers.admin);\n480:       const token = generateAccessToken(admin);\n481: \n482:       const res = await request(app.getHttpServer())\n483:         .get('/api/auth/me')\n484:         .set(authHeader(token))\n485:         .expect(200);\n486: \n487:       expect(res.body.data.role).toBe('admin');\n488:     });\n489:   });\n490: });\n\n(End of file - total 490 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\nimport { cleanDatabase } from '../setup/test-database';\nimport {\n  createTestUser,\n  seedTestUsers,\n  testUsers,\n  TEST_PASSWORD,\n  TestUserData,\n} from '../fixtures/user.fixture';\nimport {\n  generateAccessToken,\n  generateRefreshToken,\n  generatePasswordResetToken,\n  authHeader,\n  refreshCookieHeader,","truncated":false,"loaded":[]},"title":"backend/test/e2e/auth.e2e-spec.ts","time":{"start":1779187541677,"end":1779187541950}},"id":"prt_e3fd7613c001KM3vbYvRhmNSrS","sessionID":"ses_1c02c80f1ffeMPOpX92Fqk2guI","messageID":"msg_e3fd750960018HZTWjMIKDmdXT"}}
