50:     }\n51:   }\n52: \n53:   public getTypeOrmConfig() {\n54:     return {\n55:       host: this.getValue(\"POSTGRES_HOST\"),\n56:       port: parseInt(this.getValue(\"POSTGRES_PORT\")),\n57:       username: this.getValue(\"POSTGRES_USER\"),\n58:       password: this.getValue(\"POSTGRES_PASSWORD\"),\n59:       database: this.getValue(\"POSTGRES_DATABASE\"),\n60:       synchronize: !this.isProduction(),\n61:     };\n62:   }\n63: \n64:   public getAuthJWTConfig() {\n65:     const secret = this.getValue(\"AUTH_JWT_SECRET\", false);\n66:     if (!secret) {\n67:       throw new Error(\"AUTH_JWT_SECRET is required — no fallback allowed\");\n68:     }\n69:     return {\n70:       AUTH_JWT_SECRET: secret,\n71:       AUTH_TOKEN_COOKIE_NAME: this.getValue(\"AUTH_TOKEN_COOKIE_NAME\"),\n72:       AUTH_TOKEN_EXPIRE_TIME:\n73:         this.getValue(\"AUTH_TOKEN_EXPIRE_TIME\", false) || \"86400\",\n74:       AUTH_TOKEN_EXPIRE_TIME_REMEMBER_ME:\n75:         this.getValue(\"AUTH_TOKEN_EXPIRE_TIME_REMEMBER_ME\", false) || \"2592000\",\n76:       AUTH_REFRESH_TOKEN_COOKIE_NAME: this.getValue(\n77:         \"AUTH_REFRESH_TOKEN_COOKIE_NAME\",\n78:       ),\n79:       AUTH_REFRESH_TOKEN_EXPIRE_TIME:\n80:         this.getValue(\"AUTH_REFRESH_TOKEN_EXPIRE_TIME\", false) || \"2592000\",\n81:     };\n82:   }\n83: \n84:   // TODO: CUSTOMIZE — Add project-specific config methods below\n85:   // Example: getMailConfig(), getAwsConfig(), etc.\n86: }\n87: \n88: const envConfigService = new EnvConfigService(process.env).ensureValues([\n89:   // TODO: CUSTOMIZE — List required env vars for your project\n90:   \"POSTGRES_HOST\",\n91:   \"POSTGRES_PORT\",\n92:   \"POSTGRES_USER\",\n93:   \"POSTGRES_PASSWORD\",\n94:   \"POSTGRES_DATABASE\",\n95: ]);\n96: \n97: export { envConfigService };\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"import dotenv from \"dotenv\";\ndotenv.config();\n\nclass EnvConfigService {\n  constructor(private env: { [k: string]: string | undefined }) {