{"type":"tool_use","timestamp":1779247330093,"sessionID":"ses_1bca1f04effeVrfS1B3q4O2Kw9","part":{"type":"tool","tool":"read","callID":"call_03_LTodtdRtxtkYV0gLNccK9433","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/interceptors/set-token.interceptor.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/interceptors/set-token.interceptor.ts</path>\n<type>file</type>\n<content>\n1: import {\n2:   CallHandler,\n3:   ExecutionContext,\n4:   Injectable,\n5:   NestInterceptor,\n6: } from \"@nestjs/common\";\n7: import { ConfigService } from \"@nestjs/config\";\n8: import { catchError, map, Observable, throwError } from \"rxjs\";\n9: \n10: /**\n11:  * SetTokenInterceptor — automatically sets httpOnly cookies when the service\n12:  * returns a response containing a token.\n13:  *\n14:  * Usage: @UseInterceptors(SetTokenInterceptor) on login/register/refresh endpoints.\n15:  *\n16:  * The service must return: { success: true, data: { token: '...' } }\n17:  * or the interceptor will pass the response through unchanged.\n18:  */\n19: @Injectable()\n20: export class SetTokenInterceptor implements NestInterceptor {\n21:   constructor(private readonly configService: ConfigService) {}\n22: \n23:   intercept(context: ExecutionContext, next: CallHandler): Observable<any> {\n24:     const res = context.switchToHttp().getResponse();\n25:     const isProduction = this.configService.get<string>(\"MODE\") === \"PROD\";\n26: \n27:     return next.handle().pipe(\n28:       map((value) => {\n29:         if (value?.success && value?.data?.token) {\n30:           res.cookie(\n31:             this.configService.getOrThrow<string>(\"AUTH_TOKEN_COOKIE_NAME\"),\n32:             value.data.token,\n33:             {\n34:               httpOnly: true,\n35:               secure: isProduction,\n36:               sameSite: isProduction ? \"strict\" : \"none\",\n37:               path: \"/\",\n38:             },\n39:           );\n40:         }\n41: \n42:         // Also handle refreshToken if present\n43:         if (value?.success && value?.data?.refreshToken) {\n44:           res.cookie(\n45:             this.configService.getOrThrow<string>(\n46:               \"AUTH_REFRESH_TOKEN_COOKIE_NAME\",\n47:             ),\n48:             value.data.refreshToken,\n49:             {\n50:               httpOnly: true,\n51:               secure: isProduction,\n52:               sameSite: isProduction ? \"strict\" : \"none\",\n53:               path: \"/\",\n54:             },\n55:           );\n56:         }\n57: \n58:         return value;\n59:       }),\n60:       catchError((err) => {\n61:         return throwError(() => err);\n62:       }),\n63:     );\n64:   }\n65: }\n\n(End of file - total 65 lines)\n</content>","metadata":{"preview":"import {\n  CallHandler,\n  ExecutionContext,\n  Injectable,\n  NestInterceptor,\n} from \"@nestjs/common\";\nimport { ConfigService } from \"@nestjs/config\";\nimport { catchError, map, Observable, throwError } from \"rxjs\";\n\n/**\n * SetTokenInterceptor — automatically sets httpOnly cookies when the service\n * returns a response containing a token.\n *\n * Usage: @UseInterceptors(SetTokenInterceptor) on login/register/refresh endpoints.\n *\n * The service must return: { success: true, data: { token: '...' } }\n * or the interceptor will pass the response through unchanged.\n */\n@Injectable()\nexport class SetTokenInterceptor implements NestInterceptor {","truncated":false,"loaded":[]},"title":"backend/src/core/interceptors/set-token.interceptor.ts","time":{"start":1779247329256,"end":1779247330092}},"id":"prt_e4367aaa3001sDLVFP689AzgAQ","sessionID":"ses_1bca1f04effeVrfS1B3q4O2Kw9","messageID":"msg_e4366a5a40012DoDBnhBVGa414"}}
