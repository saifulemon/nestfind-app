         );\n42:     }\n43: }\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"import {\n    Injectable,\n    NestInterceptor,\n    ExecutionContext,\n    CallHandler,\n    Logger,\n} from '@nestjs/common';\nimport { Observable } from 'rxjs';\nimport { tap, catchError } from 'rxjs/operators';\nimport { throwError } from 'rxjs';\n\n/**\n * LoggingInterceptor — logs incoming requests and response times.\n *\n * Output: [HTTP] GET /api/users 200 +45ms\n */\n@Injectable()\nexport class LoggingInterceptor implements NestInterceptor {\n    private readonly logger = new Logger('HTTP');\n","truncated":false,"loaded":[]},"title":"backend/src/core/interceptors/logging.interceptor.ts","time":{"start":1779247332584,"end":1779247332871}},"id":"prt_e4367b7e8001M1wqhiGkv619BG","sessionID":"ses_1bca1f04effeVrfS1B3q4O2Kw9","messageID":"msg_e4366a5a40012DoDBnhBVGa414"}}
