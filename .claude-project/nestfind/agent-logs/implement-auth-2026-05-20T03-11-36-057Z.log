{"type":"tool_use","timestamp":1779247695017,"sessionID":"ses_1bca1f04effeVrfS1B3q4O2Kw9","part":{"type":"tool","tool":"write","callID":"call_00_0gM826spO8bp0PRq2IPV7959","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/auth/services/auth.service.ts","content":"import {\n  Injectable,\n  UnauthorizedException,\n  ForbiddenException,\n  BadRequestException,\n  NotFoundException,\n} from '@nestjs/common';\nimport { JwtService } from '@nestjs/jwt';\nimport * as bcrypt from 'bcrypt';\nimport { v4 as uuid } from 'uuid';\nimport { InjectRepository } from '@nestjs/typeorm';\nimport { Repository, MoreThan } from 'typeorm';\nimport { UserService } from '../../users/user.service';\nimport { User } from '../../users/entities/user.entity';\nimport { RefreshToken } from '../entities/refresh-token.entity';\nimport { PasswordResetToken } from '../entities/password-reset-token.entity';\nimport { RegisterDto } from '../dto/register.dto';\nimport { LoginDto } from '../dto/login.dto';\nimport { RoleEnum } from '../../../common/enums/role.enum';\nimport { UserStatusEnum } from '../../../common/enums/user-status.enum';\n\n@Injectable()\nexport class AuthService {\n  constructor(\n    private readonly userService: UserService,\n    private readonly jwtService: JwtService,\n    @InjectRepository(RefreshToken)\n    private readonly refreshTokenRepo: Repository<RefreshToken>,\n    @InjectRepository(PasswordResetToken)\n    private readonly passwordResetTokenRepo: Repository<PasswordResetToken>,\n  ) {}\n\n  async register(dto: RegisterDto): Promise<Partial<User>> {\n    const existing = await this.userService.findByEmail(dto.email);\n    if (existing) {\n      throw new BadRequestException('Email already registered!');\n    }\n\n    const hashedPassword = await bcrypt.hash(dto.password, 10);\n\n    const user = await this.userService.createUser({\n      name: dto.name,\n      email: dto.email,\n      password: hashedPassword,\n      phone: dto.phone ?? null,\n      role: RoleEnum.RENTER,\n      status: UserStatusEnum.ACTIVE,\n    });\n\n    return this.sanitizeUser(user);\n  }\n\n  async login(\n    dto: LoginDto,\n  ): Promise<{ accessToken: string; refreshToken: string; user: Partial<User> }> {\n    const user = await this.userService.findByEmailWithPassword(dto.email);\n\n    if (!user) {\n      throw new UnauthorizedException('Invalid email or password!');\n    }\n\n    if (user.status === UserStatusEnum.SUSPENDED) {\n      throw new ForbiddenException('Account is suspended!');\n    }\n\n    const isPasswordValid = await bcrypt.compare(dto.password, user.password);\n    if (!isPasswordValid) {\n      throw new UnauthorizedException('Invalid email or password!');\n    }\n\n    const tokens = await this.generateTokens(user);\n    return { ...tokens, user: this.sanitizeUser(user) };\n  }\n\n  async refresh(\n    refreshToken: string,\n  ): Promise<{ accessToken: string; refreshToken: string; user: Partial<User> }> {\n    if (!refreshToken) {\n      throw new UnauthorizedException('No refresh token provided!');\n    }\n\n    const existingToken = await this.findRefreshToken(refreshToken);\n\n    if (!existingToken) {\n      throw new UnauthorizedException('Invalid refresh token!');\n    }\n\n    if (existingToken.revokedAt) {\n      throw new UnauthorizedException('Refresh token has been revoked!');\n    }\n\n    if (new Date() > existingToken.expiresAt) {\n      throw new UnauthorizedException('Refresh token has expired!');\n    }\n\n    existingToken.revokedAt = new Date();\n    await this.refreshTokenRepo.save(existingToken);\n\n    const tokens = await this.generateTokens(existingToken.user);\n    return { ...tokens, user: this.sanitizeUser(existingToken.user) };\n  }\n\n  async logout(refreshToken: string): Promise<void> {\n    const existing = await this.findRefreshToken(refreshToken);\n    if (existing && !existing.revokedAt) {\n      existing.revokedAt = new Date();\n      await this.refreshTokenRepo.save(existing);\n    }\n  }\n\n  async forgotPassword(email: string): Promise<void> {\n    const user = await this.userService.findByEmail(email);\n    if (!user) {\n      return;\n    }\n\n    const tokenValue = uuid();\n\n    const resetToken = this.passwordResetTokenRepo.create({\n      userId: user.id,\n      token: tokenValue,\n      expiresAt: new Date(Date.now() + 60 * 60 * 1000),\n    });\n    await this.passwordResetTokenRepo.save(resetToken);\n  }\n\n  async resetPassword(token: string, password: string): Promise<void> {\n    if (!token) {\n      throw new BadRequestException('Reset token is required!');\n    }\n\n    const resetToken = await this.findResetToken(token);\n\n    if (!resetToken) {\n      throw new NotFoundException('Invalid or expired reset token!');\n    }\n\n    if (resetToken.usedAt) {\n      throw new BadRequestException('Reset token has already been used!');\n    }\n\n    if (new Date() > resetToken.expiresAt) {\n      throw new BadRequestException('Reset token has expired!');\n    }\n\n    const hashedPassword = await bcrypt.hash(password, 10);\n\n    await this.userService.update(resetToken.userId, {\n      password: hashedPassword,\n    });\n\n    resetToken.usedAt = new Date();\n    await this.passwordResetTokenRepo.save(resetToken);\n  }\n\n  async getCurrentUser(userId: string): Promise<Partial<User>> {\n    const user = await this.userService.findByIdOrFail(userId);\n    return this.sanitizeUser(user);\n  }\n\n  private async generateTokens(\n    user: User,\n  ): Promise<{ accessToken: string; refreshToken: string }> {\n    const payload = {\n      sub: user.id,\n      email: user.email,\n      role: user.role,\n    };\n\n    const accessToken = this.jwtService.sign(payload, { expiresIn: '1h' });\n\n    const tokenValue = uuid();\n    const refreshToken = this.refreshTokenRepo.create({\n      userId: user.id,\n      token: tokenValue,\n      expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),\n    });\n    await this.refreshTokenRepo.save(refreshToken);\n\n    return { accessToken, refreshToken: tokenValue };\n  }\n\n  private sanitizeUser(user: User): Partial<User> {\n    const { password, refreshTokens, resetTokens, ...safe } = user;\n    return safe;\n  }\n\n  private async findRefreshToken(\n    token: string,\n  ): Promise<(RefreshToken & { user: User }) | null> {\n    return this.refreshTokenRepo.findOne({\n      where: { token },\n      relations: ['user'],\n    });\n  }\n\n  private async findResetToken(\n    token: string,\n  ): Promise<PasswordResetToken | null> {\n    return this.passwordResetTokenRepo.findOne({\n      where: { token },\n    });\n  }\n}\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/auth/services/auth.service.ts","exists":true,"truncated":false},"title":"backend/src/modules/auth/services/auth.service.ts","time":{"start":1779247694254,"end":1779247695011}},"id":"prt_e436c89ff001MBAmelP05MxTiE","sessionID":"ses_1bca1f04effeVrfS1B3q4O2Kw9","messageID":"msg_e436c616a001WPkBZWnv0kNWE8"}}
