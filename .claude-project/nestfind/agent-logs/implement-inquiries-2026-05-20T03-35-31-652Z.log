   data: inquiry,\n    };\n  }\n}\n","filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/inquiries/inquiry-submit.controller.ts"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/inquiries/inquiry-submit.controller.ts","exists":false,"truncated":false},"title":"backend/src/modules/inquiries/inquiry-submit.controller.ts","time":{"start":1779249331459,"end":1779249331772}},"id":"prt_e4385fcf3001dDw5GKEJNJuzQ7","sessionID":"ses_1bc8c0c0bffeEZb75VgBylzEVF","messageID":"msg_e4384f04b0010NHl23XF2PbvJQ"}}
