Property;\n35: \n36:   beforeAll(async () => {\n37:     const context = await createTestApp();\n38:     app = context.app;\n39:     module = context.module;\n40:     dataSource = getDataSource(module);\n41:   });\n42: \n43:   afterAll(async () => {\n44:     await closeTestApp({ app, module });\n45:   });\n46: \n47:   beforeEach(async () => {\n48:     await cleanDatabase(dataSource);\n49:     const seededUsers = await seedTestUsers(dataSource);\n50:     adminUser = seededUsers.admin;\n51:     renterUser = seededUsers.renter;\n52:     renter2User = seededUsers.renter2;\n53:     adminToken = generateAccessToken(adminUser);\n54:     renterToken = generateAccessToken(renterUser);\n55:     renter2Token = generateAccessToken(renter2User);\n56: \n57:     const seededProps = await seedTestProperties(dataSource);\n58:     property1 = seededProps.downtownApt;\n59:     property2 = seededProps.suburbanHouse;\n60:   });\n61: \n62:   // ─── GET /inquiries/my (Renter's Own Inquiries) ────────────────────\n63:   describe('GET /api/inquiries/my', () => {\n64:     beforeEach(async () => {\n65:       // Renter1 submits inquiries on property1 and property2\n66:       await request(app.getHttpServer())\n67:         .post(`/api/properties/${property1.id}/inquiries`)\n68:         .set(authHeader(renterToken))\n69:         .send({ message: 'First inquiry from renter1 about property1.' })\n70:         .expect(201);\n71: \n72:       await request(app.getHttpServer())\n73:         .post(`/api/properties/${property2.id}/inquiries`)\n74:         .set(authHeader(renterToken))\n75:         .send({ message: 'Second inquiry from renter1 about property2.' })\n76:         .expect(201);\n77: \n78:       // Renter2 submits an inquiry on property1 (should NOT appear in renter1's list)\n79:       await request(app.getHttpServer())\n80:         .post(`/api/properties/${property1.id}/inquiries`)\n81:         .set(authHeader(renter2Token))\n82:         .send({ message: 'Inquiry from renter2 about property1.' })\n83:         .expect(201);\n84:     });\n85: \n86:     it('should return 200 with paginated inquiries list (renter only)', async () => {\n87:       const res = await request(app.getHttpServer())\n88:         .get('/api/inquiries/my')\n89:         .set(authHeader(renterToken))\n90:         .expect(200);\n91: \n92:       expect(res.body.success).toBe(true);\n93:       expect(res.body.statusCode).toBe(200);\n94:       expect(res.body.message).toMatch(/inquiries/i);\n95:       expect(res.body.data).toHaveProperty('items');\n96:       expect(res.body.data).toHaveProperty('meta');\n97:       expect(res.body.data.meta).toHaveProperty('total');\n98:       expect(res.body.data.meta).toHaveProperty('page');\n99:       expect(res.body.data.meta).toHaveProperty('limit');\n100:       expect(res.body.data.meta).toHaveProperty('totalPages');\n101:       expect(Array.isArray(res.body.data.items)).toBe(true);\n102:     });\n103: \n104:     it('should return inquiry items with correct shape', async () => {\n105:       const res = await request(app.getHttpServer())\n106:         .get('/api/inquiries/my')\n107:         .set(authHeader(renterToken))\n108:         .expect(200);\n109: \n110:       if (res.body.data.items.length > 0) {\n111:         const item = res.body.data.items[0];\n112:         expect(item).toHaveProperty('id');\n113:         expect(item).toHaveProperty('property');\n114:         expect(item.property).toHaveProperty('id');\n115:         expect(item.property).toHaveProperty('title');\n116:         expect(item).toHaveProperty('name');\n117:         expect(item).toHaveProperty('email');\n118:         expect(item).toHaveProperty('phone');\n119:         expect(item).toHaveProperty('message');\n120:         expect(item).toHaveProperty('status');\n121:         expect(item).toHaveProperty('response');\n122:         expect(item).toHaveProperty('respondedAt');\n123:         expect(item).toHaveProperty('createdAt');\n124:       }\n125:     });\n126: \n127:     it('should only return inquiries for the authenticated renter', async () => {\n128:       const res = await request(app.getHttpServer())\n129:         .get('/api/inquiries/my')\n130:         .set(authHeader(renterToken))\n131:         .expect(200);\n132: \n133:       // Renter1 should see exactly 2 inquiries (their own)\n134:       expect(res.body.data.meta.total).toBe(2);\n135:       expect(res.body.data.items).toHaveLength(2);\n136: \n137:       // All inquiries should belong to renter1\n138:       for (const item of res.body.data.items) {\n139:         expect(item.email).toBe(renterUser.email);\n140:       }\n141:     });\n142: \n143:     it('should not include inquiries from other renters', async () => {\n144:       const res = await request(app.getHttpServer())\n145:         .get('/api/inquiries/my')\n146:         .set(authHeader(renterToken))\n147:         .expect(200);\n148: \n149:       const messages = res.body.data.items.map((i: any) => i.message);\n150:       expect(messages).not.toContain('Inquiry from renter2 about property1.');\n151:     });\n152: \n153:     it('should return empty items array when renter has no inquiries', async () => {\n154:       // Use a fresh user with no inquiries\n155:       const freshUser = await createTestUser(dataSource, {\n156:         name: 'Fresh Renter',\n157:         email: 'fresh@test.com',\n158:         password: 'TestPass123!',\n159:         role: testUsers.renter.role,\n160:         status: testUsers.renter.status,\n161:       });\n162:       const freshToken = generateAccessToken(freshUser);\n163: \n164:       const res = await request(app.getHttpServer())\n165:         .get('/api/inquiries/my')\n166:         .set(authHeader(freshToken))\n167:         .expect(200);\n168: \n169:       expect(res.body.data.items).toHaveLength(0);\n170:       expect(res.body.data.meta.total).toBe(0);\n171:     });\n172: \n173:     it('should support pagination with page and limit', async () => {\n174:       const res = await request(app.getHttpServer())\n175:         .get('/api/inquiries/my?page=1&limit=1')\n176:         .set(authHeader(renterToken))\n177:         .expect(200);\n178: \n179:       expect(res.body.data.meta.page).toBe(1);\n180:       expect(res.body.data.meta.limit).toBe(1);\n181:       expect(res.body.data.items).toHaveLength(1);\n182:       expect(res.body.data.meta.total).toBe(2);\n183:     });\n184: \n185:     it('should support sorting', async () => {\n186:       const res = await request(app.getHttpServer())\n187:         .get('/api/inquiries/my?sortBy=newest')\n188:         .set(authHeader(renterToken))\n189:         .expect(200);\n190: \n191:       expect(res.body.success).toBe(true);\n192:     });\n193: \n194:     it('should return 400 for invalid pagination params', async () => {\n195:       await request(app.getHttpServer())\n196:         .get('/api/inquiries/my?limit=9999')\n197:         .set(authHeader(renterToken))\n198:         .expect(400);\n199:     });\n200: \n201:     it('should return 401 when not authenticated', async () => {\n202:       await request(app.getHttpServer())\n203:         .get('/api/inquiries/my')\n204:         .expect(401);\n205:     });\n206: \n207:     it('should return 401 with invalid token', async () => {\n208:       await request(app.getHttpServer())\n209:         .get('/api/inquiries/my')\n210:         .set(authHeader('invalid-token'))\n211:         .expect(401);\n212:     });\n213: \n214:     it('should return 403 when authenticated as admin (renter only)', async () => {\n215:       await request(app.getHttpServer())\n216:         .get('/api/inquiries/my')\n217:         .set(authHeader(adminToken))\n218:         .expect(403);\n219:     });\n220: \n221:     it('should include response data when admin has responded', async () => {\n222:       // Submit an inquiry\n223:       const submitRes = await request(app.getHttpServer())\n224:         .post(`/api/properties/${property1.id}/inquiries`)\n225:         .set(authHeader(renterToken))\n226:         .send({ message: 'Inquiry that will get a response.' })\n227:         .expect(201);\n228: \n229:       const inquiryId = submitRes.body.data.id;\n230: \n231:       // Admin responds\n232:       await request(app.getHttpServer())\n233:         .post(`/api/inquiries/${inquiryId}/respond`)\n234:         .set(authHeader(adminToken))\n235:         .send({ response: 'Thank you for your interest. The property is still available.' })\n236:         .expect(200);\n237: \n238:       // Renter fetches their inquiries\n239:       const res = await request(app.getHttpServer())\n240:         .get('/api/inquiries/my')\n241:         .set(authHeader(renterToken))\n242:         .expect(200);\n243: \n244:       const respondedInquiry = res.body.data.items.find(\n245:         (i: any) => i.id === inquiryId,\n246:       );\n247:       expect(respondedInquiry).toBeDefined();\n248:       expect(respondedInquiry.status).toBe('responded');\n249:       expect(respondedInquiry.response).toBeTruthy();\n250:       expect(respondedInquiry.respondedAt).toBeTruthy();\n251:     });\n252: \n253:     it('should include property title for each inquiry', async () => {\n254:       const res = await request(app.getHttpServer())\n255:         .get('/api/inquiries/my')\n256:         .set(authHeader(renterToken))\n257:         .expect(200);\n258: \n259:       const propertyIds = res.body.data.items.map((i: any) => i.property.id);\n260:       expect(propertyIds).toContain(property1.id);\n261:       expect(propertyIds).toContain(property2.id);\n262: \n263:       for (const item of res.body.data.items) {\n264:         expect(item.property).toHaveProperty('title');\n265:       }\n266:     });\n267:   });\n268: \n269: });\n\n(End of file - total 269 lines)\n</content>","metadata":{"preview":"import { INestApplication } from '@nestjs/common';\nimport { TestingModule } from '@nestjs/testing';\nimport request from 'supertest';\nimport { DataSource } from 'typeorm';\n\nimport { createTestApp, closeTestApp, getDataSource }