erty, (property) => property.inquiries, { onDelete: 'SET NULL' })\n51:   @JoinColumn({ name: 'property_id' })\n52:   property: Property;\n53: \n54:   @ManyToOne(() => User, (user) => user.inquiries, { onDelete: 'SET NULL' })\n55:   @JoinColumn({ name: 'user_id' })\n56:   user: User;\n57: }\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"import {\n  Entity,\n  Column,\n  Index,\n  ManyToOne,\n  JoinColumn,\n} from 'typeorm';\nimport { BaseEntity } from '../../../core/base/base.entity';\nimport { InquiryStatusEnum } from '../../../common/enums/inquiry-status.enum';\nimport { Property } from '../../properties/entities/property.entity';\nimport { User } from '../../users/entities/user.entity';\n\n@Entity('inquiries')\n@Index(['propertyId'])\n@Index(['userId'])\n@Index(['status'])\n@Index(['status', 'createdAt'])\nexport class Inquiry extends BaseEntity {\n  @Column({ name: 'property_id', type: 'uuid', nullable: true })\n  propertyId: string | null;","truncated":false,"loaded":[]},"title":"backend/src/modules/inquiries/entities/inquiry.entity.ts","time":{"start":1779248604540,"end":1779248604849}},"id":"prt_e437b2060001Dm0zVXFK3Y9xYj","sessionID":"ses_1bc8c0c0bffeEZb75VgBylzEVF","messageID":"msg_e437a6cd5001XT7m9W61PF03r8"}}
