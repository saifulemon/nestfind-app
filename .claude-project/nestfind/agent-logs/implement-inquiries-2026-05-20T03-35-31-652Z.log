e.createWithUniqueCheck(dto);\n48:     return {\n49:       success: true,\n50:       statusCode: 201,\n51:       message: 'Amenity created successfully',\n52:       data: amenity,\n53:       timestamp: new Date().toISOString(),\n54:       path: this.getPath(req),\n55:     };\n56:   }\n57: \n58:   @Roles('admin')\n59:   @Patch(':id')\n60:   async update(\n61:     @Param('id', ParseUUIDPipe) id: string,\n62:     @Body() dto: UpdateAmenityDto,\n63:     @Req() req: Request,\n64:   ) {\n65:     const amenity = (await this.amenityService.updateWithUniqueCheck(id, dto))!;\n66:     return {\n67:       success: true,\n68:       statusCode: 200,\n69:       message: 'Amenity updated successfully',\n70:       data: amenity,\n71:       timestamp: new Date().toISOString(),\n72:       path: this.getPath(req),\n73:     };\n74:   }\n75: \n76:   @Roles('admin')\n77:   @Delete(':id')\n78:   async remove(@Param('id', ParseUUIDPipe) id: string, @Req() req: Request) {\n79:     await this.amenityService.remove(id);\n80:     return {\n81:       success: true,\n82:       statusCode: 200,\n83:       message: 'Amenity deleted successfully',\n84:       data: null,\n85:       timestamp: new Date().toISOString(),\n86:       path: this.getPath(req),\n87:     };\n88:   }\n89: \n90:   private getPath(req: Request): string {\n91:     return req.originalUrl?.split('?')[0] ?? req.path;\n92:   }\n93: }\n\n(End of file - total 93 lines)\n</content>","metadata":{"preview":"import {\n  Controller,\n  Get,\n  Post,\n  Patch,\n  Delete,\n  Body,\n  Param,\n  Req,\n  HttpCode,\n  HttpStatus,\n  ParseUUIDPipe,\n  UseGuards,\n} from '@nestjs/common';\nimport { Request } from 'express';\nimport { Public } from '../../core/decorators/public.decorator';\nimport { Roles } from '../../core/decorators/roles.decorator';\nimport { JwtAuthGuard } from '../../core/guards/jwt-auth.guard';\nimport { RolesGuard } from '../../core/guards/roles.guard';\nimport { AmenityService } from './amenity.service';","truncated":false,"