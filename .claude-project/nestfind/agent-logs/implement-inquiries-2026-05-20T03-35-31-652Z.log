tingModule;\n25: }\n26: \n27: /**\n28:  * Creates a NestJS test application with all entities registered against\n29:  * an in-memory SQLite database (no external PostgreSQL dependency for tests).\n30:  *\n31:  * Accepts optional feature modules to register. When modules don't exist yet\n32:  * (RED phase), pass an empty array — the test app will start but routes\n33:  * won't be registered, causing all requests to 404.\n34:  */\n35: export async function createTestApp(\n36:   featureModules: any[] = [],\n37: ): Promise<TestAppContext> {\n38:   const moduleFixture: TestingModule = await Test.createTestingModule({\n39:     imports: [\n40:       TypeOrmModule.forRoot({\n41:         type: 'better-sqlite3',\n42:         database: ':memory:',\n43:         entities: [\n44:           User,\n45:           RefreshToken,\n46:           PasswordResetToken,\n47:           Property,\n48:           PropertyPhoto,\n49:           Amenity,\n50:           PropertyAmenity,\n51:           Favorite,\n52:           Inquiry,\n53:         ],\n54:         synchronize: true,\n55:         dropSchema: true,\n56:         logging: false,\n57:       }),\n58:       TypeOrmModule.forFeature([\n59:         User,\n60:         RefreshToken,\n61:         PasswordResetToken,\n62:         Property,\n63:         PropertyPhoto,\n64:         Amenity,\n65:         PropertyAmenity,\n66:         Favorite,\n67:         Inquiry,\n68:       ]),\n69:       ...featureModules,\n70:     ],\n71:   }).compile();\n72: \n73:   const app = moduleFixture.createNestApplication();\n74: \n75:   app.setGlobalPrefix('api');\n76:   app.useGlobalPipes(\n77:     new ValidationPipe({\n78:       whitelist: true,\n79:       forbidNonWhitelisted: true,\n80:       transform: true,\n81:       transformOptions: { enableImplicitConversion: true },\n82:     }),\n83:   );\n84:   app.useGlobalFilters(new AllExceptionsFilter(), new HttpExceptionFilter());\n85:   app.useGlobalInterceptors(new LoggingInterceptor(), new TransformInterceptor());\n86: \n87:   await app.init();\n88: \n89:   return { app, module: moduleFixture };\n90: }\n91: \n92: /**\n93:  * Gracefully closes the test application and module.\n94:  */\n95: export async function closeTestApp(context: TestAppContext): Promise<void> {\n96:   await context.app.close();\n97: }\n98: \n99: /**\n100:  * Returns the TypeORM DataSource from the test module for direct DB access.\n101:  */\n102: export function getDataSource(module: TestingModule): DataSource {\n103:   return module.get(DataSource);\n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"import { Test, TestingModule } from '@nestjs/testing';\nimport { INestApplication, ValidationPipe } from '@nestjs/common';\nimport { TypeOrmModule } from '@nestjs/typeorm';\nimport { DataSource } from 'typeorm';\n\nimport { HttpExceptionFilter } from '../../src/core/filters/http-exception.filter';\nimport { AllExceptionsFilter } from '../../src/core/filters/all-exceptions.filter';\nimport { TransformInterceptor } from '../../src/core/interceptors/transform.interceptor';\nimport { LoggingInterceptor } from '../../src/core/interceptors/logging.interceptor';\n\n// Import all entities for the test database\nimport { User } from '../../src/modules/users/entities/user.entity';\nimport { RefreshToken } from '../../src/modules/auth/entities/refresh-token.entity';\nimport { PasswordResetToken } from '../../src/modules/auth/entities/password-reset-token.entity';\nimport { Property } from '../../src/modules/properties/entities/property.entity';\nimport { PropertyPhoto } from '../../src/modules/properties/entities/property-photo.entity';\nimport { Amenity } from '../../src/modules/properties/entities/amenity.entity';\nimport { PropertyAmenity } from '../../src/modules/properties/entities/property-amenity.entity';\nimport { Favorite } from '../../src/modules/favorites/entities/favorite.entity';\nimport { Inquiry } from '../../src/modules/inquiries/entities/inquiry.entity';","truncated":false,"lo