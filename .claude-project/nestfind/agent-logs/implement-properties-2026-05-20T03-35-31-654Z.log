{"type":"tool_use","timestamp":1779249574989,"sessionID":"ses_1bc8c0a70ffemYD3KuZZ4coPT1","part":{"type":"tool","tool":"write","callID":"call_00_9Bi6X54kFEQLDmatLpqX9000","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/properties/property.controller.ts","content":"import {\n  Controller,\n  Get,\n  Post,\n  Patch,\n  Delete,\n  Body,\n  Param,\n  Query,\n  ParseUUIDPipe,\n  HttpCode,\n  HttpStatus,\n  UseInterceptors,\n  UploadedFiles,\n} from '@nestjs/common';\nimport { FilesInterceptor } from '@nestjs/platform-express';\nimport { memoryStorage } from 'multer';\nimport { Public } from '../../core/decorators/public.decorator';\nimport { Roles } from '../../core/decorators/roles.decorator';\nimport { CurrentUser } from '../../core/decorators/current-user.decorator';\nimport { PropertyService } from './property.service';\nimport { CreatePropertyDto } from './dtos/create-property.dto';\nimport { UpdatePropertyDto } from './dtos/update-property.dto';\nimport { ReorderPhotosDto } from './dtos/reorder-photos.dto';\nimport { IJwtPayload } from '../../shared/interfaces/jwt-payload.interface';\n\n@Controller('properties')\nexport class PropertyController {\n  constructor(private readonly propertyService: PropertyService) {}\n\n  @Public()\n  @Get()\n  @HttpCode(HttpStatus.OK)\n  async search(@Query() query: any) {\n    const result = await this.propertyService.search(query);\n    return {\n      message: 'Properties retrieved successfully',\n      data: {\n        items: result.items,\n        meta: {\n          total: result.total,\n          page: result.page,\n          limit: result.limit,\n          totalPages: result.totalPages,\n        },\n      },\n    };\n  }\n\n  @Public()\n  @Get(':id')\n  @HttpCode(HttpStatus.OK)\n  async findOne(\n    @Param('id', ParseUUIDPipe) id: string,\n    @CurrentUser() user?: IJwtPayload,\n  ) {\n    const property = await this.propertyService.findByIdOrFail(\n      id,\n      user?.id,\n    );\n    return { message: 'Property retrieved successfully', data: property };\n  }\n\n  @Roles('admin')\n  @Post()\n  @HttpCode(HttpStatus.CREATED)\n  async create(@Body() dto: CreatePropertyDto) {\n    const property = await this.propertyService.createProperty(dto);\n    return { message: 'Property created successfully', data: property };\n  }\n\n  @Roles('admin')\n  @Patch(':id')\n  @HttpCode(HttpStatus.OK)\n  async update(\n    @Param('id', ParseUUIDPipe) id: string,\n    @Body() dto: UpdatePropertyDto,\n  ) {\n    const property = await this.propertyService.updateProperty(id, dto);\n    return { message: 'Property updated successfully', data: property };\n  }\n\n  @Roles('admin')\n  @Delete(':id')\n  @HttpCode(HttpStatus.OK)\n  async archive(@Param('id', ParseUUIDPipe) id: string) {\n    await this.propertyService.archive(id);\n    return { message: 'Property archived successfully', data: null };\n  }\n\n  @Roles('admin')\n  @Post(':id/photos')\n  @HttpCode(HttpStatus.CREATED)\n  @UseInterceptors(\n    FilesInterceptor('files', 10, { storage: memoryStorage() }),\n  )\n  async uploadPhotos(\n    @Param('id', ParseUUIDPipe) id: string,\n    @UploadedFiles() files: Express.Multer.File[],\n  ) {\n    if (!files || files.length === 0) {\n      return { message: 'Photos uploaded successfully', data: [] };\n    }\n    const photos = await this.propertyService.uploadPhotos(id, files);\n    return { message: 'Photos uploaded successfully', data: photos };\n  }\n\n  @Roles('admin')\n  @Delete(':id/photos/:photoId')\n  @HttpCode(HttpStatus.OK)\n  async deletePhoto(\n    @Param('id', ParseUUIDPipe) id: string,\n    @Param('photoId', ParseUUIDPipe) photoId: string,\n  ) {\n    await this.propertyService.deletePhoto(id, photoId);\n    return { message: 'Photo deleted successfully', data: null };\n  }\n\n  @Roles('admin')\n  @Patch(':id/photos/:photoId/primary')\n  @HttpCode(HttpStatus.OK)\n  async setPrimaryPhoto(\n    @Param('id', ParseUUIDPipe) id: string,\n    @Param('photoId', ParseUUIDPipe) photoId: string,\n  ) {\n    const photo = await this.propertyService.setPrimaryPhoto(id, photoId);\n    return { message: 'Primary photo set successfully', data: photo };\n  }\n\n  @Roles('admin')\n  @Patch(':id/photos/reorder')\n  @HttpCode(HttpStatus.OK)\n  async reorderPhotos(\n    @Param('id', ParseUUIDPipe) id: string,\n    @Body() dto: ReorderPhotosDto,\n  ) {\n    const photos = await this.propertyService.reorderPhotos(\n      id,\n      dto.photoIds,\n    );\n    return { message: 'Photos reordered successfully', data: photos };\n  }\n}\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/modules/properties/property.controller.ts","exists":true,"truncated":false},"title":"backend/src/modules/properties/property.controller.ts","time":{"start":1779249574644,"end":1779249574986}},"id":"prt_e43896d76001i5cUw6nGZAedu6","sessionID":"ses_1bc8c0a70ffemYD3KuZZ4coPT1","messageID":"msg_e43895589001doEWKS7PR3b6Kt"}}
