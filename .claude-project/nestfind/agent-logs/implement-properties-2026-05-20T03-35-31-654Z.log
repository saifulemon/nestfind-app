\n41:   return {\n42:     Cookie: `access_token=${accessToken}; refresh_token=${refreshToken}`,\n43:   };\n44: }\n\n(End of file - total 44 lines)\n</content>","metadata":{"preview":"import { User } from '../../src/modules/users/entities/user.entity';\n\n/**\n * Builds a mock JWT access token string for testing.\n * NOTE: In RED phase, this is a placeholder — actual JWT signing\n * requires the auth module implementation. Tests that require valid\n * tokens will FAIL until the auth controller/service is implemented.\n *\n * For tests that need to simulate an authenticated request, use\n * the `authHeader` helper which sets the cookie header.\n */\nexport function generateAccessToken(user: User): string {\n  // Placeholder token — real implementation will sign with jwt service\n  return `mock-access-token-${user.id}-${user.role}`;\n}\n\nexport function generateRefreshToken(user: User): string {\n  return `mock-refresh-token-${user.id}`;\n}\n","truncated":false,"loaded":[]},"title":"backend/test/fixtures/auth.fixture.ts","time":{"start":1779248851320,"end":1779248851611}},"id":"prt_e437ee4b4001j1vzWy0ZteX7Eq","sessionID":"ses_1bc8c0a70ffemYD3KuZZ4coPT1","messageID":"msg_e437e4bc400113rybTEOU5wN0X"}}
