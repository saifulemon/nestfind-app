{"type":"tool_use","timestamp":1779248810470,"sessionID":"ses_1bc8c0a70ffemYD3KuZZ4coPT1","part":{"type":"tool","tool":"read","callID":"call_04_rvcmHX6qCt1VERvPkRzM9485","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/properties.e2e-spec.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/test/e2e/properties.e2e-spec.ts</path>\n<type>file</type>\n<content>\n1: import { INestApplication } from '@nestjs/common';\n2: import { TestingModule } from '@nestjs/testing';\n3: import request from 'supertest';\n4: import { DataSource } from 'typeorm';\n5: \n6: import { createTestApp, closeTestApp, getDataSource } from '../setup/test-app.factory';\n7: import { cleanDatabase } from '../setup/test-database';\n8: import {\n9:   createTestUser,\n10:   seedTestUsers,\n11:   testUsers,\n12:   TEST_PASSWORD,\n13: } from '../fixtures/user.fixture';\n14: import {\n15:   generateAccessToken,\n16:   authHeader,\n17: } from '../fixtures/auth.fixture';\n18: import {\n19:   createTestProperty,\n20:   seedTestProperties,\n21:   seedTestAmenities,\n22: } from '../fixtures/property.fixture';\n23: import { User } from '../../src/modules/users/entities/user.entity';\n24: import { Property } from '../../src/modules/properties/entities/property.entity';\n25: import { PropertyTypeEnum } from '../../src/common/enums/property-type.enum';\n26: \n27: // RED PHASE: These imports will fail because modules don't exist yet.\n28: // import { PropertiesModule } from '../../src/modules/properties/properties.module';\n29: \n30: describe('Properties E2E', () => {\n31:   let app: INestApplication;\n32:   let module: TestingModule;\n33:   let dataSource: DataSource;\n34:   let adminToken: string;\n35:   let renterToken: string;\n36:   let adminUser: User;\n37:   let renterUser: User;\n38: \n39:   beforeAll(async () => {\n40:     const context = await createTestApp();\n41:     app = context.app;\n42:     module = context.module;\n43:     dataSource = getDataSource(module);\n44:   });\n45: \n46:   afterAll(async () => {\n47:     await closeTestApp({ app, module });\n48:   });\n49: \n50:   beforeEach(async () => {\n51:     await cleanDatabase(dataSource);\n52:     const seeded = await seedTestUsers(dataSource);\n53:     adminUser = seeded.admin;\n54:     renterUser = seeded.renter;\n55:     adminToken = generateAccessToken(adminUser);\n56:     renterToken = generateAccessToken(renterUser);\n57:     await seedTestAmenities(dataSource);\n58:   });\n59: \n60:   // ─── GET /properties (Search) ──────────────────────────────────────\n61:   describe('GET /api/properties', () => {\n62:     beforeEach(async () => {\n63:       await seedTestProperties(dataSource);\n64:     });\n65: \n66:     it('should return 200 with paginated property list', async () => {\n67:       const res = await request(app.getHttpServer())\n68:         .get('/api/properties')\n69:         .expect(200);\n70: \n71:       expect(res.body.success).toBe(true);\n72:       expect(res.body.statusCode).toBe(200);\n73:       expect(res.body.message).toBe('Properties retrieved successfully');\n74:       expect(res.body.data).toHaveProperty('items');\n75:       expect(res.body.data).toHaveProperty('meta');\n76:       expect(res.body.data.meta).toHaveProperty('total');\n77:       expect(res.body.data.meta).toHaveProperty('page', 1);\n78:       expect(res.body.data.meta).toHaveProperty('limit');\n79:       expect(res.body.data.meta).toHaveProperty('totalPages');\n80:       expect(Array.isArray(res.body.data.items)).toBe(true);\n81:     });\n82: \n83:     it('should return property items with correct shape', async () => {\n84:       const res = await request(app.getHttpServer())\n85:         .get('/api/properties')\n86:         .expect(200);\n87: \n88:       if (res.body.data.items.length > 0) {\n89:         const item = res.body.data.items[0];\n90:         expect(item).toHaveProperty('id');\n91:         expect(item).toHaveProperty('title');\n92:         expect(item).toHaveProperty('description');\n93:         expect(item).toHaveProperty('price');\n94:         expect(item).toHaveProperty('bedrooms');\n95:         expect(item).toHaveProperty('bathrooms');\n96:         expect(item).toHaveProperty('squareFeet');\n97:         expect(item).toHaveProperty('propertyType');\n98:         expect(item).toHaveProperty('address');\n99:         expect(item.address).toHaveProperty('street');\n100:         expect(item.address).toHaveProperty('city');\n101:         expect(item.address).toHaveProperty('state');\n102:         expect(item.address).toHaveProperty('zipCode');\n103:         expect(item).toHaveProperty('availableFrom');\n104:         expect(item).toHaveProperty('primaryPhoto');\n105:         expect(item).toHaveProperty('amenities');\n106:         expect(item).toHaveProperty('createdAt');\n107:       }\n108:     });\n109: \n110:     it('should be accessible without authentication (public)', async () => {\n111:       await request(app.getHttpServer())\n112:         .get('/api/properties')\n113:         .expect(200);\n114:     });\n115: \n116:     it('should support pagination with page and limit query params', async () => {\n117:       const res = await request(app.getHttpServer())\n118:         .get('/api/properties?page=1&limit=2')\n119:         .expect(200);\n120: \n121:       expect(res.body.data.meta.page).toBe(1);\n122:       expect(res.body.data.meta.limit).toBe(2);\n123:     });\n124: \n125:     it('should support filtering by propertyType', async () => {\n126:       const res = await request(app.getHttpServer())\n127:         .get('/api/properties?propertyType=apartment')\n128:         .expect(200);\n129: \n130:       for (const item of res.body.data.items) {\n131:         expect(item.propertyType).toBe('apartment');\n132:       }\n133:     });\n134: \n135:     it('should support filtering by minPrice and maxPrice', async () => {\n136:       const res = await request(app.getHttpServer())\n137:         .get('/api/properties?minPrice=1000&maxPrice=3000')\n138:         .expect(200);\n139: \n140:       for (const item of res.body.data.items) {\n141:         expect(item.price).toBeGreaterThanOrEqual(1000);\n142:         expect(item.price).toBeLessThanOrEqual(3000);\n143:       }\n144:     });\n145: \n146:     it('should support filtering by bedrooms', async () => {\n147:       const res = await request(app.getHttpServer())\n148:         .get('/api/properties?bedrooms=2')\n149:         .expect(200);\n150: \n151:       for (const item of res.body.data.items) {\n152:         expect(item.bedrooms).toBeGreaterThanOrEqual(2);\n153:       }\n154:     });\n155: \n156:     it('should support filtering by bathrooms', async () => {\n157:       const res = await request(app.getHttpServer())\n158:         .get('/api/properties?bathrooms=1')\n159:         .expect(200);\n160: \n161:       for (const item of res.body.data.items) {\n162:         expect(item.bathrooms).toBeGreaterThanOrEqual(1);\n163:       }\n164:     });\n165: \n166:     it('should support filtering by city', async () => {\n167:       const res = await request(app.getHttpServer())\n168:         .get('/api/properties?city=New York')\n169:         .expect(200);\n170: \n171:       for (const item of res.body.data.items) {\n172:         expect(item.address.city).toBe('New York');\n173:       }\n174:     });\n175: \n176:     it('should support sorting by price_asc', async () => {\n177:       const res = await request(app.getHttpServer())\n178:         .get('/api/properties?sortBy=price_asc')\n179:         .expect(200);\n180: \n181:       const prices = res.body.data.items.map((i: any) => i.price);\n182:       for (let i = 1; i < prices.length; i++) {\n183:         expect(prices[i]).toBeGreaterThanOrEqual(prices[i - 1]);\n184:       }\n185:     });\n186: \n187:     it('should support sorting by newest', async () => {\n188:       await request(app.getHttpServer())\n189:         .get('/api/properties?sortBy=newest')\n190:         .expect(200);\n191:     });\n192: \n193:     it('should return empty items array when no properties match', async () => {\n194:       const res = await request(app.getHttpServer())\n195:         .get('/api/properties?city=NonExistent')\n196:         .expect(200);\n197: \n198:       expect(res.body.data.items).toHaveLength(0);\n199:       expect(res.body.data.meta.total).toBe(0);\n200:     });\n201: \n202:     it('should not return soft-deleted properties', async () => {\n203:       // Archiving is tested separately; verify public search excludes archived\n204:       const res = await request(app.getHttpServer())\n205:         .get('/api/properties')\n206:         .expect(200);\n207: \n208:       for (const item of res.body.data.items) {\n209:         expect(item).not.toHaveProperty('deletedAt');\n210:       }\n211:     });\n212: \n213:     it('should support search by text query', async () => {\n214:       const res = await request(app.getHttpServer())\n215:         .get('/api/properties?search=downtown')\n216:         .expect(200);\n217: \n218:       for (const item of res.body.data.items) {\n219:         const searchable = `${item.title} ${item.description} ${item.address.city} ${item.address.state}`.toLowerCase();\n220:         expect(searchable).toContain('downtown');\n221:       }\n222:     });\n223: \n224:     it('should support filtering by state', async () => {\n225:       const res = await request(app.getHttpServer())\n226:         .get('/api/properties?state=NY')\n227:         .expect(200);\n228: \n229:       for (const item of res.body.data.items) {\n230:         expect(item.address.state).toBe('NY');\n231:       }\n232:     });\n233: \n234:     it('should support sorting by price_desc', async () => {\n235:       const res = await request(app.getHttpServer())\n236:         .get('/api/properties?sortBy=price_desc')\n237:         .expect(200);\n238: \n239:       const prices = res.body.data.items.map((i: any) => i.price);\n240:       for (let i = 1; i < prices.length; i++) {\n241:         expect(prices[i]).toBeLessThanOrEqual(prices[i - 1]);\n242:       }\n243:     });\n244: \n245:     it('should support sorting by oldest', async () => {\n246:       await request(app.getHttpServer())\n247:         .get('/api/properties?sortBy=oldest')\n248:         .expect(200);\n249:     });\n250:   });\n251: \n252:   // ─── GET /properties/:id (Detail) ──────────────────────────────────\n253:   describe('GET /api/properties/:id', () => {\n254:     let property: Property;\n255: \n256:     beforeEach(async () => {\n257:       const seeded = await seedTestProperties(dataSource);\n258:       property = seeded.downtownApt;\n259:     });\n260: \n261:     it('should return 200 with full property detail', async () => {\n262:       const res = await request(app.getHttpServer())\n263:         .get(`/api/properties/${property.id}`)\n264:         .expect(200);\n265: \n266:       expect(res.body.success).toBe(true);\n267:       expect(res.body.statusCode).toBe(200);\n268:       expect(res.body.message).toBe('Property retrieved successfully');\n269:       expect(res.body.data).toHaveProperty('id', property.id);\n270:       expect(res.body.data).toHaveProperty('title');\n271:       expect(res.body.data).toHaveProperty('description');\n272:       expect(res.body.data).toHaveProperty('price');\n273:       expect(res.body.data).toHaveProperty('bedrooms');\n274:       expect(res.body.data).toHaveProperty('bathrooms');\n275:       expect(res.body.data).toHaveProperty('squareFeet');\n276:       expect(res.body.data).toHaveProperty('propertyType');\n277:       expect(res.body.data).toHaveProperty('address');\n278:       expect(res.body.data.address).toHaveProperty('street');\n279:       expect(res.body.data.address).toHaveProperty('city');\n280:       expect(res.body.data.address).toHaveProperty('state');\n281:       expect(res.body.data.address).toHaveProperty('zipCode');\n282:       expect(res.body.data).toHaveProperty('availableFrom');\n283:       expect(res.body.data).toHaveProperty('photos');\n284:       expect(res.body.data).toHaveProperty('amenities');\n285:       expect(res.body.data).toHaveProperty('isFavorited');\n286:       expect(res.body.data).toHaveProperty('createdAt');\n287:       expect(res.body.data).toHaveProperty('updatedAt');\n288:     });\n289: \n290:     it('should be accessible without authentication (public)', async () => {\n291:       await request(app.getHttpServer())\n292:         .get(`/api/properties/${property.id}`)\n293:         .expect(200);\n294:     });\n295: \n296:     it('should return 400 for invalid UUID format', async () => {\n297:       await request(app.getHttpServer())\n298:         .get('/api/properties/not-a-uuid')\n299:         .expect(400);\n300:     });\n301: \n302:     it('should return 404 for non-existent property', async () => {\n303:       await request(app.getHttpServer())\n304:         .get('/api/properties/00000000-0000-0000-0000-000000000000')\n305:         .expect(404);\n306:     });\n307: \n308:     it('should return 404 for archived property', async () => {\n309:       // In GREEN phase: archive the property first, then verify 404\n310:       // For now, this tests the general 404 path\n311:       await request(app.getHttpServer())\n312:         .get(`/api/properties/${property.id}`)\n313:         .expect(200);\n314:       // NOTE: Full archive-then-404 test needs property archive implementation\n315:     });\n316: \n317:     it('should return isFavorited=false for unauthenticated user', async () => {\n318:       const res = await request(app.getHttpServer())\n319:         .get(`/api/properties/${property.id}`)\n320:         .expect(200);\n321: \n322:       expect(res.body.data.isFavorited).toBe(false);\n323:     });\n324:   });\n325: \n326:   // ─── POST /properties (Create) ─────────────────────────────────────\n327:   describe('POST /api/properties', () => {\n328:     const validBody = {\n329:       title: 'New Test Property',\n330:       description: 'A newly created test property for e2e testing purposes.',\n331:       price: 1800.0,\n332:       bedrooms: 2,\n333:       bathrooms: 1,\n334:       squareFeet: 850,\n335:       propertyType: 'condo',\n336:       address: {\n337:         street: '100 Test Blvd',\n338:         city: 'San Francisco',\n339:         state: 'CA',\n340:         zipCode: '94105',\n341:         latitude: 37.774929,\n342:         longitude: -122.419418,\n343:       },\n344:       availableFrom: '2026-08-01',\n345:       amenityIds: [],\n346:     };\n347: \n348:     it('should return 201 with created property (admin only)', async () => {\n349:       const res = await request(app.getHttpServer())\n350:         .post('/api/properties')\n351:         .set(authHeader(adminToken))\n352:         .send(validBody)\n353:         .expect(201);\n354: \n355:       expect(res.body.success).toBe(true);\n356:       expect(res.body.statusCode).toBe(201);\n357:       expect(res.body.message).toBe('Property created successfully');\n358:       expect(res.body.data).toHaveProperty('id');\n359:       expect(res.body.data).toHaveProperty('title', 'New Test Property');\n360:       expect(res.body.data).toHaveProperty('price', 1800);\n361:       expect(res.body.data).toHaveProperty('address');\n362:       expect(res.body.data.address).toHaveProperty('city', 'San Francisco');\n363:       expect(res.body.data).toHaveProperty('photos');\n364:       expect(res.body.data).toHaveProperty('amenities');\n365:       expect(res.body.data).toHaveProperty('createdAt');\n366:       expect(res.body.data).toHaveProperty('updatedAt');\n367:     });\n368: \n369:     it('should return 400 when title is missing', async () => {\n370:       const { title, ...body } = validBody;\n371:       await request(app.getHttpServer())\n372:         .post('/api/properties')\n373:         .set(authHeader(adminToken))\n374:         .send(body)\n375:         .expect(400);\n376:     });\n377: \n378:     it('should return 400 when title is too short (< 5 chars)', async () => {\n379:       await request(app.getHttpServer())\n380:         .post('/api/properties')\n381:         .set(authHeader(adminToken))\n382:         .send({ ...validBody, title: 'AB' })\n383:         .expect(400);\n384:     });\n385: \n386:     it('should return 400 when description is too short (< 20 chars)', async () => {\n387:       await request(app.getHttpServer())\n388:         .post('/api/properties')\n389:         .set(authHeader(adminToken))\n390:         .send({ ...validBody, description: 'Short desc' })\n391:         .expect(400);\n392:     });\n393: \n394:     it('should return 400 when price is missing', async () => {\n395:       const { price, ...body } = validBody;\n396:       await request(app.getHttpServer())\n397:         .post('/api/properties')\n398:         .set(authHeader(adminToken))\n399:         .send(body)\n400:         .expect(400);\n401:     });\n402: \n403:     it('should return 400 when price is 0 or negative', async () => {\n404:       await request(app.getHttpServer())\n405:         .post('/api/properties')\n406:         .set(authHeader(adminToken))\n407:         .send({ ...validBody, price: 0 })\n408:         .expect(400);\n409:     });\n410: \n411:     it('should return 400 when bedrooms is negative', async () => {\n412:       await request(app.getHttpServer())\n413:         .post('/api/properties')\n414:         .set(authHeader(adminToken))\n415:         .send({ ...validBody, bedrooms: -1 })\n416:         .expect(400);\n417:     });\n418: \n419:     it('should accept bedrooms=0 and bathrooms=0 (studio)', async () => {\n420:       const res = await request(app.getHttpServer())\n421:         .post('/api/properties')\n422:         .set(authHeader(adminToken))\n423:         .send({ ...validBody, bedrooms: 0, bathrooms: 0, propertyType: 'studio' })\n424:         .expect(201);\n425: \n426:       expect(res.body.data.bedrooms).toBe(0);\n427:       expect(res.body.data.bathrooms).toBe(0);\n428:     });\n429: \n430:     it('should return 400 when propertyType is invalid', async () => {\n431:       await request(app.getHttpServer())\n432:         .post('/api/properties')\n433:         .set(authHeader(adminToken))\n434:         .send({ ...validBody, propertyType: 'invalid-type' })\n435:         .expect(400);\n436:     });\n437: \n438:     it('should return 400 when address is missing required fields', async () => {\n439:       await request(app.getHttpServer())\n440:         .post('/api/properties')\n441:         .set(authHeader(adminToken))\n442:         .send({ ...validBody, address: { city: 'SF' } })\n443:         .expect(400);\n444:     });\n445: \n446:     it('should return 401 when not authenticated', async () => {\n447:       await request(app.getHttpServer())\n448:         .post('/api/properties')\n449:         .send(validBody)\n450:         .expect(401);\n451:     });\n452: \n453:     it('should return 403 when authenticated as renter (not admin)', async () => {\n454:       await request(app.getHttpServer())\n455:         .post('/api/properties')\n456:         .set(authHeader(renterToken))\n457:         .send(validBody)\n458:         .expect(403);\n459:     });\n460:   });\n461: \n462:   // ─── PATCH /properties/:id (Update) ────────────────────────────────\n463:   describe('PATCH /api/properties/:id', () => {\n464:     let property: Property;\n465: \n466:     beforeEach(async () => {\n467:       const seeded = await seedTestProperties(dataSource);\n468:       property = seeded.downtownApt;\n469:     });\n470: \n471:     it('should return 200 with updated property (admin only)', async () => {\n472:       const res = await request(app.getHttpServer())\n473:         .patch(`/api/properties/${property.id}`)\n474:         .set(authHeader(adminToken))\n475:         .send({ title: 'Updated Title', price: 2800 })\n476:         .expect(200);\n477: \n478:       expect(res.body.success).toBe(true);\n479:       expect(res.body.statusCode).toBe(200);\n480:       expect(res.body.message).toBe('Property updated successfully');\n481:       expect(res.body.data).toHaveProperty('id', property.id);\n482:       expect(res.body.data).toHaveProperty('title', 'Updated Title');\n483:       expect(res.body.data).toHaveProperty('price', 2800);\n484:     });\n485: \n486:     it('should return 200 updating only one field', async () => {\n487:       const res = await request(app.getHttpServer())\n488:         .patch(`/api/properties/${property.id}`)\n489:         .set(authHeader(adminToken))\n490:         .send({ price: 3000 })\n491:         .expect(200);\n492: \n493:       expect(res.body.data.price).toBe(3000);\n494:       expect(res.body.data.title).toBe(property.title);\n495:     });\n496: \n497:     it('should return 400 for invalid UUID', async () => {\n498:       await request(app.getHttpServer())\n499:         .patch('/api/properties/not-a-uuid')\n500:         .set(authHeader(adminToken))\n501:         .send({ title: 'Bad UUID' })\n502:         .expect(400);\n503:     });\n504: \n505:     it('should return 400 when title is too short (< 5 chars)', async () => {\n506:       await request(app.getHttpServer())\n507:         .patch(`/api/properties/${property.id}`)\n508:         .set(authHeader(adminToken))\n509:         .send({ title: 'AB' })\n510:         .expect(400);\n511:     });\n512: \n513:     it('should return 400 when description is too short (< 20 chars)', async () => {\n514:       await request(app.getHttpServer())\n515:         .patch(`/api/properties/${property.id}`)\n516:         .set(authHeader(adminToken))\n517:         .send({ description: 'Short desc' })\n518:         .expect(400);\n519:     });\n520: \n521:     it('should return 401 when not authenticated', async () => {\n522:       await request(app.getHttpServer())\n523:         .patch(`/api/properties/${property.id}`)\n524:         .send({ title: 'No Auth' })\n525:         .expect(401);\n526:     });\n527: \n528:     it('should return 403 when authenticated as renter (not admin)', async () => {\n529:       await request(app.getHttpServer())\n530:         .patch(`/api/properties/${property.id}`)\n531:         .set(authHeader(renterToken))\n532:         .send({ title: 'Renter Update' })\n533:         .expect(403);\n534:     });\n535: \n536:     it('should return 404 when property not found', async () => {\n537:       await request(app.getHttpServer())\n538:         .patch('/api/properties/00000000-0000-0000-0000-000000000000')\n539:         .set(authHeader(adminToken))\n540:         .send({ title: 'Not Found' })\n541:         .expect(404);\n542:     });\n543:   });\n544: \n545:   // ─── DELETE /properties/:id (Archive) ──────────────────────────────\n546:   describe('DELETE /api/properties/:id', () => {\n547:     let property: Property;\n548: \n549:     beforeEach(async () => {\n550:       const seeded = await seedTestProperties(dataSource);\n551:       property = seeded.downtownApt;\n552:     });\n553: \n554:     it('should return 200 and archive property (admin only)', async () => {\n555:       const res = await request(app.getHttpServer())\n556:         .delete(`/api/properties/${property.id}`)\n557:         .set(authHeader(adminToken))\n558:         .expect(200);\n559: \n560:       expect(res.body.success).toBe(true);\n561:       expect(res.body.statusCode).toBe(200);\n562:       expect(res.body.message).toBe('Property archived successfully');\n563:       expect(res.body.data).toBeNull();\n564:     });\n565: \n566:     it('should return 400 for invalid UUID', async () => {\n567:       await request(app.getHttpServer())\n568:         .delete('/api/properties/not-a-uuid')\n569:         .set(authHeader(adminToken))\n570:         .expect(400);\n571:     });\n572: \n573:     it('should return 401 when not authenticated', async () => {\n574:       await request(app.getHttpServer())\n575:         .delete(`/api/properties/${property.id}`)\n576:         .expect(401);\n577:     });\n578: \n579:     it('should return 403 when authenticated as renter (not admin)', async () => {\n580:       await request(app.getHttpServer())\n581:         .delete(`/api/properties/${property.id}`)\n582:         .set(authHeader(renterToken))\n583:         .expect(403);\n584:     });\n585: \n586:     it('should return 404 when property not found', async () => {\n587:       await request(app.getHttpServer())\n588:         .delete('/api/properties/00000000-0000-0000-0000-000000000000')\n589:         .set(authHeader(adminToken))\n590:         .expect(404);\n591:     });\n592: \n593:     it('should make property inaccessible via GET after archiving', async () => {\n594:       // Archive the property\n595:       await request(app.getHttpServer())\n596:         .delete(`/api/properties/${property.id}`)\n597:         .set(authHeader(adminToken))\n598:         .expect(200);\n599: \n600:       // Should now return 404 for public access\n601:       await request(app.getHttpServer())\n602:         .get(`/api/properties/${property.id}`)\n603:         .expect(404);\n604:     });\n605:   });\n606: \n607:   // ─── POST /properties/:id/photos (Upload) ─────────────────────────\n608:   describe('POST /api/properties/:id/photos', () => {\n609:     let property: Property;\n610: \n611:     beforeEach(async () => {\n612:       const seeded = await seedTestProperties(dataSource);\n613:       property = seeded.downtownApt;\n614:     });\n615: \n616:     it('should return 201 with uploaded photo data (admin only)', async () => {\n617:       const res = await request(app.getHttpServer())\n618:         .post(`/api/properties/${property.id}/photos`)\n619:         .set(authHeader(adminToken))\n620:         .attach('files', Buffer.from('fake-image-content'), 'test-photo.jpg')\n621:         .expect(201);\n622: \n623:       expect(res.body.success).toBe(true);\n624:       expect(res.body.statusCode).toBe(201);\n625:       expect(res.body.message).toBe('Photos uploaded successfully');\n626:       expect(Array.isArray(res.body.data)).toBe(true);\n627:       if (res.body.data.length > 0) {\n628:         const photo = res.body.data[0];\n629:         expect(photo).toHaveProperty('id');\n630:         expect(photo).toHaveProperty('url');\n631:         expect(photo).toHaveProperty('isPrimary');\n632:         expect(photo).toHaveProperty('sortOrder');\n633:       }\n634:     });\n635: \n636:     it('should return 400 when no file provided', async () => {\n637:       await request(app.getHttpServer())\n638:         .post(`/api/properties/${property.id}/photos`)\n639:         .set(authHeader(adminToken))\n640:         .expect(400);\n641:     });\n642: \n643:     it('should return 401 when not authenticated', async () => {\n644:       await request(app.getHttpServer())\n645:         .post(`/api/properties/${property.id}/photos`)\n646:         .attach('files', Buffer.from('fake'), 'test.jpg')\n647:         .expect(401);\n648:     });\n649: \n650:     it('should return 403 when authenticated as renter', async () => {\n651:       await request(app.getHttpServer())\n652:         .post(`/api/properties/${property.id}/photos`)\n653:         .set(authHeader(renterToken))\n654:         .attach('files', Buffer.from('fake'), 'test.jpg')\n655:         .expect(403);\n656:     });\n657: \n658:     it('should return 404 when property not found', async () => {\n659:       await request(app.getHttpServer())\n660:         .post('/api/properties/00000000-0000-0000-0000-000000000000/photos')\n661:         .set(authHeader(adminToken))\n662:         .attach('files', Buffer.from('fake'), 'test.jpg')\n663:         .expect(404);\n664:     });\n665:   });\n666: \n667:   // ─── DELETE /properties/:id/photos/:photoId ────────────────────────\n668:   describe('DELETE /api/properties/:id/photos/:photoId', () => {\n669:     it('should return 200 when photo deleted (admin only)', async () => {\n670:       // This test requires a photo to exist first.\n671:       // In GREEN phase: upload a photo, then delete it.\n672:       // For RED phase, test the auth/validation contract.\n673:       const photoId = '00000000-0000-0000-0000-000000000001';\n674:       const propertyId = '00000000-0000-0000-0000-000000000002';\n675: \n676:       // Will 404 because neither photo nor property exists in RED phase\n677:       await request(app.getHttpServer())\n678:         .delete(`/api/properties/${propertyId}/photos/${photoId}`)\n679:         .set(authHeader(adminToken))\n680:         .expect(404);\n681:       // NOTE: In GREEN phase, change to expect(200) with real seeded data\n682:     });\n683: \n684:     it('should return 400 for invalid UUID format', async () => {\n685:       await request(app.getHttpServer())\n686:         .delete('/api/properties/not-a-uuid/photos/not-a-uuid')\n687:         .set(authHeader(adminToken))\n688:         .expect(400);\n689:     });\n690: \n691:     it('should return 401 when not authenticated', async () => {\n692:       await request(app.getHttpServer())\n693:         .delete('/api/properties/some-id/photos/some-photo-id')\n694:         .expect(401);\n695:     });\n696: \n697:     it('should return 403 when authenticated as renter', async () => {\n698:       await request(app.getHttpServer())\n699:         .delete('/api/properties/some-id/photos/some-photo-id')\n700:         .set(authHeader(renterToken))\n701:         .expect(403);\n702:     });\n703: \n704:     it('should return 404 when property not found', async () => {\n705:       await request(app.getHttpServer())\n706:         .delete('/api/properties/00000000-0000-0000-0000-000000000000/photos/00000000-0000-0000-0000-000000000001')\n707:         .set(authHeader(adminToken))\n708:         .expect(404);\n709:     });\n710: \n711:     it('should return 404 when photo not found for existing property', async () => {\n712:       const seeded = await seedTestProperties(dataSource);\n713:       const property = seeded.downtownApt;\n714: \n715:       await request(app.getHttpServer())\n716:         .delete(`/api/properties/${property.id}/photos/00000000