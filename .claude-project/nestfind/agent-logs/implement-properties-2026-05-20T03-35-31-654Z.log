y = await this.propertyService.update(id, dto);\n36:     return { message: 'Property updated successfully', data: property };\n37:   }\n38: \n39:   @Roles('admin')\n40:   @Delete(':id')\n41:   async archive(@Param('id', ParseUUIDPipe) id: string) {\n42:     await this.propertyService.archive(id);\n43:     return { message: 'Property archived successfully', data: null };\n44:   }\n45: }\n\n(End of file - total 45 lines)\n</content>","metadata":{"preview":"import { Controller, Get, Post, Patch, Delete, Body, Param, Query, ParseUUIDPipe } from '@nestjs/common';\nimport { Public } from '../../core/decorators/public.decorator';\nimport { Roles } from '../../core/decorators/roles.decorator';\nimport { PropertyService } from './property.service';\nimport { Property } from './entities/property.entity';\n\n@Controller('properties')\nexport class PropertyController {\n  constructor(private readonly propertyService: PropertyService) {}\n\n  @Public()\n  @Get()\n  async search(@Query() query: any) {\n    const result = await this.propertyService.search(query);\n    return { message: 'Properties retrieved successfully', data: { items: result.items, meta: { total: result.total, page: result.page, limit: result.limit, totalPages: result.totalPages } } };\n  }\n\n  @Public()\n  @Get(':id')\n  async findOne(@Param('id', ParseUUIDPipe) id: string) {","truncated":false,"loaded":[]},"title":"backend/src/modules/properties/property.controller.ts","time":{"start":1779248783546,"end":1779248783833}},"id":"prt_e437ddc06001HXrzlDp43OKh9m","sessionID":"ses_1bc8c0a70ffemYD3KuZZ4coPT1","messageID":"msg_e437db14b001XSkMRI1KB84uii"}}
