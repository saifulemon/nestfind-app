ar', length: 200 })\n49:   addressStreet: string;\n50: \n51:   @Column({ name: 'address_city', type: 'varchar', length: 100 })\n52:   addressCity: string;\n53: \n54:   @Column({ name: 'address_state', type: 'varchar', length: 100 })\n55:   addressState: string;\n56: \n57:   @Column({ name: 'address_zip_code', type: 'varchar', length: 10 })\n58:   addressZipCode: string;\n59: \n60:   @Column({ name: 'address_latitude', type: 'decimal', precision: 10, scale: 7, nullable: true })\n61:   addressLatitude: number | null;\n62: \n63:   @Column({ name: 'address_longitude', type: 'decimal', precision: 10, scale: 7, nullable: true })\n64:   addressLongitude: number | null;\n65: \n66:   @Column({ name: 'available_from', type: 'date', nullable: true })\n67:   availableFrom: string | null;\n68: \n69:   @OneToMany(() => PropertyPhoto, (photo) => photo.property)\n70:   photos: PropertyPhoto[];\n71: \n72:   @OneToMany(() => PropertyAmenity, (pa) => pa.property)\n73:   propertyAmenities: PropertyAmenity[];\n74: \n75:   @OneToMany(() => Favorite, (favorite) => favorite.property)\n76:   favorites: Favorite[];\n77: \n78:   @OneToMany(() => Inquiry, (inquiry) => inquiry.property)\n79:   inquiries: Inquiry[];\n80: }\n\n(End of file - total 80 lines)\n</content>","metadata":{"preview":"import {\n  Entity,\n  Column,\n  Index,\n  OneToMany,\n} from 'typeorm';\nimport { BaseEntity } from '../../../core/base/base.entity';\nimport { PropertyTypeEnum } from '../../../common/enums/property-type.enum';\nimport { PropertyPhoto } from './property-photo.entity';\nimport { PropertyAmenity } from './property-amenity.entity';\nimport { Favorite } from '../../favorites/entities/favorite.entity';\nimport { Inquiry } from '../../inquiries/entities/inquiry.entity';\n\n@Entity('properties')\n@Index(['propertyType'])\n@Index(['price'])\n@Index(['bedrooms'])\n@Index(['bathrooms'])\n@Index(['addressCity'])\n@Index(['addressState'])","truncated":false,"loaded":[]},"title":"backend/src/modules/properties/entitie