\n47: \n48:     @ApiPropertyOptional({ example: '2024-11-02T10:30:00.000Z' })\n49:     timestamp?: string;\n50: \n51:     @ApiPropertyOptional({ example: '/api/v1/users' })\n52:     path?: string;\n53: \n54:     constructor(partial: Partial<ResponsePayloadDto<T>>) {\n55:         Object.assign(this, partial);\n56:         this.timestamp = this.timestamp || new Date().toISOString();\n57:     }\n58: }\n59: \n60: export class SuccessResponseDto<T = unknown> extends ResponsePayloadDto<T> {\n61:     constructor(\n62:         data: T,\n63:         message: string = 'Success',\n64:         statusCode: number = 200,\n65:     ) {\n66:         super({\n67:             success: true,\n68:             statusCode,\n69:             message,\n70:             data,\n71:             timestamp: new Date().toISOString(),\n72:         });\n73:     }\n74: }\n75: \n76: export class ErrorResponseDto extends ResponsePayloadDto {\n77:     constructor(\n78:         message: string,\n79:         statusCode: number = 500,\n80:         error?: ErrorDetailDto[],\n81:         path?: string,\n82:     ) {\n83:         super({\n84:             success: false,\n85:             statusCode,\n86:             message,\n87:             error,\n88:             path,\n89:             timestamp: new Date().toISOString(),\n90:         });\n91:     }\n92: }\n93: \n94: export class PaginationMetaDto {\n95:     @ApiProperty({ example: 1 })\n96:     page: number;\n97: \n98:     @ApiProperty({ example: 10 })\n99:     limit: number;\n100: \n101:     @ApiProperty({ example: 100 })\n102:     total: number;\n103: \n104:     @ApiProperty({ example: 10 })\n105:     totalPages: number;\n106: \n107:     @ApiProperty({ example: true })\n108:     hasNextPage: boolean;\n109: \n110:     @ApiProperty({ example: false })\n111:     hasPreviousPage: boolean;\n112: \n113:     constructor(page: number, limit: number, total: number) {\n114:         this.page = page;\n115:         this.limit = limit;\n116:         this.total = total;\n117:         this.totalPages = Math.ceil(total / limit);\n118:         this.hasNextPage = page < this.totalPages;\n119:         this.hasPreviousPage = page > 1;\n120:     }\n121: }\n122: \n123: export class PaginatedResponseDto<T = unknown> extends ResponsePayloadDto<T[]> {\n124:     @ApiProperty({ description: 'Pagination metadata' })\n125:     meta: PaginationMetaDto;\n126: \n127:     constructor(\n128:         data: T[],\n129:         page: number,\n130:         limit: number,\n131:         total: number,\n132:         message: string = 'Data retrieved successfully',\n133:     ) {\n134:         super({\n135:             success: true,\n136:             statusCode: 200,\n137:             message,\n138:             data,\n139:             timestamp: new Date().toISOString(),\n140:         });\n141:         this.meta = new PaginationMetaDto(page, limit, total);\n142:     }\n143: }\n\n(End of file - total 143 lines)\n</content>","metadata":{"preview":"import { ApiProperty, ApiPropertyOptional } from '@nestjs/swagger';\n\nexport class ErrorDetailDto {\n    @ApiProperty({\n        example: 'email',\n        description: 'Field name related to the error (if applicable)',\n    })\n    field?: string;\n\n    @ApiProperty({\n        example: 'Invalid format',\n        description: 'Human readable reason for the error',\n    })\n    reason?: string;\n\n    @ApiPropertyOptional({\n        example: { minLength: 'Must be at least 8 characters' },\n        description: 'Constraint keys and messages (from class-validator)',\n    })\n    constraints?: Record<string, string>;","truncated":false,"loaded":[]},"title":"backend/src/shared/dtos/response-payload.dto.ts","time":{"start":1779248245603,"end":1779248245874}},"id":"prt_e4375a70e001mmR75rbONvcbSA","sessionID":"ses_1bc8c0b3affePoqf4jbaEmtf7P","messageID":"msg_e43758b7a001y7BNH2G7N6OZsG"}}
