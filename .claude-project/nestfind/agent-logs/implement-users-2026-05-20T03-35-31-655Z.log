\n36:       throw new BadRequestException('Email already registered!');\n37:     }\n38: \n39:     const hashedPassword = await bcrypt.hash(dto.password, 10);\n40: \n41:     const user = await this.userService.createUser({\n42:       name: dto.name,\n43:       email: dto.email,\n44:       password: hashedPassword,\n45:       phone: dto.phone ?? null,\n46:       role: RoleEnum.RENTER,\n47:       status: UserStatusEnum.ACTIVE,\n48:     });\n49: \n50:     return this.sanitizeUser(user);\n51:   }\n52: \n53:   async login(\n54:     dto: LoginDto,\n55:   ): Promise<{ accessToken: string; refreshToken: string; user: Partial<User> }> {\n56:     const user = await this.userService.findByEmailWithPassword(dto.email);\n57: \n58:     if (!user) {\n59:       throw new UnauthorizedException('Invalid email or password!');\n60:     }\n61: \n62:     if (user.status === UserStatusEnum.SUSPENDED) {\n63:       throw new ForbiddenException('Account is suspended!');\n64:     }\n65: \n66:     const isPasswordValid = await bcrypt.compare(dto.password, user.password);\n67:     if (!isPasswordValid) {\n68:       throw new UnauthorizedException('Invalid email or password!');\n69:     }\n70: \n71:     const tokens = await this.generateTokens(user);\n72:     return { ...tokens, user: this.sanitizeUser(user) };\n73:   }\n74: \n75:   async refresh(\n76:     refreshToken: string,\n77:   ): Promise<{ accessToken: string; refreshToken: string; user: Partial<User> }> {\n78:     if (!refreshToken) {\n79:       throw new UnauthorizedException('No refresh token provided!');\n80:     }\n81: \n82:     const existingToken = await this.findRefreshToken(refreshToken);\n83: \n84:     if (!existingToken) {\n85:       throw new UnauthorizedException('Invalid refresh token!');\n86:     }\n87: \n88:     if (existingToken.revokedAt) {\n89:       throw new UnauthorizedException('Refresh token has been revoked!');\n90:     }\n91: \n92:     if (new Date() > existingToken.expiresAt) {\n93:       throw new UnauthorizedException('Refresh token has expired!');\n94:     }\n95: \n96:     existingToken.revokedAt = new Date();\n97:     await this.refreshTokenRepo.save(existingToken);\n98: \n99:     const tokens = await this.generateTokens(existingToken.user);\n100:     return { ...tokens, user: this.sanitizeUser(existingToken.user) };\n101:   }\n102: \n103:   async logout(refreshToken: string): Promise<void> {\n104:     const existing = await this.findRefreshToken(refreshToken);\n105:     if (existing && !existing.revokedAt) {\n106:       existing.revokedAt = new Date();\n107:       await this.refreshTokenRepo.save(existing);\n108:     }\n109:   }\n110: \n111:   async forgotPassword(email: string): Promise<void> {\n112:     const user = await this.userService.findByEmail(email);\n113:     if (!user) {\n114:       return;\n115:     }\n116: \n117:     const tokenValue = uuid();\n118: \n119:     const resetToken = this.passwordResetTokenRepo.create({\n120:       userId: user.id,\n121:       token: tokenValue,\n122:       expiresAt: new Date(Date.now() + 60 * 60 * 1000),\n123:     });\n124:     await this.passwordResetTokenRepo.save(resetToken);\n125:   }\n126: \n127:   async resetPassword(token: string, password: string): Promise<void> {\n128:     if (!token) {\n129:       throw new BadRequestException('Reset token is required!');\n130:     }\n131: \n132:     const resetToken = await this.findResetToken(token);\n133: \n134:     if (!resetToken) {\n135:       throw new NotFoundException('Invalid or expired reset token!');\n136:     }\n137: \n138:     if (resetToken.usedAt) {\n139:       throw new BadRequestException('Reset token has already been used!');\n140:     }\n141: \n142:     if (new Date() > resetToken.expiresAt) {\n143:       throw new BadRequestException('Reset token has expired!');\n144:     }\n145: \n146:     const hashedPassword = await bcrypt.hash(password, 10);\n147: \n148:     await this.userService.update(resetToken.userId, {\n149:       password: hashedPassword,\n150:     });\n151: \n152:     resetToken.usedAt = new Date();\n153:     await this.passwordResetTokenRepo.save(resetToken);\n154:   }\n155: \n156:   async getCurrentUser(userId: string): Promise<Partial<User>> {\n157:     const user = await this.userService.findByIdOrFail(userId);\n158:     return this.sanitizeUser(user);\n159:   }\n160: \n161:   private async generateTokens(\n162:     user: User,\n163:   ): Promise<{ accessToken: string; refreshToken: string }> {\n164:     const payload = {\n165:       sub: user.id,\n166:       email: user.email,\n167:       role: user.role,\n168:     };\n169: \n170:     const accessToken = this.jwtService.sign(payload, { expiresIn: '1h' });\n171: \n172:     const tokenValue = uuid();\n173:     const refreshToken = this.refreshTokenRepo.create({\n174:       userId: user.id,\n175:       token: tokenValue,\n176:       expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),\n177:     });\n178:     await this.refreshTokenRepo.save(refreshToken);\n179: \n180:     return { accessToken, refreshToken: tokenValue };\n181:   }\n182: \n183:   private sanitizeUser(user: User): Partial<User> {\n184:     const { password, refreshTokens, resetTokens, ...safe } = user;\n185:     return safe;\n186:   }\n187: \n188:   private async findRefreshToken(\n189:     token: string,\n190:   ): Promise<(RefreshToken & { user: User }) | null> {\n191:     return this.refreshTokenRepo.findOne({\n192:       where: { token },\n193:       relations: ['user'],\n194:     });\n195:   }\n196: \n197:   private async findResetToken(\n198:     token: string,\n199:   ): Promise<PasswordResetToken | null> {\n200:     return this.passwordResetTokenRepo.findOne({\n201:       where: { token },\n202:     });\n203:   }\n204: }\n\n(End of file - total 204 lines)\n</content>","metadata":{"preview":"import {\n  Injectable,\n  UnauthorizedException,\n  ForbiddenException,\n  BadRequestException,\n  NotFoundException,\n} from '@nestjs/common';\nimport { JwtService } from '@nestjs/jwt';\nim