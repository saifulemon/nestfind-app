ository.findByUserAndProperty(\n43:       userId,\n44:       propertyId,\n45:     );\n46:     if (!favorite) {\n47:       throw new NotFoundException('Favorite not found!');\n48:     }\n49:     await this.favoriteRepository.delete(favorite.id);\n50:   }\n51: \n52:   async findByUser(\n53:     userId: string,\n54:     page: number = 1,\n55:     limit: number = 20,\n56:   ): Promise<{\n57:     items: Record<string, unknown>[];\n58:     total: number;\n59:     page: number;\n60:     limit: number;\n61:     totalPages: number;\n62:   }> {\n63:     const take = Math.min(limit, 100);\n64:     const skip = (page - 1) * take;\n65:     const [items, total] =\n66:       await this.favoriteRepository.findByUserIdWithProperty(\n67:         userId,\n68:         skip,\n69:         take,\n70:       );\n71: \n72:     const mapped = items.map((fav) => {\n73:       const p = fav.property;\n74:       const primaryPhoto = p?.photos?.find((ph) => ph.isPrimary);\n75: \n76:       return {\n77:         id: fav.id,\n78:         property: p\n79:           ? {\n80:               id: p.id,\n81:               title: p.title,\n82:               price: p.price,\n83:               bedrooms: p.bedrooms,\n84:               bathrooms: p.bathrooms,\n85:               propertyType: p.propertyType,\n86:               address: {\n87:                 city: p.addressCity,\n88:                 state: p.addressState,\n89:               },\n90:               primaryPhoto: primaryPhoto?.url ?? null,\n91:             }\n92:           : null,\n93:         createdAt: fav.createdAt,\n94:       };\n95:     });\n96: \n97:     return {\n98:       items: mapped,\n99:       total,\n100:       page,\n101:       limit: take,\n102:       totalPages: Math.ceil(total / take) || 1,\n103:     };\n104:   }\n105: \n106:   async isFavorited(userId: string, propertyId: string): Promise<boolean> {\n107:     const favorite = await this.favoriteRepository.findByUserAndProperty(\n108:       userId,\n109:       propertyId,\n110:     )