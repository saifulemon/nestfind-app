(limit, 10) : 20;\n42:     const result = await this.favoriteService.findByUser(user.id, p, l);\n43:     return {\n44:       success: true,\n45:       statusCode: 200,\n46:       message: 'Favorites retrieved successfully.',\n47:       data: {\n48:         items: result.items,\n49:         meta: {\n50:           total: result.total,\n51:           page: result.page,\n52:           limit: result.limit,\n53:           totalPages: result.totalPages,\n54:         },\n55:       },\n56:     };\n57:   }\n58: \n59:   @Post()\n60:   @HttpCode(HttpStatus.CREATED)\n61:   @ApiOperation({ summary: 'Add a property to favorites' })\n62:   @ApiResponse({ status: 201, description: 'Property added to favorites' })\n63:   @ApiResponse({ status: 400, description: 'Validation failed' })\n64:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n65:   @ApiResponse({ status: 403, description: 'Not a renter' })\n66:   @ApiResponse({ status: 404, description: 'Property not found' })\n67:   @Roles('renter')\n68:   async add(\n69:     @CurrentUser() user: IJwtPayload,\n70:     @Body() dto: CreateFavoriteDto,\n71:   ) {\n72:     const favorite = await this.favoriteService.add(user.id, dto.propertyId);\n73:     return {\n74:       success: true,\n75:       statusCode: 201,\n76:       message: 'Property added to favorites.',\n77:       data: {\n78:         id: favorite.id,\n79:         propertyId: favorite.propertyId,\n80:         createdAt: favorite.createdAt,\n81:       },\n82:     };\n83:   }\n84: \n85:   @Delete(':propertyId')\n86:   @HttpCode(HttpStatus.OK)\n87:   @ApiOperation({ summary: 'Remove a property from favorites' })\n88:   @ApiResponse({ status: 200, description: 'Property removed from favorites' })\n89:   @ApiResponse({ status: 400, description: 'Invalid UUID format' })\n90:   @ApiResponse({ status: 401, description: 'Not authenticated' })\n91:   @ApiResponse({ status: 403, description: 'Not a renter' })\n92:   @ApiResponse({ status: 404, description: 'Favorite not found' })\n93:   @Roles('renter')\n94:   async remove(\n95:     @CurrentUser() user: IJwtPayload,\n96:     @Param('propertyId', ParseUUIDPipe) propertyId: string,\n97:   ) {\n98:     await this.favoriteService.removeByPropertyId(user.id, propertyId);\n99:     return {\n100:       success: true,\n101:       statusCode: 200,\n102:       message: 'Property removed from favorites.',\n103:       data: null,\n104:     };\n105:   }\n106: }\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"import {\n  Controller,\n  Get,\n  Post,\n  Delete,\n  Body,\n  Param,\n  Query,\n  HttpCode,\n  HttpStatus,\n  ParseUUIDPipe,\n  UseGuards,\n} from '@nestjs/common';\nimport { ApiTags, ApiOperation, ApiResponse } from '@nestjs/swagger';\nimport { Roles } from '../../core/decorators/roles.decorator';\nimport { CurrentUser } from '../../core/decorators/current-user.decorator';\nimport { RolesGuard } from '../../core/guards/roles.guard';\nimport { FavoriteService } from './favorite.service';\nimport { CreateFavoriteDto } from './dto/create-favorite.dto';\nimport type { IJwtPayload } from '../../shared/interfaces';","truncated":false,"loaded":[]},"title":"backend/src/modules/favorites/favorite.controller.ts","time":{"start":1779248490843,"end":1779248491114}},"id":"prt_e43796413001w7XsYnnkqpvEoM","sessionID":"ses_1bc8c0b3affePoqf4jbaEmtf7P","messageID":"msg_e437953c5001DLC4SmVJ2IPKSc"}}
