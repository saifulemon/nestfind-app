{"type":"tool_use","timestamp":1779248364991,"sessionID":"ses_1bc8c0b3affePoqf4jbaEmtf7P","part":{"type":"tool","tool":"read","callID":"call_03_PEaOB9dlp40tbTbSbu6R8181","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/decorators/api-swagger.decorator.ts"},"output":"<path>/Users/saifulpotential/Potential/nestfind-sample/backend/src/core/decorators/api-swagger.decorator.ts</path>\n<type>file</type>\n<content>\n1: import { applyDecorators, Type } from \"@nestjs/common\";\n2: import {\n3:   ApiOperation,\n4:   ApiResponse,\n5:   ApiBody,\n6:   ApiBearerAuth,\n7:   ApiCookieAuth,\n8:   ApiExtraModels,\n9:   ApiParam,\n10:   ApiQuery,\n11:   getSchemaPath,\n12: } from \"@nestjs/swagger\";\n13: import { ResponsePayloadDto, ErrorDetailDto } from \"../../shared/dtos\";\n14: import { ApiResponseData } from \"./api-response-data.decorator\";\n15: \n16: export interface ErrorResponseConfig {\n17:   status: number;\n18:   description?: string;\n19: }\n20: \n21: export type ApiOperationType =\n22:   | \"create\"\n23:   | \"getAll\"\n24:   | \"getOne\"\n25:   | \"update\"\n26:   | \"delete\"\n27:   | \"search\"\n28:   | \"count\"\n29:   | \"custom\";\n30: \n31: export interface ApiSwaggerOptions {\n32:   /** Resource name (e.g., 'User', 'Product') */\n33:   resourceName: string;\n34:   /** Request body DTO */\n35:   requestDto?: Type<any>;\n36:   /** Response data DTO (used in ResponsePayloadDto.data) */\n37:   responseDto?: Type<any>;\n38:   /** HTTP success status code (default: 200) */\n39:   successStatus?: number;\n40:   /** If true, response data is an array */\n41:   isArray?: boolean;\n42:   /** Whether endpoint requires bearer auth (default: true) */\n43:   requiresAuth?: boolean;\n44:   /** Array of error responses to document */\n45:   errors?: ErrorResponseConfig[];\n46:   /** Operation type for auto-generating summary and common errors */\n47:   operation?: ApiOperationType;\n48:   /** Custom operation summary (overrides auto-generated) */\n49:   summary?: string;\n50:   /** ID parameter name for getOne/update/delete (default: 'id') */\n51:   paramName?: string;\n52:   /** Add pagination query params for getAll (default: false) */\n53:   withPagination?: boolean;\n54: }\n55: \n56: export function ApiSwagger(options: ApiSwaggerOptions) {\n57:   const config: Required<\n58:     Pick<\n59:       ApiSwaggerOptions,\n60:       | \"successStatus\"\n61:       | \"isArray\"\n62:       | \"requiresAuth\"\n63:       | \"withPagination\"\n64:       | \"paramName\"\n65:       | \"operation\"\n66:     >\n67:   > &\n68:     ApiSwaggerOptions = {\n69:     successStatus: 200,\n70:     isArray: false,\n71:     requiresAuth: true,\n72:     withPagination: false,\n73:     paramName: \"id\",\n74:     operation: \"custom\",\n75:     ...options,\n76:   };\n77: \n78:   const decorators: Array<\n79:     ClassDecorator | MethodDecorator | PropertyDecorator\n80:   > = [];\n81: \n82:   decorators.push(ApiExtraModels(ResponsePayloadDto, ErrorDetailDto));\n83: \n84:   // Auto-generate summary from operation type\n85:   let summary = config.summary;\n86:   if (!summary && config.operation) {\n87:     const resourceLower = config.resourceName.toLowerCase();\n88:     switch (config.operation) {\n89:       case \"create\":\n90:         summary = `Create a new ${resourceLower}`;\n91:         break;\n92:       case \"getAll\":\n93:         summary = `Get all ${resourceLower}`;\n94:         break;\n95:       case \"getOne\":\n96:         summary = `Get ${resourceLower} by ${config.paramName}`;\n97:         break;\n98:       case \"update\":\n99:         summary = `Update ${resourceLower}`;\n100:         break;\n101:       case \"delete\":\n102:         summary = `Delete ${resourceLower}`;\n103:         break;\n104:       case \"search\":\n105:         summary = `Search ${resourceLower}`;\n106:         break;\n107:       case \"count\":\n108:         summary = `Count ${resourceLower}`;\n109:         break;\n110:       default:\n111:         summary = config.resourceName;\n112:     }\n113:   }\n114: \n115:   decorators.push(ApiOperation({ summary }));\n116: \n117:   // Add param decorator for single-resource operations\n118:   if ([\"getOne\", \"update\", \"delete\"].includes(config.operation)) {\n119:     decorators.push(\n120:       ApiParam({\n121:         name: config.paramName,\n122:         type: String,\n123:         format: \"uuid\",\n124:         description: `${config.resourceName} ${config.paramName}`,\n125:       }),\n126:     );\n127:   }\n128: \n129:   // Add pagination query params\n130:   if (config.operation === \"getAll\" && config.withPagination) {\n131:     decorators.push(\n132:       ApiQuery({ name: \"page\", required: false, type: Number, example: 1 }),\n133:       ApiQuery({ name: \"limit\", required: false, type: Number, example: 10 }),\n134:       ApiQuery({ name: \"search\", required: false, type: String }),\n135:       ApiQuery({\n136:         name: \"sortBy\",\n137:         required: false,\n138:         type: String,\n139:         example: \"createdAt\",\n140:       }),\n141:       ApiQuery({\n142:         name: \"sortOrder\",\n143:         required: false,\n144:         enum: [\"ASC\", \"DESC\"],\n145:         example: \"DESC\",\n146:       }),\n147:     );\n148:   }\n149: \n150:   // Auth decorators\n151:   if (config.requiresAuth) {\n152:     decorators.push(ApiBearerAuth());\n153:     // TODO: CUSTOMIZE — Match this to your AUTH_TOKEN_COOKIE_NAME env var\n154:     decorators.push(ApiCookieAuth(\"access_token\"));\n155:     decorators.push(\n156:       ApiResponse({\n157:         status: 401,\n158:         description: \"Unauthorized - Invalid or missing authentication token\",\n159:         schema: {\n160:           type: \"object\",\n161:           properties: {\n162:             success: { type: \"boolean\", example: false },\n163:             statusCode: { type: \"number\", example: 401 },\n164:             message: { type: \"string\", example: \"Unauthorized\" },\n165:             data: { type: \"null\", nullable: true, example: null },\n166:             error: {\n167:               type: \"array\",\n168:               items: { $ref: getSchemaPath(ErrorDetailDto) },\n169:             },\n170:           },\n171:         },\n172:       }),\n173:     );\n174:   }\n175: \n176:   if (config.requestDto) {\n177:     decorators.push(ApiBody({ type: config.requestDto }));\n178:   }\n179: \n180:   // Success response\n181:   if (config.responseDto) {\n182:     decorators.push(\n183:       ApiResponseData(\n184:         config.responseDto,\n185:         config.successStatus,\n186:         config.isArray,\n187:       ) as any,\n188:     );\n189:   } else {\n190:     decorators.push(\n191:       ApiResponse({\n192:         status: config.successStatus,\n193:         description: \"Successful response\",\n194:         schema: { $ref: getSchemaPath(ResponsePayloadDto) },\n195:       }),\n196:     );\n197:   }\n198: \n199:   // Auto-generate common error responses based on operation\n200:   const autoErrors: ErrorResponseConfig[] = [];\n201:   if (config.operation === \"create\") {\n202:     autoErrors.push(\n203:       { status: 400, description: \"Validation failed\" },\n204:       { status: 409, description: `${config.resourceName} already exists` },\n205:     );\n206:   } else if ([\"getOne\", \"update\", \"delete\"].includes(config.operation)) {\n207:     autoErrors.push({\n208:       status: 404,\n209:       description: `${config.resourceName} not found`,\n210:     });\n211:     if (config.operation === \"update\") {\n212:       autoErrors.push({ status: 400, description: \"Validation failed\" });\n213:     }\n214:   }\n215: \n216:   const allErrors = [...autoErrors, ...(config.errors || [])];\n217:   const uniqueErrors = Array.from(\n218:     new Map(allErrors.map((e) => [e.status, e])).values(),\n219:   );\n220: \n221:   uniqueErrors.forEach((error) => {\n222:     decorators.push(\n223:       ApiResponse({\n224:         status: error.status,\n225:         description: error.description || `Error ${error.status}`,\n226:       }),\n227:     );\n228:   });\n229: \n230:   return applyDecorators(...decorators);\n231: }\n\n(End of file - total 231 lines)\n</content>","metadata":{"preview":"import { applyDecorators, Type } from \"@nestjs/common\";\nimport {\n  ApiOperation,\n  ApiResponse,\n  ApiBody,\n  ApiBearerAuth,\n  ApiCookieAuth,\n  ApiExtraModels,\n  ApiParam,\n  ApiQuery,\n  getSchemaPath,\n} from \"@nestjs/swagger\";\nimport { ResponsePayloadDto, ErrorDetailDto } from \"../../shared/dtos\";\nimport { ApiResponseData } from \"./api-response-data.decorator\";\n\nexport interface ErrorResponseConfig {\n  status: number;\n  description?: string;\n}\n","truncated":false,"loaded":[]},"title":"backend/src/core/decorators/api-swagger.decorator.ts","time":{"start":1779248364720,"end":1779248364989}},"id":"prt_e4377781a001KFEeWXq8fvlScm","sessionID":"ses_1bc8c0b3affePoqf4jbaEmtf7P","messageID":"msg_e43765ecb001cVEYIjaekuo1zM"}}
