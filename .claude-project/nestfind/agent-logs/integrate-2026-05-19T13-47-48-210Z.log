@@ -216,14 +216,14 @@\n   <div\n     className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n     style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.4),rgba(124,58,237,0.4))' }}\n   />\n-  <button\n-    onClick={(e) => toggleFav(prop, e)}\n-    className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${prop.isFavorited ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n+    <button\n+    onClick={(e) => toggleFav(prop.id, e)}\n+    className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${favoritedIds.has(prop.id) ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n     data-testid={`A-06-search-fav-btn-${i}`}\n   >\n-    <Heart className=\"w-[18px] h-[18px]\" fill={prop.isFavorited ? 'currentColor' : 'none'} />\n+    <Heart className=\"w-[18px] h-[18px]\" fill={favoritedIds.has(prop.id) ? 'currentColor' : 'none'} />\n   </button>\n </div>\n <div className=\"p-[20px]\">\n   <div className=\"text-[22px] font-bold\">\n","additions":4,"deletions":4},"truncated":false},"title":"frontend/app/pages/renter/search.tsx","time":{"start":1779199296411,"end":1779199296687}},"id":"prt_e408a8d3d001VwMExqZtBkh2Ji","sessionID":"ses_1bf81dad4ffe1rXjRF8ncL7rCd","messageID":"msg_e408a7f75001dgWfbc6NE70YHO"}}
