 \n28:   useEffect(() => {\n29:     if (actionState?.error) {\n30:       const errors = JSON.parse(state.error);\n31:       Object.keys(errors).forEach((key) => {\n32:         form.setError(key as keyof LoginFormData, {\n33:           message: errors[key],\n34:         });\n35:       });\n36:     }\n37:   }, [actionState, form]);\n38: \n39:   return (\n40:     <div className=\"bg-[#0B0F1A] min-h-screen text-[#F1F5F9]\">\n41:       <div className=\"flex items-center justify-center min-h-[calc(100vh-73px)] p-6\">\n42:         <div className=\"w-full max-w-[420px] bg-[rgba(255,255,255,0.04)] backdrop-blur-[12px] border border-[rgba(255,255,255,0.08)] rounded-[16px] p-[40px]\">\n43:           <h2 className=\"text-[28px] font-bold mb-2 tracking-[-0.02em]\">\n44:             {t('auth.welcomeBack')}\n45:           </h2>\n46:           <p className=\"text-sm text-[#94A3B8] mb-8 leading-relaxed\">\n47:             {t('auth.signInSubtitle')}\n48:           </p>\n49: \n50:           <form action={}>\n51:             <div className=\"mb-4\">\n52:               <label\n53:                 htmlFor=\"login-email\"\n54:                 className=\"block text-[13px] font-medium text-[#94A3B8] mb-[6px]\"\n55:               >\n56:                 {t('auth.emailAddress')}\n57:               </label>\n58:               <input\n59:                 id=\"login-email\"\n60:                 type=\"email\"\n61:                 placeholder={t('auth.emailPlaceholder')}\n62:                 data-testid=\"login-email\"\n63:                 {...form.register('email')}\n64:                 className={inputClass}\n65:               />\n66:               {form.formState.errors.email && (\n67:                 <p className=\"text-[#F87171] text-xs mt-1\">\n68:                   {form.formState.errors.email.message}\n69:                 </p>\n70:               )}\n71:             </div>\n72: \n73:             <div className=\"mb-4\">\n74:               <div className=\"flex justify-between items-center 