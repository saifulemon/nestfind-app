i]: !prev[i] }));\n44:   };\n45: \n46:   return (\n47:     <div className=\"max-w-[1440px] mx-auto\">\n48:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n49:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n50:           NestFind\n51:         </div>\n52:         <div className=\"flex gap-[32px] items-center\">\n53:           <Link to=\"/search\" className=\"text-[#F1F5F9] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-browse\">Browse</Link>\n54:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-favorites\">Favorites</Link>\n55:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-inquiries\">My Inquiries</Link>\n56:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-profile\">Profile</Link>\n57:         </div>\n58:       </nav>\n59: \n60:       <section className=\"p-[48px]\">\n61:         <div className=\"flex gap-[12px] items-center mb-[24px] flex-wrap\">\n62:           <div className=\"flex-1 min-w-[280px] relative\">\n63:             <Search className=\"absolute left-[16px] top-1/2 -translate-y-1/2 text-[#64748B] w-[20px] h-[20px]\" />\n64:             <input type=\"text\" placeholder=\"Search by city, neighborhood, or ZIP...\" className={`${inputClass} !pl-[44px]`} data-testid=\"A-06-search-input\" />\n65:           </div>\n66:           <select className={`${selectClass} w-[170px]`} data-testid=\"A-06-search-price-range\">\n67:             <option>Price Range</option>\n68:             <option>$500 - $1,000</option>\n69:   