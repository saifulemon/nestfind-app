{"type":"tool_use","timestamp":1779199232871,"sessionID":"ses_1bf81dad4ffe1rXjRF8ncL7rCd","part":{"type":"tool","tool":"write","callID":"call_00_GgaIXPwsPCwVuJB9R9KA8220","state":{"status":"completed","input":{"filePath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/renter/search.tsx","content":"import { useState, useCallback } from 'react';\nimport { Link } from 'react-router-dom';\nimport { Search, X, Map, Heart, ChevronLeft, ChevronRight, Bed, Bath, Ruler } from 'lucide-react';\nimport { usePropertySearch } from '~/hooks/api/useProperties';\nimport { useAddFavorite, useRemoveFavorite } from '~/hooks/api/useFavorites';\nimport type { PropertyListItem, PropertyTypeEnum, PropertySearchParams } from '~/types/api/property';\n\nexport const inputClass =\n  'h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nexport const selectClass =\n  'h-[48px] bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nconst PROPERTY_TYPE_MAP: Record<string, PropertyTypeEnum> = {\n  '': undefined as unknown as PropertyTypeEnum,\n  'apartment': 'apartment',\n  'condo': 'condo',\n  'townhouse': 'townhouse',\n  'house': 'house',\n  'studio': 'studio',\n};\n\nconst SORT_MAP: Record<string, PropertySearchParams['sortBy']> = {\n  '': 'newest',\n  'price_asc': 'price_asc',\n  'price_desc': 'price_desc',\n  'newest': 'newest',\n  'oldest': 'oldest',\n};\n\nexport default function SearchPage() {\n  const [searchText, setSearchText] = useState('');\n  const [filters, setFilters] = useState<PropertySearchParams>({\n    sortBy: 'newest',\n    page: 1,\n    limit: 20,\n  });\n\n  const { data, isLoading, isError, error } = usePropertySearch(filters);\n  const addFav = useAddFavorite();\n  const removeFav = useRemoveFavorite();\n\n  const properties = data?.items ?? [];\n  const meta = data?.meta;\n  const chips = [\n    filters.city && `${filters.city}`,\n    filters.minPrice && filters.maxPrice\n      ? `$${filters.minPrice} - $${filters.maxPrice}`\n      : filters.minPrice\n        ? `$${filters.minPrice}+`\n        : filters.maxPrice\n          ? `Up to $${filters.maxPrice}`\n          : null,\n    filters.bedrooms ? `${filters.bedrooms}+ Beds` : null,\n    filters.propertyType ? filters.propertyType.charAt(0).toUpperCase() + filters.propertyType.slice(1) : null,\n  ].filter(Boolean) as string[];\n\n  const handleSearch = useCallback(() => {\n    setFilters((prev) => ({ ...prev, search: searchText || undefined, page: 1 }));\n  }, [searchText]);\n\n  const handleKeyDown = useCallback(\n    (e: React.KeyboardEvent) => {\n      if (e.key === 'Enter') handleSearch();\n    },\n    [handleSearch],\n  );\n\n  const updateFilter = useCallback((key: keyof PropertySearchParams, value: string) => {\n    setFilters((prev) => {\n      const next = { ...prev, page: 1 };\n      if (key === 'propertyType') {\n        next.propertyType = (value as PropertyTypeEnum) || undefined;\n      } else if (key === 'bedrooms') {\n        next.bedrooms = value ? parseInt(value, 10) : undefined;\n      } else if (key === 'sortBy') {\n        next.sortBy = SORT_MAP[value] || 'newest';\n      } else if (key === 'minPrice') {\n        if (value === '500-1000') { next.minPrice = 500; next.maxPrice = 1000; }\n        else if (value === '1000-1500') { next.minPrice = 1000; next.maxPrice = 1500; }\n        else if (value === '1500-2000') { next.minPrice = 1500; next.maxPrice = 2000; }\n        else if (value === '2000-3000') { next.minPrice = 2000; next.maxPrice = 3000; }\n        else if (value === '3000+') { next.minPrice = 3000; next.maxPrice = undefined; }\n        else { next.minPrice = undefined; next.maxPrice = undefined; }\n      }\n      return next;\n    });\n  }, []);\n\n  const setPage = useCallback((page: number) => {\n    setFilters((prev) => ({ ...prev, page }));\n  }, []);\n\n  const toggleFav = (prop: PropertyListItem, e: React.MouseEvent) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (prop.isFavorited) {\n      removeFav.mutate(prop.id);\n    } else {\n      addFav.mutate({ propertyId: prop.id });\n    }\n  };\n\n  return (\n    <div className=\"max-w-[1440px] mx-auto\">\n      <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n        <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n          NestFind\n        </div>\n        <div className=\"flex gap-[32px] items-center\">\n          <Link to=\"/search\" className=\"text-[#F1F5F9] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-browse\">Browse</Link>\n          <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-favorites\">Favorites</Link>\n          <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-inquiries\">My Inquiries</Link>\n          <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-profile\">Profile</Link>\n        </div>\n      </nav>\n\n      <section className=\"p-[48px]\">\n        <div className=\"flex gap-[12px] items-center mb-[24px] flex-wrap\">\n          <div className=\"flex-1 min-w-[280px] relative\">\n            <Search className=\"absolute left-[16px] top-1/2 -translate-y-1/2 text-[#64748B] w-[20px] h-[20px]\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search by city, neighborhood, or ZIP...\"\n              className={`${inputClass} !pl-[44px]`}\n              data-testid=\"A-06-search-input\"\n              value={searchText}\n              onChange={(e) => setSearchText(e.target.value)}\n              onKeyDown={handleKeyDown}\n            />\n          </div>\n          <select\n            className={`${selectClass} w-[170px]`}\n            data-testid=\"A-06-search-price-range\"\n            onChange={(e) => updateFilter('minPrice', e.target.value)}\n          >\n            <option value=\"\">Price Range</option>\n            <option value=\"500-1000\">$500 - $1,000</option>\n            <option value=\"1000-1500\">$1,000 - $1,500</option>\n            <option value=\"1500-2000\">$1,500 - $2,000</option>\n            <option value=\"2000-3000\">$2,000 - $3,000</option>\n            <option value=\"3000+\">$3,000+</option>\n          </select>\n          <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-bedrooms\" onChange={(e) => updateFilter('bedrooms', e.target.value)}>\n            <option value=\"\">Bedrooms</option>\n            <option value=\"0\">Studio</option>\n            <option value=\"1\">1 Bed</option>\n            <option value=\"2\">2 Beds</option>\n            <option value=\"3\">3 Beds</option>\n            <option value=\"4\">4+ Beds</option>\n          </select>\n          <select className={`${selectClass} w-[160px]`} data-testid=\"A-06-search-property-type\" onChange={(e) => updateFilter('propertyType', e.target.value)}>\n            <option value=\"\">Property Type</option>\n            <option value=\"apartment\">Apartment</option>\n            <option value=\"condo\">Condo</option>\n            <option value=\"townhouse\">Townhouse</option>\n            <option value=\"house\">Single Family</option>\n          </select>\n          <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-sort\" onChange={(e) => updateFilter('sortBy', e.target.value)}>\n            <option value=\"newest\">Sort: Newest</option>\n            <option value=\"price_asc\">Price: Low to High</option>\n            <option value=\"price_desc\">Price: High to Low</option>\n          </select>\n          <button className=\"w-[48px] h-[48px] rounded-[8px] bg-transparent text-[#94A3B8] inline-flex items-center justify-center cursor-pointer transition-all duration-200 border-none hover:bg-white/10 hover:text-[#F1F5F9]\" data-testid=\"A-06-search-map-toggle\" title=\"Toggle map view\">\n            <Map className=\"w-[22px] h-[22px]\" />\n          </button>\n        </div>\n\n        {chips.length > 0 && (\n          <div className=\"flex gap-[8px] items-center mb-[20px] flex-wrap\">\n            {chips.map((chip) => (\n              <span key={chip} className=\"inline-flex items-center gap-[6px] px-[14px] py-[6px] bg-white/5 border border-white/10 rounded-full text-[13px] text-[#94A3B8] cursor-pointer transition-all duration-200 bg-[rgba(74,144,217,0.15)] border-[rgba(74,144,217,0.4)] text-[#4A90D9]\">\n                {chip}\n                <X className=\"w-[14px] h-[14px] cursor-pointer\" />\n              </span>\n            ))}\n            <span className=\"text-[#64748B] text-[14px] ml-auto\">\n              Showing {meta?.total ?? 0} properties\n            </span>\n          </div>\n        )}\n\n        {isLoading && (\n          <div className=\"flex items-center justify-center py-[80px] text-[#64748B] text-[16px]\">\n            Loading properties...\n          </div>\n        )}\n\n        {isError && (\n          <div className=\"flex items-center justify-center py-[80px] text-[#F87171] text-[16px]\">\n            {(error as Error)?.message || 'Failed to load properties. Please try again.'}\n          </div>\n        )}\n\n        {!isLoading && !isError && properties.length === 0 && (\n          <div className=\"flex flex-col items-center justify-center py-[80px] text-[#64748B]\">\n            <p className=\"text-[18px]\">No properties found</p>\n            <p className=\"text-[14px] mt-[8px]\">Try adjusting your search filters</p>\n          </div>\n        )}\n\n        {!isLoading && !isError && properties.length > 0 && (\n          <div className=\"grid grid-cols-4 gap-[20px]\">\n            {properties.map((prop, i) => (\n              <Link key={prop.id} to={`/detail/${prop.id}`} className=\"no-underline text-inherit\">\n                <div className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(74,144,217,0.15)] hover:-translate-y-[2px]\">\n                  <div className=\"relative\">\n                    <div\n                      className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n                      style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.4),rgba(124,58,237,0.4))' }}\n                    />\n                    <button\n                      onClick={(e) => toggleFav(prop, e)}\n                      className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${prop.isFavorited ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n                      data-testid={`A-06-search-fav-btn-${i}`}\n                    >\n                      <Heart className=\"w-[18px] h-[18px]\" fill={prop.isFavorited ? 'currentColor' : 'none'} />\n                    </button>\n                  </div>\n                  <div className=\"p-[20px]\">\n                    <div className=\"text-[22px] font-bold\">\n                      ${prop.price.toLocaleString()}\n                      <small className=\"text-[14px] font-normal text-[#94A3B8]\">/mo</small>\n                    </div>\n                    <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">{prop.address.street}, {prop.address.city}, {prop.address.state}</div>\n                    <div className=\"flex gap-[16px] text-[13px] text-[#64748B] flex-wrap\">\n                      <span><Bed className=\"w-[14px] h-[14px] inline\" /> {prop.bedrooms} {prop.bedrooms === 1 ? 'Bed' : 'Beds'}</span>\n                      <span><Bath className=\"w-[14px] h-[14px] inline\" /> {prop.bathrooms} {prop.bathrooms === 1 ? 'Bath' : 'Baths'}</span>\n                      <span><Ruler className=\"w-[14px] h-[14px] inline\" /> {prop.squareFeet?.toLocaleString()} sqft</span>\n                    </div>\n                  </div>\n                </div>\n              </Link>\n            ))}\n          </div>\n        )}\n\n        {meta && meta.totalPages > 1 && (\n          <div className=\"flex gap-[4px] justify-center mt-[32px]\">\n            <button\n              className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n              data-testid=\"A-06-search-pagination-prev\"\n              onClick={() => setPage(Math.max(1, meta.page - 1))}\n              disabled={meta.page <= 1}\n            >\n              <ChevronLeft className=\"w-[18px] h-[18px]\" />\n            </button>\n            {Array.from({ length: Math.min(meta.totalPages, 5) }, (_, i) => i + 1).map((n) => (\n              <button\n                key={n}\n                className={`w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium cursor-pointer border-none transition-all duration-200 ${n === meta.page ? 'bg-[linear-gradient(135deg,#4A90D9,#7C3AED)] text-white' : 'text-[#94A3B8] bg-transparent hover:bg-white/10 hover:text-[#F1F5F9]'}`}\n                data-testid={`A-06-search-pagination-${n}`}\n                onClick={() => setPage(n)}\n              >\n                {n}\n              </button>\n            ))}\n            {meta.totalPages > 5 && (\n              <span className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8]\">...</span>\n            )}\n            <button\n              className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n              data-testid=\"A-06-search-pagination-next\"\n              onClick={() => setPage(Math.min(meta.totalPages, meta.page + 1))}\n              disabled={meta.page >= meta.totalPages}\n            >\n              <ChevronRight className=\"w-[18px] h-[18px]\" />\n            </button>\n          </div>\n        )}\n      </section>\n    </div>\n  );\n}\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/pages/renter/search.tsx","exists":true,"truncated":false},"title":"frontend/app/pages/renter/search.tsx","time":{"start":1779199232584,"end":1779199232868}},"id":"prt_e4087b44e001cmjwpt8Vcwphs0","sessionID":"ses_1bf81dad4ffe1rXjRF8ncL7rCd","messageID":"msg_e40879475001xzICWmjBbwoD54"}}
