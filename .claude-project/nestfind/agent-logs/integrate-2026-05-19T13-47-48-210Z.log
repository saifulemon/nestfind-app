61:               key={i}\n62:               onClick={() => setActiveThumb(i)}\n63:               className={`w-[80px] h-[60px] rounded-[8px] object-cover cursor-pointer border-2 bg-white/5 transition-all duration-200 hover:border-[rgba(74,144,217,0.3)] ${i === activeThumb ? 'border-[#4A90D9]' : 'border-transparent'}`}\n64:               style={{ background: gradient }}\n65:               data-testid={`A-07-detail-thumb-${i}`}\n66:               role=\"button\"\n67:               tabIndex={0}\n68:               onKeyDown={(e) => { if (e.key === 'Enter') { setActiveThumb(i); } }}\n69:             />\n70:           ))}\n71:         </div>\n72: \n73:         <div className=\"flex items-center gap-[16px] mt-[32px] mb-[4px]\">\n74:           <h2 className=\"text-[36px] font-bold tracking-[-0.02em]\">\n75:             $1,850<small className=\"text-[18px] font-normal text-[#94A3B8]\">/mo</small>\n76:           </h2>\n77:           <span className=\"inline-block px-[10px] py-[2px] rounded-full text-[11px] font-semibold text-[#4ADE80] shadow-[0_0_8px_rgba(74,222,128,0.3)]\">Available Now</span>\n78:           <button\n79:             onClick={() => setFavorited(!favorited)}\n80:             className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 ml-auto ${favorited ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n81:             data-testid=\"A-07-detail-fav-btn\"\n82:           >\n83:             <Heart className=\"w-[20px] h-[20px]\" fill={favorited ? 'currentColor' : 'none'} />\n84:           </button>\n85:         </div>\n86:         <p className=\"text-[16px] text-[#94A3B8] mb-[32px]\">\n87:           <MapPin className=\"w-[16px] h-[16px] inline align-[-2px]\" />\n88:           {' '}321 Elm St, Austin, TX 78701 &mdash; Downtown Austin\n89:         </p>\n90: \n91:         <div className=\"grid grid-cols-4