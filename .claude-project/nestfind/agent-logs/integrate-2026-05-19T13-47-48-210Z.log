jectWithValue(error.message);\n45:     }\n46:   }\n47: );\n48: \n49: export const logoutUser = createAsyncThunk(\n50:   'auth/logoutUser',\n51:   async (_, { rejectWithValue }) => {\n52:     try {\n53:       await httpService.post('/auth/logout');\n54:     } catch (error: any) {\n55:       return rejectWithValue(error.message);\n56:     }\n57:   }\n58: );\n59: \n60: const authSlice = createSlice({\n61:   name: 'auth',\n62:   initialState,\n63:   reducers: {\n64:     clearAuthError(state) {\n65:       state.error = null;\n66:     },\n67:     setAuthChecked(state) {\n68:       state.authChecked = true;\n69:     },\n70:   },\n71:   extraReducers: (builder) => {\n72:     builder\n73:       .addCase(loginUser.pending, (state) => {\n74:         state.isLoading = true;\n75:         state.error = null;\n76:       })\n77:       .addCase(loginUser.fulfilled, (state, action) => {\n78:         state.isLoading = false;\n79:         state.isAuthenticated = true;\n80:         state.authChecked = true;\n81:         state.user = action.payload;\n82:       })\n83:       .addCase(loginUser.rejected, (state, action) => {\n84:         state.isLoading = false;\n85:         state.authChecked = true;\n86:         state.error = action.payload as string;\n87:       })\n88:       .addCase(registerUser.pending, (state) => {\n89:         state.isLoading = true;\n90:         state.error = null;\n91:       })\n92:       .addCase(registerUser.fulfilled, (state, action) => {\n93:         state.isLoading = false;\n94:         state.isAuthenticated = true;\n95:         state.authChecked = true;\n96:         state.user = action.payload;\n97:       })\n98:       .addCase(registerUser.rejected, (state, action) => {\n99:         state.isLoading = false;\n100:         state.authChecked = true;\n101:         state.error = action.payload as string;\n102:       })\n103:       .addCase(fetchCurrentUser.pending, (state) => {\n104:         state.isLoading = true;\n105:       })\n106:       .addCase(fetchCurrentUser.fulfilled, (state, action) => {\n107:         state.isLoading = false;\n108:         state.isAuthenticated = true;\n109:         state.authChecked = true;\n110:         state.user = action.payload;\n111:       })\n112:       .addCase(fetchCurrentUser.rejected, (state) => {\n113:         state.isLoading = false;\n114:         state.isAuthenticated = false;\n115:         state.authChecked = true;\n116:         state.user = null;\n117:       })\n118:       .addCase(logoutUser.fulfilled, (state) => {\n119:         state.isAuthenticated = false;\n120:         state.authChecked = true;\n121:         state.user = null;\n122:       })\n123:       .addCase(logoutUser.rejected, (state) => {\n124:         state.isAuthenticated = false;\n125:         state.authChecked = true;\n126:         state.user = null;\n127:       });\n128:   },\n129: });\n130: \n131: export const { clearAuthError, setAuthChecked } = authSlice.actions;\n132: export default authSlice.reducer;\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"import { createSlice, createAsyncThunk } from '@reduxjs/toolkit';\nimport { httpService } from '~/services/httpService';\nimport type { AuthState, AuthUser, LoginCredentials, RegisterCredentials } from '~/types/auth';\n\nconst initialState: AuthState = {\n  user: null,\n  isAuthenticated: false,\n  isLoading: false,\n  authChecked: false,\n  error: null,\n};\n\nexport const loginUser = createAsyncThunk(\n  'auth/loginUser',\n  async (credentials: LoginCredentials, { rejectWithValue }) => {\n    try {\n      const response = await httpService.post<{ data: AuthUser }>('/auth/login', credentials);\n      return response.data;\n    } catch (error: any) {\n      return rejectWithValue(error.message);","truncated":false,"loaded":[]},"title":"frontend/app/redux/features/authSlice.ts","time":{"start":1779198712841,"end":1779198713119}},"id":"prt_e4081d4a5001zuRp0Je85i2wY2","sessionID":"ses_1bf81dad4ffe1rXjRF8ncL7rCd","messageID":"msg_e4081c60d001J3JLv