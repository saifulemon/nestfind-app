er;\n  bathrooms: number;\n  squareFeet?: number;\n  propertyType: PropertyTypeEnum;\n  address: PropertyAddress;\n  availableFrom?: string;\n  amenityIds: string[];\n}\n\nexport type UpdatePropertyDto = Partial<CreatePropertyDto>;\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/saifulpotential/Potential/nestfind-sample/frontend/app/types/api/property.d.ts","exists":false,"truncated":false},"title":"frontend/app/types/api/property.d.ts","time":{"start":1779198829379,"end":1779198829657}},"id":"prt_e40835f29001MUZMZUZQ9Xh72U","sessionID":"ses_1bf81dad4ffe1rXjRF8ncL7rCd","messageID":"msg_e4083504a001yL7IV1jaiBV4oR"}}
