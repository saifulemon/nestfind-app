t-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-08-fav-nav-inquiries\">My Inquiries</Link>\n27:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-08-fav-nav-profile\">Profile</Link>\n28:         </div>\n29:       </nav>\n30: \n31:       <div className=\"pt-[48px] px-[48px] pb-0\">\n32:         <div className=\"text-[12px] font-semibold uppercase tracking-[0.08em] text-[#4A90D9] mb-[8px]\">Saved</div>\n33:         <h2 className=\"text-[32px] font-bold tracking-[-0.02em]\">\n34:           My Favorites <span className=\"text-[#94A3B8] font-normal text-[20px]\">({count})</span>\n35:         </h2>\n36:       </div>\n37: \n38:       <section className=\"p-[48px]\" style={{ paddingTop: '24px' }}>\n39:         {isLoading && (\n40:           <div className=\"flex items-center justify-center py-[80px] text-[#64748B] text-[16px]\">\n41:             Loading favorites...\n42:           </div>\n43:         )}\n44: \n45:         {isError && (\n46:           <div className=\"flex items-center justify-center py-[80px] text-[#F87171] text-[16px]\">\n47:             {(error as Error)?.message || 'Failed to load favorites'}\n48:           </div>\n49:         )}\n50: \n51:         {!isLoading && !isError && favorites.length === 0 && (\n52:           <div className=\"flex flex-col items-center justify-center py-[80px] text-[#64748B]\">\n53:             <Heart className=\"w-[48px] h-[48px] mb-[16px] text-[#64748B]\" />\n54:             <p className=\"text-[18px]\">No favorites yet</p>\n55:             <p className=\"text-[14px] mt-[8px]\">Save properties you like by clicking the heart icon</p>\n56:             <Link to=\"/search\" className=\"mt-[16px] text-[#4A90D9] hover:underline\">Browse properties</Link>\n57:           </div>\n58:         )}\n59: \n60:         {!isLoading && !isError && favorites.length > 0 && (\n61:           <div className=\"grid grid-cols-3 gap-[20px]\">\n62:             {favorites.map((fav: FavoriteItem, i: number) => {\n63:               const prop = fav.property;\n64:               return (\n65:                 <div key={fav.id} className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(74,144,217,0.15)] hover:-translate-y-[2px]\">\n66:                   <div className=\"relative\">\n67:                     <div\n68:                       className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n69:                       style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.35),rgba(124,58,237,0.35))' }}\n70:                     />\n71:                     <button\n72:                       onClick={() => handleRemove(prop.id)}\n73:                       className=\"w-[36px] h-[36px] rounded-full bg-[rgba(248,113,113,0.2)] text-[#F87171] border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px]\"\n74:                       data-testid={`A-08-fav-fav-btn-${i}`}\n75:                     >\n76:                       <Heart className=\"w-[18px] h-[18px]\" fill=\"currentColor\" />\n77:                     </button>\n78:                   </div>\n79:                   <div className=\"p-[20px]\">\n80:                     <div className=\"text-[22px] font-bold\">\n81:                       ${prop.price.toLocaleString()}\n82:                       <small className=\"text-[14px] font-normal text-[#94A3B8]\">/mo</small>\n83:                     </div>\n84:                     <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">\n85:                       {prop.address.city}, {prop.address.state}\n86:                     </div>\n87:                     <div className=\"flex gap-[16px] text-[13px] text-[#64748B] flex-wrap\">\n88:                       <span