DESC',\n25:     page: 1,\n26:     limit: 20,\n27:   });\n28: \n29:   const { data, isLoading, isError, error } = usePropertySearch(filters);\n30:   const addFav = useAddFavorite();\n31:   const removeFav = useRemoveFavorite();\n32:   const [favoritedIds, setFavoritedIds] = useState<Set<string>>(new Set());\n33: \n34:   const properties = data?.items ?? [];\n35:   const meta = data?.meta;\n36:   const chips = [\n37:     filters.city && `${filters.city}`,\n38:     filters.minPrice && filters.maxPrice\n39:       ? `$${filters.minPrice} - $${filters.maxPrice}`\n40:       : filters.minPrice\n41:         ? `$${filters.minPrice}+`\n42:         : filters.maxPrice\n43:           ? `Up to $${filters.maxPrice}`\n44:           : null,\n45:     filters.bedrooms ? `${filters.bedrooms}+ Beds` : null,\n46:     filters.propertyType ? filters.propertyType.charAt(0).toUpperCase() + filters.propertyType.slice(1) : null,\n47:   ].filter(Boolean) as string[];\n48: \n49:   const handleSearch = useCallback(() => {\n50:     setFilters((prev) => ({ ...prev, search: searchText || undefined, page: 1 }));\n51:   }, [searchText]);\n52: \n53:   const handleKeyDown = useCallback(\n54:     (e: React.KeyboardEvent) => {\n55:       if (e.key === 'Enter') handleSearch();\n56:     },\n57:     [handleSearch],\n58:   );\n59: \n60:   const updateFilter = useCallback((key: keyof PropertySearchParams, value: string) => {\n61:     setFilters((prev) => {\n62:       const next = { ...prev, page: 1 };\n63:       if (key === 'propertyType') {\n64:         next.propertyType = (value as PropertyTypeEnum) || undefined;\n65:       } else if (key === 'bedrooms') {\n66:         next.bedrooms = value ? parseInt(value, 10) : undefined;\n67:       } else if (key === 'sortBy') {\n68:         const opt = SORT_OPTIONS[value];\n69:         if (opt) {\n70:           next.sortBy = opt.sortBy;\n71:           next.sortOrder = opt.sortOrder;\n72:         }\n73:       } else if (key === 'minPrice') {\n74:         if (value === '500-1000') { next.minPrice = 500; next.maxPrice = 1000; }\n75:         else if (value === '1000-1500') { next.minPrice = 1000; next.maxPrice = 1500; }\n76:         else if (value === '1500-2000') { next.minPrice = 1500; next.maxPrice = 2000; }\n77:         else if (value === '2000-3000') { next.minPrice = 2000; next.maxPrice = 3000; }\n78:         else if (value === '3000+') { next.minPrice = 3000; next.maxPrice = undefined; }\n79:         else { next.minPrice = undefined; next.maxPrice = undefined; }\n80:       }\n81:       return next;\n82:     });\n83:   }, []);\n84: \n85:   const setPage = useCallback((page: number) => {\n86:     setFilters((prev) => ({ ...prev, page }));\n87:   }, []);\n88: \n89:   const toggleFav = (propertyId: string, e: React.MouseEvent) => {\n90:     e.preventDefault();\n91:     e.stopPropagation();\n92:     const isFav = favoritedIds.has(propertyId);\n93:     setFavoritedIds((prev) => {\n94:       const next = new Set(prev);\n95:       if (isFav) {\n96:         next.delete(propertyId);\n97:         removeFav.mutate(propertyId);\n98:       } else {\n99:         next.add(propertyId);\n100:         addFav.mutate({ propertyId });\n101:       }\n102:       return next;\n103:     });\n104:   };\n105: \n106:   return (\n107:     <div className=\"max-w-[1440px] mx-auto\">\n108:       <nav className=\"flex justify-between items-center px-[48px] py-[16px] border-b border-white/10\">\n109:         <div className=\"text-[24px] font-bold bg-gradient-to-r from-[#4A90D9] to-[#7C3AED] bg-clip-text text-transparent\">\n110:           NestFind\n111:         </div>\n112:         <div className=\"flex gap-[32px] items-center\">\n113:           <Link to=\"/search\" className=\"text-[#F1F5F9] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-browse\">Browse</Link>\n114:           <Link to=\"/favorites\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-favorites\">Favorites</Link>\n115:           <Link to=\"/inquiries\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-inquiries\">My Inquiries</Link>\n116:           <Link to=\"/profile\" className=\"text-[#94A3B8] no-underline text-[14px] font-medium transition-colors hover:text-[#F1F5F9]\" data-testid=\"A-06-search-nav-profile\">Profile</Link>\n117:         </div>\n118:       </nav>\n119: \n120:       <section className=\"p-[48px]\">\n121:         <div className=\"flex gap-[12px] items-center mb-[24px] flex-wrap\">\n122:           <div className=\"flex-1 min-w-[280px] relative\">\n123:             <Search className=\"absolute left-[16px] top-1/2 -translate-y-1/2 text-[#64748B] w-[20px] h-[20px]\" />\n124:             <input\n125:               type=\"text\"\n126:               placeholder=\"Search by city, neighborhood, or ZIP...\"\n127:               className={`${inputClass} !pl-[44px]`}\n128:               data-testid=\"A-06-search-input\"\n129:               value={searchText}\n130:               onChange={(e) => setSearchText(e.target.value)}\n131:               onKeyDown={handleKeyDown}\n132:             />\n133:           </div>\n134:           <select\n135:             className={`${selectClass} w-[170px]`}\n136:             data-testid=\"A-06-search-price-range\"\n137:             onChange={(e) => updateFilter('minPrice', e.target.value)}\n138:           >\n139:             <option value=\"\">Price Range</option>\n140:             <option value=\"500-1000\">$500 - $1,000</option>\n141:             <option value=\"1000-1500\">$1,000 - $1,500</option>\n142:             <option value=\"1500-2000\">$1,500 - $2,000</option>\n143:             <option value=\"2000-3000\">$2,000 - $3,000</option>\n144:             <option value=\"3000+\">$3,000+</option>\n145:           </select>\n146:           <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-bedrooms\" onChange={(e) => updateFilter('bedrooms', e.target.value)}>\n147:             <option value=\"\">Bedrooms</option>\n148:             <option value=\"0\">Studio</option>\n149:             <option value=\"1\">1 Bed</option>\n150:             <option value=\"2\">2 Beds</option>\n151:             <option value=\"3\">3 Beds</option>\n152:             <option value=\"4\">4+ Beds</option>\n153:           </select>\n154:           <select className={`${selectClass} w-[160px]`} data-testid=\"A-06-search-property-type\" onChange={(e) => updateFilter('propertyType', e.target.value)}>\n155:             <option value=\"\">Property Type</option>\n156:             <option value=\"apartment\">Apartment</option>\n157:             <option value=\"condo\">Condo</option>\n158:             <option value=\"townhouse\">Townhouse</option>\n159:             <option value=\"house\">Single Family</option>\n160:           </select>\n161:           <select className={`${selectClass} w-[150px]`} data-testid=\"A-06-search-sort\" onChange={(e) => updateFilter('sortBy', e.target.value)}>\n162:             <option value=\"newest\">Sort: Newest</option>\n163:             <option value=\"price_asc\">Price: Low to High</option>\n164:             <option value=\"price_desc\">Price: High to Low</option>\n165:           </select>\n166:           <button className=\"w-[48px] h-[48px] rounded-[8px] bg-transparent text-[#94A3B8] inline-flex items-center justify-center cursor-pointer transition-all duration-200 border-none hover:bg-white/10 hover:text-[#F1F5F9]\" data-testid=\"A-06-search-map-toggle\" title=\"Toggle map view\">\n167:             <Map className=\"w-[22px] h-[22px]\" />\n168:           </button>\n169:         </div>\n170: \n171:         {chips.length > 0 && (\n172:           <div className=\"flex gap-[8px] items-center mb-[20px] flex-wrap\">\n173:             {chips.map((chip) => (\n174:               <span key={chip} className=\"inline-flex items-center gap-[6px] px-[14px] py-[6px] bg-white/5 border border-white/10 rounded-full text-[13px] text-[#94A3B8] cursor-pointer transition-all duration-200 bg-[rgba(74,144,217,0.15)] border-[rgba(74,144,217,0.4)] text-[#4A90D9]\">\n175:                 {chip}\n176:                 <X className=\"w-[14px] h-[14px] cursor-pointer\" />\n177:               </span>\n178:             ))}\n179:             <span className=\"text-[#64748B] text-[14px] ml-auto\">\n180:               Showing {meta?.total ?? 0} properties\n181:             </span>\n182:           </div>\n183:         )}\n184: \n185:         {isLoading && (\n186:           <div className=\"flex items-center justify-center py-[80px] text-[#64748B] text-[16px]\">\n187:             Loading properties...\n188:           </div>\n189:         )}\n190: \n191:         {isError && (\n192:           <div className=\"flex items-center justify-center py-[80px] text-[#F87171] text-[16px]\">\n193:             {(error as Error)?.message || 'Failed to load properties. Please try again.'}\n194:           </div>\n195:         )}\n196: \n197:         {!isLoading && !isError && properties.length === 0 && (\n198:           <div className=\"flex flex-col items-center justify-center py-[80px] text-[#64748B]\">\n199:             <p className=\"text-[18px]\">No properties found</p>\n200:             <p className=\"text-[14px] mt-[8px]\">Try adjusting your search filters</p>\n201:           </div>\n202:         )}\n203: \n204:         {!isLoading && !isError && properties.length > 0 && (\n205:           <div className=\"grid grid-cols-4 gap-[20px]\">\n206:             {properties.map((prop, i) => (\n207:               <Link key={prop.id} to={`/detail/${prop.id}`} className=\"no-underline text-inherit\">\n208:                 <div className=\"bg-white/5 backdrop-blur-[12px] border border-white/10 rounded-[12px] overflow-hidden transition-all duration-300 hover:shadow-[0_0_20px_rgba(74,144,217,0.15)] hover:-translate-y-[2px]\">\n209:                   <div className=\"relative\">\n210:                     <div\n211:                       className=\"w-full h-[200px] object-cover bg-cover bg-center\"\n212:                       style={prop.primaryPhoto ? { backgroundImage: `url(${prop.primaryPhoto})` } : { background: 'linear-gradient(135deg,rgba(74,144,217,0.4),rgba(124,58,237,0.4))' }}\n213:                     />\n214:                       <button\n215:                       onClick={(e) => toggleFav(prop.id, e)}\n216:                       className={`w-[36px] h-[36px] rounded-full border-none inline-flex items-center justify-center cursor-pointer transition-all duration-200 absolute top-[12px] right-[12px] ${favoritedIds.has(prop.id) ? 'bg-[rgba(248,113,113,0.2)] text-[#F87171]' : 'bg-white/10 text-[#94A3B8] hover:bg-[rgba(248,113,113,0.15)] hover:text-[#F87171]'}`}\n217:                       data-testid={`A-06-search-fav-btn-${i}`}\n218:                     >\n219:                       <Heart className=\"w-[18px] h-[18px]\" fill={favoritedIds.has(prop.id) ? 'currentColor' : 'none'} />\n220:                     </button>\n221:                   </div>\n222:                   <div className=\"p-[20px]\">\n223:                     <div className=\"text-[22px] font-bold\">\n224:                       ${prop.price.toLocaleString()}\n225:                       <small className=\"text-[14px] font-normal text-[#94A3B8]\">/mo</small>\n226:                     </div>\n227:                     <div className=\"text-[#94A3B8] text-[14px] my-[4px] mb-[8px]\">{prop.addressStreet}, {prop.addressCity}, {prop.addressState}</div>\n228:                     <div className=\"flex gap-[16px] text-[13px] text-[#64748B] flex-wrap\">\n229:                       <span><Bed className=\"w-[14px] h-[14px] inline\" /> {prop.bedrooms} {prop.bedrooms === 1 ? 'Bed' : 'Beds'}</span>\n230:                       <span><Bath className=\"w-[14px] h-[14px] inline\" /> {prop.bathrooms} {prop.bathrooms === 1 ? 'Bath' : 'Baths'}</span>\n231:                       <span><Ruler className=\"w-[14px] h-[14px] inline\" /> {prop.squareFeet?.toLocaleString()} sqft</span>\n232:                     </div>\n233:                   </div>\n234:                 </div>\n235:               </Link>\n236:             ))}\n237:           </div>\n238:         )}\n239: \n240:         {meta && meta.totalPages > 1 && (\n241:           <div className=\"flex gap-[4px] justify-center mt-[32px]\">\n242:             <button\n243:               className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n244:               data-testid=\"A-06-search-pagination-prev\"\n245:               onClick={() => setPage(Math.max(1, meta.page - 1))}\n246:               disabled={meta.page <= 1}\n247:             >\n248:               <ChevronLeft className=\"w-[18px] h-[18px]\" />\n249:             </button>\n250:             {Array.from({ length: Math.min(meta.totalPages, 5) }, (_, i) => i + 1).map((n) => (\n251:               <button\n252:                 key={n}\n253:                 className={`w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium cursor-pointer border-none transition-all duration-200 ${n === meta.page ? 'bg-[linear-gradient(135deg,#4A90D9,#7C3AED)] text-white' : 'text-[#94A3B8] bg-transparent hover:bg-white/10 hover:text-[#F1F5F9]'}`}\n254:                 data-testid={`A-06-search-pagination-${n}`}\n255:                 onClick={() => setPage(n)}\n256:               >\n257:                 {n}\n258:               </button>\n259:             ))}\n260:             {meta.totalPages > 5 && (\n261:               <span className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8]\">...</span>\n262:             )}\n263:             <button\n264:               className=\"w-[36px] h-[36px] rounded-[8px] flex items-center justify-center text-[13px] font-medium text-[#94A3B8] cursor-pointer bg-transparent border-none transition-all duration-200 hover:bg-white/10 hover:text-[#F1F5F9]\"\n265:               data-testid=\"A-06-search-pagination-next\"\n266:               onClick={() => setPage(Math.min(meta.totalPages, meta.page + 1))}\n267:               disabled={meta.page >= meta.totalPages}\n268:             >\n269:               <ChevronRight className=\"w-[18px] h-[18px]\" />\n270:             </button>\n271:           </div>\n272:         )}\n273:       </section>\n274:     </div>\n275:   );\n276: }\n\n(End of file - total 276 lines)\n</content>","metadata":{"preview":"import { useState, useCallback } from 'react';\nimport { Link } from 'react-router-dom';\nimport { Search, X, Map, Heart, ChevronLeft, ChevronRight, Bed, Bath, Ruler } from 'lucide-react';\nimport { usePropertySearch } from '~/hooks/api/useProperties';\nimport { useAddFavorite, useRemoveFavorite } from '~/hooks/api/useFavorites';\nimport type { PropertyTypeEnum, PropertySearchParams } from '~/types/api/property';\n\nexport const inputClass =\n  'h-[48px] w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] placeholder:text-[#64748B] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nexport const selectClass =\n  'h-[48px] bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.08)] rounded-[10px] px-[16px] text-[#F1F5F9] text-[14px] outline-none font-[inherit] focus:border-[rgba(74,144,217,0.5)] focus:shadow-[0_0_0_3px_rgba(74,144,217,0.1)]';\n\nconst SORT_OPTIONS: Record<string, { sortBy: string; sortOrder: 'ASC' | 'DESC' }> = {\n  'newest': { sortBy: 'createdAt', sortOrder: 'DESC' },\n  'price_asc': { sortBy: 'price', sortOrder: 'ASC' },\n  'price_desc': { sortBy: 'price', sortOrder: 'DESC' },\n};\n\nexport default function SearchPage() {"