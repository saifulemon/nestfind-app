 && (\n82:         <div className=\"mt-4 p-3 rounded bg-green-500/10 text-green-500 text-sm\">Property created successfully!</div>\n83:       )}\n84: \n85:       <form onSubmit={handleSubmit} className=\"mt-6 space-y-4 max-w-2xl\">\n86:         <div>\n87:           <label className=\"block text-sm font-medium mb-1\">Title</label>\n88:           <input name=\"title\" required minLength={5} maxLength={200} defaultValue={existingProperty?.title || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n89:         </div>\n90:         <div>\n91:           <label className=\"block text-sm font-medium mb-1\">Description</label>\n92:           <textarea name=\"description\" required minLength={20} maxLength={5000} rows={4} defaultValue={existingProperty?.description || ''} className=\"w-full rounded-md border bg-background px-3 py-2 text-sm resize-y\" />\n93:         </div>\n94:         <div className=\"grid grid-cols-3 gap-4\">\n95:           <div>\n96:             <label className=\"block text-sm font-medium mb-1\">Price ($/mo)</label>\n97:             <input name=\"price\" type=\"number\" required min={0} step=\"0.01\" defaultValue={existingProperty?.price || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n98:           </div>\n99:           <div>\n100:             <label className=\"block text-sm font-medium mb-1\">Bedrooms</label>\n101:             <input name=\"bedrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bedrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n102:           </div>\n103:           <div>\n104:             <label className=\"block text-sm font-medium mb-1\">Bathrooms</label>\n105:             <input name=\"bathrooms\" type=\"number\" required min={0} defaultValue={existingProperty?.bathrooms ?? ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n106:           </div>\n107:         </div>\n108:         <div className=\"grid grid-cols-2 gap-4\">\n109:           <div>\n110:             <label className=\"block text-sm font-medium mb-1\">Square Feet</label>\n111:             <input name=\"squareFeet\" type=\"number\" min={0} defaultValue={existingProperty?.squareFeet || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n112:           </div>\n113:           <div>\n114:             <label className=\"block text-sm font-medium mb-1\">Property Type</label>\n115:             <select name=\"propertyType\" required defaultValue={existingProperty?.propertyType || 'apartment'} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\">\n116:               {PROPERTY_TYPES.map((t) => (\n117:                 <option key={t} value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>\n118:               ))}\n119:             </select>\n120:           </div>\n121:         </div>\n122:         <div>\n123:           <label className=\"block text-sm font-medium mb-1\">Available From</label>\n124:           <input name=\"availableFrom\" type=\"date\" defaultValue={existingProperty?.availableFrom?.split('T')[0] || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n125:         </div>\n126:         <fieldset className=\"border rounded-md p-4\">\n127:           <legend className=\"text-sm font-medium px-2\">Address</legend>\n128:           <div className=\"grid grid-cols-2 gap-4\">\n129:             <div className=\"col-span-2\">\n130:               <label className=\"block text-sm mb-1\">Street</label>\n131:               <input name=\"addressStreet\" required maxLength={200} defaultValue={existingProperty?.addressStreet || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n132:             </div>\n133:             <div>\n134:               <label className=\"block text-sm mb-1\">City</label>\n135:               <input name=\"addressCity\" required maxLength={100} defaultValue={existingProperty?.addressCity || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n136:             </div>\n137:             <div>\n138:               <label className=\"block text-sm mb-1\">State</label>\n139:               <input name=\"addressState\" required maxLength={100} defaultValue={existingProperty?.addressState || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n140:             </div>\n141:             <div>\n142:               <label className=\"block text-sm mb-1\">ZIP Code</label>\n143:               <input name=\"addressZipCode\" required maxLength={10} defaultValue={existingProperty?.addressZipCode || ''} className=\"w-full h-10 rounded-md border bg-background px-3 text-sm\" />\n144:             </div>\n145:           </div>\n146:         </fieldset>\n147: \n148:         {amenities && amenities.length > 0 && (\n149:           <div>\n150:             <label className=\"block text-sm font-medium mb-2\">Amenities</label>\n151:             <div className=\"flex flex-wrap gap-2\">\n152:               {amenities.map((a) => (\n153:                 <label key={a.id} className=\"flex items-center gap-1.5 px-3 py-1.5 border rounded-md text-sm cursor-pointer hover:bg-muted\">\n154:                   <input\n155:                     type=\"checkbox\"\n156:                     checked={selectedAmenities.includes(a.id)}\n157:                     onChange={() => toggleAmenity(a.id)}\n158:                     className=\"accent-primary\"\n159:                   />\n160:                   {a.name}\n161:                 </label>\n162:               ))}\n163:             </div>\n164:           </div>\n165:         )}\n166: \n167:         <button type=\"submit\" disabled={isPending} className=\"inline-flex items-center justify-center h-10 px-6 rounded-md bg-primary text-primary-foreground text-sm font-semibold hover:opacity-90 disabled:opacity-50\">\n168:           {isPending ? 'Saving...' : isEdit ? 'Update Property' : 'Create Property'}\n169:         </button>\n170:       </form>\n171:     </div>\n172:   );\n173: }\n\n(End of file - total 173 lines)\n</content>","metadata":{"preview":"import { useState, type FormEvent } from 'react';\nimport { useNavigate, useParams } from 'react-router-dom';\nimport { useCreateProperty, useUpdateProperty, usePropertyDetail } from '~/hooks/api/useProperties';\nimport { useAmenityList } from '~/hooks/api/useAmenities';\nimport type { CreatePropertyDto, PropertyTypeEnum } from '~/types/api/property';\nimport { PROPERTY_TYPES } from '~/types/api/property';\n\nexport default function PropertyForm() {\n  const { id } = useParams<{ id: string }>();\n  const navigate = useNavigate();\n  const isEdit = !!id;\n\n  const { data: existingProperty, isLoading: loadingExisting } = usePropertyDetail(id);\n  const { data: amenities } = useAmenityList();\n  const createProperty = useCreateProperty();\n  const updateProperty = useUpdateProperty();\n\n  const [error, setError] = useState<string | null>(null);\n  const [selectedAmenities, setSelectedAmenities] = useState<string[]>([]);\n","truncated":false,"loaded":[]},"title":"frontend/app/pages/admin/property-form.tsx","time":{"start":1779252681630,"end":1779252681914}},"id":"prt_e43b956b40013gA6Hy9or5qXem","sessionID":"ses_1bc4b4b8cffe0nK0wwHHNx2kzK","messageID":"msg_e43b91fb3001AIG2uqSG5q3cv4"}}
