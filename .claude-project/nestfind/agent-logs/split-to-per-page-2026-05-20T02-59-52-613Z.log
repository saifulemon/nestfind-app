ass=\"text-sm text-gray-500 mt-2\">Start finding your perfect nest</p>\n30:         </div>\n31: \n32:         <!-- Form -->\n33:         <form class=\"space-y-5\" onsubmit=\"event.preventDefault();\">\n34:             \n35:             <!-- Full Name Input -->\n36:             <div class=\"space-y-1.5\">\n37:                 <label for=\"fullname\" class=\"block text-sm font-medium text-gray-700\">\n38:                     Full Name <span class=\"text-red-500\">*</span>\n39:                 </label>\n40:                 <input type=\"text\" id=\"fullname\" name=\"fullname\" placeholder=\"John Doe\" class=\"block w-full h-11 px-3 rounded-md border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:border-[#0066CC] focus:outline-none focus:ring-4 focus:ring-[#0066CC]/10 transition-all shadow-sm\" required=\"\">\n41:             </div>\n42: \n43:             <!-- Email Input -->\n44:             <div class=\"space-y-1.5\">\n45:                 <label for=\"email\" class=\"block text-sm font-medium text-gray-700\">\n46:                     Email address <span class=\"text-red-500\">*</span>\n47:                 </label>\n48:                 <input type=\"email\" id=\"email\" name=\"email\" placeholder=\"name@company.com\" class=\"block w-full h-11 px-3 rounded-md border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:border-[#0066CC] focus:outline-none focus:ring-4 focus:ring-[#0066CC]/10 transition-all shadow-sm\" required=\"\">\n49:             </div>\n50: \n51:             <!-- Phone Number Input (Optional) -->\n52:             <div class=\"space-y-1.5\">\n53:                 <label for=\"phone\" class=\"block text-sm font-medium text-gray-700\">\n54:                     Phone Number <span class=\"text-gray-400 font-normal ml-0.5\">(optional)</span>\n55:                 </label>\n56:                 <input type=\"tel\" id=\"phone\" name=\"phone\" placeholder=\"+1 (555) 000-0000\" class=\"block w-full h-11 px-