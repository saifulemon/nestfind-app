">\n281:                                             <span class=\"iconify\" data-icon=\"lucide:trash-2\" data-width=\"16\" data-height=\"16\"></span>\n282:                                         </button>\n283:                                     </div>\n284:                                 </td>\n285:                             </tr>\n286: \n287:                             <!-- Row 2 -->\n288:                             <tr class=\"hover:bg-gray-50 transition-colors group\">\n289:                                 <td class=\"px-6 py-4\">\n290:                                     <input type=\"checkbox\" class=\"custom-checkbox\">\n291:                                 </td>\n292:                                 <td class=\"px-6 py-4\">\n293:                                     <div class=\"flex items-center gap-3\">\n294:                                         <img src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-1.2.1&amp;auto=format&amp;fit=facearea&amp;facepad=2&amp;w=256&amp;h=256&amp;q=80\" class=\"h-10 w-10 rounded-full object-cover border border-gray-200\" alt=\"Avatar\">\n295:                                         <div>\n296:                                             <div class=\"text-sm font-medium text-gray-900\">David Chen</div>\n297:                                             <div class=\"text-xs text-gray-500\">ID: #R-1024</div>\n298:                                         </div>\n299:                                     </div>\n300:                                 </td>\n301:                                 <td class=\"px-6 py-4 text-sm text-gray-600\">david.chen@outlook.com</td>\n302:                                 <td class=\"px-6 py-4 text-sm text-gray-600\">+1 (555) 987-6543</td>\n303:                                 <td class=\"px-6 py-4 text-sm text-gray-600 text-center\">\n304:                                     <span class=\"inline-flex items-center gap-1 bg-gray-100 px-2 py-0.5 rounded-md\">\n305:       