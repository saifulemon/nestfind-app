   12%\n159:                         </span>\n160:                         <span class=\"text-gray-400 ml-2\">from last month</span>\n161:                     </div>\n162:                 </div>\n163: \n164:                 <!-- Stat 2 -->\n165:                 <div class=\"bg-white rounded-lg p-6 shadow-sm border border-gray-100\">\n166:                     <div class=\"flex items-start justify-between\">\n167:                         <div>\n168:                             <p class=\"text-sm font-medium text-gray-500\">Total Renters</p>\n169:                             <h3 class=\"text-2xl font-semibold text-gray-900 mt-2 tracking-tight\">2,345</h3>\n170:                         </div>\n171:                         <div class=\"p-2.5 rounded-full bg-emerald-50 text-emerald-600\">\n172:                             <span class=\"iconify\" data-icon=\"lucide:users\" data-width=\"20\" data-height=\"20\"></span>\n173:                         </div>\n174:                     </div>\n175:                     <div class=\"mt-4 flex items-center text-xs\">\n176:                         <span class=\"text-green-600 font-medium flex items-center gap-0.5\">\n177:                             <span class=\"iconify\" data-icon=\"lucide:trending-up\" data-width=\"14\" data-height=\"14\"></span>\n178:                             8%\n179:                         </span>\n180:                         <span class=\"text-gray-400 ml-2\">from last month</span>\n181:                     </div>\n182:                 </div>\n183: \n184:                 <!-- Stat 3 -->\n185:                 <div class=\"bg-white rounded-lg p-6 shadow-sm border border-gray-100\">\n186:                     <div class=\"flex items-start justify-between\">\n187:                         <div>\n188:                             <p class=\"text-sm font-medium text-gray-500\">Monthly Inquiries</p>\n189:                             <h3 class=\"text-2xl font-semibold text-gray-900 mt-2 tracking-tight\">89</h3>\n190: