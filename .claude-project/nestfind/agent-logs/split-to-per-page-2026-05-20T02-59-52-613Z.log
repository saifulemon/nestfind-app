data-icon=\"lucide:home\" data-width=\"18\" data-height=\"18\" style=\"stroke-width: 1.5;\"></span>\n31:             </div>\n32:             <span class=\"text-lg font-semibold tracking-tight text-gray-900\">NestFind</span>\n33:         </div>\n34:         <div class=\"hidden md:flex flex-1 justify-center max-w-[400px]\">\n35:             <div class=\"w-full h-10 bg-gray-100 rounded-full border border-gray-200\"></div>\n36:         </div>\n37:         <div class=\"flex items-center gap-6 flex-shrink-0 w-48 justify-end\">\n38:             <div class=\"h-4 w-16 bg-gray-200 rounded\"></div>\n39:             <div class=\"h-4 w-16 bg-gray-200 rounded\"></div>\n40:         </div>\n41:     </nav>\n42: \n43:     <!-- Main Content (Background Context) -->\n44:     <main class=\"flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-8 blur-[2px] opacity-50 pointer-events-none select-none\" aria-hidden=\"true\">\n45:         <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-3 h-[400px] mb-8\">\n46:             <div class=\"lg:col-span-7 h-full bg-gray-300 rounded-xl\"></div>\n47:             <div class=\"hidden lg:grid lg:col-span-5 grid-cols-2 gap-3 h-full\">\n48:                 <div class=\"bg-gray-300 rounded-xl\"></div>\n49:                 <div class=\"bg-gray-300 rounded-xl\"></div>\n50:                 <div class=\"bg-gray-300 rounded-xl\"></div>\n51:                 <div class=\"bg-gray-300 rounded-xl\"></div>\n52:             </div>\n53:         </div>\n54:         <div class=\"flex flex-col lg:flex-row gap-12\">\n55:             <div class=\"w-full lg:w-[60%] space-y-8\">\n56:                 <div class=\"border-b border-gray-200 pb-8\">\n57:                     <div class=\"h-8 w-3/4 bg-gray-300 rounded mb-4\"></div>\n58:                     <div class=\"h-4 w-1/2 bg-gray-200 rounded\"></div>\n59:                 </div>\n60:             </div>\n61:             <div class=\"w-full lg:w-[40%]\">\n62:                 <div class=\"bg-white rounded-xl border border-gray-200 h-64\"></div>\n63:             </div>\n64:         </div>\n65:     </main>\n66: \n67:     <!-- INQUIRY MODAL OVERLAY -->\n68:     <div class=\"fixed inset-0 z-50 overflow-y-auto\" role=\"dialog\" aria-modal=\"true\">\n69:         \n70:         <!-- Backdrop -->\n71:         <div class=\"fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity\"></div>\n72: \n73:         <!-- Modal Positioning -->\n74:         <div class=\"flex min-h-full items-center justify-center p-4 text-center sm:p-0\">\n75:             \n76:             <!-- Modal Panel -->\n77:             <div class=\"relative transform overflow-hidden rounded-xl bg-white text-left shadow-2xl transition-all sm:my-8 w-full max-w-[560px] p-6 sm:p-8\">\n78:                 \n79:                 <!-- Close Button -->\n80:                 <button type=\"button\" class=\"absolute top-6 right-6 text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-[#0066CC] rounded-full p-1 transition-colors\">\n81:                     <span class=\"iconify\" data-icon=\"lucide:x\" data-width=\"20\" data-height=\"20\" style=\"stroke-width: 1.5;\"></span>\n82:                 </button>\n83: \n84:                 <!-- Header -->\n85:                 <h3 class=\"text-xl font-semibold leading-6 text-gray-900 mb-6 tracking-tight\">Contact about this property</h3>\n86: \n87:                 <!-- Property Mini-Card -->\n88:                 <div class=\"flex items-center gap-4 p-3 border border-gray-200 rounded-lg mb-6 bg-white shadow-sm\">\n89:                     <!-- Image -->\n90:                     <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg\" alt=\"Property Thumbnail\" class=\"h-20 w-20 flex-shrink-0 rounded-lg object-cover bg-gray-100\">\n91:                     \n92:                     <!-- Details -->\n93:                     <div class=\"min-w-0 flex-1\">\n94:                         <h4 class=\"text-sm font-medium text-gray-900 truncate\">Modern Downtown Apartment</h4>\n95:                         <p class=\"text-xs text-gray-500 truncate mb-1.5\">1024 Market Street, San Francisco, CA</p>\n96:                         <p class=\"text-base font-semibold text-[#0066CC]\">$2,500<span class=\"text-xs text-gray-500 font-normal ml-0.5\">/mo</span></p>\n97:                     </div>\n98:                 </div>\n99: \n100:                 <!-- Form -->\n101:                 <form action=\"#\" method=\"POST\">\n102:                     <div class=\"space-y-4\">\n103:                         \n104:                         <!-- Name Field -->\n105:                         <div>\n106:                             <label for=\"name\" class=\"block text-sm font-medium leading-6 text-gray-700 mb-1.5\">Your Name <span class=\"text-[#FF6B6B]\">*</span></label>\n107:                             <input type=\"text\" name=\"name\" id=\"name\" required=\"\" class=\"block w-full h-11 rounded-lg border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#0066CC] sm:text-sm sm:leading-6 transition-shadow bg-white px-3\" placeholder=\"Jane Doe\">\n108:                         </div>\n109: \n110:                         <!-- Email Field -->\n111:                         <div>\n112:                             <label for=\"email\" class=\"block text-sm font-medium leading-6 text-gray-700 mb-1.5\">Email Address <span class=\"text-[#FF6B6B]\">*</span></label>\n113:                             <input type=\"email\" name=\"email\" id=\"email\" required=\"\" class=\"block w-full h-11 rounded-lg border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#0066CC] sm:text-sm sm:leading-6 transition-shadow bg-white px-3\" placeholder=\"jane@example.com\">\n114:                         </div>\n115: \n116:                         <!-- Phone Field -->\n117:                         <div>\n118:                             <label for=\"phone\" class=\"block text-sm font-medium leading-6 text-gray-700 mb-1.5\">Phone Number <span class=\"text-gray-400 font-normal\">(Optional)</span></label>\n119:                             <input type=\"tel\" name=\"phone\" id=\"phone\" class=\"block w-full h-11 rounded-lg border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#0066CC] sm:text-sm sm:leading-6 transition-shadow bg-white px-3\" placeholder=\"(555) 123-4567\">\n120:                         </div>\n121: \n122:                         <!-- Message Field -->\n123:                         <div>\n124:                             <label for=\"message\" class=\"block text-sm font-medium leading-6 text-gray-700 mb-1.5\">Message <span class=\"text-[#FF6B6B]\">*</span></label>\n125:                             <textarea name=\"message\" id=\"message\" rows=\"4\" required=\"\" class=\"block w-full min-h-[120px] rounded-lg border-0 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-[#0066CC] sm:text-sm sm:leading-6 transition-shadow bg-white px-3 resize-y\" placeholder=\"Hi, I'm interested in this property. Is it still available?\"></textarea>\n126:                         </div>\n127:                     </div>\n128: \n129:                     <!-- Actions -->\n130:                     <div class=\"mt-8 flex items-center justify-end gap-3\">\n131:                         <button type=\"button\" class=\"h-11 rounded-lg px-4 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-200\">\n132:                             Cancel\n133:                         </button>\n134:                         <button type=\"submit\" class=\"h-11 rounded-lg bg-[#0066CC] px-6 text-sm font-medium text-white