path>\n355:                     </svg>\n356:                 </span>\n357:             </button>\n358:         </div>\n359: \n360:     </main>\n361: \n362:     <!-- Load More Properties Script -->\n363:     <script>\n364:         // Additional properties data\n365:         const moreProperties = [\n366:             {\n367:                 price: \"$2,800\",\n368:                 type: \"Townhouse\",\n369:                 typeColor: \"green\",\n370:                 address: \"445 Oak Street, Berkeley, CA\",\n371:                 beds: 3,\n372:                 baths: 2,\n373:                 sqft: \"1,650\",\n374:                 image: \"photo-1570129477492-45c003edd2be\",\n375:                 badge: null\n376:             },\n377:             {\n378:                 price: \"$4,500\",\n379:                 type: \"House\",\n380:                 typeColor: \"orange\",\n381:                 address: \"1200 Sunset Blvd, Los Angeles, CA\",\n382:                 beds: 4,\n383:                 baths: 3,\n384:                 sqft: \"2,800\",\n385:                 image: \"photo-1564013799919-ab600027ffc6\",\n386:                 badge: \"Pet Friendly\"\n387:             },\n388:             {\n389:                 price: \"$1,950\",\n390:                 type: \"Studio\",\n391:                 typeColor: \"purple\",\n392:                 address: \"88 Howard St, San Francisco, CA\",\n393:                 beds: 0,\n394:                 baths: 1,\n395:                 sqft: \"450\",\n396:                 image: \"photo-1493809842364-78817add7ffb\",\n397:                 badge: null\n398:             },\n399:             {\n400:                 price: \"$3,100\",\n401:                 type: \"Apartment\",\n402:                 typeColor: \"blue\",\n403:                 address: \"555 Marina Blvd, Sausalito, CA\",\n404:                 beds: 2,\n405:                 baths: 2,\n406:                 sqft: \"1,100\",\n407:                 image: \"photo-1558036117-15d82a90b9b1\",\n408:                 badge: \"New Listing\"\n409:             },\n410:             {\n411:                 price: \"$5,500\",\n412:                 type: \"Luxury\",\n413:                 typeColor: \"gold\",\n414:                 address: \"1 Embarcadero Center, SF, CA\",\n415:                 beds: 3,\n416:                 baths: 2.5,\n417:                 sqft: \"2,200\",\n418:                 image: \"photo-1600607687939-ce8a6c25118c\",\n419:                 badge: null\n420:             },\n421:             {\n422:                 price: \"$2,100\",\n423:                 type: \"Condo\",\n424:                 typeColor: \"blue\",\n425:                 address: \"300 Spear St, San Francisco, CA\",\n426:                 beds: 1,\n427:                 baths: 1,\n428:                 sqft: \"720\",\n429:                 image: \"photo-1600566753190-17f0baa2a6c3\",\n430:                 badge: \"Price Drop\"\n431:             }\n432:         ];\n433: \n434:         let currentPage = 0;\n435:         const propertiesPerPage = 6;\n436:         let totalLoaded = 6; // Initial 6 cards shown\n437: \n438:         function getTypeStyles(typeColor) {\n439:             const styles = {\n440:                 blue: { bg: 'bg-blue-50', text: 'text-[#0066CC]', ring: 'ring-[#0066CC]/20' },\n441:                 orange: { bg: 'bg-orange-50', text: 'text-orange-700', ring: 'ring-orange-700/20' },\n442:                 purple: { bg: 'bg-purple-50', text: 'text-purple-700', ring: 'ring-purple-700/20' },\n443:                 green: { bg: 'bg-green-50', text: 'text-green-700', ring: 'ring-green-600/20' },\n444:                 gold: { bg: 'bg-amber-50', text: 'text-amber-700', ring: 'ring-amber-700/20' }\n445:             };\n446:             return styles[typeColor] || styles.blue;\n447:         }\n448: \n449:         function getBadgeStyles(badge) {\n450:             if (badge === 'New Listing') {\n451:                 return 'bg-white/90 text-gray-900 ring-gray-200';\n452:             } else if (badge === 'Price Drop') {\n453:                 return 'bg-green-50/90 text-green-700 ring-green-600/20';\n454:             } else if (badge === 'Pet Friendly') {\n455:                 return 'bg-blue-50/90 text-blue-700 ring-blue-600/20';\n456:             }\n457:             return 'bg-white/90 text-gray-900 ring-gray-200';\n458:         }\n459: \n460:         function createPropertyCard(property) {\n461:             const typeStyles = getTypeStyles(property.typeColor);\n462:             const badgeHTML = property.badge ? `\n463:                 <div class=\"absolute bottom-3 left-3\">\n464:                     <span class=\"inline-flex items-center rounded-md ${getBadgeStyles(property.badge)} backdrop-blur-md px-2 py-1 text-xs font-medium shadow-sm ring-1 ring-inset\">\n465:                         ${property.badge}\n466:                     </span>\n467:                 </div>\n468:             ` : '';\n469: \n470:             return `\n471:                 <a href=\"./06-property-detail.html\" class=\"group bg-white rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col overflow-hidden relative cursor-pointer opacity-0 animate-fadeIn\">\n472:                     <div class=\"aspect-[16/10] bg-gray-100 relative overflow-hidden\">\n473:                         <img src=\"https://images.unsplash.com/${property.image}?auto=format&fit=crop&q=80&w=800\" alt=\"Property\" class=\"w-full h-full object-cover transition-transform duration-500 group-hover:scale-105\">\n474:                         <button onclick=\"event.preventDefault(); event.stopPropagation(); this.querySelector('.iconify').classList.toggle('text-[#FF6B6B]');\" class=\"absolute top-3 right-3 p-2 bg-white/90 backdrop-blur-sm rounded-full shadow-sm hover:bg-white transition-colors group/heart\">\n475:                             <span class=\"iconify text-gray-400 group-hover/heart:text-[#FF6B6B] transition-colors\" data-icon=\"lucide:heart\" data-width=\"18\" data-height=\"18\" style=\"stroke-width: 1.5;\"></span>\n476:                         </button>\n477:                         ${badgeHTML}\n478:                     </div>\n479:                     <div class=\"p-5 flex flex-col gap-1\">\n480:                         <div class=\"flex justify-between items-start\">\n481:                             <h3 class=\"text-xl font-semibold text-gray-900 tracking-tight\">${property.price}<span class=\"text-sm font-normal text-gray-500\">/mo</span></h3>\n482:                             <span class=\"inline-flex items-center rounded-full ${typeStyles.bg} px-2 py-1 text-xs font-medium ${typeStyles.text} ring-1 ring-inset ${typeStyles.ring}\">${property.type}</span>\n483:                         </div>\n484:                         <p class=\"text-sm text-gray-500 font-medium truncate\">${property.address}</p>\n485:                         <div class=\"mt-3 flex items-center gap-3 text-sm text-gray-600\">\n486:                             <div class=\"flex items-center gap-1.5\">\n487:                                 <span class=\"iconify text-gray-400\" data-icon=\"lucide:bed-double\" data-width=\"16\" data-height=\"16\"></span>\n488:                                 ${property.beds === 0 ? 'Studio' : property.beds}\n489:                             </div>\n490:                             <span class=\"text-gray-300\">•</span>\n491:                             <div class=\"flex items-center gap-1.5\">\n492:                                 <span class=\"iconify text-gray-400\" data-icon=\"lucide:bath\" data-width=\"16\" data-height=\"16\"></span>\n493:                                 ${property.baths}\n494:                             </div>\n495:                             <span class=\"text-gray-300\">•</span>\n496:                             <div class=\"flex items-center gap-1.5\">\n497:                                 <span class=\"iconify text-gray-400\" data-icon=\"lucide:ruler\" data-width=\"16\" data-height=\"16\"></span>\n498:                                 ${property.sqft} sqft\n499:                             </div>\n500:                         </div>\n501:                     </div>\n502:                 </a>\n503:             `;\n504:         }\n505: \n506:         function loadMoreProperties() {\n507:             const btn = document.getElementById('loadMoreBtn');\n508:             const spinner = document.getElementById('loadMoreSpinner');\n509:             const text = document.getElementById('loadMoreText');\n510:             const grid = document.getElementById('propertyGrid');\n511:             const container = document.getElementById('loadMoreContainer');\n512: \n513:             // Show loading state\n514:             btn.disabled = true;\n515:             spinner.classList.remove('hidden');\n516:             text.textContent = 'Loading...';\n517: \n518:             // Simulate network delay for realistic UX\n519:             setTimeout(() => {\n520:                 const start = currentPage * propertiesPerPage;\n521:                 const end = Math.min(start + propertiesPerPage, moreProperties.length);\n522:                 const propertiesToAdd = moreProperties.slice(start, end);\n523: \n524:                 propertiesToAdd.forEach((property, index) => {\n525:                     const cardHTML = createPropertyCard(property);\n526:                     grid.insertAdjacentHTML('beforeend', cardHTML);\n527:                     totalLoaded++;\n528:                 });\n529: \n530:                 // Update results count\n531:                 const resultsHeader = document.querySelector('h2.text-lg');\n532:                 if (resultsHeader) {\n533:                     resultsHeader.textContent = `${totalLoaded} properties found`;\n534:                 }\n535: \n536:                 currentPage++;\n537: \n538:                 // Reset button state\n539:                 btn.disabled = false;\n540:                 spinner.classList.add('hidden');\n541:                 text.textContent = 'Load more properties';\n542: \n543:                 // Hide button if no more properties\n544:                 if (currentPage * propertiesPerPage >= moreProperties.length) {\n545:                     container.innerHTML = `\n546:                         <p class=\"text-sm text-gray-500\">You've seen all ${totalLoaded} properties</p>\n547:                     `;\n548:                 }\n549: \n550:                 // Trigger Iconify to render new icons\n551:                 if (window.Iconify) {\n552:                     window.Iconify.scan();\n553:                 }\n554:             }, 800);\n555:         }\n556:     </script>\n557: \n558:     <style>\n559:         @keyframes fadeIn {\n560:             from {\n561:                 opacity: 0;\n562:                 transform: translateY(10px);\n563:             }\n564:             to {\n565:                 opacity: 1;\n566:                 transform: translateY(0);\n567:             }\n568:         }\n569:         .animate-fadeIn {\n570:             animation: fadeIn 0.4s ease-out forwards;\n571:         }\n572:     </style>\n573: \n574:     <!-- Profile Data Loader -->\n575:     <script>\n576:         document.addEventListener('DOMContentLoaded', function() {\n577:             const saved = localStorage.getItem('nestfind_profile');\n578:             if (saved) {\n579:                 const profile = JSON.parse(saved);\n580:                 if (profile.avatar) {\n581:                     const navAvatar = document.getElementById('navAvatar');\n582:                     if (navAvatar) navAvatar.src = profile.avatar;\n583:                 }\n584:             }\n585:         });\n586:     </script>\n587: \n588: </body></html>\n\n(End of file - total 588 lines)\n</content>","metadata":{"preview":"<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>NestFind - Property Search</tit